---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Form Calculator - Formwork Area, Lumber & Tie Spacing";
const description = "Calculate concrete formwork area, lumber quantities, form ties, and bracing for walls, footings, and columns. Get complete material list for forming.";

const relatedCalcs = [
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume." },
  { name: "Concrete Reinforcement Calculator", url: "/concrete-reinforcement-calculator", description: "Rebar sizing." },
  { name: "Rebar Calculator", url: "/rebar-calculator", description: "Rebar requirements." },
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Mix design." },
  { name: "Retaining Wall Calculator", url: "/retaining-wall-calculator", description: "Retaining wall." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Form Calculator"
  keywords="concrete formwork, form ties, form lumber, plywood forms, concrete forming, form bracing, wall forms"
  breadcrumbs={[{ name: "Concrete Form Calculator", url: "/concrete-form-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Form Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate formwork materials including plywood, studs, walers, ties, and bracing.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Form Application</label>
          <select id="cfm-app" class="cfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="wall" selected>Wall (Two-Sided Forms)</option>
            <option value="footing">Strip Footing (Side Forms)</option>
            <option value="column">Column (Four-Sided Box)</option>
            <option value="slab-edge">Slab Edge Forms</option>
          </select>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Length (ft)</label>
            <input type="number" id="cfm-length" class="cfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="1" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Height (ft)</label>
            <input type="number" id="cfm-height" class="cfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Thickness (in)</label>
            <input type="number" id="cfm-thick" class="cfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="4" step="2">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Sheathing Material</label>
          <select id="cfm-sheathing" class="cfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="plyform" selected>Plyform (3/4" HDO Plywood)</option>
            <option value="plywood">Standard 3/4" Plywood (4x8)</option>
            <option value="osb">OSB (4x8)</option>
            <option value="lumber">2x Lumber Boards</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Stud Spacing (in O.C.)</label>
            <select id="cfm-studs" class="cfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="12" selected>12 inches</option>
              <option value="16">16 inches</option>
              <option value="24">24 inches</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Tie Spacing (in O.C.)</label>
            <select id="cfm-ties" class="cfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="16">16 inches</option>
              <option value="24" selected>24 inches</option>
              <option value="32">32 inches</option>
            </select>
          </div>
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-text mb-1">Reuse Factor</label>
              <select id="cfm-reuse" class="cfm-in w-full px-3 py-2 border border-border rounded-lg">
                <option value="1" selected>1 Use (No Reuse)</option>
                <option value="2">2 Uses</option>
                <option value="3">3 Uses</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-text mb-1">Waste Factor (%)</label>
              <input type="number" id="cfm-waste" class="cfm-in w-full px-3 py-2 border border-border rounded-lg" value="10" min="0" max="25" step="1">
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Form Area</div>
          <div class="text-4xl font-extrabold" id="cfm-area">0 sq ft</div>
          <div class="text-sm text-blue-200 mt-1"><span id="cfm-sides">2</span> form sides</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Plywood Sheets (4x8)</div>
            <div class="text-xl font-bold" id="cfm-sheets">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Studs (2x4)</div>
            <div class="text-xl font-bold" id="cfm-stud-qty">0</div>
            <div class="text-xs text-text-muted" id="cfm-stud-len">8 ft each</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Walers (2x4 double)</div>
            <div class="text-xl font-bold" id="cfm-walers">0</div>
            <div class="text-xs text-text-muted">linear feet</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Form Ties</div>
            <div class="text-xl font-bold" id="cfm-tie-qty">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Braces (2x4)</div>
            <div class="text-xl font-bold" id="cfm-braces">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Concrete Volume</div>
            <div class="text-xl font-bold" id="cfm-concrete">0 yd3</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Lateral Pressure at Base (pour rate 4 ft/hr, 70F)</div>
          <div class="text-xl font-bold" id="cfm-pressure">0 PSF</div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-form" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Concrete Formwork Design</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Lateral pressure (ACI 347):</strong> P = 150 + 9000R/T (max 150h or 2000 PSF)</p>
        <p><strong>Where:</strong> R = pour rate (ft/hr), T = temp (F), h = form height (ft)</p>
      </div>
      <ul>
        <li><strong>Plyform:</strong> Best surface finish, 3-5 reuses with form oil</li>
        <li><strong>Studs:</strong> 2x4 at 12-16" O.C. for walls up to 8 ft</li>
        <li><strong>Ties:</strong> Snap ties or she-bolts at 24" O.C. typical</li>
        <li><strong>Braces:</strong> Diagonal kickers at 6-8 ft spacing</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCFM() {
      const app = (document.getElementById('cfm-app') as HTMLSelectElement).value;
      const length = parseFloat((document.getElementById('cfm-length') as HTMLInputElement).value) || 0;
      const height = parseFloat((document.getElementById('cfm-height') as HTMLInputElement).value) || 0;
      const thick = parseFloat((document.getElementById('cfm-thick') as HTMLInputElement).value) || 8;
      const studSpacing = parseFloat((document.getElementById('cfm-studs') as HTMLSelectElement).value) || 12;
      const tieSpacing = parseFloat((document.getElementById('cfm-ties') as HTMLSelectElement).value) || 24;
      const reuse = parseInt((document.getElementById('cfm-reuse') as HTMLSelectElement).value) || 1;
      const waste = (parseFloat((document.getElementById('cfm-waste') as HTMLInputElement).value) || 0) / 100;

      // Number of form sides
      let sides = 2;
      let formPerimeter = length;
      if (app === 'wall') { sides = 2; formPerimeter = length; }
      else if (app === 'footing') { sides = 2; formPerimeter = length; }
      else if (app === 'column') { sides = 4; formPerimeter = (thick / 12) * 2 + (thick / 12) * 2; /* square column */ }
      else if (app === 'slab-edge') { sides = 1; formPerimeter = length; }

      const totalFormArea = formPerimeter * height * sides;
      const formAreaWithWaste = totalFormArea * (1 + waste) / reuse;

      // Plywood sheets: 4x8 = 32 sq ft
      const sheets = Math.ceil(formAreaWithWaste / 32);

      // Studs: one per spacing interval per side, height of form
      const studsPerSide = Math.ceil(formPerimeter / (studSpacing / 12)) + 1;
      const totalStuds = studsPerSide * sides;
      const studLen = Math.ceil(height);

      // Walers: double 2x4 at ~24" vertical spacing
      const walerRows = Math.ceil(height / 2) * sides;
      const walerLinFt = walerRows * formPerimeter * 2; // double walers

      // Form ties (walls only): grid of tie spacing
      let tieCount = 0;
      if (app === 'wall') {
        const tiesHoriz = Math.ceil(formPerimeter / (tieSpacing / 12)) + 1;
        const tiesVert = Math.ceil(height / (tieSpacing / 12)) + 1;
        tieCount = tiesHoriz * tiesVert;
      }

      // Braces: diagonal kickers every 6 ft
      const braces = Math.ceil(formPerimeter / 6) * sides;

      // Concrete volume
      const concreteCuFt = formPerimeter * height * (thick / 12);
      const concreteYd3 = concreteCuFt / 27;

      // Lateral pressure: ACI 347 simplified for R=4 ft/hr, T=70F
      // P = 150 + 9000 * R / T = 150 + 9000*4/70 = 150 + 514 = 664 PSF (max 150*h)
      const pressure = Math.min(150 + 9000 * 4 / 70, 150 * height);

      document.getElementById('cfm-area')!.textContent = Math.round(totalFormArea) + ' sq ft';
      document.getElementById('cfm-sides')!.textContent = String(sides);
      document.getElementById('cfm-sheets')!.textContent = String(sheets);
      document.getElementById('cfm-stud-qty')!.textContent = String(totalStuds);
      document.getElementById('cfm-stud-len')!.textContent = studLen + ' ft each';
      document.getElementById('cfm-walers')!.textContent = Math.round(walerLinFt) + '';
      document.getElementById('cfm-tie-qty')!.textContent = String(tieCount);
      document.getElementById('cfm-braces')!.textContent = String(braces);
      document.getElementById('cfm-concrete')!.textContent = concreteYd3.toFixed(1) + ' yd\u00B3';
      document.getElementById('cfm-pressure')!.textContent = Math.round(pressure) + ' PSF';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.cfm-in').forEach(el => {
        el.addEventListener('input', calcCFM);
        el.addEventListener('change', calcCFM);
      });
      calcCFM();
    }, 50);
  </script>
</CalculatorLayout>
