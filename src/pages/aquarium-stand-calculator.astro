---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Stand Calculator - Load Capacity & Weight";
const description = "Calculate the total weight your aquarium stand must support including water, tank, substrate, equipment, and safety margin.";
const relatedCalcs = [
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume and water weight." },
  { name: "Aquarium Glass Thickness", url: "/aquarium-glass-thickness-calculator", description: "Glass thickness for custom tanks." },
  { name: "Aquarium Substrate", url: "/aquarium-substrate-calculator", description: "Substrate weight calculator." },
  { name: "Aquarium Cost", url: "/aquarium-cost-calculator", description: "Total aquarium setup cost." },
  { name: "Aquarium Sump", url: "/aquarium-sump-calculator", description: "Sump sizing calculator." },
  { name: "Aquarium Heater", url: "/aquarium-heater-calculator", description: "Heater wattage calculator." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Stand Calculator" keywords="aquarium stand calculator, fish tank weight, aquarium stand capacity, tank weight calculator, aquarium floor support" breadcrumbs={[{ name: "Aquarium Stand", url: "/aquarium-stand-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Stand Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate the total weight your stand and floor must support for a safely placed aquarium.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Length (inches)</label>
            <input type="number" id="ast-len" class="ast-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="48" min="6" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Width (inches)</label>
            <input type="number" id="ast-wid" class="ast-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="6" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Height (inches)</label>
            <input type="number" id="ast-hgt" class="ast-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18" min="6" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tank Material</label>
            <select id="ast-mat" class="ast-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="glass" selected>Glass</option>
              <option value="acrylic">Acrylic</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Substrate Depth (inches)</label>
            <input type="number" id="ast-sub" class="ast-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0" max="6" step="0.5">
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Include Sump Below?</label>
          <select id="ast-sump" class="ast-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="0">No sump</option>
            <option value="20">Small sump (~20 gal)</option>
            <option value="40">Medium sump (~40 gal)</option>
            <option value="75">Large sump (~75 gal)</option>
          </select>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Weight on Stand</div>
          <div class="text-5xl font-extrabold font-mono" id="ast-result">0 lbs</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water Weight</div>
            <div class="text-xl font-bold font-mono" id="ast-water">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Tank Weight (empty)</div>
            <div class="text-xl font-bold font-mono" id="ast-tank">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Substrate + Decor</div>
            <div class="text-xl font-bold font-mono" id="ast-extras">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Floor Load (lbs/sq ft)</div>
            <div class="text-xl font-bold font-mono" id="ast-floor">0</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-stand" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcAST() {
      const len = parseFloat((document.getElementById('ast-len') as HTMLInputElement).value) || 0;
      const wid = parseFloat((document.getElementById('ast-wid') as HTMLInputElement).value) || 0;
      const hgt = parseFloat((document.getElementById('ast-hgt') as HTMLInputElement).value) || 0;
      const mat = (document.getElementById('ast-mat') as HTMLSelectElement).value;
      const sub = parseFloat((document.getElementById('ast-sub') as HTMLInputElement).value) || 0;
      const sumpGal = parseFloat((document.getElementById('ast-sump') as HTMLSelectElement).value) || 0;
      // Tank volume in gallons
      const gallons = (len * wid * hgt) / 231;
      const waterWeight = gallons * 8.34;
      // Tank weight (empty): glass ~1.5 lbs per gallon capacity, acrylic ~0.5 lbs
      const tankWeightPerGal = mat === 'glass' ? 1.5 : 0.5;
      const tankWeight = gallons * tankWeightPerGal;
      // Substrate weight: ~1 lb per sq inch of area per inch of depth / 12 (rough density)
      const subWeight = (len * wid * sub) / 1728 * 96; // gravel density
      // Decor/rock estimate: ~10% of tank volume weight
      const decorWeight = gallons * 0.8;
      // Sump
      const sumpWeight = sumpGal * 8.34 + sumpGal * 0.5; // water + tank
      const totalWeight = waterWeight + tankWeight + subWeight + decorWeight + sumpWeight;
      // Floor load: weight per square foot of stand footprint
      const footprintSqFt = (len * wid) / 144;
      const floorLoad = footprintSqFt > 0 ? (totalWeight / footprintSqFt).toFixed(0) : '0';
      document.getElementById('ast-result')!.textContent = Math.round(totalWeight) + ' lbs';
      document.getElementById('ast-water')!.textContent = Math.round(waterWeight + sumpGal * 8.34) + ' lbs';
      document.getElementById('ast-tank')!.textContent = Math.round(tankWeight) + ' lbs';
      document.getElementById('ast-extras')!.textContent = Math.round(subWeight + decorWeight) + ' lbs';
      document.getElementById('ast-floor')!.textContent = floorLoad + ' lbs/sqft';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.ast-in').forEach(el => { el.addEventListener('input', calcAST); el.addEventListener('change', calcAST); });
      calcAST();
    }, 50);
  </script>
</CalculatorLayout>
