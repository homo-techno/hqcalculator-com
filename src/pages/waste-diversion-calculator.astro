---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Waste Diversion Calculator - Diversion Rate & Landfill Reduction";
const description = "Calculate your waste diversion rate and landfill reduction from recycling, composting, and other waste reduction strategies.";
const relatedCalcs = [
  { name: "Recycling", url: "/recycling-calculator", description: "Recycling impact." },
  { name: "Composting Rate", url: "/composting-rate-calculator", description: "Compost C:N ratio." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Carbon Offset", url: "/carbon-offset-calculator", description: "Carbon offsets." },
  { name: "Green Building", url: "/green-building-calculator", description: "Green certification." },
  { name: "Carbon Tax", url: "/carbon-tax-calculator", description: "Carbon tax." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Waste Diversion Calculator" keywords="waste diversion calculator, diversion rate, landfill reduction, recycling rate, zero waste calculator" breadcrumbs={[{ name: "Waste Diversion", url: "/waste-diversion-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Waste Diversion Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate your waste diversion rate and environmental impact from recycling and composting.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Weekly Waste Generation (lbs)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Trash to Landfill</label><input type="number" id="wdv-trash" class="wdv-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="0" max="200" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Recycling (paper, plastic, glass)</label><input type="number" id="wdv-recycle" class="wdv-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="15" min="0" max="200" step="1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Composting (food/yard)</label><input type="number" id="wdv-compost" class="wdv-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="0" max="100" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Donations/Reuse</label><input type="number" id="wdv-reuse" class="wdv-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0" max="50" step="1"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">E-Waste/Hazardous (lbs/month)</label><input type="number" id="wdv-ewaste" class="wdv-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0" max="50" step="0.5"></div>
        <h3 class="font-semibold text-text">Costs</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Landfill Cost ($/ton)</label><input type="number" id="wdv-lfcost" class="wdv-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="60" min="20" max="200" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">People in Household</label><input type="number" id="wdv-people" class="wdv-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" max="10" step="1"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Waste Diversion Rate</div>
          <div class="text-4xl font-extrabold" id="wdv-rate">0%</div>
          <div class="text-sm text-blue-200 mt-1" id="wdv-grade">Calculating...</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Total Weekly Waste</div><div class="text-xl font-bold" id="wdv-total">0 lbs</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Landfill Reduction</div><div class="text-xl font-bold" id="wdv-reduction">0 lbs/yr</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Per Person/Day</div><div class="text-xl font-bold" id="wdv-perperson">0 lbs</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">CO₂ Avoided/Year</div><div class="text-xl font-bold" id="wdv-co2">0 lbs</div></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Landfill Disposal Savings</div>
          <div class="text-2xl font-bold" id="wdv-savings">$0/yr</div>
        </div>
      </div>
      <ShareButton calculatorId="waste-diversion" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Waste Diversion</h2>
      <p>The average American generates about 4.9 lbs of waste per day, with a national diversion rate of about 32%. Diversion includes recycling (curbside and drop-off), composting, donation, and reuse. San Francisco leads with 80% diversion. Each ton diverted from landfill prevents about 2,000 lbs of CO₂ equivalent greenhouse gas emissions from methane generation and embodied energy savings.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcWDV() {
      const trash = parseFloat((document.getElementById('wdv-trash') as HTMLInputElement).value) || 0;
      const recycle = parseFloat((document.getElementById('wdv-recycle') as HTMLInputElement).value) || 0;
      const compost = parseFloat((document.getElementById('wdv-compost') as HTMLInputElement).value) || 0;
      const reuse = parseFloat((document.getElementById('wdv-reuse') as HTMLInputElement).value) || 0;
      const ewaste = parseFloat((document.getElementById('wdv-ewaste') as HTMLInputElement).value) || 0;
      const lfCost = parseFloat((document.getElementById('wdv-lfcost') as HTMLInputElement).value) || 60;
      const people = parseFloat((document.getElementById('wdv-people') as HTMLInputElement).value) || 4;
      const ewasteWeekly = ewaste / 4.33;
      const totalWeekly = trash + recycle + compost + reuse + ewasteWeekly;
      const diverted = recycle + compost + reuse + ewasteWeekly;
      const diversionRate = totalWeekly > 0 ? (diverted / totalWeekly * 100) : 0;
      const annualDiverted = diverted * 52;
      const perPersonDay = people > 0 ? trash / people / 7 : 0;
      const co2Avoided = annualDiverted / 2000 * 2000;
      const savingsPerYear = annualDiverted / 2000 * lfCost;
      let grade = 'Needs Improvement';
      if (diversionRate >= 75) grade = 'Excellent - Near Zero Waste!';
      else if (diversionRate >= 50) grade = 'Good';
      else if (diversionRate >= 32) grade = 'Average (US national rate)';
      document.getElementById('wdv-rate')!.textContent = diversionRate.toFixed(0) + '%';
      document.getElementById('wdv-grade')!.textContent = grade;
      document.getElementById('wdv-total')!.textContent = totalWeekly.toFixed(0) + ' lbs';
      document.getElementById('wdv-reduction')!.textContent = Math.round(annualDiverted).toLocaleString() + ' lbs/yr';
      document.getElementById('wdv-perperson')!.textContent = perPersonDay.toFixed(1) + ' lbs';
      document.getElementById('wdv-co2')!.textContent = Math.round(co2Avoided).toLocaleString() + ' lbs';
      document.getElementById('wdv-savings')!.textContent = '$' + Math.round(savingsPerYear).toLocaleString() + '/yr';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.wdv-in').forEach(el => { el.addEventListener('input', calcWDV); el.addEventListener('change', calcWDV); }); calcWDV(); }, 50);
  </script>
</CalculatorLayout>
