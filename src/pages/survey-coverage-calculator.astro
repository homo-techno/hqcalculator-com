---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Survey Coverage Calculator - Archaeological Survey Sampling Fraction";
const description = "Calculate archaeological survey coverage, sampling fraction, walker spacing, and detection probability for pedestrian surface survey.";
const relatedCalcs = [
  { name: "Site Grid", url: "/site-grid-calculator", description: "Grid layout." },
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Site Catchment", url: "/site-catchment-calculator", description: "Territory analysis." },
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
  { name: "Excavation Volume", url: "/excavation-volume-calculator", description: "Dig unit volume." },
  { name: "Carrying Capacity", url: "/carrying-capacity-calculator", description: "Land capacity." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Survey Coverage Calculator" keywords="archaeological survey, survey coverage, sampling fraction, pedestrian survey, transect, walker spacing, detection probability" breadcrumbs={[{ name: "Survey Coverage", url: "/survey-coverage-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Survey Coverage Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate survey coverage, sampling fractions, and detection probabilities for archaeological pedestrian survey. Plan transect spacing and crew requirements.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Study Area (sq km)</label>
          <input type="number" id="svc-totalarea" class="svc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="25" min="0.01" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Area Actually Surveyed (sq km)</label>
          <input type="number" id="svc-surveyed" class="svc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6.25" min="0.01" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Walker Spacing (m)</label>
          <input type="number" id="svc-spacing" class="svc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="15" min="1" max="100" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Walkers</label>
          <input type="number" id="svc-walkers" class="svc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Transect Length (km)</label>
          <input type="number" id="svc-translen" class="svc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0.1" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Ground Visibility (%)</label>
          <input type="number" id="svc-visibility" class="svc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="70" min="5" max="100" step="5">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Sites Found</label>
          <input type="number" id="svc-sites" class="svc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="0" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Sampling Fraction</div>
          <div class="text-4xl font-extrabold" id="svc-fraction">0</div>
          <div class="text-sm text-blue-200 mt-1">of total study area</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Effective Coverage</div>
            <div class="text-xl font-bold" id="svc-effective">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Swath Width</div>
            <div class="text-xl font-bold" id="svc-swath">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Site Density</div>
            <div class="text-xl font-bold" id="svc-density">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Estimated Total Sites</div>
            <div class="text-xl font-bold" id="svc-esttotal">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Area per Transect Pass</div>
            <div class="text-xl font-bold" id="svc-transarea">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Detection Probability</div>
            <div class="text-xl font-bold" id="svc-detect">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="survey-coverage" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Survey Coverage Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Sampling Fraction</strong> = Surveyed Area / Total Area</p>
        <p><strong>Effective Coverage</strong> = Sampling Fraction * (Visibility / 100)</p>
        <p><strong>Swath Width</strong> = Walkers * Spacing</p>
        <p><strong>Total Sites Est.</strong> = Sites Found / Effective Coverage</p>
      </div>
      <p>Archaeological survey design balances coverage against resources. Closer walker spacing increases detection probability but reduces area covered. Ground visibility (affected by vegetation, plowing, erosion) directly impacts effective coverage. Standard practice recommends at least 20% sampling fraction for regional surveys.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSVC() {
      const totalArea = parseFloat((document.getElementById('svc-totalarea') as HTMLInputElement).value) || 0;
      const surveyed = parseFloat((document.getElementById('svc-surveyed') as HTMLInputElement).value) || 0;
      const spacing = parseFloat((document.getElementById('svc-spacing') as HTMLInputElement).value) || 0;
      const walkers = parseFloat((document.getElementById('svc-walkers') as HTMLInputElement).value) || 0;
      const transLen = parseFloat((document.getElementById('svc-translen') as HTMLInputElement).value) || 0;
      const visibility = parseFloat((document.getElementById('svc-visibility') as HTMLInputElement).value) || 0;
      const sites = parseFloat((document.getElementById('svc-sites') as HTMLInputElement).value) || 0;

      const samplingFraction = totalArea > 0 ? surveyed / totalArea : 0;
      const effectiveCoverage = samplingFraction * (visibility / 100);
      const swathWidthM = walkers * spacing;
      const swathWidthKm = swathWidthM / 1000;
      const transAreaSqKm = transLen * swathWidthKm;
      const siteDensity = surveyed > 0 ? sites / surveyed : 0;
      const estTotalSites = effectiveCoverage > 0 ? sites / effectiveCoverage : 0;
      const detectProb = visibility / 100;

      document.getElementById('svc-fraction')!.textContent = (samplingFraction * 100).toFixed(1) + '%';
      document.getElementById('svc-effective')!.textContent = (effectiveCoverage * 100).toFixed(1) + '%';
      document.getElementById('svc-swath')!.textContent = swathWidthM.toFixed(0) + ' m';
      document.getElementById('svc-density')!.textContent = siteDensity.toFixed(2) + ' /sq km';
      document.getElementById('svc-esttotal')!.textContent = Math.round(estTotalSites).toLocaleString();
      document.getElementById('svc-transarea')!.textContent = transAreaSqKm.toFixed(4) + ' sq km';
      document.getElementById('svc-detect')!.textContent = (detectProb * 100).toFixed(0) + '%';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.svc-in').forEach(el => { el.addEventListener('input', calcSVC); el.addEventListener('change', calcSVC); });
      calcSVC();
    }, 50);
  </script>
</CalculatorLayout>
