---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Child Dosage Calculator - Pediatric Medication Dosage by Weight";
const description = "Calculate safe pediatric medication doses for common OTC medicines like acetaminophen (Tylenol) and ibuprofen (Advil/Motrin) based on your child's weight and age.";

const relatedCalcs = [
  { name: "Child BMI Calculator", url: "/child-bmi-calculator", description: "BMI percentiles." },
  { name: "Child Nutrition Calculator", url: "/child-nutrition-calculator", description: "Nutrition needs." },
  { name: "Baby Formula Calculator", url: "/baby-formula-calculator", description: "Formula feeding." },
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Growth tracking." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "BMI Calculator", url: "/bmi-calculator", description: "Adult BMI." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Child Dosage Calculator"
  keywords="child dosage calculator, pediatric dosage, children's tylenol dose, children's motrin dose, acetaminophen dosage by weight, ibuprofen dosage kids"
  breadcrumbs={[{ name: "Child Dosage Calculator", url: "/child-dosage-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Child Dosage Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate safe OTC medication doses for children based on weight. Always verify with your pediatrician.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="p-3 bg-yellow-50 border border-yellow-200 rounded-xl mb-4">
        <p class="text-sm text-yellow-800"><strong>Disclaimer:</strong> This calculator provides general dosage guidelines only. Always consult your pediatrician or pharmacist before giving medication to your child.</p>
      </div>

      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Weight (lbs)</label>
          <input type="number" id="cds-weight" class="cds-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="6" max="200" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age (years)</label>
          <input type="number" id="cds-age" class="cds-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0" max="17" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Medication</label>
          <select id="cds-med" class="cds-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="acetaminophen" selected>Acetaminophen (Tylenol)</option>
            <option value="ibuprofen">Ibuprofen (Advil/Motrin)</option>
            <option value="diphenhydramine">Diphenhydramine (Benadryl)</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Recommended Dose</div>
        <div class="text-5xl font-extrabold" id="cds-dose">--</div>
        <div class="text-sm text-blue-200 mt-1" id="cds-form">formulation info</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Dose in mg</div>
          <div class="text-lg font-bold" id="cds-mg">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Dose Frequency</div>
          <div class="text-lg font-bold" id="cds-freq">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Max Daily Doses</div>
          <div class="text-lg font-bold" id="cds-maxdoses">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Max Daily Amount</div>
          <div class="text-lg font-bold" id="cds-maxdaily">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Dosage by Weight Chart</h3>
        <div class="text-xs" id="cds-chart"></div>
      </div>

      <ShareButton calculatorId="child-dosage" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Pediatric Medication Dosing Guidelines</h2>
      <p>Weight-based dosing is more accurate than age-based dosing for children. Always use the measuring device that comes with the medication, never a household spoon.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Key Safety Rules</h3>
      <ul>
        <li><strong>Acetaminophen:</strong> 10-15 mg/kg every 4-6 hours. No more than 5 doses in 24 hours.</li>
        <li><strong>Ibuprofen:</strong> 5-10 mg/kg every 6-8 hours. Not for babies under 6 months.</li>
        <li><strong>Diphenhydramine:</strong> 1-1.25 mg/kg every 6 hours. Not for children under 2 without doctor approval.</li>
        <li>Never give aspirin to children (risk of Reye's syndrome)</li>
        <li>Do not combine medications without consulting a doctor</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">When to Call the Doctor</h3>
      <p>Contact your pediatrician if fever persists more than 3 days, if your child is under 3 months with any fever, or if symptoms worsen despite medication.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCDS() {
      const weight = parseFloat((document.getElementById('cds-weight') as HTMLInputElement).value) || 30;
      const age = parseFloat((document.getElementById('cds-age') as HTMLInputElement).value) || 3;
      const med = (document.getElementById('cds-med') as HTMLSelectElement).value;

      const weightKg = weight * 0.453592;

      interface MedInfo {
        mgPerKg: number;
        maxMg: number;
        frequency: string;
        maxDoses: number;
        minAge: number;
        concentration: string;
        mgPerMl: number;
      }

      const meds: Record<string, MedInfo> = {
        acetaminophen: {
          mgPerKg: 15, maxMg: 1000, frequency: 'Every 4-6 hours',
          maxDoses: 5, minAge: 0, concentration: '160 mg / 5 mL', mgPerMl: 32
        },
        ibuprofen: {
          mgPerKg: 10, maxMg: 400, frequency: 'Every 6-8 hours',
          maxDoses: 4, minAge: 0.5, concentration: '100 mg / 5 mL', mgPerMl: 20
        },
        diphenhydramine: {
          mgPerKg: 1.25, maxMg: 50, frequency: 'Every 6 hours',
          maxDoses: 4, minAge: 2, concentration: '12.5 mg / 5 mL', mgPerMl: 2.5
        },
      };

      const info = meds[med];
      let doseMg = Math.min(weightKg * info.mgPerKg, info.maxMg);
      doseMg = Math.round(doseMg);

      const doseMl = doseMg / info.mgPerMl;
      const maxDailyMg = doseMg * info.maxDoses;

      let warning = '';
      if (age < info.minAge) {
        warning = 'Not recommended for this age. Consult your pediatrician.';
      }

      const tsp = doseMl / 5;
      let doseDisplay = doseMl.toFixed(1) + ' mL';
      if (tsp >= 1) {
        doseDisplay += ' (' + tsp.toFixed(1) + ' tsp)';
      }

      document.getElementById('cds-dose')!.textContent = warning || doseDisplay;
      document.getElementById('cds-form')!.textContent = info.concentration;
      document.getElementById('cds-mg')!.textContent = doseMg + ' mg';
      document.getElementById('cds-freq')!.textContent = info.frequency;
      document.getElementById('cds-maxdoses')!.textContent = info.maxDoses + ' per day';
      document.getElementById('cds-maxdaily')!.textContent = maxDailyMg + ' mg/day';

      // Weight chart
      const weights = [12, 18, 24, 30, 36, 48, 60, 72, 96];
      document.getElementById('cds-chart')!.innerHTML =
        '<div class="grid grid-cols-4 gap-2 font-semibold text-text-muted mb-1"><span>Weight (lbs)</span><span>Dose (mg)</span><span>Liquid (mL)</span><span>Liquid (tsp)</span></div>' +
        weights.map(w => {
          const wKg = w * 0.453592;
          const mg = Math.min(Math.round(wKg * info.mgPerKg), info.maxMg);
          const ml = mg / info.mgPerMl;
          const t = ml / 5;
          const isHighlighted = Math.abs(w - weight) <= 3;
          return `<div class="grid grid-cols-4 gap-2 py-1 ${isHighlighted ? 'bg-blue-50 rounded font-bold' : ''}"><span>${w} lbs</span><span>${mg} mg</span><span>${ml.toFixed(1)} mL</span><span>${t.toFixed(1)} tsp</span></div>`;
        }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.cds-in').forEach(el => {
        el.addEventListener('input', calcCDS);
        el.addEventListener('change', calcCDS);
      });
      calcCDS();
    }, 50);
  </script>
</CalculatorLayout>
