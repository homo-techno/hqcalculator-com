---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Battery Storage Calculator - Home Battery Sizing for Solar Backup";
const description = "Calculate the right home battery storage capacity (kWh) for solar backup based on your daily usage, solar production, and backup duration needs.";
const relatedCalcs = [
  { name: "Solar Battery", url: "/solar-battery-calculator", description: "Solar batteries." },
  { name: "Solar Panel", url: "/solar-panel-calculator", description: "Solar sizing." },
  { name: "Net Metering", url: "/net-metering-calculator", description: "Net metering." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "EV vs Gas", url: "/ev-vs-gas-calculator", description: "EV comparison." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Battery Storage Calculator" keywords="battery storage calculator, home battery sizing, solar battery kWh, backup power calculator, Tesla Powerwall sizing" breadcrumbs={[{ name: "Battery Storage", url: "/battery-storage-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Battery Storage Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Size your home battery storage system for solar backup and energy independence.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Daily Energy Profile</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Daily Usage (kWh)</label><input type="number" id="bst-daily" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="5" max="200" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Evening Usage (%)</label><input type="number" id="bst-evening" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="60" min="20" max="90" step="5"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Solar Production (kWh/day)</label><input type="number" id="bst-solar" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="32" min="0" max="200" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Self-Consumption (%)</label><input type="number" id="bst-self" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="10" max="90" step="5"></div>
        </div>
        <h3 class="font-semibold text-text">Battery Specs</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Depth of Discharge (%)</label><input type="number" id="bst-dod" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="90" min="50" max="100" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Round-trip Efficiency (%)</label><input type="number" id="bst-rte" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="90" min="70" max="98" step="1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Backup Duration (hours)</label><input type="number" id="bst-backup" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="1" max="72" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Battery Cost ($/kWh)</label><input type="number" id="bst-cost" class="bst-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="500" min="100" max="2000" step="50"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Recommended Battery Size</div>
          <div class="text-4xl font-extrabold" id="bst-size">0</div>
          <div class="text-sm text-blue-200 mt-1">kWh (usable)</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Nominal Capacity</div><div class="text-xl font-bold" id="bst-nominal">0 kWh</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Estimated Cost</div><div class="text-xl font-bold" id="bst-estcost">$0</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Excess Solar Stored</div><div class="text-xl font-bold" id="bst-stored">0 kWh/day</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Backup Capacity</div><div class="text-xl font-bold" id="bst-backupcap">0 hours</div></div>
        </div>
      </div>
      <ShareButton calculatorId="battery-storage" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Sizing Home Battery Storage</h2>
      <p>Home batteries store excess solar energy for use during evening and nighttime hours or during grid outages. Key sizing factors include daily evening/night usage (typically 50-70% of total), depth of discharge (DoD, usually 80-100% for lithium), and round-trip efficiency (85-95%). A typical home needs 10-20 kWh of usable storage. The nominal capacity must be larger than usable capacity to account for DoD limits.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcBST() {
      const daily = parseFloat((document.getElementById('bst-daily') as HTMLInputElement).value) || 30;
      const evening = parseFloat((document.getElementById('bst-evening') as HTMLInputElement).value) || 60;
      const solar = parseFloat((document.getElementById('bst-solar') as HTMLInputElement).value) || 32;
      const selfPct = parseFloat((document.getElementById('bst-self') as HTMLInputElement).value) || 40;
      const dod = parseFloat((document.getElementById('bst-dod') as HTMLInputElement).value) || 90;
      const rte = parseFloat((document.getElementById('bst-rte') as HTMLInputElement).value) || 90;
      const backup = parseFloat((document.getElementById('bst-backup') as HTMLInputElement).value) || 12;
      const costPerKwh = parseFloat((document.getElementById('bst-cost') as HTMLInputElement).value) || 500;
      const eveningUsage = daily * (evening / 100);
      const excessSolar = solar * (1 - selfPct / 100);
      const storageNeeded = Math.min(eveningUsage, excessSolar) / (rte / 100);
      const backupNeeded = (daily / 24) * backup / (rte / 100);
      const usableKwh = Math.max(storageNeeded, backupNeeded);
      const nominalKwh = usableKwh / (dod / 100);
      const estCost = nominalKwh * costPerKwh;
      const backupHours = usableKwh > 0 ? usableKwh * (rte / 100) / (daily / 24) : 0;
      document.getElementById('bst-size')!.textContent = usableKwh.toFixed(1);
      document.getElementById('bst-nominal')!.textContent = nominalKwh.toFixed(1) + ' kWh';
      document.getElementById('bst-estcost')!.textContent = '$' + Math.round(estCost).toLocaleString();
      document.getElementById('bst-stored')!.textContent = excessSolar.toFixed(1) + ' kWh/day';
      document.getElementById('bst-backupcap')!.textContent = backupHours.toFixed(1) + ' hours';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.bst-in').forEach(el => { el.addEventListener('input', calcBST); el.addEventListener('change', calcBST); }); calcBST(); }, 50);
  </script>
</CalculatorLayout>
