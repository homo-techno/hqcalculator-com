---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Wind Turbine Calculator - Small Turbine Output Estimation";
const description = "Estimate small wind turbine energy output from wind speed, rotor diameter, and air density using the wind power equation.";
const relatedCalcs = [
  { name: "Wind Power", url: "/wind-power-calculator", description: "Wind energy basics." },
  { name: "Solar Panel", url: "/solar-panel-calculator", description: "Solar sizing." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "Battery Storage", url: "/battery-storage-calculator", description: "Battery sizing." },
  { name: "Renewable Mix", url: "/renewable-mix-calculator", description: "Energy portfolio." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Wind Turbine Calculator" keywords="wind turbine calculator, small wind turbine output, wind energy estimation, turbine rotor size, wind speed power" breadcrumbs={[{ name: "Wind Turbine", url: "/wind-turbine-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Wind Turbine Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate annual energy output from a small wind turbine based on wind speed and rotor size.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Turbine Specifications</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Rotor Diameter (m)</label><input type="number" id="wtb-dia" class="wtb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="30" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Average Wind Speed (m/s)</label><input type="number" id="wtb-wind" class="wtb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="1" max="25" step="0.5"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Air Density (kg/m³)</label><input type="number" id="wtb-rho" class="wtb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.225" min="0.9" max="1.5" step="0.005"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Turbine Efficiency (%)</label><input type="number" id="wtb-eff" class="wtb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="35" min="10" max="59" step="1"></div>
        </div>
        <h3 class="font-semibold text-text">Economics</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Capacity Factor (%)</label><input type="number" id="wtb-cf" class="wtb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="25" min="5" max="50" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Electricity Rate ($/kWh)</label><input type="number" id="wtb-rate" class="wtb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.14" min="0.01" max="1" step="0.01"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Annual Output</div>
          <div class="text-4xl font-extrabold" id="wtb-annual">0</div>
          <div class="text-sm text-blue-200 mt-1">kWh/year</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Rated Power</div><div class="text-xl font-bold" id="wtb-rated">0 kW</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Swept Area</div><div class="text-xl font-bold" id="wtb-area">0 m²</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Savings</div><div class="text-xl font-bold" id="wtb-savings">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">CO₂ Avoided/Year</div><div class="text-xl font-bold" id="wtb-co2">0 kg</div></div>
        </div>
      </div>
      <ShareButton calculatorId="wind-turbine" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">How Wind Turbine Output is Calculated</h2>
      <p>Wind power follows the equation P = 0.5 * rho * A * V³ * Cp, where rho is air density, A is swept area, V is wind speed, and Cp is the power coefficient. The Betz limit caps theoretical efficiency at 59.3%. Annual output uses the capacity factor to account for variable wind conditions. Small turbines typically range from 1-10 kW rated power.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcWTB() {
      const dia = parseFloat((document.getElementById('wtb-dia') as HTMLInputElement).value) || 5;
      const wind = parseFloat((document.getElementById('wtb-wind') as HTMLInputElement).value) || 6;
      const rho = parseFloat((document.getElementById('wtb-rho') as HTMLInputElement).value) || 1.225;
      const eff = parseFloat((document.getElementById('wtb-eff') as HTMLInputElement).value) || 35;
      const cf = parseFloat((document.getElementById('wtb-cf') as HTMLInputElement).value) || 25;
      const rate = parseFloat((document.getElementById('wtb-rate') as HTMLInputElement).value) || 0.14;
      const area = Math.PI * Math.pow(dia / 2, 2);
      const ratedPower = 0.5 * rho * area * Math.pow(wind, 3) * (eff / 100) / 1000;
      const annualKWh = ratedPower * 8760 * (cf / 100);
      const savings = annualKWh * rate;
      const co2 = annualKWh * 0.417;
      document.getElementById('wtb-annual')!.textContent = Math.round(annualKWh).toLocaleString();
      document.getElementById('wtb-rated')!.textContent = ratedPower.toFixed(2) + ' kW';
      document.getElementById('wtb-area')!.textContent = area.toFixed(1) + ' m\u00B2';
      document.getElementById('wtb-savings')!.textContent = '$' + Math.round(savings).toLocaleString();
      document.getElementById('wtb-co2')!.textContent = Math.round(co2).toLocaleString() + ' kg';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.wtb-in').forEach(el => { el.addEventListener('input', calcWTB); el.addEventListener('change', calcWTB); }); calcWTB(); }, 50);
  </script>
</CalculatorLayout>
