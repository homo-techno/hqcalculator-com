---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Breastmilk Storage Calculator - Storage Time Guidelines by Method";
const description = "Calculate how long breastmilk stays fresh by storage method and temperature. Follow CDC and AAP guidelines for safe breastmilk storage and thawing.";

const relatedCalcs = [
  { name: "Baby Formula Calculator", url: "/baby-formula-calculator", description: "Formula feeding." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "Child Nutrition Calculator", url: "/child-nutrition-calculator", description: "Nutrition needs." },
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper expenses." },
  { name: "Child Dosage Calculator", url: "/child-dosage-calculator", description: "Medication dosing." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare costs." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Breastmilk Storage Calculator"
  keywords="breastmilk storage calculator, breast milk storage guidelines, how long does breastmilk last, pumped milk storage, breastmilk expiration"
  breadcrumbs={[{ name: "Breastmilk Storage Calculator", url: "/breastmilk-storage-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Breastmilk Storage Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Determine how long your pumped breastmilk stays fresh based on storage method and when it was expressed.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">When Was Milk Expressed?</label>
          <input type="datetime-local" id="bms-expressed" class="bms-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Storage Method</label>
          <select id="bms-method" class="bms-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="counter" selected>Countertop / Room Temperature</option>
            <option value="cooler">Insulated Cooler with Ice Packs</option>
            <option value="fridge">Refrigerator (back, not door)</option>
            <option value="freezer">Freezer Compartment (inside fridge)</option>
            <option value="deepfreeze">Deep Freezer (standalone)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Room Temperature (if countertop)</label>
          <select id="bms-temp" class="bms-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="cool">Cool (60-70F / 16-21C)</option>
            <option value="normal" selected>Normal (70-77F / 21-25C)</option>
            <option value="warm">Warm (77-85F / 25-29C)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Amount Stored (oz)</label>
          <input type="number" id="bms-amount" class="bms-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="0.5" max="32" step="0.5">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Time Remaining</div>
        <div class="text-5xl font-extrabold" id="bms-remaining">--</div>
        <div class="text-sm text-blue-200 mt-1" id="bms-expires">use by time</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Max Storage Time</div>
          <div class="text-lg font-bold" id="bms-maxtime">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Ideal Use By</div>
          <div class="text-lg font-bold" id="bms-ideal">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Status</div>
          <div class="text-lg font-bold" id="bms-status">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Feedings Available</div>
          <div class="text-lg font-bold" id="bms-feedings">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Complete Storage Guide</h3>
        <div class="text-xs" id="bms-guide"></div>
      </div>

      <ShareButton calculatorId="breastmilk-storage" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Breastmilk Storage Guidelines</h2>
      <p>Proper storage of breastmilk ensures your baby gets safe, nutritious milk. These guidelines follow CDC and Academy of Breastfeeding Medicine recommendations.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Key Storage Tips</h3>
      <ul>
        <li>Always label containers with the date and time of expression</li>
        <li>Store milk in the back of the fridge or freezer, not the door</li>
        <li>Use BPA-free containers or breastmilk storage bags</li>
        <li>Leave room in containers for expansion when freezing</li>
        <li>Store in small amounts (2-4 oz) to minimize waste</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Thawing Guidelines</h3>
      <ul>
        <li>Thaw overnight in the refrigerator (safest method)</li>
        <li>Thaw under warm running water or in a warm water bath</li>
        <li>Never microwave breastmilk</li>
        <li>Use thawed milk within 24 hours</li>
        <li>Never refreeze thawed breastmilk</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcBMS() {
      const expressedInput = (document.getElementById('bms-expressed') as HTMLInputElement).value;
      const method = (document.getElementById('bms-method') as HTMLSelectElement).value;
      const temp = (document.getElementById('bms-temp') as HTMLSelectElement).value;
      const amount = parseFloat((document.getElementById('bms-amount') as HTMLInputElement).value) || 4;

      // Storage limits in hours
      const limits: Record<string, { max: number; ideal: number; label: string }> = {
        counter: { max: 4, ideal: 2, label: 'Room Temperature' },
        cooler: { max: 24, ideal: 12, label: 'Insulated Cooler' },
        fridge: { max: 96, ideal: 72, label: 'Refrigerator (4C/39F)' },
        freezer: { max: 4320, ideal: 2160, label: 'Freezer (-18C/0F)' },
        deepfreeze: { max: 8760, ideal: 4380, label: 'Deep Freezer (-20C/-4F)' },
      };

      // Adjust counter time by temperature
      if (method === 'counter') {
        if (temp === 'cool') { limits.counter.max = 6; limits.counter.ideal = 4; }
        else if (temp === 'warm') { limits.counter.max = 2; limits.counter.ideal = 1; }
      }

      const info = limits[method];
      const expressed = expressedInput ? new Date(expressedInput) : new Date();
      const now = new Date();
      const elapsedHours = (now.getTime() - expressed.getTime()) / (1000 * 60 * 60);
      const remainingHours = Math.max(0, info.max - elapsedHours);

      function formatDuration(hours: number): string {
        if (hours < 1) return Math.round(hours * 60) + ' min';
        if (hours < 48) return Math.round(hours) + ' hours';
        if (hours < 720) return Math.round(hours / 24) + ' days';
        return Math.round(hours / 720) + ' months';
      }

      let status = 'Fresh';
      if (elapsedHours > info.max) status = 'Expired - Discard';
      else if (elapsedHours > info.ideal) status = 'Use Soon';
      else status = 'Fresh';

      const expiresDate = new Date(expressed.getTime() + info.max * 60 * 60 * 1000);
      const idealDate = new Date(expressed.getTime() + info.ideal * 60 * 60 * 1000);

      const feedings = Math.floor(amount / 3);

      document.getElementById('bms-remaining')!.textContent = formatDuration(remainingHours);
      document.getElementById('bms-expires')!.textContent = 'Expires: ' + expiresDate.toLocaleString();
      document.getElementById('bms-maxtime')!.textContent = formatDuration(info.max);
      document.getElementById('bms-ideal')!.textContent = formatDuration(info.ideal);
      document.getElementById('bms-status')!.textContent = status;
      document.getElementById('bms-feedings')!.textContent = feedings + ' (at 3 oz)';

      const allMethods = ['counter', 'cooler', 'fridge', 'freezer', 'deepfreeze'];
      document.getElementById('bms-guide')!.innerHTML =
        '<div class="grid grid-cols-4 gap-2 font-semibold text-text-muted mb-1"><span>Method</span><span>Temp</span><span>Ideal</span><span>Max</span></div>' +
        allMethods.map(m => {
          const d = limits[m];
          const isSelected = m === method;
          const temps: Record<string, string> = { counter: '77F/25C', cooler: '59F/15C', fridge: '39F/4C', freezer: '0F/-18C', deepfreeze: '-4F/-20C' };
          return `<div class="grid grid-cols-4 gap-2 py-1 ${isSelected ? 'bg-blue-50 rounded font-bold' : ''}"><span>${d.label}</span><span>${temps[m]}</span><span>${formatDuration(d.ideal)}</span><span>${formatDuration(d.max)}</span></div>`;
        }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      // Set default datetime to now
      const now = new Date();
      const offset = now.getTimezoneOffset();
      const local = new Date(now.getTime() - offset * 60000);
      (document.getElementById('bms-expressed') as HTMLInputElement).value = local.toISOString().slice(0, 16);

      document.querySelectorAll('.bms-in').forEach(el => {
        el.addEventListener('input', calcBMS);
        el.addEventListener('change', calcBMS);
      });
      calcBMS();
    }, 50);
  </script>
</CalculatorLayout>
