---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "EV vs Gas Calculator - Total Cost Comparison";
const description = "Compare the total cost of ownership between an electric vehicle and a gas vehicle including purchase price, fuel, maintenance, and depreciation.";
const relatedCalcs = [
  { name: "Electric Vehicle", url: "/electric-vehicle-calculator", description: "EV costs." },
  { name: "Gas Mileage", url: "/gas-mileage-calculator", description: "Fuel economy." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Hydrogen Fuel", url: "/hydrogen-fuel-calculator", description: "Hydrogen fuel." },
  { name: "Carbon Tax", url: "/carbon-tax-calculator", description: "Carbon tax impact." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="EV vs Gas Calculator" keywords="EV vs gas calculator, electric vehicle cost comparison, EV total cost of ownership, EV vs ICE, electric car savings" breadcrumbs={[{ name: "EV vs Gas", url: "/ev-vs-gas-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">EV vs Gas Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Compare total cost of ownership between electric and gas vehicles.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Driving Profile</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Annual Miles</label><input type="number" id="evg-miles" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12000" min="1000" max="50000" step="500"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Ownership Period (years)</label><input type="number" id="evg-years" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" max="20" step="1"></div>
        </div>
        <h3 class="font-semibold text-text">Electric Vehicle</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">EV Purchase Price ($)</label><input type="number" id="evg-evprice" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="38000" min="15000" max="120000" step="1000"></div>
          <div><label class="block text-xs font-medium text-text mb-1">EV Tax Credit ($)</label><input type="number" id="evg-credit" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="7500" min="0" max="12000" step="500"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Efficiency (kWh/100mi)</label><input type="number" id="evg-eff" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="28" min="15" max="50" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Electricity ($/kWh)</label><input type="number" id="evg-elec" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.14" min="0.01" max="0.60" step="0.01"></div>
        </div>
        <h3 class="font-semibold text-text">Gas Vehicle</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Gas Car Price ($)</label><input type="number" id="evg-gasprice" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="32000" min="10000" max="100000" step="1000"></div>
          <div><label class="block text-xs font-medium text-text mb-1">MPG (combined)</label><input type="number" id="evg-mpg" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="10" max="60" step="1"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Gas Price ($/gallon)</label><input type="number" id="evg-gas" class="evg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3.50" min="1" max="8" step="0.10"></div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1" id="evg-winner">EV vs Gas Winner</div>
          <div class="text-4xl font-extrabold" id="evg-diff">$0</div>
          <div class="text-sm text-blue-200 mt-1" id="evg-label">savings</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">EV Total Cost</div><div class="text-xl font-bold" id="evg-evtotal">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Gas Total Cost</div><div class="text-xl font-bold" id="evg-gastotal">$0</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">EV Fuel Cost/Year</div><div class="text-xl font-bold" id="evg-evfuel">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Gas Fuel Cost/Year</div><div class="text-xl font-bold" id="evg-gasfuel">$0</div></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">CO₂ Saved Over Period</div>
          <div class="text-2xl font-bold" id="evg-co2">0 tons</div>
        </div>
      </div>
      <ShareButton calculatorId="ev-vs-gas" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">EV vs Gas Total Cost of Ownership</h2>
      <p>Total cost of ownership includes purchase price, fuel/energy, maintenance, and insurance. EVs cost about 3-4 cents per mile for energy vs 10-15 cents for gasoline. EV maintenance is 40-50% lower (no oil changes, fewer brake replacements). The federal EV tax credit of up to $7,500 offsets the higher purchase price. Break-even typically occurs within 3-5 years of ownership.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcEVG() {
      const miles = parseFloat((document.getElementById('evg-miles') as HTMLInputElement).value) || 12000;
      const years = parseFloat((document.getElementById('evg-years') as HTMLInputElement).value) || 8;
      const evPrice = parseFloat((document.getElementById('evg-evprice') as HTMLInputElement).value) || 38000;
      const credit = parseFloat((document.getElementById('evg-credit') as HTMLInputElement).value) || 7500;
      const eff = parseFloat((document.getElementById('evg-eff') as HTMLInputElement).value) || 28;
      const elec = parseFloat((document.getElementById('evg-elec') as HTMLInputElement).value) || 0.14;
      const gasPrice$ = parseFloat((document.getElementById('evg-gasprice') as HTMLInputElement).value) || 32000;
      const mpg = parseFloat((document.getElementById('evg-mpg') as HTMLInputElement).value) || 30;
      const gas = parseFloat((document.getElementById('evg-gas') as HTMLInputElement).value) || 3.50;
      const evFuelYear = miles * (eff / 100) * elec;
      const gasFuelYear = (miles / mpg) * gas;
      const evMaintYear = miles * 0.04;
      const gasMaintYear = miles * 0.08;
      const evNetPrice = evPrice - credit;
      const evTotal = evNetPrice + (evFuelYear + evMaintYear) * years;
      const gasTotal = gasPrice$ + (gasFuelYear + gasMaintYear) * years;
      const diff = Math.abs(evTotal - gasTotal);
      const winner = evTotal < gasTotal ? 'EV Saves' : 'Gas Car Saves';
      const co2GasTons = miles * years / mpg * 8.887 / 1000;
      const co2EvTons = miles * years * (eff / 100) * 0.417 / 1000;
      const co2Saved = co2GasTons - co2EvTons;
      document.getElementById('evg-winner')!.textContent = winner;
      document.getElementById('evg-diff')!.textContent = '$' + Math.round(diff).toLocaleString();
      document.getElementById('evg-label')!.textContent = 'over ' + years + ' years';
      document.getElementById('evg-evtotal')!.textContent = '$' + Math.round(evTotal).toLocaleString();
      document.getElementById('evg-gastotal')!.textContent = '$' + Math.round(gasTotal).toLocaleString();
      document.getElementById('evg-evfuel')!.textContent = '$' + Math.round(evFuelYear).toLocaleString();
      document.getElementById('evg-gasfuel')!.textContent = '$' + Math.round(gasFuelYear).toLocaleString();
      document.getElementById('evg-co2')!.textContent = co2Saved.toFixed(1) + ' tons';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.evg-in').forEach(el => { el.addEventListener('input', calcEVG); el.addEventListener('change', calcEVG); }); calcEVG(); }, 50);
  </script>
</CalculatorLayout>
