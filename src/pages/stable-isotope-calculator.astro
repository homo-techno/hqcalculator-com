---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Stable Isotope Calculator - Delta C-13 & N-15 Conversion";
const description = "Convert and interpret stable isotope delta values for carbon-13 and nitrogen-15. Analyze dietary patterns, trophic levels, and C3/C4 plant consumption.";
const relatedCalcs = [
  { name: "Radiocarbon Dating", url: "/radiocarbon-dating-calculator", description: "C-14 dating." },
  { name: "Bone Measurement", url: "/bone-measurement-calculator", description: "Skeletal measurements." },
  { name: "Burial Analysis", url: "/burial-analysis-calculator", description: "Burial demographics." },
  { name: "Pollen Analysis", url: "/pollen-analysis-calculator", description: "Palynology." },
  { name: "Faunal Dating", url: "/faunal-dating-calculator", description: "Faunal assemblages." },
  { name: "Carrying Capacity", url: "/carrying-capacity-calculator", description: "Land capacity." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Stable Isotope Calculator" keywords="stable isotope, delta C-13, delta N-15, carbon isotope, nitrogen isotope, diet reconstruction, trophic level, C3 C4" breadcrumbs={[{ name: "Stable Isotope", url: "/stable-isotope-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Stable Isotope Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Convert and interpret stable isotope delta values. Analyze carbon-13 and nitrogen-15 ratios for dietary reconstruction, trophic level estimation, and C3/C4 plant consumption patterns.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Sample Type</label>
          <select id="sic-type" class="sic-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="collagen">Bone Collagen</option>
            <option value="apatite">Bone Apatite</option>
            <option value="tooth">Tooth Enamel</option>
            <option value="hair">Hair Keratin</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">delta-13C (per mil, VPDB)</label>
          <input type="number" id="sic-d13c" class="sic-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="-19.5" min="-40" max="5" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">delta-15N (per mil, AIR)</label>
          <input type="number" id="sic-d15n" class="sic-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10.2" min="-5" max="25" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">C:N Ratio (atomic)</label>
          <input type="number" id="sic-cn" class="sic-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3.2" min="0" max="10" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Collagen Yield (%)</label>
          <input type="number" id="sic-yield" class="sic-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="0" max="30" step="0.1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Dietary Interpretation</div>
          <div class="text-2xl font-extrabold" id="sic-diet">--</div>
          <div class="text-sm text-blue-200 mt-1" id="sic-detail">--</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">C3 vs C4 Signal</div>
            <div class="text-xl font-bold" id="sic-c3c4">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Trophic Level (est.)</div>
            <div class="text-xl font-bold" id="sic-trophic">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Marine % (est.)</div>
            <div class="text-xl font-bold" id="sic-marine">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Quality Check</div>
            <div class="text-xl font-bold" id="sic-quality">--</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">13C/12C Ratio (x10^-3)</div>
            <div class="text-xl font-bold" id="sic-ratio13">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">15N/14N Ratio (x10^-3)</div>
            <div class="text-xl font-bold" id="sic-ratio15">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="stable-isotope" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Stable Isotope Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>delta</strong> = ((R_sample / R_standard) - 1) * 1000</p>
        <p><strong>R_sample</strong> = R_standard * (1 + delta/1000)</p>
        <p><strong>R_VPDB (13C/12C)</strong> = 0.011237</p>
        <p><strong>R_AIR (15N/14N)</strong> = 0.003676</p>
        <p><strong>Trophic Level</strong> ~ (d15N - baseline) / 3.4 + 1</p>
      </div>
      <p>Stable isotopes of carbon distinguish C3 plants (d13C ~ -26 per mil) from C4 plants like maize (d13C ~ -12 per mil). Nitrogen-15 increases ~3.4 per mil per trophic level. Marine protein consumers show enriched d13C and d15N values compared to terrestrial diets. Acceptable C:N ratios for collagen are 2.9-3.6.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSIC() {
      const d13c = parseFloat((document.getElementById('sic-d13c') as HTMLInputElement).value) || 0;
      const d15n = parseFloat((document.getElementById('sic-d15n') as HTMLInputElement).value) || 0;
      const cn = parseFloat((document.getElementById('sic-cn') as HTMLInputElement).value) || 0;
      const yieldPct = parseFloat((document.getElementById('sic-yield') as HTMLInputElement).value) || 0;

      const rVPDB = 0.011237;
      const rAIR = 0.003676;
      const r13 = rVPDB * (1 + d13c / 1000);
      const r15 = rAIR * (1 + d15n / 1000);

      let c3c4 = '';
      if (d13c < -23) c3c4 = 'Pure C3 (terrestrial)';
      else if (d13c < -18) c3c4 = 'Mixed C3/C4 or marine';
      else if (d13c < -14) c3c4 = 'Significant C4/marine';
      else c3c4 = 'Predominantly C4';

      const baseTL = 3;
      const trophicLevel = 1 + (d15n - baseTL) / 3.4;

      const terrestrialEnd = -21;
      const marineEnd = -12;
      let marinePct = 0;
      if (d13c >= marineEnd) marinePct = 100;
      else if (d13c <= terrestrialEnd) marinePct = 0;
      else marinePct = ((d13c - terrestrialEnd) / (marineEnd - terrestrialEnd)) * 100;

      let quality = '';
      if (cn >= 2.9 && cn <= 3.6 && yieldPct >= 1) quality = 'Good';
      else if (cn >= 2.5 && cn <= 4.0 && yieldPct >= 0.5) quality = 'Acceptable';
      else quality = 'Poor - diagenesis likely';

      let diet = '';
      let detail = '';
      if (marinePct > 50) {
        diet = 'Marine-Dominated Diet';
        detail = 'Significant fish/shellfish consumption';
      } else if (d13c > -18) {
        diet = 'C4 Plant Consumer';
        detail = 'Maize, millet, or sorghum based diet';
      } else if (d15n > 12) {
        diet = 'High Protein / Freshwater Fish';
        detail = 'Elevated trophic level suggests carnivory or freshwater resources';
      } else if (d15n > 9) {
        diet = 'Mixed Omnivore';
        detail = 'Animal protein with plant foods';
      } else if (d15n > 6) {
        diet = 'Plant-Based with Some Animal Protein';
        detail = 'Primarily herbivorous with supplementary meat/dairy';
      } else {
        diet = 'Herbivore / Vegan';
        detail = 'Predominantly plant-based subsistence';
      }

      document.getElementById('sic-diet')!.textContent = diet;
      document.getElementById('sic-detail')!.textContent = detail;
      document.getElementById('sic-c3c4')!.textContent = c3c4;
      document.getElementById('sic-trophic')!.textContent = trophicLevel.toFixed(1);
      document.getElementById('sic-marine')!.textContent = marinePct.toFixed(1) + '%';
      document.getElementById('sic-quality')!.textContent = quality;
      document.getElementById('sic-ratio13')!.textContent = (r13 * 1000).toFixed(4);
      document.getElementById('sic-ratio15')!.textContent = (r15 * 1000).toFixed(4);

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.sic-in').forEach(el => { el.addEventListener('input', calcSIC); el.addEventListener('change', calcSIC); });
      calcSIC();
    }, 50);
  </script>
</CalculatorLayout>
