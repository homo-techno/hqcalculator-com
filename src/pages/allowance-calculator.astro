---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Allowance Calculator - Age-Appropriate Allowance with Savings Split";
const description = "Calculate age-appropriate allowance amounts for kids with recommended savings, spending, and giving splits. Build financial literacy from an early age.";

const relatedCalcs = [
  { name: "School Supply Calculator", url: "/school-supply-calculator", description: "School costs." },
  { name: "College Fund Calculator", url: "/college-fund-calculator", description: "College savings." },
  { name: "Budget Calculator", url: "/budget-calculator", description: "Family budgeting." },
  { name: "Savings Calculator", url: "/savings-calculator", description: "Savings growth." },
  { name: "Birthday Party Calculator", url: "/birthday-party-calculator", description: "Party budget." },
  { name: "Compound Interest Calculator", url: "/compound-interest-calculator", description: "Interest growth." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Allowance Calculator"
  keywords="allowance calculator, kids allowance, how much allowance, age appropriate allowance, children allowance guide, allowance by age"
  breadcrumbs={[{ name: "Allowance Calculator", url: "/allowance-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Allowance Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Find the right allowance amount for your child with recommended savings, spending, and giving allocations.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age</label>
          <input type="number" id="alw-age" class="alw-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="4" max="18" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Allowance Method</label>
          <select id="alw-method" class="alw-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="dollar" selected>$1 Per Year of Age (traditional)</option>
            <option value="half">$0.50 Per Year of Age</option>
            <option value="chore">Chore-Based ($2-$5 per chore)</option>
            <option value="custom">Custom Amount</option>
          </select>
        </div>

        <div id="alw-custom-wrap" class="hidden">
          <label class="block text-sm font-medium text-text mb-1">Custom Weekly Amount ($)</label>
          <input type="number" id="alw-custom" class="alw-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="1" max="200" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Savings Percentage (%)</label>
          <input type="number" id="alw-save" class="alw-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="0" max="100" step="5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Giving/Charity Percentage (%)</label>
          <input type="number" id="alw-give" class="alw-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="0" max="50" step="5">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Weekly Allowance</div>
        <div class="text-5xl font-extrabold" id="alw-weekly">--</div>
        <div class="text-sm text-blue-200 mt-1">recommended amount</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Monthly Total</div>
          <div class="text-lg font-bold" id="alw-monthly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Yearly Total</div>
          <div class="text-lg font-bold" id="alw-yearly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Weekly Savings</div>
          <div class="text-lg font-bold" id="alw-weeksave">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Weekly Spending</div>
          <div class="text-lg font-bold" id="alw-weekspend">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Savings Projection</h3>
        <div class="text-xs" id="alw-projection"></div>
      </div>

      <ShareButton calculatorId="allowance" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">How Much Allowance Should Kids Get?</h2>
      <p>A common rule of thumb is $1 per year of age per week. So a 10-year-old would receive $10/week. However, the right amount depends on your family's budget and what the allowance is expected to cover.</p>

      <h3 class="text-xl font-semibold text-text mt-8">The 3-Jar Method</h3>
      <ul>
        <li><strong>Spend (50-60%):</strong> Money for everyday wants and small purchases</li>
        <li><strong>Save (30-40%):</strong> Set aside for larger goals and future needs</li>
        <li><strong>Give (10%):</strong> Charitable giving and gifts for others</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">When to Start</h3>
      <p>Most experts recommend starting allowance between ages 5-7, when children begin understanding money concepts. Start simple and increase responsibility as they grow.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcALW() {
      const age = parseFloat((document.getElementById('alw-age') as HTMLInputElement).value) || 8;
      const method = (document.getElementById('alw-method') as HTMLSelectElement).value;
      const customAmt = parseFloat((document.getElementById('alw-custom') as HTMLInputElement).value) || 10;
      const savePct = parseFloat((document.getElementById('alw-save') as HTMLInputElement).value) || 0;
      const givePct = parseFloat((document.getElementById('alw-give') as HTMLInputElement).value) || 0;

      // Show/hide custom
      const customWrap = document.getElementById('alw-custom-wrap')!;
      customWrap.classList.toggle('hidden', method !== 'custom');

      let weekly: number;
      if (method === 'dollar') {
        weekly = age;
      } else if (method === 'half') {
        weekly = age * 0.5;
      } else if (method === 'chore') {
        const choresPerWeek = Math.min(age - 2, 7);
        const chorePay = age < 8 ? 2 : age < 13 ? 3 : 5;
        weekly = choresPerWeek * chorePay;
      } else {
        weekly = customAmt;
      }

      weekly = Math.round(weekly * 100) / 100;
      const monthly = weekly * 4.33;
      const yearly = weekly * 52;
      const spendPct = Math.max(0, 100 - savePct - givePct);
      const weeklySave = weekly * savePct / 100;
      const weeklySpend = weekly * spendPct / 100;
      const weeklyGive = weekly * givePct / 100;

      document.getElementById('alw-weekly')!.textContent = '$' + weekly.toFixed(2);
      document.getElementById('alw-monthly')!.textContent = '$' + monthly.toFixed(0);
      document.getElementById('alw-yearly')!.textContent = '$' + yearly.toFixed(0);
      document.getElementById('alw-weeksave')!.textContent = '$' + weeklySave.toFixed(2);
      document.getElementById('alw-weekspend')!.textContent = '$' + weeklySpend.toFixed(2);

      // Savings projection
      const yearlySaved = weeklySave * 52;
      const rows: string[] = [];
      let cumulative = 0;
      for (let y = 1; y <= 5; y++) {
        cumulative += yearlySaved;
        const withInterest = cumulative * Math.pow(1.04, y);
        rows.push(`<div class="grid grid-cols-3 gap-2 py-1"><span>Year ${y}</span><span>$${cumulative.toFixed(0)}</span><span>$${withInterest.toFixed(0)} (4% interest)</span></div>`);
      }

      document.getElementById('alw-projection')!.innerHTML =
        '<div class="grid grid-cols-3 gap-2 font-semibold text-text-muted mb-1"><span>Period</span><span>Saved</span><span>With Interest</span></div>' +
        rows.join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.alw-in').forEach(el => {
        el.addEventListener('input', calcALW);
        el.addEventListener('change', calcALW);
      });
      calcALW();
    }, 50);
  </script>
</CalculatorLayout>
