---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Stratigraphy Calculator - Layer Depth to Age Estimation";
const description = "Estimate the age of archaeological or geological layers from depth using sedimentation rates. Calculate deposition time and layer correlation.";
const relatedCalcs = [
  { name: "Radiocarbon Dating", url: "/radiocarbon-dating-calculator", description: "C-14 age calculation." },
  { name: "Geological Time", url: "/geological-time-calculator", description: "Era & period lookup." },
  { name: "Fossil Age", url: "/fossil-age-calculator", description: "Multi-method dating." },
  { name: "Excavation Volume", url: "/excavation-volume-calculator", description: "Dig unit volume." },
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Luminescence Dating", url: "/luminescence-dating-calculator", description: "OSL/TL dating." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Stratigraphy Calculator" keywords="stratigraphy, stratigraphic layer, sedimentation rate, depth to age, layer dating, archaeological stratigraphy, geological layers" breadcrumbs={[{ name: "Stratigraphy", url: "/stratigraphy-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Stratigraphy Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate the age of a stratigraphic layer from its depth below surface and known sedimentation rate. Useful for both archaeological and geological contexts.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Layer Depth Below Surface (cm)</label>
          <input type="number" id="stg-depth" class="stg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="150" min="0" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Sedimentation Rate (cm per century)</label>
          <input type="number" id="stg-rate" class="stg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0.01" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Known Date Layer Depth (cm) - Optional Anchor</label>
          <input type="number" id="stg-ancdepth" class="stg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" step="1" placeholder="0 = surface (modern)">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Known Date Layer Age (years BP)</label>
          <input type="number" id="stg-ancage" class="stg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" step="1" placeholder="0 = present">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Layer Thickness (cm)</label>
          <input type="number" id="stg-thick" class="stg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Layer Age</div>
          <div class="text-4xl font-extrabold" id="stg-age">0</div>
          <div class="text-sm text-blue-200 mt-1" id="stg-ageunit">years BP</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Deposition Time (layer)</div>
            <div class="text-xl font-bold" id="stg-deptime">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Age Range (top-bottom)</div>
            <div class="text-xl font-bold" id="stg-range">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Rate (cm/year)</div>
            <div class="text-xl font-bold" id="stg-cmyr">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Calendar Year (est.)</div>
            <div class="text-xl font-bold" id="stg-calyr">--</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="stratigraphy" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Stratigraphic Age Estimation</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Age</strong> = Anchor Age + (Depth - Anchor Depth) / Rate * 100</p>
        <p><strong>Deposition Time</strong> = Layer Thickness / Rate * 100 years</p>
      </div>
      <p>The Law of Superposition states that in undisturbed sediments, older layers lie beneath younger ones. By knowing the sedimentation rate, archaeologists can estimate the age of a layer from its depth. Sedimentation rates vary greatly depending on environment, climate, and human activity.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSTG() {
      const depth = parseFloat((document.getElementById('stg-depth') as HTMLInputElement).value) || 0;
      const rateCmCentury = parseFloat((document.getElementById('stg-rate') as HTMLInputElement).value) || 0;
      const ancDepth = parseFloat((document.getElementById('stg-ancdepth') as HTMLInputElement).value) || 0;
      const ancAge = parseFloat((document.getElementById('stg-ancage') as HTMLInputElement).value) || 0;
      const thickness = parseFloat((document.getElementById('stg-thick') as HTMLInputElement).value) || 0;

      const rateCmYr = rateCmCentury / 100;
      const depthDiff = depth - ancDepth;
      const age = rateCmYr > 0 ? ancAge + depthDiff / rateCmYr : 0;
      const depTime = rateCmYr > 0 ? thickness / rateCmYr : 0;
      const ageTop = rateCmYr > 0 ? ancAge + (depth - thickness / 2 - ancDepth) / rateCmYr : 0;
      const ageBottom = rateCmYr > 0 ? ancAge + (depth + thickness / 2 - ancDepth) / rateCmYr : 0;

      const calYear = 1950 - age;
      let calStr = '--';
      if (age >= 0 && age < 100000) {
        calStr = calYear < 0 ? Math.abs(Math.round(calYear)) + ' BC' : Math.round(calYear) + ' AD';
      }

      document.getElementById('stg-age')!.textContent = Math.round(age).toLocaleString();
      document.getElementById('stg-ageunit')!.textContent = 'years BP';
      document.getElementById('stg-deptime')!.textContent = Math.round(depTime).toLocaleString() + ' years';
      document.getElementById('stg-range')!.textContent = Math.round(ageTop).toLocaleString() + ' - ' + Math.round(ageBottom).toLocaleString() + ' BP';
      document.getElementById('stg-cmyr')!.textContent = rateCmYr.toFixed(4);
      document.getElementById('stg-calyr')!.textContent = calStr;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.stg-in').forEach(el => { el.addEventListener('input', calcSTG); el.addEventListener('change', calcSTG); });
      calcSTG();
    }, 50);
  </script>
</CalculatorLayout>
