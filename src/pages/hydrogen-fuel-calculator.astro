---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Hydrogen Fuel Calculator - Fuel Cell Energy Output & Efficiency";
const description = "Calculate hydrogen fuel cell energy output, efficiency, and cost comparison with gasoline and electricity.";
const relatedCalcs = [
  { name: "EV vs Gas", url: "/ev-vs-gas-calculator", description: "EV cost comparison." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "Gas Mileage", url: "/gas-mileage-calculator", description: "Fuel economy." },
  { name: "Renewable Mix", url: "/renewable-mix-calculator", description: "Energy portfolio." },
  { name: "Carbon Offset", url: "/carbon-offset-calculator", description: "Offset carbon." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Hydrogen Fuel Calculator" keywords="hydrogen fuel cell calculator, hydrogen energy output, fuel cell efficiency, hydrogen vs gasoline, green hydrogen" breadcrumbs={[{ name: "Hydrogen Fuel", url: "/hydrogen-fuel-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Hydrogen Fuel Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate hydrogen fuel cell energy output, efficiency, and economics.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Hydrogen Input</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Hydrogen Mass (kg)</label><input type="number" id="hfc-mass" class="hfc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0.1" max="1000" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Fuel Cell Efficiency (%)</label><input type="number" id="hfc-eff" class="hfc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="60" min="20" max="80" step="1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">H2 Cost ($/kg)</label><input type="number" id="hfc-h2cost" class="hfc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="1" max="30" step="0.5"></div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Production Method</label>
            <select id="hfc-method" class="hfc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="green">Green (Electrolysis - Renewable)</option>
              <option value="blue">Blue (SMR + Carbon Capture)</option>
              <option value="grey" selected>Grey (Steam Methane Reforming)</option>
            </select>
          </div>
        </div>
        <h3 class="font-semibold text-text">Comparison</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Gasoline Price ($/gal)</label><input type="number" id="hfc-gas" class="hfc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3.50" min="1" max="10" step="0.10"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Electricity Rate ($/kWh)</label><input type="number" id="hfc-elec" class="hfc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.14" min="0.01" max="1" step="0.01"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Electrical Energy Output</div>
          <div class="text-4xl font-extrabold" id="hfc-output">0</div>
          <div class="text-sm text-blue-200 mt-1">kWh</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">H2 Energy Content</div><div class="text-xl font-bold" id="hfc-energy">0 kWh</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Gasoline Equivalent</div><div class="text-xl font-bold" id="hfc-gge">0 gal</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">H2 Cost</div><div class="text-xl font-bold" id="hfc-totalcost">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">CO₂ Emissions</div><div class="text-xl font-bold" id="hfc-co2">0 kg</div></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Cost per kWh (delivered)</div>
          <div class="text-2xl font-bold" id="hfc-cpkwh">$0.00</div>
        </div>
      </div>
      <ShareButton calculatorId="hydrogen-fuel" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Hydrogen Fuel Cells</h2>
      <p>Hydrogen has the highest energy density per mass of any fuel at 33.3 kWh/kg (120 MJ/kg). Fuel cells convert hydrogen to electricity at 40-60% efficiency, producing only water. One kg of H2 equals about 1 gallon of gasoline in energy. Green hydrogen from renewable electrolysis produces near-zero CO₂, while grey hydrogen from natural gas reforming emits about 10 kg CO₂ per kg H2.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    const hfcCO2: Record<string, number> = { green: 0.5, blue: 3, grey: 10 };
    function calcHFC() {
      const mass = parseFloat((document.getElementById('hfc-mass') as HTMLInputElement).value) || 5;
      const eff = parseFloat((document.getElementById('hfc-eff') as HTMLInputElement).value) || 60;
      const h2cost = parseFloat((document.getElementById('hfc-h2cost') as HTMLInputElement).value) || 10;
      const method = (document.getElementById('hfc-method') as HTMLSelectElement).value;
      const gasPrice = parseFloat((document.getElementById('hfc-gas') as HTMLInputElement).value) || 3.50;
      const elecRate = parseFloat((document.getElementById('hfc-elec') as HTMLInputElement).value) || 0.14;
      const energyContent = mass * 33.3;
      const electricalOut = energyContent * (eff / 100);
      const gge = mass * 1.0;
      const totalCost = mass * h2cost;
      const costPerKWh = electricalOut > 0 ? totalCost / electricalOut : 0;
      const co2 = mass * (hfcCO2[method] || 10);
      document.getElementById('hfc-output')!.textContent = electricalOut.toFixed(1);
      document.getElementById('hfc-energy')!.textContent = energyContent.toFixed(1) + ' kWh';
      document.getElementById('hfc-gge')!.textContent = gge.toFixed(1) + ' gal';
      document.getElementById('hfc-totalcost')!.textContent = '$' + totalCost.toFixed(2);
      document.getElementById('hfc-co2')!.textContent = co2.toFixed(1) + ' kg';
      document.getElementById('hfc-cpkwh')!.textContent = '$' + costPerKWh.toFixed(3);
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.hfc-in').forEach(el => { el.addEventListener('input', calcHFC); el.addEventListener('change', calcHFC); }); calcHFC(); }, 50);
  </script>
</CalculatorLayout>
