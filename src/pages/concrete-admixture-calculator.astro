---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Admixture Calculator - Accelerator, Retarder & Plasticizer Dosage";
const description = "Calculate concrete admixture dosage rates for accelerators, retarders, water reducers, superplasticizers, and air-entraining agents per cubic yard.";

const relatedCalcs = [
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Mix design ratios." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Concrete Curing Calculator", url: "/concrete-curing-calculator", description: "Curing time." },
  { name: "Concrete Strength Calculator", url: "/concrete-strength-calculator", description: "Strength testing." },
  { name: "Concrete Color Calculator", url: "/concrete-color-calculator", description: "Color pigment dosage." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Admixture Calculator"
  keywords="concrete admixture, accelerator, retarder, water reducer, superplasticizer, air entraining, admixture dosage"
  breadcrumbs={[{ name: "Concrete Admixture Calculator", url: "/concrete-admixture-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Admixture Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate admixture dosage rates for accelerators, retarders, and plasticizers per batch.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Admixture Type</label>
          <select id="cam-type" class="cam-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="accelerator" selected>Accelerator (Calcium Chloride)</option>
            <option value="nonchloride">Non-Chloride Accelerator</option>
            <option value="retarder">Retarder (Set Time Extension)</option>
            <option value="wr">Water Reducer (Type A)</option>
            <option value="mrwr">Mid-Range Water Reducer</option>
            <option value="hrwr">High-Range Water Reducer (Superplasticizer)</option>
            <option value="aea">Air-Entraining Agent</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Concrete Volume (cubic yards)</label>
          <input type="number" id="cam-volume" class="cam-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0.5" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Cement Content (bags per yd3)</label>
          <input type="number" id="cam-cement" class="cam-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5.5" min="3" max="9" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Dosage Level</label>
          <select id="cam-dose" class="cam-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="low">Low (Minimum Recommended)</option>
            <option value="mid" selected>Standard (Mid-Range)</option>
            <option value="high">High (Maximum Recommended)</option>
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Admixture Needed</div>
          <div class="text-4xl font-extrabold" id="cam-total">0 fl oz</div>
          <div class="text-sm text-blue-200 mt-1"><span id="cam-gal">0</span> gallons</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Dosage Rate</div>
            <div class="text-xl font-bold" id="cam-rate">0 oz/cwt</div>
            <div class="text-xs text-text-muted">oz per 100 lb cement</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Per Cubic Yard</div>
            <div class="text-xl font-bold" id="cam-peryd">0 fl oz</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Effect on Set Time</div>
            <div class="text-xl font-bold" id="cam-settime">-</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water Reduction</div>
            <div class="text-xl font-bold" id="cam-water">-</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Total Cement Weight in Batch</div>
          <div class="text-xl font-bold" id="cam-cwt">0 lbs</div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-admixture" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Concrete Admixture Dosage Guide</h2>
      <ul>
        <li><strong>Accelerator:</strong> 1-2% CaCl2 by weight of cement; speeds set 30-50%</li>
        <li><strong>Retarder:</strong> 2-5 oz/cwt; delays set 1-4 hours</li>
        <li><strong>Water reducer:</strong> 3-5 oz/cwt; reduces water 5-10%</li>
        <li><strong>Superplasticizer:</strong> 6-20 oz/cwt; reduces water 12-30%</li>
        <li><strong>Air entrainer:</strong> 0.5-3 oz/cwt; targets 4-7% air content</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    interface AdmixSpec {
      low: number; mid: number; high: number; // oz per cwt (100 lb cement)
      setEffect: string;
      waterReduction: string;
    }

    const camSpecs: Record<string, AdmixSpec> = {
      accelerator:  { low: 16, mid: 24, high: 32, setEffect: '30-50% faster', waterReduction: 'None' },
      nonchloride:  { low: 15, mid: 30, high: 45, setEffect: '25-40% faster', waterReduction: 'None' },
      retarder:     { low: 2, mid: 4, high: 6, setEffect: '1-4 hrs slower', waterReduction: '3-5%' },
      wr:           { low: 3, mid: 5, high: 7, setEffect: 'Slight retard', waterReduction: '5-10%' },
      mrwr:         { low: 4, mid: 8, high: 12, setEffect: 'Slight retard', waterReduction: '8-15%' },
      hrwr:         { low: 6, mid: 12, high: 20, setEffect: 'Variable', waterReduction: '12-30%' },
      aea:          { low: 0.5, mid: 1.5, high: 3, setEffect: 'Slight retard', waterReduction: '3-5%' },
    };

    function calcCAM() {
      const type = (document.getElementById('cam-type') as HTMLSelectElement).value;
      const volume = parseFloat((document.getElementById('cam-volume') as HTMLInputElement).value) || 0;
      const cementBagsPerYd = parseFloat((document.getElementById('cam-cement') as HTMLInputElement).value) || 5.5;
      const dose = (document.getElementById('cam-dose') as HTMLSelectElement).value;

      const spec = camSpecs[type] || camSpecs.accelerator;
      const dosageRate = spec[dose as keyof Pick<AdmixSpec, 'low' | 'mid' | 'high'>] || spec.mid;

      const cementLbsPerYd = cementBagsPerYd * 94;
      const totalCementLbs = cementLbsPerYd * volume;
      const cwt = totalCementLbs / 100;

      const totalOz = dosageRate * cwt;
      const totalGal = totalOz / 128;
      const perYd = totalOz / (volume || 1);

      document.getElementById('cam-total')!.textContent = Math.round(totalOz).toLocaleString() + ' fl oz';
      document.getElementById('cam-gal')!.textContent = totalGal.toFixed(2);
      document.getElementById('cam-rate')!.textContent = dosageRate + ' oz/cwt';
      document.getElementById('cam-peryd')!.textContent = perYd.toFixed(1) + ' fl oz';
      document.getElementById('cam-settime')!.textContent = spec.setEffect;
      document.getElementById('cam-water')!.textContent = spec.waterReduction;
      document.getElementById('cam-cwt')!.textContent = Math.round(totalCementLbs).toLocaleString() + ' lbs';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.cam-in').forEach(el => {
        el.addEventListener('input', calcCAM);
        el.addEventListener('change', calcCAM);
      });
      calcCAM();
    }, 50);
  </script>
</CalculatorLayout>
