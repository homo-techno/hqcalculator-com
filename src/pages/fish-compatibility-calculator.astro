---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Fish Compatibility Calculator - Stocking Score by Species";
const description = "Check fish compatibility scores by species temperament, size, water parameters, and swimming zone to plan a peaceful community tank.";
const relatedCalcs = [
  { name: "Fish Tank Stocking", url: "/fish-tank-stocking-calculator", description: "Fish stocking capacity calculator." },
  { name: "Fish Feeding", url: "/fish-feeding-calculator", description: "Fish feeding amount and frequency." },
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume." },
  { name: "Aquarium Water Change", url: "/aquarium-water-change-calculator", description: "Water change schedule." },
  { name: "Breeding Tank", url: "/breeding-tank-calculator", description: "Breeding tank setup calculator." },
  { name: "Aquarium Heater", url: "/aquarium-heater-calculator", description: "Heater wattage calculator." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Fish Compatibility Calculator" keywords="fish compatibility calculator, community tank, fish temperament, aquarium stocking, fish species compatibility" breadcrumbs={[{ name: "Fish Compatibility", url: "/fish-compatibility-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Fish Compatibility Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Evaluate fish compatibility based on temperament, size, preferred water conditions, and swimming zone.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-text">Fish Species 1</p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Temperament</label>
            <select id="fcc-t1" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="peaceful">Peaceful</option>
              <option value="semi" selected>Semi-Aggressive</option>
              <option value="aggressive">Aggressive</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Max Size (inches)</label>
            <input type="number" id="fcc-s1" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0.5" max="36" step="0.5">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Preferred Temp (&deg;F)</label>
            <input type="number" id="fcc-temp1" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="76" min="60" max="90" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Swimming Zone</label>
            <select id="fcc-z1" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="top">Top</option>
              <option value="mid" selected>Middle</option>
              <option value="bottom">Bottom</option>
              <option value="all">All Levels</option>
            </select>
          </div>
        </div>
        <p class="text-sm font-semibold text-text">Fish Species 2</p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Temperament</label>
            <select id="fcc-t2" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="peaceful" selected>Peaceful</option>
              <option value="semi">Semi-Aggressive</option>
              <option value="aggressive">Aggressive</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Max Size (inches)</label>
            <input type="number" id="fcc-s2" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0.5" max="36" step="0.5">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Preferred Temp (&deg;F)</label>
            <input type="number" id="fcc-temp2" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="78" min="60" max="90" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Swimming Zone</label>
            <select id="fcc-z2" class="fcc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="top">Top</option>
              <option value="mid">Middle</option>
              <option value="bottom" selected>Bottom</option>
              <option value="all">All Levels</option>
            </select>
          </div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Compatibility Score</div>
          <div class="text-5xl font-extrabold font-mono" id="fcc-result">0 / 100</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Temperament Match</div>
            <div class="text-xl font-bold font-mono" id="fcc-temper">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Size Ratio</div>
            <div class="text-xl font-bold font-mono" id="fcc-sizeratio">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Temp Overlap</div>
            <div class="text-xl font-bold font-mono" id="fcc-tempov">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Zone Conflict</div>
            <div class="text-xl font-bold font-mono" id="fcc-zone">--</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="fish-compatibility" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcFCC() {
      const t1 = (document.getElementById('fcc-t1') as HTMLSelectElement).value;
      const t2 = (document.getElementById('fcc-t2') as HTMLSelectElement).value;
      const s1 = parseFloat((document.getElementById('fcc-s1') as HTMLInputElement).value) || 1;
      const s2 = parseFloat((document.getElementById('fcc-s2') as HTMLInputElement).value) || 1;
      const temp1 = parseFloat((document.getElementById('fcc-temp1') as HTMLInputElement).value) || 76;
      const temp2 = parseFloat((document.getElementById('fcc-temp2') as HTMLInputElement).value) || 76;
      const z1 = (document.getElementById('fcc-z1') as HTMLSelectElement).value;
      const z2 = (document.getElementById('fcc-z2') as HTMLSelectElement).value;
      // Temperament score (0-30)
      const tScores: Record<string, number> = { peaceful: 0, semi: 1, aggressive: 2 };
      const tDiff = Math.abs((tScores[t1] || 0) - (tScores[t2] || 0));
      let temperScore = tDiff === 0 ? 30 : tDiff === 1 ? 15 : 0;
      // Aggressive + peaceful = bad
      if ((t1 === 'aggressive' && t2 === 'peaceful') || (t2 === 'aggressive' && t1 === 'peaceful')) temperScore = 0;
      const temperLabel = temperScore >= 25 ? 'Good' : temperScore >= 10 ? 'Caution' : 'Poor';
      // Size ratio score (0-25) - fish should be within 2:1 size ratio
      const sizeRatio = Math.max(s1, s2) / Math.min(s1, s2);
      let sizeScore = sizeRatio <= 1.5 ? 25 : sizeRatio <= 2 ? 20 : sizeRatio <= 3 ? 10 : 0;
      const sizeLabel = sizeRatio.toFixed(1) + ':1';
      // Temperature overlap score (0-25)
      const tempDiff = Math.abs(temp1 - temp2);
      let tempScore = tempDiff <= 2 ? 25 : tempDiff <= 4 ? 20 : tempDiff <= 6 ? 10 : 0;
      const tempLabel = tempDiff <= 2 ? 'Excellent' : tempDiff <= 4 ? 'Good' : tempDiff <= 6 ? 'Fair' : 'Poor';
      // Zone conflict score (0-20) - different zones = less competition
      let zoneScore = 20;
      let zoneLabel = 'None';
      if (z1 === z2) { zoneScore = 10; zoneLabel = 'Same zone'; }
      if (z1 === 'all' || z2 === 'all') { zoneScore = 15; zoneLabel = 'Partial'; }
      if (z1 !== z2 && z1 !== 'all' && z2 !== 'all') { zoneScore = 20; zoneLabel = 'None'; }
      const total = temperScore + sizeScore + tempScore + zoneScore;
      document.getElementById('fcc-result')!.textContent = total + ' / 100';
      document.getElementById('fcc-temper')!.textContent = temperLabel;
      document.getElementById('fcc-sizeratio')!.textContent = sizeLabel;
      document.getElementById('fcc-tempov')!.textContent = tempLabel;
      document.getElementById('fcc-zone')!.textContent = zoneLabel;
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.fcc-in').forEach(el => { el.addEventListener('input', calcFCC); el.addEventListener('change', calcFCC); });
      calcFCC();
    }, 50);
  </script>
</CalculatorLayout>
