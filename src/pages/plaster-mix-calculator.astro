---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Plaster Mix Calculator - Mixing Ratios for All Plaster Types";
const description = "Calculate plaster mixing ratios and material quantities for gypsum, lime, cement, and venetian plaster. Get coverage area and number of coats.";

const relatedCalcs = [
  { name: "Stucco Calculator", url: "/stucco-calculator", description: "Stucco material estimator." },
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Concrete mix design." },
  { name: "Mortar Calculator", url: "/mortar-calculator", description: "Mortar estimator." },
  { name: "Brick Calculator", url: "/brick-calculator", description: "Brick quantity." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Tuckpointing Calculator", url: "/tuckpointing-calculator", description: "Tuckpointing mortar." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Plaster Mix Calculator"
  keywords="plaster mix ratio, gypsum plaster, lime plaster, cement plaster, plaster coverage, plaster thickness, venetian plaster"
  breadcrumbs={[{ name: "Plaster Mix Calculator", url: "/plaster-mix-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Plaster Mix Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate mixing ratios and material quantities for different plaster types and applications.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Plaster Type</label>
          <select id="pmx-type" class="pmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="gypsum" selected>Gypsum Plaster (Interior Walls)</option>
            <option value="lime">Lime Plaster (Traditional / Breathable)</option>
            <option value="cement">Cement Plaster (Exterior / Wet Areas)</option>
            <option value="venetian">Venetian / Polished Plaster</option>
            <option value="onecoat">One-Coat Plaster (Pre-mixed)</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Length (ft)</label>
            <input type="number" id="pmx-length" class="pmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Height (ft)</label>
            <input type="number" id="pmx-height" class="pmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="0" step="0.5">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Plaster Thickness (inches)</label>
          <input type="number" id="pmx-thick" class="pmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.5" min="0.125" max="2" step="0.125">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Openings to Deduct (sq ft)</label>
          <input type="number" id="pmx-openings" class="pmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" step="1">
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <label class="block text-xs font-medium text-text mb-1">Waste Factor (%)</label>
          <input type="number" id="pmx-waste" class="pmx-in w-full px-3 py-2 border border-border rounded-lg" value="10" min="0" max="30" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Plaster Needed</div>
          <div class="text-4xl font-extrabold" id="pmx-total">0 lbs</div>
          <div class="text-sm text-blue-200 mt-1">Mix Ratio: <span id="pmx-ratio">-</span></div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Coverage Area</div>
            <div class="text-xl font-bold" id="pmx-area">0 sq ft</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Number of Coats</div>
            <div class="text-xl font-bold" id="pmx-coats">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Base Material</div>
            <div class="text-xl font-bold" id="pmx-base">0 lbs</div>
            <div class="text-xs text-text-muted" id="pmx-base-label">Gypsum</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Sand / Aggregate</div>
            <div class="text-xl font-bold" id="pmx-sand">0 lbs</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water Needed</div>
            <div class="text-xl font-bold" id="pmx-water">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Bags (50 lb)</div>
            <div class="text-xl font-bold" id="pmx-bags">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="plaster-mix" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Plaster Types and Mix Ratios</h2>
      <ul>
        <li><strong>Gypsum Plaster:</strong> Pre-mixed, 1 part gypsum to 0.5 parts perlite. Interior only.</li>
        <li><strong>Lime Plaster:</strong> 1 part lime putty : 3 parts sand. Breathable, flexible.</li>
        <li><strong>Cement Plaster:</strong> 1 part cement : 4-6 parts sand. Durable, waterproof.</li>
        <li><strong>Venetian Plaster:</strong> Lime putty based, applied in thin burnished coats.</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    interface PlasterType {
      ratio: string;
      coats: number;
      density: number; // lbs per cu ft of mixed plaster
      baseLabel: string;
      basePart: number;
      sandPart: number;
      waterRatio: number; // gal per lb of dry material
    }

    const pmxTypes: Record<string, PlasterType> = {
      gypsum:   { ratio: '1 : 0.5 (Gypsum : Perlite)', coats: 2, density: 90, baseLabel: 'Gypsum', basePart: 1, sandPart: 0.5, waterRatio: 0.06 },
      lime:     { ratio: '1 : 3 (Lime : Sand)', coats: 3, density: 110, baseLabel: 'Lime Putty', basePart: 1, sandPart: 3, waterRatio: 0.05 },
      cement:   { ratio: '1 : 5 (Cement : Sand)', coats: 2, density: 120, baseLabel: 'Cement', basePart: 1, sandPart: 5, waterRatio: 0.04 },
      venetian: { ratio: 'Pre-mixed Lime Putty', coats: 4, density: 95, baseLabel: 'Lime Putty', basePart: 1, sandPart: 0, waterRatio: 0.03 },
      onecoat:  { ratio: 'Pre-mixed (Apply as-is)', coats: 1, density: 100, baseLabel: 'Pre-mixed', basePart: 1, sandPart: 0, waterRatio: 0.05 },
    };

    function calcPMX() {
      const type = (document.getElementById('pmx-type') as HTMLSelectElement).value;
      const length = parseFloat((document.getElementById('pmx-length') as HTMLInputElement).value) || 0;
      const height = parseFloat((document.getElementById('pmx-height') as HTMLInputElement).value) || 0;
      const thick = parseFloat((document.getElementById('pmx-thick') as HTMLInputElement).value) || 0.5;
      const openings = parseFloat((document.getElementById('pmx-openings') as HTMLInputElement).value) || 0;
      const waste = (parseFloat((document.getElementById('pmx-waste') as HTMLInputElement).value) || 0) / 100;

      const spec = pmxTypes[type] || pmxTypes.gypsum;
      const area = Math.max(0, length * height - openings);
      const volumeCuFt = area * (thick / 12);
      const totalWeight = volumeCuFt * spec.density * (1 + waste);

      const totalParts = spec.basePart + spec.sandPart;
      const baseWeight = totalWeight * (spec.basePart / totalParts);
      const sandWeight = totalWeight * (spec.sandPart / totalParts);
      const waterGal = totalWeight * spec.waterRatio;

      document.getElementById('pmx-total')!.textContent = Math.round(totalWeight).toLocaleString() + ' lbs';
      document.getElementById('pmx-ratio')!.textContent = spec.ratio;
      document.getElementById('pmx-area')!.textContent = Math.round(area).toLocaleString() + ' sq ft';
      document.getElementById('pmx-coats')!.textContent = String(spec.coats);
      document.getElementById('pmx-base')!.textContent = Math.round(baseWeight).toLocaleString() + ' lbs';
      document.getElementById('pmx-base-label')!.textContent = spec.baseLabel;
      document.getElementById('pmx-sand')!.textContent = Math.round(sandWeight).toLocaleString() + ' lbs';
      document.getElementById('pmx-water')!.textContent = waterGal.toFixed(1) + ' gal';
      document.getElementById('pmx-bags')!.textContent = String(Math.ceil(totalWeight / 50));

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.pmx-in').forEach(el => {
        el.addEventListener('input', calcPMX);
        el.addEventListener('change', calcPMX);
      });
      calcPMX();
    }, 50);
  </script>
</CalculatorLayout>
