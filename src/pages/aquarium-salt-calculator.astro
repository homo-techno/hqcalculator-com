---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Salt Calculator - Dosage for Brackish & Marine Tanks";
const description = "Calculate aquarium salt dosage for brackish water, marine setups, and freshwater disease treatments based on tank volume and target salinity.";
const relatedCalcs = [
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume and water weight." },
  { name: "Reef Tank", url: "/reef-tank-calculator", description: "Reef tank calcium and alkalinity dosing." },
  { name: "Aquarium Water Change", url: "/aquarium-water-change-calculator", description: "Water change volume and frequency." },
  { name: "Aquarium Medication", url: "/aquarium-medication-calculator", description: "Fish medication dosing calculator." },
  { name: "Live Rock", url: "/live-rock-calculator", description: "Live rock quantity for marine tanks." },
  { name: "Aquarium Sump", url: "/aquarium-sump-calculator", description: "Sump sizing and return pump selection." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Salt Calculator" keywords="aquarium salt calculator, marine salt mix, brackish water salt, fish tank salt dosage, aquarium salinity" breadcrumbs={[{ name: "Aquarium Salt", url: "/aquarium-salt-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Salt Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate salt dosage for brackish water, marine tank mixing, or freshwater disease treatments.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-text mb-1">Tank Volume (gallons)</label>
          <input type="number" id="as2-vol" class="as2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="55" min="1" step="1">
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Purpose</label>
          <select id="as2-purpose" class="as2-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="marine">Marine / Saltwater (SG 1.025)</option>
            <option value="brackish">Brackish Water (SG 1.005-1.015)</option>
            <option value="treatment">Freshwater Treatment (1 tbsp/5 gal)</option>
            <option value="dip">Salt Dip / Bath (high concentration)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Current Specific Gravity</label>
          <input type="number" id="as2-cur" class="as2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.000" min="1.000" max="1.035" step="0.001">
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Salt to Add</div>
          <div class="text-5xl font-extrabold font-mono" id="as2-result">0 cups</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Weight (oz)</div>
            <div class="text-xl font-bold font-mono" id="as2-oz">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Weight (grams)</div>
            <div class="text-xl font-bold font-mono" id="as2-grams">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Target SG</div>
            <div class="text-xl font-bold font-mono" id="as2-sg">1.000</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">PPT Salinity</div>
            <div class="text-xl font-bold font-mono" id="as2-ppt">0</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-salt" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcAS2() {
      const vol = parseFloat((document.getElementById('as2-vol') as HTMLInputElement).value) || 0;
      const purpose = (document.getElementById('as2-purpose') as HTMLSelectElement).value;
      const curSG = parseFloat((document.getElementById('as2-cur') as HTMLInputElement).value) || 1.0;
      // Target SG by purpose
      const targets: Record<string, number> = { marine: 1.025, brackish: 1.010, treatment: 1.002, dip: 1.015 };
      const targetSG = targets[purpose] || 1.025;
      const sgDiff = Math.max(0, targetSG - curSG);
      // Approx: 0.5 cups marine salt per gallon raises SG by ~0.025 from fresh
      // So cups = vol * (sgDiff / 0.025) * 0.5
      let cups = vol * (sgDiff / 0.025) * 0.5;
      if (purpose === 'treatment') {
        // Simple: 1 tbsp per 5 gallons = vol/5 tbsp = vol/80 cups
        cups = vol / 5 / 16; // tbsp to cups
      }
      const ozWeight = cups * 10; // marine salt ~10 oz per cup
      const grams = ozWeight * 28.35;
      // PPT from SG: ppt ≈ (SG - 1) * 1000 * 1.3 (approximate)
      const ppt = ((targetSG - 1) * 1000 * 1.3).toFixed(1);
      document.getElementById('as2-result')!.textContent = cups.toFixed(2) + ' cups';
      document.getElementById('as2-oz')!.textContent = ozWeight.toFixed(1);
      document.getElementById('as2-grams')!.textContent = Math.round(grams).toString();
      document.getElementById('as2-sg')!.textContent = targetSG.toFixed(3);
      document.getElementById('as2-ppt')!.textContent = ppt;
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.as2-in').forEach(el => { el.addEventListener('input', calcAS2); el.addEventListener('change', calcAS2); });
      calcAS2();
    }, 50);
  </script>
</CalculatorLayout>
