---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = "About Us - HQ Calculator";
const description = "Learn about HQ Calculator — the free online calculator platform with 1,300+ tools for finance, health, math, construction, and more.";

const stats = [
  { value: '1,300+', label: 'Calculators' },
  { value: '50+', label: 'Categories' },
  { value: '100%', label: 'Free' },
  { value: '<1s', label: 'Load Time' },
];
---

<CalculatorLayout
  title={title}
  description={description}
  breadcrumbs={[{ name: 'About Us', url: '/about' }]}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-text mb-6">About HQ Calculator</h1>

    <div class="space-y-6 text-text-secondary leading-relaxed">
      <p>
        HQ Calculator is a free online platform offering over 1,300 calculators across dozens of categories — from finance and health to engineering, construction, science, and everyday life.
      </p>

      <p>
        Our mission is simple: <strong class="text-text">provide the best free calculators on the internet</strong>. Every calculator is designed to deliver instant, accurate results with no sign-up, no ads wall, and no hidden fees.
      </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 my-10">
      {stats.map(stat => (
        <div class="bg-surface-alt rounded-xl p-5 text-center">
          <div class="text-2xl font-bold text-primary">{stat.value}</div>
          <div class="text-sm text-text-muted mt-1">{stat.label}</div>
        </div>
      ))}
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-xl font-semibold text-text mb-3">What Makes Us Different</h2>
        <ul class="space-y-3 text-text-secondary">
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold mt-0.5">1.</span>
            <span><strong class="text-text">Client-side calculations</strong> — all math happens in your browser. Your data never leaves your device. No server requests, no data collection.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold mt-0.5">2.</span>
            <span><strong class="text-text">Instant results</strong> — results update as you type. No "Calculate" button to click. Every page loads in under 1 second.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold mt-0.5">3.</span>
            <span><strong class="text-text">Privacy-first</strong> — no cookies, no tracking pixels, no personal data collection. We use Cloudflare Web Analytics which is fully GDPR-compliant and cookie-free.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold mt-0.5">4.</span>
            <span><strong class="text-text">Mobile-friendly</strong> — every calculator is fully responsive and works on any device, from phones to desktops.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary font-bold mt-0.5">5.</span>
            <span><strong class="text-text">No sign-up</strong> — completely free, forever. No email gates, no premium tiers, no registration.</span>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text mb-3">Our Categories</h2>
        <p class="text-text-secondary leading-relaxed mb-4">
          We cover a wide range of professional and everyday calculation needs:
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm text-text-secondary">
          {[
            'Finance & Banking', 'Health & Fitness', 'Mathematics', 'Construction & Home',
            'Engineering', 'Science & Physics', 'Cooking & Baking', 'Real Estate',
            'Education', 'Electronics', 'Environmental', 'Photography & Media',
            'Automotive', 'Astronomy', 'Agriculture', 'Woodworking',
            'Welding & Metalwork', 'Networking & IT', 'Legal & Compliance', 'Event Planning',
          ].map(cat => (
            <span class="px-3 py-2 bg-surface-alt rounded-lg">{cat}</span>
          ))}
          <span class="px-3 py-2 bg-primary/10 text-primary rounded-lg font-medium">And 30+ more...</span>
        </div>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text mb-3">Accuracy & Disclaimer</h2>
        <p class="text-text-secondary leading-relaxed">
          We strive to ensure all calculators produce accurate results based on established formulas and methodologies. However, our tools are intended for informational and educational purposes only. They should not replace professional advice from qualified financial advisors, healthcare providers, engineers, or other professionals. Please see our <a href="/terms" class="text-primary hover:underline">Terms of Use</a> for full details.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text mb-3">Contact Us</h2>
        <p class="text-text-secondary leading-relaxed">
          Have a suggestion for a new calculator? Found a bug? We'd love to hear from you.
        </p>
        <p class="text-text-secondary mt-2">
          Email: <strong>hello@hqcalculator.com</strong>
        </p>
      </section>
    </div>
  </div>
</CalculatorLayout>
