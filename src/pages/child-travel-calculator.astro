---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Child Travel Calculator - Travel with Kids Cost & Checklist";
const description = "Estimate travel costs when traveling with children. Get packing checklists, cost comparisons, and tips for stress-free family trips.";

const relatedCalcs = [
  { name: "Car Seat Calculator", url: "/car-seat-calculator", description: "Car seat guide." },
  { name: "Birthday Party Calculator", url: "/birthday-party-calculator", description: "Party budget." },
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper costs." },
  { name: "Gas Mileage Calculator", url: "/gas-mileage-calculator", description: "Fuel costs." },
  { name: "Budget Calculator", url: "/budget-calculator", description: "Trip budget." },
  { name: "Child Dosage Calculator", url: "/child-dosage-calculator", description: "Medication dosing." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Child Travel Calculator"
  keywords="travel with kids calculator, family travel cost, family vacation budget, traveling with children, family trip planner, kid travel checklist"
  breadcrumbs={[{ name: "Child Travel Calculator", url: "/child-travel-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Child Travel Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate additional costs of traveling with children and get age-specific packing reminders.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Children</label>
          <input type="number" id="ctr-kids" class="ctr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="1" max="6" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Youngest Child's Age</label>
          <select id="ctr-age" class="ctr-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="infant">Infant (under 2)</option>
            <option value="toddler" selected>Toddler (2-4)</option>
            <option value="child">Child (5-11)</option>
            <option value="teen">Teen (12+)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Trip Duration (nights)</label>
          <input type="number" id="ctr-nights" class="ctr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="30" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Travel Method</label>
          <select id="ctr-method" class="ctr-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="car" selected>Car / Road Trip</option>
            <option value="flight">Flying</option>
            <option value="train">Train</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Accommodation Type</label>
          <select id="ctr-hotel" class="ctr-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="budget">Budget Hotel ($80-120/night)</option>
            <option value="mid" selected>Mid-Range Hotel ($150-250/night)</option>
            <option value="resort">Family Resort ($250-400/night)</option>
            <option value="rental">Vacation Rental / Airbnb</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Activities Level</label>
          <select id="ctr-activities" class="ctr-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="low">Low (free/cheap activities)</option>
            <option value="medium" selected>Medium (some paid attractions)</option>
            <option value="high">High (theme parks, tours)</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Extra Kid Costs</div>
        <div class="text-5xl font-extrabold" id="ctr-total">--</div>
        <div class="text-sm text-blue-200 mt-1" id="ctr-desc">additional travel cost for children</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Per Child/Day</div>
          <div class="text-lg font-bold" id="ctr-perday">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Transport Extra</div>
          <div class="text-lg font-bold" id="ctr-transport">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Food Extra</div>
          <div class="text-lg font-bold" id="ctr-food">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Activities Extra</div>
          <div class="text-lg font-bold" id="ctr-actcost">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-4">
        <h3 class="font-semibold text-sm text-text mb-3">Cost Breakdown</h3>
        <div class="text-xs" id="ctr-breakdown"></div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Packing Checklist for Kids</h3>
        <div class="text-sm" id="ctr-checklist"></div>
      </div>

      <ShareButton calculatorId="child-travel" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Traveling with Children</h2>
      <p>Family travel requires extra planning and budget. Children add costs for food, activities, and sometimes transportation, plus you need to pack extra gear depending on their age.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Tips for Stress-Free Travel</h3>
      <ul>
        <li>Pack snacks and entertainment for transit time</li>
        <li>Build in rest days between activities</li>
        <li>Keep routines (naps, meals) as close to normal as possible</li>
        <li>Bring a first-aid kit with children's medications</li>
        <li>Book accommodations with kitchenettes to save on food</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Flying with Kids</h3>
      <ul>
        <li>Children under 2 can often fly free as a lap infant (domestic)</li>
        <li>Bring the car seat on board if you buy a seat (safest option)</li>
        <li>Pack extra changes of clothes in carry-on</li>
        <li>Have a bottle or pacifier for takeoff and landing</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCTR() {
      const kids = parseFloat((document.getElementById('ctr-kids') as HTMLInputElement).value) || 2;
      const ageGroup = (document.getElementById('ctr-age') as HTMLSelectElement).value;
      const nights = parseFloat((document.getElementById('ctr-nights') as HTMLInputElement).value) || 5;
      const method = (document.getElementById('ctr-method') as HTMLSelectElement).value;
      const hotel = (document.getElementById('ctr-hotel') as HTMLSelectElement).value;
      const activities = (document.getElementById('ctr-activities') as HTMLSelectElement).value;

      const days = nights + 1;

      // Transport cost per child (additional)
      const transportPerKid: Record<string, Record<string, number>> = {
        car: { infant: 0, toddler: 0, child: 0, teen: 0 },
        flight: { infant: 0, toddler: 250, child: 300, teen: 350 },
        train: { infant: 0, toddler: 0, child: 75, teen: 150 },
      };

      // Food per child per day
      const foodPerDay: Record<string, number> = {
        infant: 5, toddler: 15, child: 25, teen: 35
      };

      // Activity cost per child per day
      const actPerDay: Record<string, Record<string, number>> = {
        low: { infant: 0, toddler: 5, child: 10, teen: 10 },
        medium: { infant: 0, toddler: 10, child: 25, teen: 30 },
        high: { infant: 0, toddler: 15, child: 50, teen: 60 },
      };

      // Extra hotel cost per child per night (rollaway, suite upgrade)
      const hotelExtra: Record<string, number> = {
        budget: 10, mid: 15, resort: 20, rental: 25
      };

      // Gear rental/needs
      const gearCost: Record<string, number> = {
        infant: 50, toddler: 30, child: 10, teen: 0
      };

      const transport = transportPerKid[method][ageGroup] * kids;
      const food = foodPerDay[ageGroup] * days * kids;
      const act = actPerDay[activities][ageGroup] * days * kids;
      const hotelExtraCost = hotelExtra[hotel] * nights * Math.max(0, kids - 1);
      const gear = gearCost[ageGroup] * kids;

      interface CostItem { name: string; amount: number; }
      const items: CostItem[] = [
        { name: 'Transportation', amount: transport },
        { name: 'Food & Snacks', amount: food },
        { name: 'Activities & Attractions', amount: act },
        { name: 'Hotel Extras', amount: hotelExtraCost },
        { name: 'Gear & Supplies', amount: gear },
      ];

      const total = items.reduce((s, i) => s + i.amount, 0);
      const perDay = total / days / kids;

      document.getElementById('ctr-total')!.textContent = '$' + Math.round(total).toLocaleString();
      document.getElementById('ctr-desc')!.textContent = kids + ' kid' + (kids > 1 ? 's' : '') + ', ' + nights + ' nights';
      document.getElementById('ctr-perday')!.textContent = '$' + Math.round(perDay);
      document.getElementById('ctr-transport')!.textContent = '$' + Math.round(transport);
      document.getElementById('ctr-food')!.textContent = '$' + Math.round(food);
      document.getElementById('ctr-actcost')!.textContent = '$' + Math.round(act);

      document.getElementById('ctr-breakdown')!.innerHTML =
        '<div class="grid grid-cols-2 gap-2 font-semibold text-text-muted mb-1"><span>Category</span><span class="text-right">Cost</span></div>' +
        items.map(i => `<div class="grid grid-cols-2 gap-2 py-1"><span>${i.name}</span><span class="text-right font-semibold">$${Math.round(i.amount)}</span></div>`).join('') +
        `<div class="grid grid-cols-2 gap-2 py-1 mt-1 border-t border-border font-bold"><span>Total</span><span class="text-right">$${Math.round(total)}</span></div>`;

      // Checklist
      const generalItems = ['Changes of clothes (1 per day + extras)', 'Pajamas', 'Comfortable shoes', 'Sunscreen', 'Snacks for travel', 'Water bottles', 'Entertainment (books, tablets, games)', 'First aid kit with kid medications', 'Health insurance cards'];
      const infantItems = ['Diapers (10+ per day)', 'Wipes', 'Formula/bottles or nursing supplies', 'Baby carrier or stroller', 'Car seat', 'Pack-n-play or portable crib', 'Baby monitor', 'Burp cloths & bibs'];
      const toddlerItems = ['Diapers or pull-ups', 'Wipes', 'Sippy cups', 'Favorite stuffed animal/blanket', 'Stroller', 'Car seat', 'Portable potty seat'];
      const childItems = ['Backpack with activities', 'Favorite toys or comfort items', 'Booster seat if needed'];

      let checklistItems = [...generalItems];
      if (ageGroup === 'infant') checklistItems = [...infantItems, ...generalItems];
      else if (ageGroup === 'toddler') checklistItems = [...toddlerItems, ...generalItems];
      else if (ageGroup === 'child') checklistItems = [...childItems, ...generalItems];

      document.getElementById('ctr-checklist')!.innerHTML = checklistItems.map(item =>
        `<div class="flex items-start gap-2 py-0.5"><span class="text-text-muted">&#9744;</span><span>${item}</span></div>`
      ).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.ctr-in').forEach(el => {
        el.addEventListener('input', calcCTR);
        el.addEventListener('change', calcCTR);
      });
      calcCTR();
    }, 50);
  </script>
</CalculatorLayout>
