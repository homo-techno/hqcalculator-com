---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Baby Milestone Calculator - Developmental Milestones by Age";
const description = "Track your baby's expected developmental milestones by age in months. See motor, language, social, and cognitive milestones from birth to 36 months.";

const relatedCalcs = [
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Height prediction." },
  { name: "Child BMI Calculator", url: "/child-bmi-calculator", description: "BMI percentiles." },
  { name: "Baby Formula Calculator", url: "/baby-formula-calculator", description: "Formula needs." },
  { name: "Potty Training Calculator", url: "/potty-training-readiness-calculator", description: "Potty readiness." },
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper expenses." },
  { name: "Child Nutrition Calculator", url: "/child-nutrition-calculator", description: "Nutrition needs." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Baby Milestone Calculator"
  keywords="baby milestone calculator, developmental milestones, baby development by month, infant milestones, child development tracker, when does baby crawl walk talk"
  breadcrumbs={[{ name: "Baby Milestone Calculator", url: "/baby-milestone-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Baby Milestone Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">See what developmental milestones to expect at your baby's age and what is coming next.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Baby's Age (months)</label>
          <input type="number" id="bml-age" class="bml-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="0" max="36" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Or Enter Birth Date</label>
          <input type="date" id="bml-birth" class="bml-in w-full px-4 py-3 border border-border rounded-xl text-lg">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Development Stage</div>
        <div class="text-3xl font-extrabold" id="bml-stage">--</div>
        <div class="text-sm text-blue-200 mt-1" id="bml-agetext">age details</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Motor Skills</div>
          <div class="text-lg font-bold" id="bml-motor">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Language</div>
          <div class="text-lg font-bold" id="bml-language">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Social/Emotional</div>
          <div class="text-lg font-bold" id="bml-social">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Cognitive</div>
          <div class="text-lg font-bold" id="bml-cognitive">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-4">
        <h3 class="font-semibold text-sm text-text mb-3">Current Milestones</h3>
        <div class="text-sm" id="bml-current"></div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Coming Up Next</h3>
        <div class="text-sm" id="bml-upcoming"></div>
      </div>

      <ShareButton calculatorId="baby-milestone" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Developmental Milestones</h2>
      <p>Milestones are behaviors or physical skills seen in infants and children as they grow and develop. Every child develops at their own pace, and there is a wide range of normal. These milestones are general guidelines based on CDC data.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Key Milestone Categories</h3>
      <ul>
        <li><strong>Gross Motor:</strong> Large movements like rolling, sitting, crawling, walking</li>
        <li><strong>Fine Motor:</strong> Small movements like grasping, pinching, drawing</li>
        <li><strong>Language:</strong> Babbling, first words, sentences, understanding</li>
        <li><strong>Social/Emotional:</strong> Smiling, attachment, play, empathy</li>
        <li><strong>Cognitive:</strong> Problem-solving, memory, curiosity, imagination</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">When to Talk to Your Doctor</h3>
      <p>Talk to your pediatrician if your child is not meeting milestones within the expected timeframe, loses skills they previously had, or if you have any concerns about their development. Early intervention can make a significant difference.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcBML() {
      let age = parseFloat((document.getElementById('bml-age') as HTMLInputElement).value) || 0;
      const birthInput = (document.getElementById('bml-birth') as HTMLInputElement).value;

      if (birthInput) {
        const birth = new Date(birthInput);
        const now = new Date();
        const diffMs = now.getTime() - birth.getTime();
        const calcAge = diffMs / (1000 * 60 * 60 * 24 * 30.44);
        if (calcAge >= 0 && calcAge <= 36) {
          age = Math.floor(calcAge);
          (document.getElementById('bml-age') as HTMLInputElement).value = String(age);
        }
      }

      interface MilestoneSet {
        stage: string;
        motor: string;
        language: string;
        social: string;
        cognitive: string;
        details: string[];
        upcoming: string[];
      }

      const milestones: Record<number, MilestoneSet> = {
        0: {
          stage: 'Newborn',
          motor: 'Reflexes only', language: 'Crying', social: 'Prefers faces', cognitive: 'Startles to sounds',
          details: ['Lifts head briefly when on tummy', 'Grasps finger reflexively', 'Tracks objects briefly', 'Responds to loud sounds'],
          upcoming: ['Social smile (around 2 months)', 'Better head control', 'Cooing sounds', 'Tracking objects smoothly']
        },
        2: {
          stage: 'Early Infant',
          motor: 'Lifts head', language: 'Cooing', social: 'Social smile', cognitive: 'Follows objects',
          details: ['Holds head up during tummy time', 'Makes cooing and gurgling sounds', 'Smiles at people', 'Begins to follow things with eyes'],
          upcoming: ['Rolling over (4-6 months)', 'Laughing', 'Reaching for toys', 'Recognizing familiar people']
        },
        4: {
          stage: 'Active Infant',
          motor: 'Rolls over', language: 'Babbling begins', social: 'Laughs', cognitive: 'Reaches for toys',
          details: ['Rolls from tummy to back', 'Brings hands to mouth', 'Babbles with expression', 'Enjoys playing with people', 'Reaches for toy with one hand'],
          upcoming: ['Sitting without support', 'Stranger anxiety', 'Responds to own name', 'Transferring objects hand to hand']
        },
        6: {
          stage: 'Sitting Stage',
          motor: 'Sits with support', language: 'Responds to name', social: 'Stranger awareness', cognitive: 'Explores with mouth',
          details: ['Sits with support, may sit alone briefly', 'Responds to own name', 'Strings vowels together (ah, eh, oh)', 'Likes looking at self in mirror', 'Brings things to mouth to explore'],
          upcoming: ['Crawling (7-10 months)', 'First words', 'Pulling to stand', 'Pincer grasp', 'Clapping hands']
        },
        9: {
          stage: 'Mobile Stage',
          motor: 'Crawling', language: 'Mama/Dada sounds', social: 'Separation anxiety', cognitive: 'Object permanence',
          details: ['Crawls or scoots', 'Pulls to stand', 'Uses pincer grasp', 'May say mama/dada (non-specific)', 'Understands "no"', 'Points at objects'],
          upcoming: ['Walking (10-15 months)', 'First real words', 'Waving bye-bye', 'Stacking blocks']
        },
        12: {
          stage: 'Toddler Begins',
          motor: 'Cruising/First steps', language: '1-3 words', social: 'Waves bye', cognitive: 'Uses objects correctly',
          details: ['Takes first steps or walks holding furniture', 'Says 1-3 words', 'Waves bye-bye', 'Follows simple directions', 'Uses cup', 'Explores objects in different ways'],
          upcoming: ['Walking well (15 months)', 'Vocabulary explosion', 'Running', 'Stacking more blocks', 'Feeding self']
        },
        18: {
          stage: 'Active Toddler',
          motor: 'Walks well', language: '10-20 words', social: 'Parallel play', cognitive: 'Points to body parts',
          details: ['Walks independently', 'Says 10-20 words', 'Points to show things', 'Plays pretend simply', 'Scribbles', 'Can follow simple instructions'],
          upcoming: ['Running (20-24 months)', '2-word phrases', 'Climbing', 'Sorting shapes', 'Potty interest']
        },
        24: {
          stage: 'Talking Toddler',
          motor: 'Runs and climbs', language: '50+ words, 2-word phrases', social: 'Plays alongside others', cognitive: 'Sorts shapes and colors',
          details: ['Runs and kicks a ball', 'Speaks 50+ words', 'Uses 2-word sentences', 'Follows 2-step instructions', 'Begins make-believe play', 'Sorts shapes and colors'],
          upcoming: ['Riding tricycle', 'Full sentences', 'Counting', 'Playing WITH others', 'Dressing self']
        },
        30: {
          stage: 'Preschool Ready',
          motor: 'Jumps, throws', language: 'Short sentences', social: 'Takes turns', cognitive: 'Counts to 3',
          details: ['Jumps with both feet', 'Speaks in sentences of 3-4 words', 'Follows 2-3 step instructions', 'Begins to play with other children', 'Names some colors', 'Counts to 3'],
          upcoming: ['Riding tricycle well', 'Telling stories', 'Drawing shapes', 'Cooperative play', 'Writing name']
        },
        36: {
          stage: 'Preschooler',
          motor: 'Rides tricycle', language: 'Full sentences', social: 'Cooperative play', cognitive: 'Understands stories',
          details: ['Rides tricycle', 'Speaks clearly in sentences', 'Draws circles', 'Plays cooperatively', 'Understands "mine" and "yours"', 'Counts to 10'],
          upcoming: ['Writing letters', 'Complex pretend play', 'Telling detailed stories', 'Understanding time concepts']
        }
      };

      // Find closest milestone set
      const ages = Object.keys(milestones).map(Number).sort((a, b) => a - b);
      let matchAge = 0;
      for (const a of ages) {
        if (age >= a) matchAge = a;
      }

      const m = milestones[matchAge];
      const nextAge = ages.find(a => a > matchAge);
      const nextM = nextAge !== undefined ? milestones[nextAge] : null;

      document.getElementById('bml-stage')!.textContent = m.stage;
      document.getElementById('bml-agetext')!.textContent = age + ' months old';
      document.getElementById('bml-motor')!.textContent = m.motor;
      document.getElementById('bml-language')!.textContent = m.language;
      document.getElementById('bml-social')!.textContent = m.social;
      document.getElementById('bml-cognitive')!.textContent = m.cognitive;

      document.getElementById('bml-current')!.innerHTML = m.details.map(d =>
        `<div class="flex items-start gap-2 py-1"><span class="text-primary font-bold mt-0.5">&#10003;</span><span>${d}</span></div>`
      ).join('');

      const upcomingItems = nextM ? nextM.details.slice(0, 4) : m.upcoming;
      document.getElementById('bml-upcoming')!.innerHTML = upcomingItems.map(d =>
        `<div class="flex items-start gap-2 py-1"><span class="text-text-muted font-bold mt-0.5">&#9675;</span><span>${d}</span></div>`
      ).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.bml-in').forEach(el => {
        el.addEventListener('input', calcBML);
        el.addEventListener('change', calcBML);
      });
      calcBML();
    }, 50);
  </script>
</CalculatorLayout>
