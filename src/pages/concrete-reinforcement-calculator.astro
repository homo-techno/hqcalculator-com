---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Reinforcement Calculator - Rebar Spacing, Size & Quantity";
const description = "Calculate rebar spacing, bar size, and quantity for concrete slabs and walls. Get total linear feet, weight, and reinforcement ratio.";

const relatedCalcs = [
  { name: "Rebar Calculator", url: "/rebar-calculator", description: "Rebar weight and length." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume estimator." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Retaining Wall Calculator", url: "/retaining-wall-calculator", description: "Retaining wall design." },
  { name: "Concrete Form Calculator", url: "/concrete-form-calculator", description: "Formwork estimator." },
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Mix design ratios." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Reinforcement Calculator"
  keywords="rebar spacing calculator, rebar size, reinforcement ratio, concrete slab rebar, wall rebar, rebar quantity"
  breadcrumbs={[{ name: "Concrete Reinforcement Calculator", url: "/concrete-reinforcement-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Reinforcement Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate rebar spacing, size, and quantity for concrete slabs and walls.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Application</label>
          <select id="crf-app" class="crf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="slab" selected>Concrete Slab</option>
            <option value="wall">Concrete Wall</option>
            <option value="footing">Strip Footing</option>
          </select>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Length (ft)</label>
            <input type="number" id="crf-length" class="crf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Width (ft)</label>
            <input type="number" id="crf-width" class="crf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Thickness (in)</label>
            <input type="number" id="crf-thick" class="crf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="4" step="1">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Rebar Size</label>
            <select id="crf-bar" class="crf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="3">#3 (3/8 in, 0.376 lb/ft)</option>
              <option value="4" selected>#4 (1/2 in, 0.668 lb/ft)</option>
              <option value="5">#5 (5/8 in, 1.043 lb/ft)</option>
              <option value="6">#6 (3/4 in, 1.502 lb/ft)</option>
              <option value="7">#7 (7/8 in, 2.044 lb/ft)</option>
              <option value="8">#8 (1 in, 2.670 lb/ft)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Spacing (inches O.C.)</label>
            <select id="crf-spacing" class="crf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="6">6 inches</option>
              <option value="8">8 inches</option>
              <option value="10">10 inches</option>
              <option value="12" selected>12 inches</option>
              <option value="16">16 inches</option>
              <option value="18">18 inches</option>
              <option value="24">24 inches</option>
            </select>
          </div>
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="crf-both" class="crf-in rounded" checked>
            <span class="text-sm font-medium text-text">Both directions (grid pattern)</span>
          </label>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Rebar Needed</div>
          <div class="text-4xl font-extrabold" id="crf-total">0 pieces</div>
          <div class="text-sm text-blue-200 mt-1"><span id="crf-linft">0</span> linear feet</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Weight</div>
            <div class="text-xl font-bold" id="crf-weight">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">20 ft Bars Needed</div>
            <div class="text-xl font-bold" id="crf-bars20">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Reinforcement Ratio</div>
            <div class="text-xl font-bold" id="crf-ratio">0%</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Steel Area (per ft)</div>
            <div class="text-xl font-bold" id="crf-area">0 in2/ft</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-reinforcement" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Rebar Sizing Guide</h2>
      <ul>
        <li><strong>4" slab:</strong> #3 bars at 18" O.C. or welded wire mesh 6x6-W1.4xW1.4</li>
        <li><strong>6" slab:</strong> #4 bars at 12" O.C. both ways</li>
        <li><strong>8" wall:</strong> #4 bars at 12" O.C. vertical, #4 at 16" O.C. horizontal</li>
        <li><strong>Min cover:</strong> 3" for earth contact, 1.5" for exposed, 0.75" for interior</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    const crfBarData: Record<string, { diam: number; weight: number; area: number }> = {
      '3': { diam: 0.375, weight: 0.376, area: 0.11 },
      '4': { diam: 0.500, weight: 0.668, area: 0.20 },
      '5': { diam: 0.625, weight: 1.043, area: 0.31 },
      '6': { diam: 0.750, weight: 1.502, area: 0.44 },
      '7': { diam: 0.875, weight: 2.044, area: 0.60 },
      '8': { diam: 1.000, weight: 2.670, area: 0.79 },
    };

    function calcCRF() {
      const length = parseFloat((document.getElementById('crf-length') as HTMLInputElement).value) || 0;
      const width = parseFloat((document.getElementById('crf-width') as HTMLInputElement).value) || 0;
      const thick = parseFloat((document.getElementById('crf-thick') as HTMLInputElement).value) || 6;
      const barSize = (document.getElementById('crf-bar') as HTMLSelectElement).value;
      const spacing = parseFloat((document.getElementById('crf-spacing') as HTMLSelectElement).value) || 12;
      const bothDirs = (document.getElementById('crf-both') as HTMLInputElement).checked;

      const bar = crfBarData[barSize] || crfBarData['4'];
      const spacingFt = spacing / 12;

      // Bars in length direction (spanning width)
      const barsLength = Math.ceil(width / spacingFt) + 1;
      const lengthPerBarL = length;

      // Bars in width direction (spanning length)
      const barsWidth = Math.ceil(length / spacingFt) + 1;
      const lengthPerBarW = width;

      let totalPieces = barsLength;
      let totalLinFt = barsLength * lengthPerBarL;

      if (bothDirs) {
        totalPieces += barsWidth;
        totalLinFt += barsWidth * lengthPerBarW;
      }

      const totalWeight = totalLinFt * bar.weight;
      const bars20 = Math.ceil(totalLinFt / 20);

      // Reinforcement ratio: As / (b * d) where b=12in, d=thick-1.5" cover
      const effectiveD = thick - 1.5;
      const asPerFt = bar.area * (12 / spacing);
      const reinfRatio = (asPerFt / (12 * effectiveD)) * 100;

      document.getElementById('crf-total')!.textContent = totalPieces + ' pieces';
      document.getElementById('crf-linft')!.textContent = Math.round(totalLinFt).toLocaleString();
      document.getElementById('crf-weight')!.textContent = Math.round(totalWeight).toLocaleString() + ' lbs';
      document.getElementById('crf-bars20')!.textContent = String(bars20);
      document.getElementById('crf-ratio')!.textContent = reinfRatio.toFixed(3) + '%';
      document.getElementById('crf-area')!.textContent = asPerFt.toFixed(2) + ' in\u00B2/ft';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.crf-in').forEach(el => {
        el.addEventListener('input', calcCRF);
        el.addEventListener('change', calcCRF);
      });
      calcCRF();
    }, 50);
  </script>
</CalculatorLayout>
