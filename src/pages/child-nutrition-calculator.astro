---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Child Nutrition Calculator - Daily Nutritional Needs by Age";
const description = "Calculate your child's daily nutritional requirements including calories, protein, fiber, calcium, iron, and key vitamins based on age and activity level.";

const relatedCalcs = [
  { name: "Child BMI Calculator", url: "/child-bmi-calculator", description: "BMI percentile by age." },
  { name: "Baby Formula Calculator", url: "/baby-formula-calculator", description: "Formula feeding amounts." },
  { name: "Child Dosage Calculator", url: "/child-dosage-calculator", description: "Pediatric medication doses." },
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Predicted adult height." },
  { name: "Calorie Calculator", url: "/calorie-calculator", description: "General calorie needs." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Developmental milestones." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Child Nutrition Calculator"
  keywords="child nutrition calculator, kids daily calories, child protein needs, pediatric nutrition, children vitamin requirements, toddler nutrition guide"
  breadcrumbs={[{ name: "Child Nutrition Calculator", url: "/child-nutrition-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Child Nutrition Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate your child's daily nutritional needs -- calories, protein, fiber, calcium, iron, and key vitamins -- based on age, gender, and activity level.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age (years)</label>
          <input type="number" id="cnu-age" class="cnu-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="17" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Gender</label>
          <select id="cnu-gender" class="cnu-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="male">Male</option>
            <option value="female">Female</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Weight (lbs)</label>
          <input type="number" id="cnu-weight" class="cnu-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="15" max="250" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Activity Level</label>
          <select id="cnu-activity" class="cnu-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="sedentary">Sedentary (little or no exercise)</option>
            <option value="moderate" selected>Moderately Active (some play/sports)</option>
            <option value="active">Active (daily sports/vigorous play)</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Daily Calories</div>
        <div class="text-5xl font-extrabold" id="cnu-calories">--</div>
        <div class="text-sm text-blue-200 mt-1" id="cnu-desc">kcal per day</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Protein</div>
          <div class="text-lg font-bold" id="cnu-protein">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Fiber</div>
          <div class="text-lg font-bold" id="cnu-fiber">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Calcium</div>
          <div class="text-lg font-bold" id="cnu-calcium">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Iron</div>
          <div class="text-lg font-bold" id="cnu-iron">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Full Nutrient Breakdown</h3>
        <div class="text-xs space-y-1" id="cnu-breakdown"></div>
      </div>

      <ShareButton calculatorId="child-nutrition" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Children's Nutritional Needs</h2>
      <p>A child's nutritional requirements change significantly as they grow. This calculator uses USDA Dietary Reference Intakes (DRIs) and Estimated Energy Requirements (EERs) to provide age- and gender-specific recommendations.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Key Nutrients for Growing Children</h3>
      <ul>
        <li><strong>Calories:</strong> Fuel for growth, brain development, and daily activity. Requirements increase with age and activity level.</li>
        <li><strong>Protein:</strong> Essential for muscle growth, immune function, and tissue repair. Children need 0.43-0.52 g per pound of body weight.</li>
        <li><strong>Calcium:</strong> Critical for bone development. Children ages 9-18 need 1,300 mg daily -- more than adults.</li>
        <li><strong>Iron:</strong> Supports oxygen transport and brain development. Teen girls need more due to menstruation.</li>
        <li><strong>Vitamin D:</strong> Works with calcium for bone health. 600 IU daily is recommended for all children over age 1.</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Daily Calorie Ranges by Age</h3>
      <ul>
        <li><strong>1-3 years:</strong> 1,000-1,400 calories</li>
        <li><strong>4-8 years:</strong> 1,200-1,800 calories</li>
        <li><strong>9-13 years:</strong> 1,400-2,600 calories</li>
        <li><strong>14-17 years:</strong> 1,800-3,200 calories</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Tips for Balanced Child Nutrition</h3>
      <ul>
        <li>Offer a variety of fruits and vegetables at every meal</li>
        <li>Choose whole grains over refined grains</li>
        <li>Include lean protein sources like chicken, fish, beans, and eggs</li>
        <li>Limit added sugars to less than 10% of daily calories</li>
        <li>Ensure adequate dairy or calcium-fortified alternatives</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCNU() {
      const age = parseFloat((document.getElementById('cnu-age') as HTMLInputElement).value) || 5;
      const gender = (document.getElementById('cnu-gender') as HTMLSelectElement).value;
      const weightLbs = parseFloat((document.getElementById('cnu-weight') as HTMLInputElement).value) || 40;
      const activity = (document.getElementById('cnu-activity') as HTMLSelectElement).value;

      const weightKg = weightLbs * 0.4536;

      // Estimated Energy Requirements (EER) based on USDA DRI
      // Simplified EER formulas by age group and gender
      let baseCalories: number;
      if (age <= 3) {
        baseCalories = gender === 'male' ? 1000 + (age - 1) * 100 : 1000 + (age - 1) * 80;
      } else if (age <= 8) {
        baseCalories = gender === 'male' ? 1200 + (age - 4) * 100 : 1200 + (age - 4) * 70;
      } else if (age <= 13) {
        baseCalories = gender === 'male' ? 1600 + (age - 9) * 120 : 1400 + (age - 9) * 80;
      } else {
        baseCalories = gender === 'male' ? 2000 + (age - 14) * 100 : 1800 + (age - 14) * 50;
      }

      const activityMult: Record<string, number> = { sedentary: 0.9, moderate: 1.0, active: 1.15 };
      const calories = Math.round(baseCalories * activityMult[activity]);

      // Protein: DRI is 0.95 g/kg for 1-3, 0.95 for 4-8, 0.95 for 9-13, 0.85 for 14-18
      let proteinPerKg: number;
      if (age <= 3) proteinPerKg = 1.05;
      else if (age <= 8) proteinPerKg = 0.95;
      else if (age <= 13) proteinPerKg = 0.95;
      else proteinPerKg = 0.85;
      const proteinG = Math.round(weightKg * proteinPerKg);

      // Fiber: age + 5 rule (common pediatric guideline), capped by DRI
      let fiberG: number;
      if (age <= 3) fiberG = 19;
      else if (age <= 8) fiberG = 25;
      else if (age <= 13) fiberG = gender === 'male' ? 31 : 26;
      else fiberG = gender === 'male' ? 38 : 26;

      // Calcium (mg) - DRI
      let calciumMg: number;
      if (age <= 3) calciumMg = 700;
      else if (age <= 8) calciumMg = 1000;
      else calciumMg = 1300;

      // Iron (mg) - DRI
      let ironMg: number;
      if (age <= 3) ironMg = 7;
      else if (age <= 8) ironMg = 10;
      else if (age <= 13) ironMg = 8;
      else ironMg = gender === 'male' ? 11 : 15;

      // Vitamin D (IU) - 600 for all children 1-17
      const vitDIU = 600;

      // Vitamin C (mg) - DRI
      let vitCMg: number;
      if (age <= 3) vitCMg = 15;
      else if (age <= 8) vitCMg = 25;
      else if (age <= 13) vitCMg = 45;
      else vitCMg = gender === 'male' ? 75 : 65;

      // Vitamin A (mcg RAE) - DRI
      let vitAMcg: number;
      if (age <= 3) vitAMcg = 300;
      else if (age <= 8) vitAMcg = 400;
      else if (age <= 13) vitAMcg = 600;
      else vitAMcg = gender === 'male' ? 900 : 700;

      // Zinc (mg) - DRI
      let zincMg: number;
      if (age <= 3) zincMg = 3;
      else if (age <= 8) zincMg = 5;
      else if (age <= 13) zincMg = 8;
      else zincMg = gender === 'male' ? 11 : 9;

      // Water (cups) - adequate intake
      let waterCups: number;
      if (age <= 3) waterCups = 4;
      else if (age <= 8) waterCups = 5;
      else if (age <= 13) waterCups = gender === 'male' ? 8 : 7;
      else waterCups = gender === 'male' ? 11 : 8;

      // Fat: 30-40% of calories for ages 1-3, 25-35% for 4-18
      let fatG: number;
      if (age <= 3) fatG = Math.round((calories * 0.35) / 9);
      else fatG = Math.round((calories * 0.30) / 9);

      // Carbs: remaining calories after protein and fat
      const carbG = Math.round((calories - proteinG * 4 - fatG * 9) / 4);

      // Display results
      document.getElementById('cnu-calories')!.textContent = calories.toLocaleString() + ' kcal';
      document.getElementById('cnu-desc')!.textContent = gender === 'male' ? 'for a ' + age + '-year-old boy' : 'for a ' + age + '-year-old girl';
      document.getElementById('cnu-protein')!.textContent = proteinG + ' g/day';
      document.getElementById('cnu-fiber')!.textContent = fiberG + ' g/day';
      document.getElementById('cnu-calcium')!.textContent = calciumMg + ' mg/day';
      document.getElementById('cnu-iron')!.textContent = ironMg + ' mg/day';

      const rows = [
        ['Calories', calories + ' kcal', 'Total daily energy needs'],
        ['Protein', proteinG + ' g', Math.round(proteinG * 4 / calories * 100) + '% of calories'],
        ['Carbohydrates', carbG + ' g', Math.round(carbG * 4 / calories * 100) + '% of calories'],
        ['Fat', fatG + ' g', Math.round(fatG * 9 / calories * 100) + '% of calories'],
        ['Fiber', fiberG + ' g', 'Adequate intake'],
        ['Calcium', calciumMg + ' mg', 'Bone development'],
        ['Iron', ironMg + ' mg', 'Blood and brain health'],
        ['Vitamin D', vitDIU + ' IU', 'Bone and immune health'],
        ['Vitamin C', vitCMg + ' mg', 'Immune and skin health'],
        ['Vitamin A', vitAMcg + ' mcg RAE', 'Vision and growth'],
        ['Zinc', zincMg + ' mg', 'Immune function'],
        ['Water', waterCups + ' cups', 'Adequate daily intake'],
      ];

      document.getElementById('cnu-breakdown')!.innerHTML =
        '<div class="grid grid-cols-3 gap-2 font-semibold text-text-muted mb-2 pb-1 border-b border-border"><span>Nutrient</span><span>Amount</span><span>Notes</span></div>' +
        rows.map(r => '<div class="grid grid-cols-3 gap-2 py-1"><span class="font-medium">' + r[0] + '</span><span>' + r[1] + '</span><span class="text-text-muted">' + r[2] + '</span></div>').join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.cnu-in').forEach(el => {
        el.addEventListener('input', calcCNU);
        el.addEventListener('change', calcCNU);
      });
      calcCNU();
    }, 50);
  </script>
</CalculatorLayout>
