---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Solar Water Heater Calculator - System Sizing & Savings";
const description = "Calculate solar water heating system size, annual energy savings, and payback period based on household hot water demand and local climate.";
const relatedCalcs = [
  { name: "Solar Panel", url: "/solar-panel-calculator", description: "Solar panel sizing." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Water Conservation", url: "/water-conservation-calculator", description: "Water savings." },
  { name: "Heat Pump", url: "/heat-pump-efficiency-calculator", description: "Heat pump COP." },
  { name: "Energy Audit", url: "/energy-audit-calculator", description: "Home audit." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Solar Water Heater Calculator" keywords="solar water heater calculator, solar hot water sizing, solar thermal collector, solar water heating savings, solar thermal payback" breadcrumbs={[{ name: "Solar Water Heater", url: "/solar-water-heater-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Solar Water Heater Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Size a solar water heating system and estimate annual savings and payback.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Hot Water Demand</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">People in Household</label><input type="number" id="swh-people" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" max="10" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Gallons/Person/Day</label><input type="number" id="swh-gpd" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="10" max="40" step="5"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Inlet Water Temp (F)</label><input type="number" id="swh-inlet" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="55" min="35" max="75" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Desired Temp (F)</label><input type="number" id="swh-desired" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="120" min="100" max="140" step="5"></div>
        </div>
        <h3 class="font-semibold text-text">Solar & Climate</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Sun Hours/Day</label><input type="number" id="swh-sun" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="2" max="8" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Solar Fraction (%)</label><input type="number" id="swh-fraction" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="70" min="30" max="90" step="5"></div>
        </div>
        <h3 class="font-semibold text-text">Economics</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">System Cost ($)</label><input type="number" id="swh-cost" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6000" min="2000" max="15000" step="500"></div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Current Fuel Type</label>
            <select id="swh-fuel" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="electric" selected>Electric ($0.14/kWh)</option>
              <option value="gas">Natural Gas ($1.20/therm)</option>
              <option value="propane">Propane ($2.50/gal)</option>
            </select>
          </div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Federal Tax Credit (%)</label><input type="number" id="swh-itc" class="swh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="0" max="50" step="1"></div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Annual Energy Savings</div>
          <div class="text-4xl font-extrabold" id="swh-savings">$0</div>
          <div class="text-sm text-blue-200 mt-1">per year</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Collector Area</div><div class="text-xl font-bold" id="swh-area">0 sq ft</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Storage Tank</div><div class="text-xl font-bold" id="swh-tank">0 gal</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Net System Cost</div><div class="text-xl font-bold" id="swh-net">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Payback Period</div><div class="text-xl font-bold" id="swh-payback">0 yrs</div></div>
        </div>
      </div>
      <ShareButton calculatorId="solar-water-heater" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Solar Water Heating Systems</h2>
      <p>Solar water heaters use thermal collectors to heat water directly, achieving 50-80% solar fractions depending on climate. A typical family of 4 needs 60-80 gallons per day of hot water, requiring 40-64 sq ft of collector area. The energy to heat water is calculated as: BTU = gallons x 8.33 x temperature rise. Solar thermal systems qualify for the 30% federal tax credit and typically pay back in 4-8 years.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    const swhFuelCosts: Record<string, [number, number]> = {
      electric: [0.14, 3412],
      gas: [1.20, 100000],
      propane: [2.50, 91500]
    };
    function calcSWH() {
      const people = parseFloat((document.getElementById('swh-people') as HTMLInputElement).value) || 4;
      const gpd = parseFloat((document.getElementById('swh-gpd') as HTMLInputElement).value) || 20;
      const inlet = parseFloat((document.getElementById('swh-inlet') as HTMLInputElement).value) || 55;
      const desired = parseFloat((document.getElementById('swh-desired') as HTMLInputElement).value) || 120;
      const sun = parseFloat((document.getElementById('swh-sun') as HTMLInputElement).value) || 5;
      const fraction = parseFloat((document.getElementById('swh-fraction') as HTMLInputElement).value) || 70;
      const cost = parseFloat((document.getElementById('swh-cost') as HTMLInputElement).value) || 6000;
      const fuel = (document.getElementById('swh-fuel') as HTMLSelectElement).value;
      const itc = parseFloat((document.getElementById('swh-itc') as HTMLInputElement).value) || 30;
      const dailyGal = people * gpd;
      const tempRise = desired - inlet;
      const dailyBTU = dailyGal * 8.33 * tempRise;
      const annualBTU = dailyBTU * 365;
      const solarBTU = annualBTU * (fraction / 100);
      const [fuelPrice, btuPerUnit] = swhFuelCosts[fuel] || [0.14, 3412];
      const efficiency = fuel === 'electric' ? 0.95 : 0.80;
      const unitsNeeded = solarBTU / (btuPerUnit * efficiency);
      const annualSavings = unitsNeeded * fuelPrice;
      const collectorArea = Math.ceil(dailyGal * 1.0);
      const tankSize = Math.ceil(dailyGal * 1.5 / 10) * 10;
      const netCost = cost * (1 - itc / 100);
      const payback = annualSavings > 0 ? netCost / annualSavings : 99;
      document.getElementById('swh-savings')!.textContent = '$' + Math.round(annualSavings).toLocaleString();
      document.getElementById('swh-area')!.textContent = collectorArea + ' sq ft';
      document.getElementById('swh-tank')!.textContent = tankSize + ' gal';
      document.getElementById('swh-net')!.textContent = '$' + Math.round(netCost).toLocaleString();
      document.getElementById('swh-payback')!.textContent = payback.toFixed(1) + ' yrs';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.swh-in').forEach(el => { el.addEventListener('input', calcSWH); el.addEventListener('change', calcSWH); }); calcSWH(); }, 50);
  </script>
</CalculatorLayout>
