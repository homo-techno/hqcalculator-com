---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Curing Calculator - Strength Gain by Temperature & Time";
const description = "Calculate concrete curing time and compressive strength gain based on temperature, mix design, and curing method. Estimate when to strip forms and load.";

const relatedCalcs = [
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Volume estimator." },
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Mix design ratios." },
  { name: "Concrete Strength Calculator", url: "/concrete-strength-calculator", description: "Cylinder test analysis." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume calculator." },
  { name: "Rebar Calculator", url: "/rebar-calculator", description: "Rebar requirements." },
  { name: "Concrete Sealer Calculator", url: "/concrete-sealer-calculator", description: "Sealer coverage." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Curing Calculator"
  keywords="concrete curing time, strength gain, maturity method, curing temperature, form stripping time, 28 day strength"
  breadcrumbs={[{ name: "Concrete Curing Calculator", url: "/concrete-curing-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Curing Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate concrete strength gain over time based on ambient temperature and curing conditions.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Design Strength at 28 Days (PSI)</label>
          <input type="number" id="ccg-strength" class="ccg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4000" min="1000" step="500">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Average Curing Temperature</label>
          <div class="grid grid-cols-2 gap-3">
            <input type="number" id="ccg-temp" class="ccg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="70" min="20" max="120" step="1">
            <select id="ccg-unit" class="ccg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="F" selected>Fahrenheit</option>
              <option value="C">Celsius</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Cement Type</label>
          <select id="ccg-type" class="ccg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="I" selected>Type I - Normal</option>
            <option value="III">Type III - High Early Strength</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Curing Method</label>
          <select id="ccg-method" class="ccg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="moist" selected>Moist Curing (Water/Wet Burlap)</option>
            <option value="membrane">Curing Compound / Membrane</option>
            <option value="air">Air Curing (No Treatment)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Days Since Pour</label>
          <input type="number" id="ccg-days" class="ccg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="7" min="1" max="365" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Strength at Day <span id="ccg-day-label">7</span></div>
          <div class="text-4xl font-extrabold" id="ccg-current">0 PSI</div>
          <div class="text-sm text-blue-200 mt-1"><span id="ccg-pct">0</span>% of 28-day design strength</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">1-Day Strength</div>
            <div class="text-xl font-bold" id="ccg-day1">0 PSI</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">3-Day Strength</div>
            <div class="text-xl font-bold" id="ccg-day3">0 PSI</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">7-Day Strength</div>
            <div class="text-xl font-bold" id="ccg-day7">0 PSI</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">28-Day Strength</div>
            <div class="text-xl font-bold" id="ccg-day28">0 PSI</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Maturity Index</div>
            <div class="text-xl font-bold" id="ccg-maturity">0</div>
            <div class="text-xs text-text-muted">degree-hours</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Form Stripping</div>
            <div class="text-xl font-bold" id="ccg-strip">- days</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-curing" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Concrete Strength Gain Over Time</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Maturity Index:</strong> Sum of (Temperature - Datum) x Time intervals</p>
        <p><strong>Strength at day t:</strong> f28 x t / (a + b x t) (ACI hyperbolic model)</p>
      </div>

      <h3 class="text-xl font-semibold text-text mt-8">Typical Strength Gain Schedule</h3>
      <ul>
        <li><strong>Day 1:</strong> 15-20% of 28-day strength</li>
        <li><strong>Day 3:</strong> 40-50% of 28-day strength</li>
        <li><strong>Day 7:</strong> 65-75% of 28-day strength</li>
        <li><strong>Day 14:</strong> 85-90% of 28-day strength</li>
        <li><strong>Day 28:</strong> 100% of design strength</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCCG() {
      const f28 = parseFloat((document.getElementById('ccg-strength') as HTMLInputElement).value) || 4000;
      let temp = parseFloat((document.getElementById('ccg-temp') as HTMLInputElement).value) || 70;
      const unit = (document.getElementById('ccg-unit') as HTMLSelectElement).value;
      const cementType = (document.getElementById('ccg-type') as HTMLSelectElement).value;
      const method = (document.getElementById('ccg-method') as HTMLSelectElement).value;
      const days = parseFloat((document.getElementById('ccg-days') as HTMLInputElement).value) || 7;

      let tempC = unit === 'C' ? temp : (temp - 32) * 5 / 9;
      const datum = -10; // datum temperature in C

      // ACI 209 hyperbolic model: f(t) = f28 * t / (a + b*t)
      // Type I: a=4.0, b=0.85; Type III: a=2.3, b=0.92
      let a = cementType === 'III' ? 2.3 : 4.0;
      let b = cementType === 'III' ? 0.92 : 0.85;

      // Temperature adjustment factor (Nurse-Saul maturity)
      const tempFactor = Math.max(0.3, (tempC - datum) / (20 - datum));

      // Curing method efficiency
      const methodFactor = method === 'moist' ? 1.0 : method === 'membrane' ? 0.92 : 0.80;

      function strengthAtDay(t: number): number {
        const effectiveAge = t * tempFactor;
        const ratio = effectiveAge / (a + b * effectiveAge);
        return f28 * ratio * methodFactor;
      }

      const currentStrength = strengthAtDay(days);
      const pct = (currentStrength / f28) * 100;

      // Maturity index (degree-hours, Nurse-Saul)
      const maturity = (tempC - datum) * days * 24;

      // Form stripping: when strength reaches 50% of f28
      let stripDays = 1;
      while (stripDays < 365 && strengthAtDay(stripDays) < f28 * 0.5) {
        stripDays++;
      }

      document.getElementById('ccg-day-label')!.textContent = String(Math.round(days));
      document.getElementById('ccg-current')!.textContent = Math.round(currentStrength).toLocaleString() + ' PSI';
      document.getElementById('ccg-pct')!.textContent = Math.min(pct, 130).toFixed(1);
      document.getElementById('ccg-day1')!.textContent = Math.round(strengthAtDay(1)).toLocaleString() + ' PSI';
      document.getElementById('ccg-day3')!.textContent = Math.round(strengthAtDay(3)).toLocaleString() + ' PSI';
      document.getElementById('ccg-day7')!.textContent = Math.round(strengthAtDay(7)).toLocaleString() + ' PSI';
      document.getElementById('ccg-day28')!.textContent = Math.round(strengthAtDay(28)).toLocaleString() + ' PSI';
      document.getElementById('ccg-maturity')!.textContent = Math.round(maturity).toLocaleString();
      document.getElementById('ccg-strip')!.textContent = stripDays + ' days';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.ccg-in').forEach(el => {
        el.addEventListener('input', calcCCG);
        el.addEventListener('change', calcCCG);
      });
      calcCCG();
    }, 50);
  </script>
</CalculatorLayout>
