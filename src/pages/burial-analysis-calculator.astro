---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Burial Analysis Calculator - Demographic Age & Sex Distribution";
const description = "Analyze burial populations: calculate age-at-death distributions, sex ratios, life expectancy, mortality rates, and demographic profiles from cemetery data.";
const relatedCalcs = [
  { name: "Bone Measurement", url: "/bone-measurement-calculator", description: "Skeletal measurements." },
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
  { name: "Stable Isotope", url: "/stable-isotope-calculator", description: "Isotope analysis." },
  { name: "Radiocarbon Dating", url: "/radiocarbon-dating-calculator", description: "C-14 dating." },
  { name: "Faunal Dating", url: "/faunal-dating-calculator", description: "Faunal assemblages." },
  { name: "Carrying Capacity", url: "/carrying-capacity-calculator", description: "Land capacity." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Burial Analysis Calculator" keywords="burial analysis, paleodemography, age-at-death, sex ratio, life table, cemetery, mortality rate, bioarchaeology" breadcrumbs={[{ name: "Burial Analysis", url: "/burial-analysis-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Burial Analysis Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Analyze cemetery populations with demographic calculations including age-at-death distribution, sex ratios, crude mortality rates, and life expectancy estimates.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Burials</label>
          <input type="number" id="bua-total" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="85" min="1" step="1">
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Males</label>
            <input type="number" id="bua-male" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="32" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Females</label>
            <input type="number" id="bua-female" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="35" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Indeterminate</label>
            <input type="number" id="bua-indet" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18" min="0" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Subadults (0-15 yrs)</label>
            <input type="number" id="bua-subadult" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="28" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Adults (15+ yrs)</label>
            <input type="number" id="bua-adult" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="57" min="0" step="1">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Avg Adult Age-at-Death (years)</label>
          <input type="number" id="bua-avgage" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="38" min="15" max="80" step="0.5">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Cemetery Use Duration (years)</label>
          <input type="number" id="bua-duration" class="bua-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="200" min="1" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Life Expectancy at Birth</div>
          <div class="text-4xl font-extrabold" id="bua-e0">0</div>
          <div class="text-sm text-blue-200 mt-1">years (using Acsadi-Nemeskeri method)</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Sex Ratio (M:F)</div>
            <div class="text-xl font-bold" id="bua-sexratio">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Subadult Mortality</div>
            <div class="text-xl font-bold" id="bua-submort">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Crude Death Rate</div>
            <div class="text-xl font-bold" id="bua-cdr">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Living Population Est.</div>
            <div class="text-xl font-bold" id="bua-livepop">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Burials per Year</div>
            <div class="text-xl font-bold" id="bua-peryr">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Juvenility Index</div>
            <div class="text-xl font-bold" id="bua-juv">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="burial-analysis" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Paleodemographic Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Sex Ratio</strong> = Males / Females (expected ~1.0)</p>
        <p><strong>Juvenility Index</strong> = Subadults / (Subadults + Adults)</p>
        <p><strong>Crude Death Rate</strong> = 1000 / Life Expectancy at Birth</p>
        <p><strong>Living Pop</strong> = Burials * Life Expectancy / Duration</p>
      </div>
      <p>Paleodemographic analysis of burial populations provides insight into health, disease, and social structure. Life expectancy estimates use simplified life table methods. The juvenility index reflects childhood mortality and fertility rates. Sex ratios deviating from 1:1 may indicate differential burial practices.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcBUA() {
      const total = parseFloat((document.getElementById('bua-total') as HTMLInputElement).value) || 0;
      const male = parseFloat((document.getElementById('bua-male') as HTMLInputElement).value) || 0;
      const female = parseFloat((document.getElementById('bua-female') as HTMLInputElement).value) || 0;
      const subadult = parseFloat((document.getElementById('bua-subadult') as HTMLInputElement).value) || 0;
      const adult = parseFloat((document.getElementById('bua-adult') as HTMLInputElement).value) || 0;
      const avgAge = parseFloat((document.getElementById('bua-avgage') as HTMLInputElement).value) || 0;
      const duration = parseFloat((document.getElementById('bua-duration') as HTMLInputElement).value) || 1;

      const sexRatio = female > 0 ? male / female : 0;
      const subMort = total > 0 ? (subadult / total) * 100 : 0;
      const juvIndex = (subadult + adult) > 0 ? subadult / (subadult + adult) : 0;

      const avgSubadultAge = 5;
      const weightedAvgAge = total > 0 ? (subadult * avgSubadultAge + adult * avgAge) / total : 0;
      const e0 = weightedAvgAge;

      const cdr = e0 > 0 ? 1000 / e0 : 0;
      const burialsPerYear = duration > 0 ? total / duration : 0;
      const livingPop = e0 > 0 && duration > 0 ? (total * e0) / duration : 0;

      document.getElementById('bua-e0')!.textContent = e0.toFixed(1);
      document.getElementById('bua-sexratio')!.textContent = sexRatio.toFixed(2) + ':1';
      document.getElementById('bua-submort')!.textContent = subMort.toFixed(1) + '%';
      document.getElementById('bua-cdr')!.textContent = cdr.toFixed(1) + ' /1000';
      document.getElementById('bua-livepop')!.textContent = Math.round(livingPop).toLocaleString();
      document.getElementById('bua-peryr')!.textContent = burialsPerYear.toFixed(2);
      document.getElementById('bua-juv')!.textContent = juvIndex.toFixed(3);

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.bua-in').forEach(el => { el.addEventListener('input', calcBUA); el.addEventListener('change', calcBUA); });
      calcBUA();
    }, 50);
  </script>
</CalculatorLayout>
