---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Stucco Calculator - Coverage Area, Coats & Material Quantities";
const description = "Calculate stucco material quantities including scratch coat, brown coat, and finish coat. Get cement, sand, lime, and lath requirements.";

const relatedCalcs = [
  { name: "Plaster Mix Calculator", url: "/plaster-mix-calculator", description: "Plaster mixing ratios." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Mortar Calculator", url: "/mortar-calculator", description: "Mortar estimator." },
  { name: "Brick Calculator", url: "/brick-calculator", description: "Brick quantity." },
  { name: "Veneer Stone Calculator", url: "/veneer-stone-calculator", description: "Stone veneer coverage." },
  { name: "Concrete Color Calculator", url: "/concrete-color-calculator", description: "Color pigment dosage." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Stucco Calculator"
  keywords="stucco calculator, stucco coverage, scratch coat, brown coat, finish coat, stucco materials, stucco cement"
  breadcrumbs={[{ name: "Stucco Calculator", url: "/stucco-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Stucco Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate stucco material quantities for scratch, brown, and finish coats.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Length (ft)</label>
            <input type="number" id="stc-length" class="stc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Height (ft)</label>
            <input type="number" id="stc-height" class="stc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="9" min="1" step="0.5">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Openings to Deduct (sq ft)</label>
          <input type="number" id="stc-openings" class="stc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="0" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Stucco System</label>
          <select id="stc-system" class="stc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="3coat" selected>3-Coat (Scratch + Brown + Finish)</option>
            <option value="2coat">2-Coat (Base + Finish) over CMU</option>
            <option value="1coat">1-Coat (Synthetic / EIFS)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Finish Type</label>
          <select id="stc-finish" class="stc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="sand" selected>Sand Finish (Smooth)</option>
            <option value="dash">Dash Finish (Textured)</option>
            <option value="lace">Lace / Skip Trowel</option>
            <option value="santa">Santa Barbara (Smooth)</option>
          </select>
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <label class="block text-xs font-medium text-text mb-1">Waste Factor (%)</label>
          <input type="number" id="stc-waste" class="stc-in w-full px-3 py-2 border border-border rounded-lg" value="10" min="0" max="25" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Coverage Area</div>
          <div class="text-4xl font-extrabold" id="stc-area">0 sq ft</div>
          <div class="text-sm text-blue-200 mt-1"><span id="stc-coats">3</span>-coat system</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Portland Cement</div>
            <div class="text-xl font-bold" id="stc-cement">0 bags</div>
            <div class="text-xs text-text-muted">94 lb bags</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Mason Sand</div>
            <div class="text-xl font-bold" id="stc-sand">0 cu ft</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Hydrated Lime</div>
            <div class="text-xl font-bold" id="stc-lime">0 bags</div>
            <div class="text-xs text-text-muted">50 lb bags</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Metal Lath</div>
            <div class="text-xl font-bold" id="stc-lath">0 sheets</div>
            <div class="text-xs text-text-muted">2.5 lb/yd, 27x96 in</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Thickness</div>
            <div class="text-xl font-bold" id="stc-thick">0 in</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Finish Material</div>
            <div class="text-xl font-bold" id="stc-finish-qty">0</div>
            <div class="text-xs text-text-muted" id="stc-finish-label">bags</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="stucco" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Three-Coat Stucco System</h2>
      <ul>
        <li><strong>Scratch coat:</strong> 3/8" thick, 1:3 cement:sand ratio</li>
        <li><strong>Brown coat:</strong> 3/8" thick, 1:4 cement:sand ratio</li>
        <li><strong>Finish coat:</strong> 1/8" thick, varies by texture</li>
        <li><strong>Total thickness:</strong> Approximately 7/8" (22 mm)</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSTC() {
      const length = parseFloat((document.getElementById('stc-length') as HTMLInputElement).value) || 0;
      const height = parseFloat((document.getElementById('stc-height') as HTMLInputElement).value) || 0;
      const openings = parseFloat((document.getElementById('stc-openings') as HTMLInputElement).value) || 0;
      const system = (document.getElementById('stc-system') as HTMLSelectElement).value;
      const finish = (document.getElementById('stc-finish') as HTMLSelectElement).value;
      const waste = (parseFloat((document.getElementById('stc-waste') as HTMLInputElement).value) || 0) / 100;

      const area = Math.max(0, length * height - openings) * (1 + waste);

      // Thicknesses per system
      let scratchThick = 0, brownThick = 0, finishThick = 0.125;
      let numCoats = 3;

      if (system === '3coat') {
        scratchThick = 0.375; brownThick = 0.375; finishThick = 0.125;
        numCoats = 3;
      } else if (system === '2coat') {
        scratchThick = 0; brownThick = 0.375; finishThick = 0.125;
        numCoats = 2;
      } else {
        scratchThick = 0; brownThick = 0; finishThick = 0.125;
        numCoats = 1;
      }

      const totalThick = scratchThick + brownThick + finishThick;

      // Cement: scratch coat 1:3, brown coat 1:4
      // Per 100 sq ft at 3/8" thick: ~2.6 bags cement for scratch, ~2.0 for brown
      const scratchCementPer100 = 2.6;
      const brownCementPer100 = 2.0;
      const finishCementPer100 = 0.8;

      let cementBags = 0;
      if (scratchThick > 0) cementBags += (area / 100) * scratchCementPer100;
      if (brownThick > 0) cementBags += (area / 100) * brownCementPer100;
      cementBags += (area / 100) * finishCementPer100;

      // Sand: ~3 cu ft per bag of cement for scratch, ~4 for brown
      let sandCuFt = 0;
      if (scratchThick > 0) sandCuFt += (area / 100) * scratchCementPer100 * 3;
      if (brownThick > 0) sandCuFt += (area / 100) * brownCementPer100 * 4;
      sandCuFt += (area / 100) * finishCementPer100 * 3;

      // Lime: ~10% of cement weight = 0.1 x bags
      const limeBags = Math.ceil(cementBags * 0.5 * 94 / 50); // 50lb bags

      // Lath: 27x96in sheets = 18 sq ft each; only for 3-coat on frame
      const lathSheets = system === '3coat' ? Math.ceil(area / 18) : 0;

      // Finish material
      let finishQty = Math.ceil(area / 100); // bags per 100 sq ft
      let finishLabel = 'bags finish coat';
      if (finish === 'dash') { finishQty = Math.ceil(area / 80); finishLabel = 'bags dash mix'; }

      document.getElementById('stc-area')!.textContent = Math.round(area).toLocaleString() + ' sq ft';
      document.getElementById('stc-coats')!.textContent = String(numCoats);
      document.getElementById('stc-cement')!.textContent = Math.ceil(cementBags) + ' bags';
      document.getElementById('stc-sand')!.textContent = Math.round(sandCuFt) + ' cu ft';
      document.getElementById('stc-lime')!.textContent = limeBags + ' bags';
      document.getElementById('stc-lath')!.textContent = lathSheets + ' sheets';
      document.getElementById('stc-thick')!.textContent = totalThick.toFixed(3) + ' in';
      document.getElementById('stc-finish-qty')!.textContent = String(finishQty);
      document.getElementById('stc-finish-label')!.textContent = finishLabel;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.stc-in').forEach(el => {
        el.addEventListener('input', calcSTC);
        el.addEventListener('change', calcSTC);
      });
      calcSTC();
    }, 50);
  </script>
</CalculatorLayout>
