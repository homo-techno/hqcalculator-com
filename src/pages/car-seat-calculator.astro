---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Car Seat Calculator - Find the Right Car Seat by Age, Height & Weight";
const description = "Determine which car seat type your child needs based on age, height, and weight. Follow AAP and NHTSA safety guidelines for rear-facing, forward-facing, and booster seats.";

const relatedCalcs = [
  { name: "Child BMI Calculator", url: "/child-bmi-calculator", description: "BMI percentiles." },
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Height prediction." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "Child Travel Calculator", url: "/child-travel-calculator", description: "Travel with kids." },
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper expenses." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare costs." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Car Seat Calculator"
  keywords="car seat calculator, car seat by age, car seat weight requirements, when to change car seat, booster seat requirements, car seat safety"
  breadcrumbs={[{ name: "Car Seat Calculator", url: "/car-seat-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Car Seat Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Find the right car seat for your child based on their age, height, and weight following safety guidelines.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age</label>
          <div class="flex gap-3">
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Years</label>
              <input type="number" id="crs-years" class="crs-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0" max="12" step="1">
            </div>
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Months</label>
              <input type="number" id="crs-months" class="crs-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" max="11" step="1">
            </div>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Weight (lbs)</label>
          <input type="number" id="crs-weight" class="crs-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="28" min="4" max="120" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Height (inches)</label>
          <input type="number" id="crs-height" class="crs-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="34" min="18" max="65" step="0.5">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Recommended Car Seat</div>
        <div class="text-3xl font-extrabold" id="crs-type">--</div>
        <div class="text-sm text-blue-200 mt-1" id="crs-direction">facing direction</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Safety Priority</div>
          <div class="text-lg font-bold" id="crs-safety">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Next Transition</div>
          <div class="text-lg font-bold" id="crs-next">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Price Range</div>
          <div class="text-lg font-bold" id="crs-price">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Seat Belt Ready</div>
          <div class="text-lg font-bold" id="crs-seatbelt">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">All Car Seat Stages</h3>
        <div class="text-xs" id="crs-stages"></div>
      </div>

      <ShareButton calculatorId="car-seat" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Car Seat Safety Guidelines</h2>
      <p>The AAP recommends keeping children rear-facing as long as possible, ideally until age 2 or until they outgrow the height/weight limit. Every transition should be delayed as long as safely possible.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Car Seat Stages</h3>
      <ul>
        <li><strong>Rear-Facing Infant Seat:</strong> Birth to 30-35 lbs (keep rear-facing as long as possible)</li>
        <li><strong>Rear-Facing Convertible:</strong> Can be used rear-facing up to 40-50 lbs</li>
        <li><strong>Forward-Facing with Harness:</strong> 2+ years, 25-65 lbs</li>
        <li><strong>Booster Seat:</strong> 4+ years, 40-100 lbs, under 4'9"</li>
        <li><strong>Seat Belt Only:</strong> 4'9"+ tall, typically 8-12 years old</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">The 5-Step Seat Belt Test</h3>
      <p>Before switching to a seat belt alone, check: (1) Child sits all the way back, (2) Knees bend at seat edge, (3) Lap belt sits on upper thighs, (4) Shoulder belt crosses mid-chest, (5) Child can stay seated properly for the whole trip.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCRS() {
      const years = parseFloat((document.getElementById('crs-years') as HTMLInputElement).value) || 0;
      const months = parseFloat((document.getElementById('crs-months') as HTMLInputElement).value) || 0;
      const weight = parseFloat((document.getElementById('crs-weight') as HTMLInputElement).value) || 28;
      const height = parseFloat((document.getElementById('crs-height') as HTMLInputElement).value) || 34;
      const ageMonths = years * 12 + months;

      let seatType = '';
      let direction = '';
      let safety = '';
      let next = '';
      let price = '';
      let seatbelt = 'No';
      let currentStage = 0;

      // Seat belt readiness: 4'9" (57 inches) and 80+ lbs, age 8+
      const seatbeltReady = height >= 57 && weight >= 80 && ageMonths >= 96;

      if (ageMonths < 24 && weight < 40 && height < 43) {
        seatType = 'Rear-Facing Car Seat';
        direction = 'Rear-facing -- safest position';
        safety = 'Keep rear-facing!';
        next = 'At 2 yrs or max height/weight';
        price = '$80 - $350';
        currentStage = 0;
      } else if (ageMonths < 48 && weight < 65) {
        seatType = 'Forward-Facing Harness';
        direction = 'Forward-facing with 5-point harness';
        safety = 'Use harness to max limit';
        next = 'At 40+ lbs, 4+ years';
        price = '$100 - $400';
        currentStage = 1;
      } else if (!seatbeltReady) {
        seatType = 'Booster Seat';
        direction = 'Forward-facing with vehicle belt';
        safety = 'High-back preferred';
        next = "At 4'9\" tall, 80+ lbs";
        price = '$25 - $200';
        currentStage = 2;
      } else {
        seatType = 'Seat Belt Only';
        direction = 'No car seat needed';
        safety = 'Seat belt fits properly';
        next = 'None -- graduated!';
        price = 'N/A';
        seatbelt = 'Yes';
        currentStage = 3;
      }

      if (seatbeltReady) seatbelt = 'Yes';

      document.getElementById('crs-type')!.textContent = seatType;
      document.getElementById('crs-direction')!.textContent = direction;
      document.getElementById('crs-safety')!.textContent = safety;
      document.getElementById('crs-next')!.textContent = next;
      document.getElementById('crs-price')!.textContent = price;
      document.getElementById('crs-seatbelt')!.textContent = seatbelt;

      const stages = [
        { name: 'Rear-Facing', age: 'Birth - 2+ yrs', weight: 'Up to 40-50 lbs', height: 'Up to 43"' },
        { name: 'Forward-Facing Harness', age: '2 - 4+ yrs', weight: '25-65 lbs', height: 'Up to 49"' },
        { name: 'Booster Seat', age: '4 - 8+ yrs', weight: '40-100 lbs', height: 'Under 4\'9"' },
        { name: 'Seat Belt Only', age: '8+ yrs', weight: '80+ lbs', height: '4\'9"+ tall' },
      ];

      document.getElementById('crs-stages')!.innerHTML =
        '<div class="grid grid-cols-4 gap-2 font-semibold text-text-muted mb-1"><span>Stage</span><span>Age</span><span>Weight</span><span>Height</span></div>' +
        stages.map((s, i) => {
          return `<div class="grid grid-cols-4 gap-2 py-1 ${i === currentStage ? 'bg-blue-50 rounded font-bold' : ''}"><span>${s.name}</span><span>${s.age}</span><span>${s.weight}</span><span>${s.height}</span></div>`;
        }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.crs-in').forEach(el => {
        el.addEventListener('input', calcCRS);
        el.addEventListener('change', calcCRS);
      });
      calcCRS();
    }, 50);
  </script>
</CalculatorLayout>
