---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Medication Calculator - Fish Treatment Dosing";
const description = "Calculate accurate fish medication dosages by tank volume and treatment type for common aquarium diseases and parasites.";
const relatedCalcs = [
  { name: "Aquarium Salt", url: "/aquarium-salt-calculator", description: "Salt dosage for freshwater treatments." },
  { name: "Aquarium Water Change", url: "/aquarium-water-change-calculator", description: "Water change volume and schedule." },
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume and weight." },
  { name: "Fish Tank Stocking", url: "/fish-tank-stocking-calculator", description: "Fish stocking capacity calculator." },
  { name: "Fish Feeding", url: "/fish-feeding-calculator", description: "Fish feeding amount calculator." },
  { name: "Aquarium Nitrogen Cycle", url: "/aquarium-nitrogen-cycle-calculator", description: "Track nitrogen cycle progression." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Medication Calculator" keywords="aquarium medication calculator, fish medication dosage, ich treatment, fish disease treatment, aquarium medicine dosing" breadcrumbs={[{ name: "Aquarium Medication", url: "/aquarium-medication-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Medication Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate precise medication dosages for your aquarium based on actual water volume and treatment type.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-text mb-1">Net Water Volume (gallons)</label>
          <input type="number" id="amd-vol" class="amd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="1" step="1">
          <p class="text-xs text-text-muted mt-1">Subtract ~15% from total volume for substrate, decor, etc.</p>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Medication / Treatment</label>
          <select id="amd-med" class="amd-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="ich">Ich Treatment (malachite green) - 1 drop/gal</option>
            <option value="melafix">Melafix (tea tree) - 5 ml per 10 gal</option>
            <option value="pimafix">Pimafix (antifungal) - 5 ml per 10 gal</option>
            <option value="erythromycin">Erythromycin (200 mg/10 gal)</option>
            <option value="metronidazole">Metronidazole (250 mg/10 gal)</option>
            <option value="praziquantel">Praziquantel (dewormer) - 2.5 mg/L</option>
            <option value="methylene_blue">Methylene Blue - 1 tsp/10 gal</option>
            <option value="aquarium_salt">Aquarium Salt - 1 tbsp/5 gal</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Dose Adjustment</label>
          <select id="amd-adj" class="amd-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="1">Full Dose (standard)</option>
            <option value="0.5">Half Dose (sensitive fish / scaleless)</option>
            <option value="0.75">3/4 Dose (precautionary)</option>
          </select>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Medication Dose</div>
          <div class="text-5xl font-extrabold font-mono" id="amd-result">0</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Metric Amount</div>
            <div class="text-xl font-bold font-mono" id="amd-metric">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Treatment Duration</div>
            <div class="text-xl font-bold font-mono" id="amd-dur">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Redose Interval</div>
            <div class="text-xl font-bold font-mono" id="amd-interval">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water Change Before Redose</div>
            <div class="text-xl font-bold font-mono" id="amd-wc">25%</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-medication" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcAMD() {
      const vol = parseFloat((document.getElementById('amd-vol') as HTMLInputElement).value) || 0;
      const med = (document.getElementById('amd-med') as HTMLSelectElement).value;
      const adj = parseFloat((document.getElementById('amd-adj') as HTMLSelectElement).value) || 1;
      const liters = vol * 3.785;
      interface MedInfo { dose: string; metric: string; duration: string; interval: string; wc: string; }
      const meds: Record<string, MedInfo> = {
        ich: { dose: (vol * 1 * adj).toFixed(0) + ' drops', metric: (vol * 0.05 * adj).toFixed(1) + ' ml', duration: '14 days', interval: 'Every 24 hrs', wc: '25%' },
        melafix: { dose: (vol / 10 * 5 * adj).toFixed(1) + ' ml', metric: (vol / 10 * 5 * adj).toFixed(1) + ' ml', duration: '7 days', interval: 'Daily', wc: '25%' },
        pimafix: { dose: (vol / 10 * 5 * adj).toFixed(1) + ' ml', metric: (vol / 10 * 5 * adj).toFixed(1) + ' ml', duration: '7 days', interval: 'Daily', wc: '25%' },
        erythromycin: { dose: (vol / 10 * 200 * adj).toFixed(0) + ' mg', metric: (vol / 10 * 200 * adj / 1000).toFixed(2) + ' g', duration: '5 days', interval: 'Every 24 hrs', wc: '25%' },
        metronidazole: { dose: (vol / 10 * 250 * adj).toFixed(0) + ' mg', metric: (vol / 10 * 250 * adj / 1000).toFixed(2) + ' g', duration: '3 days', interval: 'Every 48 hrs', wc: '25%' },
        praziquantel: { dose: (liters * 2.5 * adj).toFixed(0) + ' mg', metric: (liters * 2.5 * adj / 1000).toFixed(2) + ' g', duration: '5-7 days', interval: 'Single dose', wc: '100% after' },
        methylene_blue: { dose: (vol / 10 * adj).toFixed(1) + ' tsp', metric: (vol / 10 * 5 * adj).toFixed(1) + ' ml', duration: '3-5 days', interval: 'Single dose', wc: '25%' },
        aquarium_salt: { dose: (vol / 5 * adj).toFixed(1) + ' tbsp', metric: (vol / 5 * 15 * adj).toFixed(0) + ' g', duration: '7-10 days', interval: 'After WC only', wc: '25%' },
      };
      const info = meds[med] || meds['ich'];
      document.getElementById('amd-result')!.textContent = info.dose;
      document.getElementById('amd-metric')!.textContent = info.metric;
      document.getElementById('amd-dur')!.textContent = info.duration;
      document.getElementById('amd-interval')!.textContent = info.interval;
      document.getElementById('amd-wc')!.textContent = info.wc;
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.amd-in').forEach(el => { el.addEventListener('input', calcAMD); el.addEventListener('change', calcAMD); });
      calcAMD();
    }, 50);
  </script>
</CalculatorLayout>
