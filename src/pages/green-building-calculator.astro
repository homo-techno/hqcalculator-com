---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Green Building Calculator - LEED-like Certification Point Estimation";
const description = "Estimate your green building certification points across categories like energy, water, materials, and indoor air quality.";
const relatedCalcs = [
  { name: "Energy Audit", url: "/energy-audit-calculator", description: "Home audit." },
  { name: "Insulation ROI", url: "/insulation-roi-calculator", description: "Insulation savings." },
  { name: "Passive House", url: "/passive-house-calculator", description: "Passive design." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Water Conservation", url: "/water-conservation-calculator", description: "Water savings." },
  { name: "LED Savings", url: "/led-savings-calculator", description: "LED savings." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Green Building Calculator" keywords="green building calculator, LEED points estimation, green certification, sustainable building, green building score" breadcrumbs={[{ name: "Green Building", url: "/green-building-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Green Building Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate green building certification points across sustainability categories.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Energy Efficiency (max 33 pts)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Energy Reduction vs Code (%)</label><input type="number" id="gbc-energy" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="0" max="100" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">On-site Renewable (%)</label><input type="number" id="gbc-renew" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="15" min="0" max="100" step="5"></div>
        </div>
        <h3 class="font-semibold text-text">Water Efficiency (max 11 pts)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Indoor Water Reduction (%)</label><input type="number" id="gbc-water" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="35" min="0" max="60" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Outdoor Water Reduction (%)</label><input type="number" id="gbc-outdoor" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="50" min="0" max="100" step="10"></div>
        </div>
        <h3 class="font-semibold text-text">Materials & Resources (max 13 pts)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Recycled Content (%)</label><input type="number" id="gbc-recycled" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" max="100" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Regional Materials (%)</label><input type="number" id="gbc-regional" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" max="100" step="5"></div>
        </div>
        <h3 class="font-semibold text-text">Indoor Environmental Quality (max 15 pts)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Ventilation</label>
            <select id="gbc-vent" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">Enhanced (+30% above code)</option>
              <option value="2" selected>Meets ASHRAE 62.1</option>
              <option value="1">Below standard</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Low-VOC Materials</label>
            <select id="gbc-voc" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="4">All categories low-VOC</option>
              <option value="2" selected>Some low-VOC</option>
              <option value="0">Standard materials</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Daylighting Coverage (%)</label>
          <input type="number" id="gbc-daylight" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="50" min="0" max="100" step="10">
        </div>
        <h3 class="font-semibold text-text">Site & Location (max 26 pts)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Public Transit Access</label>
            <select id="gbc-transit" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="6">Within 0.25 mi of rail</option>
              <option value="3" selected>Within 0.25 mi of bus</option>
              <option value="0">No transit nearby</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Stormwater Management</label>
            <select id="gbc-storm" class="gbc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">Full retention/treatment</option>
              <option value="1" selected>Partial management</option>
              <option value="0">No management</option>
            </select>
          </div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Points</div>
          <div class="text-4xl font-extrabold" id="gbc-total">0 / 110</div>
          <div class="text-sm text-blue-200 mt-1" id="gbc-level">Calculating...</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Energy Points</div><div class="text-xl font-bold" id="gbc-epoints">0 / 33</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Water Points</div><div class="text-xl font-bold" id="gbc-wpoints">0 / 11</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Materials Points</div><div class="text-xl font-bold" id="gbc-mpoints">0 / 13</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">IEQ Points</div><div class="text-xl font-bold" id="gbc-ipoints">0 / 15</div></div>
        </div>
      </div>
      <ShareButton calculatorId="green-building" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Green Building Certification Levels</h2>
      <p>LEED (Leadership in Energy and Environmental Design) has four certification levels: Certified (40-49 points), Silver (50-59), Gold (60-79), and Platinum (80+) out of 110 possible points. The largest category is Energy and Atmosphere (33 points), making energy efficiency the most impactful area. Water efficiency, materials selection, indoor air quality, and site sustainability round out the scoring categories.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcGBC() {
      const energy = parseFloat((document.getElementById('gbc-energy') as HTMLInputElement).value) || 0;
      const renew = parseFloat((document.getElementById('gbc-renew') as HTMLInputElement).value) || 0;
      const water = parseFloat((document.getElementById('gbc-water') as HTMLInputElement).value) || 0;
      const outdoor = parseFloat((document.getElementById('gbc-outdoor') as HTMLInputElement).value) || 0;
      const recycled = parseFloat((document.getElementById('gbc-recycled') as HTMLInputElement).value) || 0;
      const regional = parseFloat((document.getElementById('gbc-regional') as HTMLInputElement).value) || 0;
      const vent = parseInt((document.getElementById('gbc-vent') as HTMLSelectElement).value) || 0;
      const voc = parseInt((document.getElementById('gbc-voc') as HTMLSelectElement).value) || 0;
      const daylight = parseFloat((document.getElementById('gbc-daylight') as HTMLInputElement).value) || 0;
      const transit = parseInt((document.getElementById('gbc-transit') as HTMLSelectElement).value) || 0;
      const storm = parseInt((document.getElementById('gbc-storm') as HTMLSelectElement).value) || 0;
      const ePoints = Math.min(33, Math.round(energy / 100 * 18 + renew / 100 * 7) + (energy >= 50 ? 5 : 0) + (renew >= 100 ? 3 : 0));
      const wPoints = Math.min(11, Math.round(water / 60 * 6 + outdoor / 100 * 4) + (water >= 40 ? 1 : 0));
      const mPoints = Math.min(13, Math.round(recycled / 100 * 6 + regional / 100 * 4) + (recycled >= 50 ? 2 : 0) + (regional >= 50 ? 1 : 0));
      const iPoints = Math.min(15, vent + voc + Math.round(daylight / 100 * 4) + (daylight >= 75 ? 2 : 0));
      const sPoints = Math.min(26, transit + storm + 5);
      const total = ePoints + wPoints + mPoints + iPoints + sPoints;
      let level = 'Not Certified';
      if (total >= 80) level = 'Platinum';
      else if (total >= 60) level = 'Gold';
      else if (total >= 50) level = 'Silver';
      else if (total >= 40) level = 'Certified';
      document.getElementById('gbc-total')!.textContent = total + ' / 110';
      document.getElementById('gbc-level')!.textContent = level;
      document.getElementById('gbc-epoints')!.textContent = ePoints + ' / 33';
      document.getElementById('gbc-wpoints')!.textContent = wPoints + ' / 11';
      document.getElementById('gbc-mpoints')!.textContent = mPoints + ' / 13';
      document.getElementById('gbc-ipoints')!.textContent = iPoints + ' / 15';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.gbc-in').forEach(el => { el.addEventListener('input', calcGBC); el.addEventListener('change', calcGBC); }); calcGBC(); }, 50);
  </script>
</CalculatorLayout>
