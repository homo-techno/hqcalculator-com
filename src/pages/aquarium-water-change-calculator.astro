---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Water Change Calculator - Volume & Frequency";
const description = "Calculate optimal water change volume and frequency to maintain healthy nitrate levels in your aquarium based on stocking and tank size.";
const relatedCalcs = [
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume and water weight." },
  { name: "Aquarium Nitrogen Cycle", url: "/aquarium-nitrogen-cycle-calculator", description: "Track nitrogen cycle progression." },
  { name: "Aquarium Salt", url: "/aquarium-salt-calculator", description: "Salt dosage for aquarium treatments." },
  { name: "Fish Tank Stocking", url: "/fish-tank-stocking-calculator", description: "Fish stocking capacity calculator." },
  { name: "Aquarium Medication", url: "/aquarium-medication-calculator", description: "Fish medication dosing calculator." },
  { name: "Aquarium Evaporation", url: "/aquarium-evaporation-calculator", description: "Water evaporation rate estimator." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Water Change Calculator" keywords="aquarium water change calculator, fish tank water change, nitrate management, water change schedule, aquarium maintenance" breadcrumbs={[{ name: "Aquarium Water Change", url: "/aquarium-water-change-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Water Change Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Determine the ideal water change volume and schedule to keep nitrate levels safe for your fish.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tank Volume (gallons)</label>
            <input type="number" id="awc-vol" class="awc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="55" min="1" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Current Nitrate (ppm)</label>
            <input type="number" id="awc-no3" class="awc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="0" step="5">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Target Nitrate (ppm)</label>
            <input type="number" id="awc-target" class="awc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" step="5">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tap Water Nitrate (ppm)</label>
            <input type="number" id="awc-tap" class="awc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0" step="1">
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Stocking Level</label>
          <select id="awc-stock" class="awc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="light">Lightly Stocked</option>
            <option value="moderate" selected>Moderately Stocked</option>
            <option value="heavy">Heavily Stocked</option>
            <option value="overstocked">Overstocked</option>
          </select>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Water Change Needed</div>
          <div class="text-5xl font-extrabold font-mono" id="awc-result">0%</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Volume to Remove</div>
            <div class="text-xl font-bold font-mono" id="awc-gal">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Frequency</div>
            <div class="text-xl font-bold font-mono" id="awc-freq">Weekly</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Post-Change Nitrate</div>
            <div class="text-xl font-bold font-mono" id="awc-post">0 ppm</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water Weight</div>
            <div class="text-xl font-bold font-mono" id="awc-weight">0 lbs</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-water-change" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcAWC() {
      const vol = parseFloat((document.getElementById('awc-vol') as HTMLInputElement).value) || 0;
      const no3 = parseFloat((document.getElementById('awc-no3') as HTMLInputElement).value) || 0;
      const target = parseFloat((document.getElementById('awc-target') as HTMLInputElement).value) || 0;
      const tap = parseFloat((document.getElementById('awc-tap') as HTMLInputElement).value) || 0;
      const stock = (document.getElementById('awc-stock') as HTMLSelectElement).value;
      // Water change % to reach target nitrate from current
      // After WC: new_no3 = no3 * (1 - pct) + tap * pct
      // Solve for pct: pct = (no3 - target) / (no3 - tap)
      let pct = 0;
      if (no3 > tap && no3 > target) {
        pct = (no3 - target) / (no3 - tap);
      }
      pct = Math.min(pct, 0.9); // max 90%
      pct = Math.max(pct, 0);
      const changeGal = vol * pct;
      const postNO3 = no3 * (1 - pct) + tap * pct;
      const weight = changeGal * 8.34;
      // Frequency recommendation based on stocking
      const freqMap: Record<string, string> = {
        light: 'Every 2 weeks',
        moderate: 'Weekly',
        heavy: '2x per week',
        overstocked: 'Every 3 days'
      };
      const freq = freqMap[stock] || 'Weekly';
      document.getElementById('awc-result')!.textContent = (pct * 100).toFixed(0) + '%';
      document.getElementById('awc-gal')!.textContent = changeGal.toFixed(1) + ' gal';
      document.getElementById('awc-freq')!.textContent = freq;
      document.getElementById('awc-post')!.textContent = postNO3.toFixed(1) + ' ppm';
      document.getElementById('awc-weight')!.textContent = weight.toFixed(0) + ' lbs';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.awc-in').forEach(el => { el.addEventListener('input', calcAWC); el.addEventListener('change', calcAWC); });
      calcAWC();
    }, 50);
  </script>
</CalculatorLayout>
