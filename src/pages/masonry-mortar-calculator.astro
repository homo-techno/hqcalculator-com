---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Masonry Mortar Calculator - Quantity by Type (N, S, M, O)";
const description = "Calculate mortar quantity by ASTM type (N, S, M, O) for brick and block masonry. Get cement, lime, sand proportions and bags needed.";

const relatedCalcs = [
  { name: "Mortar Calculator", url: "/mortar-calculator", description: "General mortar estimator." },
  { name: "Brick Calculator", url: "/brick-calculator", description: "Brick quantity." },
  { name: "Block Wall Calculator", url: "/block-wall-calculator", description: "CMU block calculator." },
  { name: "Tuckpointing Calculator", url: "/tuckpointing-calculator", description: "Tuckpointing mortar." },
  { name: "Grout Volume Calculator", url: "/grout-volume-calculator", description: "Grout for CMU cells." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Masonry Mortar Calculator"
  keywords="mortar type N, mortar type S, mortar type M, mortar type O, masonry mortar, cement lime sand ratio, mortar quantity"
  breadcrumbs={[{ name: "Masonry Mortar Calculator", url: "/masonry-mortar-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Masonry Mortar Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate mortar quantities by ASTM type with precise cement, lime, and sand proportions.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Mortar Type</label>
          <select id="mmr-type" class="mmr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="M">Type M - High Strength (2,500 PSI) - Foundations, Retaining</option>
            <option value="S" selected>Type S - Structural (1,800 PSI) - Below Grade, Exterior</option>
            <option value="N">Type N - General Purpose (750 PSI) - Above Grade</option>
            <option value="O">Type O - Low Strength (350 PSI) - Interior, Non-Structural</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Masonry Unit</label>
          <select id="mmr-unit" class="mmr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="brick" selected>Standard Brick (8 x 2.25 x 3.75 in)</option>
            <option value="modular">Modular Brick (7.625 x 2.25 x 3.625 in)</option>
            <option value="cmu8">8" CMU Block (15.625 x 7.625 x 7.625 in)</option>
            <option value="cmu12">12" CMU Block (15.625 x 7.625 x 11.625 in)</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Length (ft)</label>
            <input type="number" id="mmr-length" class="mmr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Height (ft)</label>
            <input type="number" id="mmr-height" class="mmr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" step="0.5">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Joint Thickness (in)</label>
            <select id="mmr-joint" class="mmr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="0.375" selected>3/8 inch (standard)</option>
              <option value="0.5">1/2 inch</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Waste Factor (%)</label>
            <input type="number" id="mmr-waste" class="mmr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="0" max="25" step="1">
          </div>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Mortar Volume Needed</div>
          <div class="text-4xl font-extrabold" id="mmr-volume">0 cu ft</div>
          <div class="text-sm text-blue-200 mt-1">Type <span id="mmr-type-label">S</span> - Ratio: <span id="mmr-ratio">1 : 0.5 : 4.5</span></div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Portland Cement</div>
            <div class="text-xl font-bold" id="mmr-cement">0 bags</div>
            <div class="text-xs text-text-muted">94 lb bags</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Hydrated Lime</div>
            <div class="text-xl font-bold" id="mmr-lime">0 bags</div>
            <div class="text-xs text-text-muted">50 lb bags</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Mason Sand</div>
            <div class="text-xl font-bold" id="mmr-sand">0 cu ft</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Pre-Mixed Bags (80 lb)</div>
            <div class="text-xl font-bold" id="mmr-premix">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Masonry Units</div>
            <div class="text-xl font-bold" id="mmr-units">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Compressive Strength</div>
            <div class="text-xl font-bold" id="mmr-strength">0 PSI</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="masonry-mortar" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">ASTM C270 Mortar Types</h2>
      <ul>
        <li><strong>Type M (1:0.25:3):</strong> 2,500 PSI - foundations, retaining walls, below grade</li>
        <li><strong>Type S (1:0.5:4.5):</strong> 1,800 PSI - exterior walls, structural masonry</li>
        <li><strong>Type N (1:1:6):</strong> 750 PSI - above-grade general purpose, most common</li>
        <li><strong>Type O (1:2:9):</strong> 350 PSI - interior non-load-bearing partitions</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    interface MortarSpec {
      cement: number; lime: number; sand: number;
      ratio: string; strength: number;
    }

    const mmrSpecs: Record<string, MortarSpec> = {
      'M': { cement: 1, lime: 0.25, sand: 3, ratio: '1 : 0.25 : 3', strength: 2500 },
      'S': { cement: 1, lime: 0.5, sand: 4.5, ratio: '1 : 0.5 : 4.5', strength: 1800 },
      'N': { cement: 1, lime: 1, sand: 6, ratio: '1 : 1 : 6', strength: 750 },
      'O': { cement: 1, lime: 2, sand: 9, ratio: '1 : 2 : 9', strength: 350 },
    };

    const mmrUnitData: Record<string, { w: number; h: number; d: number }> = {
      brick:   { w: 8, h: 2.25, d: 3.75 },
      modular: { w: 7.625, h: 2.25, d: 3.625 },
      cmu8:    { w: 15.625, h: 7.625, d: 7.625 },
      cmu12:   { w: 15.625, h: 7.625, d: 11.625 },
    };

    function calcMMR() {
      const mortarType = (document.getElementById('mmr-type') as HTMLSelectElement).value;
      const unitType = (document.getElementById('mmr-unit') as HTMLSelectElement).value;
      const wallL = parseFloat((document.getElementById('mmr-length') as HTMLInputElement).value) || 0;
      const wallH = parseFloat((document.getElementById('mmr-height') as HTMLInputElement).value) || 0;
      const joint = parseFloat((document.getElementById('mmr-joint') as HTMLSelectElement).value) || 0.375;
      const waste = (parseFloat((document.getElementById('mmr-waste') as HTMLInputElement).value) || 0) / 100;

      const spec = mmrSpecs[mortarType] || mmrSpecs['S'];
      const unit = mmrUnitData[unitType] || mmrUnitData.brick;

      const area = wallL * wallH;
      const courseH = (unit.h + joint) / 12;
      const unitL = (unit.w + joint) / 12;
      const unitsPerSqFt = 1 / (courseH * unitL);
      const totalUnits = Math.ceil(unitsPerSqFt * area * (1 + waste));

      // Mortar volume per unit: bed joint + head joint
      const bedVol = (unit.w / 12) * (unit.d / 12) * (joint / 12);
      const headVol = (unit.h / 12) * (unit.d / 12) * (joint / 12);
      const mortarPerUnit = bedVol + headVol;
      const totalMortarCuFt = mortarPerUnit * totalUnits * (1 + waste);

      // Proportions by volume
      const totalParts = spec.cement + spec.lime + spec.sand;
      const cementCuFt = totalMortarCuFt * (spec.cement / totalParts);
      const limeCuFt = totalMortarCuFt * (spec.lime / totalParts);
      const sandCuFt = totalMortarCuFt * (spec.sand / totalParts);

      // 1 bag cement = 94 lbs ~= 1 cu ft; 1 bag lime = 50 lbs ~= 1 cu ft
      const cementBags = Math.ceil(cementCuFt);
      const limeBags = Math.ceil(limeCuFt);
      const premixBags = Math.ceil(totalMortarCuFt / 0.50); // 80 lb bag = ~0.5 cu ft

      document.getElementById('mmr-volume')!.textContent = totalMortarCuFt.toFixed(1) + ' cu ft';
      document.getElementById('mmr-type-label')!.textContent = mortarType;
      document.getElementById('mmr-ratio')!.textContent = spec.ratio;
      document.getElementById('mmr-cement')!.textContent = cementBags + ' bags';
      document.getElementById('mmr-lime')!.textContent = limeBags + ' bags';
      document.getElementById('mmr-sand')!.textContent = sandCuFt.toFixed(1) + ' cu ft';
      document.getElementById('mmr-premix')!.textContent = String(premixBags);
      document.getElementById('mmr-units')!.textContent = totalUnits.toLocaleString();
      document.getElementById('mmr-strength')!.textContent = spec.strength.toLocaleString() + ' PSI';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.mmr-in').forEach(el => {
        el.addEventListener('input', calcMMR);
        el.addEventListener('change', calcMMR);
      });
      calcMMR();
    }, 50);
  </script>
</CalculatorLayout>
