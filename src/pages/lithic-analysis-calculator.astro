---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Lithic Analysis Calculator - Flake-to-Core Ratio & Reduction Index";
const description = "Analyze stone tool assemblages: calculate flake-to-core ratios, cortex percentage, reduction stage index, and debitage analysis metrics.";
const relatedCalcs = [
  { name: "Ceramic Analysis", url: "/ceramic-analysis-calculator", description: "Pottery analysis." },
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Artifact Illustration", url: "/artifact-illustration-calculator", description: "Drawing scale." },
  { name: "Obsidian Hydration", url: "/obsidian-hydration-calculator", description: "Obsidian dating." },
  { name: "Excavation Volume", url: "/excavation-volume-calculator", description: "Dig unit volume." },
  { name: "Site Grid", url: "/site-grid-calculator", description: "Grid layout planning." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Lithic Analysis Calculator" keywords="lithic analysis, flake-to-core ratio, reduction index, debitage, stone tool, cortex percentage, knapping, chipped stone" breadcrumbs={[{ name: "Lithic Analysis", url: "/lithic-analysis-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Lithic Analysis Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Analyze chipped stone assemblages by calculating flake-to-core ratios, cortex ratios, reduction indices, and debitage classification metrics.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Complete Flakes</label>
            <input type="number" id="lia-flakes" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="120" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Cores</label>
            <input type="number" id="lia-cores" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="0" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Broken Flakes/Fragments</label>
            <input type="number" id="lia-broken" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="85" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Shatter/Debris</label>
            <input type="number" id="lia-shatter" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="45" min="0" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Formal Tools</label>
            <input type="number" id="lia-tools" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="15" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Cortical Pieces (>50% cortex)</label>
            <input type="number" id="lia-cortex" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="22" min="0" step="1">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Assemblage Weight (g)</label>
          <input type="number" id="lia-weight" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3500" min="0" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Avg Core Weight (g)</label>
          <input type="number" id="lia-corewt" class="lia-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="250" min="1" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Flake-to-Core Ratio</div>
          <div class="text-4xl font-extrabold" id="lia-fcr">0</div>
          <div class="text-sm text-blue-200 mt-1" id="lia-interp">--</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Cortex Ratio</div>
            <div class="text-xl font-bold" id="lia-cortexr">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Tool-to-Debitage Ratio</div>
            <div class="text-xl font-bold" id="lia-tdr">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Debitage</div>
            <div class="text-xl font-bold" id="lia-debitage">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Completeness Index</div>
            <div class="text-xl font-bold" id="lia-complete">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Avg Piece Weight</div>
            <div class="text-xl font-bold" id="lia-avgwt">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Reduction Stage</div>
            <div class="text-xl font-bold" id="lia-stage">--</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="lithic-analysis" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Lithic Analysis Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Flake:Core Ratio</strong> = (Flakes + Broken Flakes) / Cores</p>
        <p><strong>Cortex Ratio</strong> = Cortical Pieces / Total Debitage</p>
        <p><strong>Tool:Debitage Ratio</strong> = Tools / Total Debitage</p>
        <p><strong>Completeness</strong> = Complete Flakes / (Complete + Broken)</p>
      </div>
      <p>High flake-to-core ratios suggest intensive core reduction. High cortex ratios indicate early-stage reduction or primary flaking. Low tool-to-debitage ratios suggest a production site, while high ratios suggest a use/consumption site. These metrics help reconstruct knapping strategies and site function.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcLIA() {
      const flakes = parseFloat((document.getElementById('lia-flakes') as HTMLInputElement).value) || 0;
      const cores = parseFloat((document.getElementById('lia-cores') as HTMLInputElement).value) || 0;
      const broken = parseFloat((document.getElementById('lia-broken') as HTMLInputElement).value) || 0;
      const shatter = parseFloat((document.getElementById('lia-shatter') as HTMLInputElement).value) || 0;
      const tools = parseFloat((document.getElementById('lia-tools') as HTMLInputElement).value) || 0;
      const cortex = parseFloat((document.getElementById('lia-cortex') as HTMLInputElement).value) || 0;
      const weight = parseFloat((document.getElementById('lia-weight') as HTMLInputElement).value) || 0;
      const coreWt = parseFloat((document.getElementById('lia-corewt') as HTMLInputElement).value) || 1;

      const totalDebitage = flakes + broken + shatter;
      const totalPieces = totalDebitage + cores + tools;
      const fcr = cores > 0 ? (flakes + broken) / cores : 0;
      const cortexRatio = totalDebitage > 0 ? cortex / totalDebitage : 0;
      const tdr = totalDebitage > 0 ? tools / totalDebitage : 0;
      const completeness = (flakes + broken) > 0 ? flakes / (flakes + broken) : 0;
      const avgWt = totalPieces > 0 ? weight / totalPieces : 0;

      let stage = '';
      let interp = '';
      if (cortexRatio > 0.4) {
        stage = 'Early / Primary';
        interp = 'Primary reduction - initial core preparation';
      } else if (cortexRatio > 0.2) {
        stage = 'Middle';
        interp = 'Secondary reduction - core shaping and flake production';
      } else if (cortexRatio > 0.05) {
        stage = 'Late';
        interp = 'Advanced reduction - tool blank production';
      } else {
        stage = 'Final / Retouch';
        interp = 'Late-stage reduction - tool finishing and maintenance';
      }

      if (fcr > 50) {
        interp += '; intensive workshop activity';
      } else if (fcr < 5 && cores > 0) {
        interp += '; limited knapping or core transport';
      }

      document.getElementById('lia-fcr')!.textContent = fcr.toFixed(1) + ':1';
      document.getElementById('lia-interp')!.textContent = interp;
      document.getElementById('lia-cortexr')!.textContent = (cortexRatio * 100).toFixed(1) + '%';
      document.getElementById('lia-tdr')!.textContent = (tdr * 100).toFixed(2) + '%';
      document.getElementById('lia-debitage')!.textContent = totalDebitage.toLocaleString() + ' pieces';
      document.getElementById('lia-complete')!.textContent = (completeness * 100).toFixed(1) + '%';
      document.getElementById('lia-avgwt')!.textContent = avgWt.toFixed(1) + ' g';
      document.getElementById('lia-stage')!.textContent = stage;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.lia-in').forEach(el => { el.addEventListener('input', calcLIA); el.addEventListener('change', calcLIA); });
      calcLIA();
    }, 50);
  </script>
</CalculatorLayout>
