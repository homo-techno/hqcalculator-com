---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Nitrogen Cycle Calculator - Cycling Tracker";
const description = "Track your aquarium nitrogen cycle progression by entering ammonia, nitrite, and nitrate readings to determine cycling stage and estimated completion.";
const relatedCalcs = [
  { name: "Aquarium Water Change", url: "/aquarium-water-change-calculator", description: "Water change volume and frequency." },
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume and weight." },
  { name: "Fish Tank Stocking", url: "/fish-tank-stocking-calculator", description: "Fish stocking capacity calculator." },
  { name: "Aquarium CO2", url: "/aquarium-co2-calculator", description: "CO2 injection rate for planted tanks." },
  { name: "Aquarium Medication", url: "/aquarium-medication-calculator", description: "Fish medication dosing calculator." },
  { name: "Aquarium Heater", url: "/aquarium-heater-calculator", description: "Heater wattage for your tank." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Nitrogen Cycle Calculator" keywords="aquarium nitrogen cycle, fish tank cycling, ammonia nitrite nitrate, aquarium cycle tracker, fishless cycling" breadcrumbs={[{ name: "Aquarium Nitrogen Cycle", url: "/aquarium-nitrogen-cycle-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Nitrogen Cycle Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Enter your water test readings to determine where you are in the nitrogen cycle and when it is safe to add fish.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Ammonia (ppm)</label>
            <input type="number" id="anc-nh3" class="anc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.5" min="0" max="10" step="0.25">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Nitrite (ppm)</label>
            <input type="number" id="anc-no2" class="anc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.25" min="0" max="10" step="0.25">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Nitrate (ppm)</label>
            <input type="number" id="anc-no3" class="anc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0" max="200" step="5">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Days Since Start</label>
            <input type="number" id="anc-days" class="anc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="14" min="0" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">pH Level</label>
            <input type="number" id="anc-ph" class="anc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="7.2" min="5" max="9" step="0.1">
          </div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Cycle Stage</div>
          <div class="text-4xl font-extrabold font-mono" id="anc-result">--</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Safe for Fish?</div>
            <div class="text-xl font-bold font-mono" id="anc-safe">No</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Est. Days Remaining</div>
            <div class="text-xl font-bold font-mono" id="anc-remain">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Toxicity Level</div>
            <div class="text-xl font-bold font-mono" id="anc-toxic">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Action Needed</div>
            <div class="text-xl font-bold font-mono" id="anc-action">--</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-nitrogen-cycle" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcANC() {
      const nh3 = parseFloat((document.getElementById('anc-nh3') as HTMLInputElement).value) || 0;
      const no2 = parseFloat((document.getElementById('anc-no2') as HTMLInputElement).value) || 0;
      const no3 = parseFloat((document.getElementById('anc-no3') as HTMLInputElement).value) || 0;
      const days = parseFloat((document.getElementById('anc-days') as HTMLInputElement).value) || 0;
      const ph = parseFloat((document.getElementById('anc-ph') as HTMLInputElement).value) || 7;
      let stage = '';
      let safe = 'No';
      let remain = '--';
      let toxic = 'Low';
      let action = 'Wait';
      if (nh3 === 0 && no2 === 0 && no3 === 0 && days < 3) {
        stage = 'Not Started';
        remain = '28-42 days';
        action = 'Add ammonia source';
      } else if (nh3 > 0 && no2 === 0 && no3 <= 5) {
        stage = 'Stage 1: Ammonia';
        remain = Math.max(7, 35 - days) + ' days';
        toxic = nh3 > 2 ? 'High' : nh3 > 0.5 ? 'Moderate' : 'Low';
        action = nh3 > 4 ? 'Water change' : 'Wait';
      } else if (nh3 > 0 && no2 > 0) {
        stage = 'Stage 2: Nitrite Rising';
        remain = Math.max(5, 28 - days) + ' days';
        toxic = 'Moderate';
        action = no2 > 5 ? 'Partial WC' : 'Wait';
      } else if (nh3 <= 0.25 && no2 > 0 && no3 > 0) {
        stage = 'Stage 3: Nitrite Peak';
        remain = Math.max(3, 21 - days) + ' days';
        toxic = no2 > 2 ? 'Moderate' : 'Low';
        action = 'Almost there';
      } else if (nh3 === 0 && no2 === 0 && no3 > 0) {
        stage = 'Cycled!';
        safe = 'Yes';
        remain = '0 days';
        toxic = 'None';
        action = no3 > 40 ? 'Water change' : 'Add fish slowly';
      } else {
        stage = 'In Progress';
        remain = Math.max(3, 30 - days) + ' days';
        toxic = (nh3 + no2) > 2 ? 'Moderate' : 'Low';
        action = 'Keep testing';
      }
      document.getElementById('anc-result')!.textContent = stage;
      document.getElementById('anc-safe')!.textContent = safe;
      document.getElementById('anc-remain')!.textContent = remain;
      document.getElementById('anc-toxic')!.textContent = toxic;
      document.getElementById('anc-action')!.textContent = action;
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.anc-in').forEach(el => { el.addEventListener('input', calcANC); el.addEventListener('change', calcANC); });
      calcANC();
    }, 50);
  </script>
</CalculatorLayout>
