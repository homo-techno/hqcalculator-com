---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Homeschool Cost Calculator - Annual Homeschooling Budget Estimator";
const description = "Estimate your annual homeschool budget including curriculum, materials, activities, and co-ops. Compare homeschool costs to traditional schooling options.";

const relatedCalcs = [
  { name: "School Supply Calculator", url: "/school-supply-calculator", description: "School supplies." },
  { name: "Tutoring Cost Calculator", url: "/tutoring-cost-calculator", description: "Tutoring costs." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare costs." },
  { name: "College Fund Calculator", url: "/college-fund-calculator", description: "College savings." },
  { name: "Budget Calculator", url: "/budget-calculator", description: "Family budget." },
  { name: "Allowance Calculator", url: "/allowance-calculator", description: "Kids allowance." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Homeschool Cost Calculator"
  keywords="homeschool cost calculator, homeschool budget, cost of homeschooling, homeschool curriculum cost, homeschool expenses"
  breadcrumbs={[{ name: "Homeschool Cost Calculator", url: "/homeschool-cost-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Homeschool Cost Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate your annual homeschooling budget including curriculum, supplies, activities, and more.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Students</label>
          <input type="number" id="hsc-students" class="hsc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="1" max="10" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Grade Level</label>
          <select id="hsc-grade" class="hsc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="elem" selected>Elementary (K-5)</option>
            <option value="middle">Middle School (6-8)</option>
            <option value="high">High School (9-12)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Curriculum Type</label>
          <select id="hsc-curriculum" class="hsc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="free">Free/Open Source Resources</option>
            <option value="budget">Budget Curriculum ($200-$400)</option>
            <option value="standard" selected>Standard Boxed Curriculum ($500-$900)</option>
            <option value="online">Online Academy ($1,000-$3,000)</option>
            <option value="premium">Premium / Custom ($2,000+)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Include Extracurriculars?</label>
          <select id="hsc-extra" class="hsc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="none">No Extracurriculars</option>
            <option value="basic" selected>Basic (1-2 activities)</option>
            <option value="moderate">Moderate (3-4 activities)</option>
            <option value="full">Full Schedule (5+ activities)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Co-op / Group Classes</label>
          <select id="hsc-coop" class="hsc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="none">None</option>
            <option value="free">Free Co-op</option>
            <option value="paid" selected>Paid Co-op ($50-$150/mo)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Field Trip Budget (monthly)</label>
          <input type="number" id="hsc-trips" class="hsc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="50" min="0" max="500" step="10">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Annual Cost</div>
        <div class="text-5xl font-extrabold" id="hsc-total">--</div>
        <div class="text-sm text-blue-200 mt-1" id="hsc-per">per student per year</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Monthly Cost</div>
          <div class="text-lg font-bold" id="hsc-monthly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Per Student</div>
          <div class="text-lg font-bold" id="hsc-perstudent">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">vs Public School Avg</div>
          <div class="text-lg font-bold" id="hsc-compare">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Curriculum Cost</div>
          <div class="text-lg font-bold" id="hsc-currcost">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Cost Breakdown</h3>
        <div class="text-xs" id="hsc-breakdown"></div>
      </div>

      <ShareButton calculatorId="homeschool-cost" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">What Does Homeschooling Cost?</h2>
      <p>Homeschooling costs range from nearly free to $5,000+ per student per year. The national average is $700-$1,800 per student annually, not counting the opportunity cost of a parent's time.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Where the Money Goes</h3>
      <ul>
        <li><strong>Curriculum:</strong> $0-$3,000+ depending on approach</li>
        <li><strong>Supplies:</strong> $100-$500 for books, art materials, science kits</li>
        <li><strong>Extracurriculars:</strong> $500-$3,000 for sports, music, art classes</li>
        <li><strong>Co-ops:</strong> $0-$1,800 per year for group learning</li>
        <li><strong>Field Trips:</strong> $200-$1,200 per year</li>
        <li><strong>Technology:</strong> $0-$500 for computer, printer, software</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Ways to Save</h3>
      <ul>
        <li>Use free online resources (Khan Academy, library databases)</li>
        <li>Buy used curriculum from homeschool swap groups</li>
        <li>Share resources with other homeschool families</li>
        <li>Take advantage of free museum and park programs</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcHSC() {
      const students = parseFloat((document.getElementById('hsc-students') as HTMLInputElement).value) || 1;
      const grade = (document.getElementById('hsc-grade') as HTMLSelectElement).value;
      const curriculum = (document.getElementById('hsc-curriculum') as HTMLSelectElement).value;
      const extra = (document.getElementById('hsc-extra') as HTMLSelectElement).value;
      const coop = (document.getElementById('hsc-coop') as HTMLSelectElement).value;
      const trips = parseFloat((document.getElementById('hsc-trips') as HTMLInputElement).value) || 0;

      const curriculumCost: Record<string, number> = {
        free: 50, budget: 300, standard: 700, online: 2000, premium: 3000
      };

      const gradeMult: Record<string, number> = { elem: 1.0, middle: 1.15, high: 1.3 };

      const extraCost: Record<string, number> = {
        none: 0, basic: 1200, moderate: 2400, full: 4000
      };

      const coopCost: Record<string, number> = {
        none: 0, free: 50, paid: 1200
      };

      // Per student costs
      const supplies = grade === 'high' ? 350 : grade === 'middle' ? 250 : 150;
      const tech = grade === 'high' ? 200 : 100;
      const testing = grade === 'high' ? 100 : 30;
      const currCost = curriculumCost[curriculum] * gradeMult[grade];

      interface CostItem { name: string; amount: number; }
      const breakdown: CostItem[] = [
        { name: 'Curriculum', amount: currCost },
        { name: 'Supplies & Materials', amount: supplies },
        { name: 'Technology', amount: tech },
        { name: 'Extracurriculars', amount: extraCost[extra] },
        { name: 'Co-op / Group Classes', amount: coopCost[coop] },
        { name: 'Field Trips', amount: trips * 10 },
        { name: 'Testing & Assessment', amount: testing },
      ];

      const perStudent = breakdown.reduce((sum, item) => sum + item.amount, 0);
      // Sibling discount on curriculum
      const sibDiscount = students > 1 ? 0.7 : 1;
      const total = Math.round(perStudent + (students - 1) * perStudent * sibDiscount);
      const monthly = Math.round(total / 12);

      // Public school comparison (taxpayer cost per student ~$13,000 but family out-of-pocket ~$1,200)
      const publicSchoolOOP = 1200;
      const diff = total - publicSchoolOOP * students;
      const compareText = diff > 0 ? '$' + Math.abs(diff).toLocaleString() + ' more' : '$' + Math.abs(diff).toLocaleString() + ' less';

      document.getElementById('hsc-total')!.textContent = '$' + total.toLocaleString();
      document.getElementById('hsc-per')!.textContent = students + ' student' + (students > 1 ? 's' : '') + ' - annual estimate';
      document.getElementById('hsc-monthly')!.textContent = '$' + monthly.toLocaleString();
      document.getElementById('hsc-perstudent')!.textContent = '$' + Math.round(total / students).toLocaleString();
      document.getElementById('hsc-compare')!.textContent = compareText;
      document.getElementById('hsc-currcost')!.textContent = '$' + Math.round(currCost).toLocaleString();

      document.getElementById('hsc-breakdown')!.innerHTML =
        '<div class="grid grid-cols-3 gap-2 font-semibold text-text-muted mb-1"><span>Category</span><span class="text-right">Per Student</span><span class="text-right">Total</span></div>' +
        breakdown.map(item => {
          const totalItem = item.name === 'Curriculum' ? Math.round(item.amount * (1 + (students - 1) * sibDiscount)) : Math.round(item.amount * students);
          return `<div class="grid grid-cols-3 gap-2 py-1"><span>${item.name}</span><span class="text-right">$${Math.round(item.amount).toLocaleString()}</span><span class="text-right font-semibold">$${totalItem.toLocaleString()}</span></div>`;
        }).join('') +
        `<div class="grid grid-cols-3 gap-2 py-1 mt-1 border-t border-border font-bold"><span>Total</span><span class="text-right">$${Math.round(perStudent).toLocaleString()}</span><span class="text-right">$${total.toLocaleString()}</span></div>`;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.hsc-in').forEach(el => {
        el.addEventListener('input', calcHSC);
        el.addEventListener('change', calcHSC);
      });
      calcHSC();
    }, 50);
  </script>
</CalculatorLayout>
