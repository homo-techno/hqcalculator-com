---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Sump Calculator - Sizing, Baffles & Return Pump";
const description = "Calculate sump dimensions, baffle placement, chamber volumes, and return pump sizing for your aquarium filtration system.";
const relatedCalcs = [
  { name: "Aquarium Flow Rate", url: "/aquarium-flow-rate-calculator", description: "Flow rate and pump sizing." },
  { name: "Reef Tank", url: "/reef-tank-calculator", description: "Reef tank parameter dosing." },
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume." },
  { name: "Aquarium Stand", url: "/aquarium-stand-calculator", description: "Stand load capacity." },
  { name: "Live Rock", url: "/live-rock-calculator", description: "Live rock quantity calculator." },
  { name: "Aquarium Evaporation", url: "/aquarium-evaporation-calculator", description: "Water evaporation rate." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Sump Calculator" keywords="aquarium sump calculator, sump sizing, baffle placement, return pump, sump chamber, reef sump" breadcrumbs={[{ name: "Aquarium Sump", url: "/aquarium-sump-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Sump Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Design your sump with proper chamber sizing, baffle placement, and return pump selection.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-text mb-1">Display Tank Volume (gallons)</label>
          <input type="number" id="asm-tank" class="asm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="75" min="10" step="5">
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Sump Length (in)</label>
            <input type="number" id="asm-len" class="asm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="36" min="12" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Sump Width (in)</label>
            <input type="number" id="asm-wid" class="asm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="8" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Sump Height (in)</label>
            <input type="number" id="asm-hgt" class="asm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="16" min="8" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Operating Water Level (in)</label>
            <input type="number" id="asm-level" class="asm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="4" max="15" step="0.5">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Head Height to Tank (ft)</label>
            <input type="number" id="asm-head" class="asm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" max="10" step="0.5">
          </div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Sump Volume (operating)</div>
          <div class="text-5xl font-extrabold font-mono" id="asm-result">0 gal</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Drain Chamber</div>
            <div class="text-xl font-bold font-mono" id="asm-drain">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Refugium/Media</div>
            <div class="text-xl font-bold font-mono" id="asm-fuge">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Return Chamber</div>
            <div class="text-xl font-bold font-mono" id="asm-return">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Return Pump (rated)</div>
            <div class="text-xl font-bold font-mono" id="asm-pump">0 GPH</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-sump" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcASM() {
      const tankVol = parseFloat((document.getElementById('asm-tank') as HTMLInputElement).value) || 0;
      const len = parseFloat((document.getElementById('asm-len') as HTMLInputElement).value) || 0;
      const wid = parseFloat((document.getElementById('asm-wid') as HTMLInputElement).value) || 0;
      const hgt = parseFloat((document.getElementById('asm-hgt') as HTMLInputElement).value) || 0;
      const level = parseFloat((document.getElementById('asm-level') as HTMLInputElement).value) || 0;
      const head = parseFloat((document.getElementById('asm-head') as HTMLInputElement).value) || 0;
      // Operating volume
      const operatingGal = (len * wid * level) / 231;
      // Chamber proportions: drain 30%, refugium 40%, return 30%
      const drainGal = operatingGal * 0.30;
      const fugeGal = operatingGal * 0.40;
      const returnGal = operatingGal * 0.30;
      // Return pump: total system turnover 5-10x per hour
      // Target flow at display = tankVol * 5 GPH
      const targetFlow = tankVol * 5;
      // Account for head loss: ~10% per foot
      const headLoss = 1 + head * 0.10;
      const ratedPump = Math.ceil(targetFlow * headLoss);
      document.getElementById('asm-result')!.textContent = operatingGal.toFixed(1) + ' gal';
      document.getElementById('asm-drain')!.textContent = drainGal.toFixed(1) + ' gal';
      document.getElementById('asm-fuge')!.textContent = fugeGal.toFixed(1) + ' gal';
      document.getElementById('asm-return')!.textContent = returnGal.toFixed(1) + ' gal';
      document.getElementById('asm-pump')!.textContent = ratedPump + ' GPH';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.asm-in').forEach(el => { el.addEventListener('input', calcASM); el.addEventListener('change', calcASM); });
      calcASM();
    }, 50);
  </script>
</CalculatorLayout>
