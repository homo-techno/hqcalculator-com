---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Birthday Party Calculator - Party Budget Planner for Kids";
const description = "Plan your child's birthday party budget including venue, food, decorations, favors, and entertainment. Get cost estimates by party size and style.";

const relatedCalcs = [
  { name: "Allowance Calculator", url: "/allowance-calculator", description: "Kids allowance." },
  { name: "Budget Calculator", url: "/budget-calculator", description: "Family budget." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper costs." },
  { name: "School Supply Calculator", url: "/school-supply-calculator", description: "School costs." },
  { name: "Tip Calculator", url: "/tip-calculator", description: "Tipping guide." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Birthday Party Calculator"
  keywords="birthday party calculator, kids party budget, birthday party cost, party planning calculator, children birthday budget, party expense planner"
  breadcrumbs={[{ name: "Birthday Party Calculator", url: "/birthday-party-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Birthday Party Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Plan and budget your child's birthday party with detailed cost breakdowns.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Guests</label>
          <input type="number" id="bpc-guests" class="bpc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="15" min="3" max="50" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age</label>
          <input type="number" id="bpc-age" class="bpc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="1" max="18" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Venue</label>
          <select id="bpc-venue" class="bpc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="home" selected>Home / Backyard</option>
            <option value="park">Local Park (free)</option>
            <option value="restaurant">Restaurant / Pizza Place</option>
            <option value="activity">Activity Venue (trampoline, bowling)</option>
            <option value="premium">Premium Venue (party hall, farm)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Food & Drinks</label>
          <select id="bpc-food" class="bpc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="simple">Simple (cake & snacks)</option>
            <option value="pizza" selected>Pizza & Drinks</option>
            <option value="catered">Catered Meal</option>
            <option value="full">Full Spread (appetizers, meal, dessert)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Entertainment</label>
          <select id="bpc-entertain" class="bpc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="diy" selected>DIY Games & Activities</option>
            <option value="character">Character / Face Painter</option>
            <option value="performer">Magician / Performer</option>
            <option value="bounce">Bounce House Rental</option>
            <option value="none">No Entertainment</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Decorations Level</label>
          <select id="bpc-decor" class="bpc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="minimal">Minimal (basic balloons)</option>
            <option value="standard" selected>Standard (themed)</option>
            <option value="elaborate">Elaborate (custom setup)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Party Favors</label>
          <select id="bpc-favors" class="bpc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="none">None</option>
            <option value="simple" selected>Simple Goodie Bags ($3-5 each)</option>
            <option value="medium">Medium Quality ($5-10 each)</option>
            <option value="premium">Premium ($10-15 each)</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Party Budget</div>
        <div class="text-5xl font-extrabold" id="bpc-total">--</div>
        <div class="text-sm text-blue-200 mt-1" id="bpc-perguest">per guest cost</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Venue Cost</div>
          <div class="text-lg font-bold" id="bpc-venuecost">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Food & Cake</div>
          <div class="text-lg font-bold" id="bpc-foodcost">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Entertainment</div>
          <div class="text-lg font-bold" id="bpc-entertaincost">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Decor & Favors</div>
          <div class="text-lg font-bold" id="bpc-decorcost">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Detailed Breakdown</h3>
        <div class="text-xs" id="bpc-breakdown"></div>
      </div>

      <ShareButton calculatorId="birthday-party" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Planning a Birthday Party Budget</h2>
      <p>The average children's birthday party costs $300-$500, but can range from $100 for a simple home party to $1,000+ for a premium venue experience. The key is setting a budget and prioritizing what matters most to your child.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Budget-Friendly Tips</h3>
      <ul>
        <li>Host at home or a free public park</li>
        <li>Make your own decorations and cake</li>
        <li>Plan DIY games instead of hiring entertainment</li>
        <li>Keep the guest list manageable (a common rule: child's age + 1)</li>
        <li>Shop dollar stores for party supplies and favors</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Average Party Costs by Age</h3>
      <ul>
        <li><strong>1-3 years:</strong> $100-$300 (smaller, simpler parties)</li>
        <li><strong>4-7 years:</strong> $200-$500 (themed parties, more guests)</li>
        <li><strong>8-12 years:</strong> $300-$700 (activity-based parties)</li>
        <li><strong>13+ years:</strong> $200-$800 (outings, experiences)</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcBPC() {
      const guests = parseFloat((document.getElementById('bpc-guests') as HTMLInputElement).value) || 15;
      const age = parseFloat((document.getElementById('bpc-age') as HTMLInputElement).value) || 6;
      const venue = (document.getElementById('bpc-venue') as HTMLSelectElement).value;
      const food = (document.getElementById('bpc-food') as HTMLSelectElement).value;
      const entertain = (document.getElementById('bpc-entertain') as HTMLSelectElement).value;
      const decor = (document.getElementById('bpc-decor') as HTMLSelectElement).value;
      const favors = (document.getElementById('bpc-favors') as HTMLSelectElement).value;

      // Venue costs
      const venueCosts: Record<string, number> = {
        home: 0, park: 0, restaurant: 8 * guests, activity: 20 * guests, premium: 300 + 15 * guests
      };

      // Food per person
      const foodPerPerson: Record<string, number> = {
        simple: 3, pizza: 6, catered: 15, full: 22
      };
      const cakeCost = guests <= 15 ? 30 : guests <= 25 ? 50 : 75;

      // Entertainment
      const entertainCosts: Record<string, number> = {
        diy: 20, character: 175, performer: 250, bounce: 200, none: 0
      };

      // Decorations
      const decorCosts: Record<string, number> = {
        minimal: 20, standard: 60, elaborate: 150
      };

      // Favors per guest
      const favorPerGuest: Record<string, number> = {
        none: 0, simple: 4, medium: 7.5, premium: 12.5
      };

      // Invitations
      const invitations = guests <= 10 ? 10 : 20;

      interface CostItem { name: string; amount: number; }
      const items: CostItem[] = [
        { name: 'Venue', amount: venueCosts[venue] },
        { name: 'Food & Drinks', amount: foodPerPerson[food] * guests },
        { name: 'Birthday Cake', amount: cakeCost },
        { name: 'Entertainment', amount: entertainCosts[entertain] },
        { name: 'Decorations', amount: decorCosts[decor] },
        { name: 'Party Favors', amount: favorPerGuest[favors] * guests },
        { name: 'Invitations', amount: invitations },
        { name: 'Plates/Cups/Napkins', amount: Math.ceil(guests / 8) * 5 },
      ];

      const total = items.reduce((s, i) => s + i.amount, 0);
      const perGuest = total / guests;

      const venueTot = venueCosts[venue];
      const foodTot = foodPerPerson[food] * guests + cakeCost;
      const entertainTot = entertainCosts[entertain];
      const decorTot = decorCosts[decor] + favorPerGuest[favors] * guests;

      document.getElementById('bpc-total')!.textContent = '$' + Math.round(total).toLocaleString();
      document.getElementById('bpc-perguest')!.textContent = '$' + perGuest.toFixed(0) + ' per guest';
      document.getElementById('bpc-venuecost')!.textContent = '$' + Math.round(venueTot);
      document.getElementById('bpc-foodcost')!.textContent = '$' + Math.round(foodTot);
      document.getElementById('bpc-entertaincost')!.textContent = '$' + Math.round(entertainTot);
      document.getElementById('bpc-decorcost')!.textContent = '$' + Math.round(decorTot);

      document.getElementById('bpc-breakdown')!.innerHTML =
        '<div class="grid grid-cols-2 gap-2 font-semibold text-text-muted mb-1"><span>Item</span><span class="text-right">Cost</span></div>' +
        items.map(i => `<div class="grid grid-cols-2 gap-2 py-1"><span>${i.name}</span><span class="text-right font-semibold">$${Math.round(i.amount)}</span></div>`).join('') +
        `<div class="grid grid-cols-2 gap-2 py-1 mt-1 border-t border-border font-bold"><span>Total</span><span class="text-right">$${Math.round(total)}</span></div>`;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.bpc-in').forEach(el => {
        el.addEventListener('input', calcBPC);
        el.addEventListener('change', calcBPC);
      });
      calcBPC();
    }, 50);
  </script>
</CalculatorLayout>
