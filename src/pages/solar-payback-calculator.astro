---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Solar Payback Calculator - Panel System ROI & Lifetime Savings";
const description = "Calculate your solar panel system payback period and lifetime savings based on system cost, energy production, electricity rates, and incentives.";
const relatedCalcs = [
  { name: "Solar Panel", url: "/solar-panel-calculator", description: "Solar panel sizing." },
  { name: "Solar Battery", url: "/solar-battery-calculator", description: "Battery storage." },
  { name: "Net Metering", url: "/net-metering-calculator", description: "Net metering credits." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "ROI Calculator", url: "/roi-calculator", description: "Return on investment." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Solar Payback Calculator" keywords="solar payback period, solar panel ROI, solar savings calculator, solar investment, solar panel payback time" breadcrumbs={[{ name: "Solar Payback", url: "/solar-payback-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Solar Payback Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate how quickly your solar panel investment pays for itself and total lifetime savings.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">System Details</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">System Size (kW)</label><input type="number" id="spb-kw" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" max="50" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Total Cost ($)</label><input type="number" id="spb-cost" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="24000" min="0" step="500"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Sun Hours/Day</label><input type="number" id="spb-sun" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="10" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">System Efficiency (%)</label><input type="number" id="spb-eff" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="80" min="50" max="100" step="1"></div>
        </div>
        <h3 class="font-semibold text-text">Financial</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Electricity Rate ($/kWh)</label><input type="number" id="spb-rate" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.14" min="0.01" max="1" step="0.01"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Annual Rate Increase (%)</label><input type="number" id="spb-esc" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0" max="10" step="0.5"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Federal Tax Credit (%)</label><input type="number" id="spb-itc" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="0" max="50" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Other Rebates ($)</label><input type="number" id="spb-rebate" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" step="100"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">System Lifespan (years)</label><input type="number" id="spb-life" class="spb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="25" min="10" max="40" step="1"></div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Payback Period</div>
          <div class="text-4xl font-extrabold" id="spb-payback">0</div>
          <div class="text-sm text-blue-200 mt-1">years</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Net Cost After Credits</div><div class="text-xl font-bold" id="spb-net">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Production</div><div class="text-xl font-bold" id="spb-prod">0 kWh</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Year 1 Savings</div><div class="text-xl font-bold" id="spb-y1">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Lifetime Savings</div><div class="text-xl font-bold" id="spb-lifetime">$0</div></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Lifetime ROI</div>
          <div class="text-2xl font-bold" id="spb-roi">0%</div>
        </div>
      </div>
      <ShareButton calculatorId="solar-payback" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Solar Payback</h2>
      <p>The solar payback period is the time it takes for your cumulative energy savings to equal your net investment. Factors include system size, local sun hours, electricity rates, rate escalation, and available incentives like the federal Investment Tax Credit (ITC). Most residential systems pay back in 6-12 years with 25+ year lifespans, yielding significant net savings.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcSPB() {
      const kw = parseFloat((document.getElementById('spb-kw') as HTMLInputElement).value) || 8;
      const cost = parseFloat((document.getElementById('spb-cost') as HTMLInputElement).value) || 0;
      const sun = parseFloat((document.getElementById('spb-sun') as HTMLInputElement).value) || 5;
      const eff = parseFloat((document.getElementById('spb-eff') as HTMLInputElement).value) || 80;
      const rate = parseFloat((document.getElementById('spb-rate') as HTMLInputElement).value) || 0.14;
      const esc = parseFloat((document.getElementById('spb-esc') as HTMLInputElement).value) || 0;
      const itc = parseFloat((document.getElementById('spb-itc') as HTMLInputElement).value) || 0;
      const rebate = parseFloat((document.getElementById('spb-rebate') as HTMLInputElement).value) || 0;
      const life = parseFloat((document.getElementById('spb-life') as HTMLInputElement).value) || 25;
      const annualKWh = kw * sun * 365 * (eff / 100);
      const netCost = cost * (1 - itc / 100) - rebate;
      const y1Savings = annualKWh * rate;
      let cumSavings = 0;
      let payback = life;
      let totalSavings = 0;
      for (let y = 1; y <= life; y++) {
        const curRate = rate * Math.pow(1 + esc / 100, y - 1);
        const degraded = annualKWh * (1 - 0.005 * (y - 1));
        const ySavings = degraded * curRate;
        cumSavings += ySavings;
        totalSavings += ySavings;
        if (cumSavings >= netCost && payback === life) {
          payback = y - 1 + (netCost - (cumSavings - ySavings)) / ySavings;
        }
      }
      const roi = netCost > 0 ? ((totalSavings - netCost) / netCost * 100) : 0;
      document.getElementById('spb-payback')!.textContent = payback < life ? payback.toFixed(1) : 'N/A';
      document.getElementById('spb-net')!.textContent = '$' + Math.round(netCost).toLocaleString();
      document.getElementById('spb-prod')!.textContent = Math.round(annualKWh).toLocaleString() + ' kWh';
      document.getElementById('spb-y1')!.textContent = '$' + Math.round(y1Savings).toLocaleString();
      document.getElementById('spb-lifetime')!.textContent = '$' + Math.round(totalSavings).toLocaleString();
      document.getElementById('spb-roi')!.textContent = roi.toFixed(0) + '%';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.spb-in').forEach(el => { el.addEventListener('input', calcSPB); el.addEventListener('change', calcSPB); }); calcSPB(); }, 50);
  </script>
</CalculatorLayout>
