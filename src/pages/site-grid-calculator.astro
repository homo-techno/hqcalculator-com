---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Site Grid Calculator - Archaeological Grid Layout & Unit Numbering";
const description = "Plan archaeological site grid layouts with unit numbering, calculate total units, excavation area coverage, and generate grid coordinates.";
const relatedCalcs = [
  { name: "Excavation Volume", url: "/excavation-volume-calculator", description: "Dig unit volume." },
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Survey Coverage", url: "/survey-coverage-calculator", description: "Survey sampling." },
  { name: "Site Catchment", url: "/site-catchment-calculator", description: "Territory analysis." },
  { name: "Square Footage", url: "/square-footage-calculator", description: "Area calculations." },
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Site Grid Calculator" keywords="archaeological grid, site layout, unit numbering, excavation grid, site planning, grid coordinates, datum point" breadcrumbs={[{ name: "Site Grid", url: "/site-grid-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Site Grid Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Plan an archaeological site grid system. Calculate total units, coverage area, and generate grid coordinates from a datum point.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Site Length N-S (m)</label>
            <input type="number" id="sgr-nslen" class="sgr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="50" min="1" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Site Width E-W (m)</label>
            <input type="number" id="sgr-ewlen" class="sgr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="1" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Unit Size (m)</label>
            <input type="number" id="sgr-unit" class="sgr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="0.5" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Baulk Width (cm)</label>
            <input type="number" id="sgr-baulk" class="sgr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" step="5">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Sampling Strategy</label>
          <select id="sgr-strategy" class="sgr-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="100">Full Excavation (100%)</option>
            <option value="50">Checkerboard (50%)</option>
            <option value="25">Quarter Sample (25%)</option>
            <option value="10">10% Random Sample</option>
            <option value="5">5% Random Sample</option>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Datum Northing (m)</label>
            <input type="number" id="sgr-datn" class="sgr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="500" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Datum Easting (m)</label>
            <input type="number" id="sgr-date" class="sgr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="500" step="1">
          </div>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Grid Units</div>
          <div class="text-4xl font-extrabold" id="sgr-total">0</div>
          <div class="text-sm text-blue-200 mt-1" id="sgr-dims">--</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Units to Excavate</div>
            <div class="text-xl font-bold" id="sgr-excavate">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Site Area</div>
            <div class="text-xl font-bold" id="sgr-area">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Excavation Area</div>
            <div class="text-xl font-bold" id="sgr-excarea">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Grid Range</div>
            <div class="text-sm font-bold" id="sgr-range">--</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Rows (N-S)</div>
            <div class="text-xl font-bold" id="sgr-rows">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Columns (E-W)</div>
            <div class="text-xl font-bold" id="sgr-cols">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="site-grid" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Archaeological Grid Systems</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Units N-S</strong> = Site Length / (Unit Size + Baulk Width)</p>
        <p><strong>Units E-W</strong> = Site Width / (Unit Size + Baulk Width)</p>
        <p><strong>Total Units</strong> = Rows * Columns</p>
        <p><strong>Units to Dig</strong> = Total * Sample Fraction</p>
      </div>
      <p>Archaeological sites are divided into grid systems referenced to a datum point. Units are typically 1x1m or 2x2m. Baulks (unexcavated walls between units) preserve stratigraphic profiles. Sampling strategies balance coverage against time and cost.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSGR() {
      const nsLen = parseFloat((document.getElementById('sgr-nslen') as HTMLInputElement).value) || 0;
      const ewLen = parseFloat((document.getElementById('sgr-ewlen') as HTMLInputElement).value) || 0;
      const unitSize = parseFloat((document.getElementById('sgr-unit') as HTMLInputElement).value) || 1;
      const baulkCm = parseFloat((document.getElementById('sgr-baulk') as HTMLInputElement).value) || 0;
      const samplePct = parseFloat((document.getElementById('sgr-strategy') as HTMLSelectElement).value) || 100;
      const datN = parseFloat((document.getElementById('sgr-datn') as HTMLInputElement).value) || 0;
      const datE = parseFloat((document.getElementById('sgr-date') as HTMLInputElement).value) || 0;

      const baulkM = baulkCm / 100;
      const cellSize = unitSize + baulkM;
      const rows = Math.floor(nsLen / cellSize);
      const cols = Math.floor(ewLen / cellSize);
      const totalUnits = rows * cols;
      const unitsToExcavate = Math.round(totalUnits * (samplePct / 100));
      const siteArea = nsLen * ewLen;
      const excArea = unitsToExcavate * unitSize * unitSize;

      const maxN = datN + nsLen;
      const maxE = datE + ewLen;
      const rangeStr = 'N' + datN + '-N' + maxN + ' / E' + datE + '-E' + maxE;

      document.getElementById('sgr-total')!.textContent = totalUnits.toLocaleString();
      document.getElementById('sgr-dims')!.textContent = rows + ' rows x ' + cols + ' columns (' + unitSize + 'm units)';
      document.getElementById('sgr-excavate')!.textContent = unitsToExcavate.toLocaleString();
      document.getElementById('sgr-area')!.textContent = siteArea.toLocaleString() + ' sq m';
      document.getElementById('sgr-excarea')!.textContent = excArea.toLocaleString() + ' sq m';
      document.getElementById('sgr-range')!.textContent = rangeStr;
      document.getElementById('sgr-rows')!.textContent = rows.toString();
      document.getElementById('sgr-cols')!.textContent = cols.toString();

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.sgr-in').forEach(el => { el.addEventListener('input', calcSGR); el.addEventListener('change', calcSGR); });
      calcSGR();
    }, 50);
  </script>
</CalculatorLayout>
