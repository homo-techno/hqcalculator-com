---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Carrying Capacity Calculator - Ancient Population Land Support";
const description = "Estimate the carrying capacity of land for ancient populations based on subsistence strategy, arable land, crop yield, and caloric requirements.";
const relatedCalcs = [
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
  { name: "Site Catchment", url: "/site-catchment-calculator", description: "Territory analysis." },
  { name: "Survey Coverage", url: "/survey-coverage-calculator", description: "Survey sampling." },
  { name: "Pollen Analysis", url: "/pollen-analysis-calculator", description: "Palynology." },
  { name: "Faunal Dating", url: "/faunal-dating-calculator", description: "Faunal assemblages." },
  { name: "Burial Analysis", url: "/burial-analysis-calculator", description: "Burial demographics." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Carrying Capacity Calculator" keywords="carrying capacity, land capacity, ancient population, subsistence, crop yield, caloric requirement, agricultural productivity, hunter gatherer" breadcrumbs={[{ name: "Carrying Capacity", url: "/carrying-capacity-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Carrying Capacity Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate how many people a given area of land could support under different subsistence strategies, from hunter-gathering to intensive agriculture.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Subsistence Strategy</label>
          <select id="cca-strategy" class="cca-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="hg">Hunter-Gatherer</option>
            <option value="hort">Horticulture (swidden/slash-and-burn)</option>
            <option value="agri" selected>Rain-Fed Agriculture</option>
            <option value="irrig">Irrigated Agriculture</option>
            <option value="pastoral">Pastoral Nomadism</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Land Area (sq km)</label>
          <input type="number" id="cca-area" class="cca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="100" min="0.1" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Percentage Arable/Usable (%)</label>
          <input type="number" id="cca-arable" class="cca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="1" max="100" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Crop Yield (kg/hectare/year)</label>
          <input type="number" id="cca-yield" class="cca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="800" min="10" step="10">
          <p class="text-xs text-text-muted mt-1">Typical ancient: Wheat 500-1000, Rice 1000-2000, Maize 600-1200</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Caloric Value (kcal/kg of crop)</label>
          <input type="number" id="cca-calkg" class="cca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3400" min="100" step="100">
          <p class="text-xs text-text-muted mt-1">Wheat ~3400, Rice ~3600, Maize ~3650, Potato ~770</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Daily Caloric Need (kcal/person)</label>
          <input type="number" id="cca-daily" class="cca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2200" min="1500" max="4000" step="100">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Fallow Factor (% of land fallow at any time)</label>
          <input type="number" id="cca-fallow" class="cca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="33" min="0" max="90" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Maximum Carrying Capacity</div>
          <div class="text-4xl font-extrabold" id="cca-pop">0</div>
          <div class="text-sm text-blue-200 mt-1">persons</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Effective Arable Land</div>
            <div class="text-xl font-bold" id="cca-effland">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Pop. Density</div>
            <div class="text-xl font-bold" id="cca-density">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Annual Production</div>
            <div class="text-xl font-bold" id="cca-production">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Calories per Year</div>
            <div class="text-xl font-bold" id="cca-totalcal">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Ha per Person</div>
            <div class="text-xl font-bold" id="cca-happ">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Sustainable Pop (80%)</div>
            <div class="text-xl font-bold" id="cca-sustain">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="carrying-capacity" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Carrying Capacity Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Effective Land</strong> = Total Area * (Arable% / 100) * (1 - Fallow% / 100)</p>
        <p><strong>Annual Production</strong> = Effective Ha * Yield (kg/ha)</p>
        <p><strong>Total Calories</strong> = Production * Cal/kg</p>
        <p><strong>Max Pop</strong> = Total Calories / (Daily Need * 365)</p>
      </div>
      <p>Carrying capacity represents the maximum population a given area can sustain under a specific subsistence system. Hunter-gatherers typically support 0.01-1 person/sq km, while intensive agriculture supports 50-200+ persons/sq km. Fallow periods, seed reserves, and loss factors reduce effective production. The sustainable population (80% of max) provides a buffer for poor harvests.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCCA() {
      const strategy = (document.getElementById('cca-strategy') as HTMLSelectElement).value;
      const areaSqKm = parseFloat((document.getElementById('cca-area') as HTMLInputElement).value) || 0;
      const arablePct = parseFloat((document.getElementById('cca-arable') as HTMLInputElement).value) || 0;
      let yieldKgHa = parseFloat((document.getElementById('cca-yield') as HTMLInputElement).value) || 0;
      const calPerKg = parseFloat((document.getElementById('cca-calkg') as HTMLInputElement).value) || 0;
      const dailyCal = parseFloat((document.getElementById('cca-daily') as HTMLInputElement).value) || 2200;
      const fallowPct = parseFloat((document.getElementById('cca-fallow') as HTMLInputElement).value) || 0;

      const areaHa = areaSqKm * 100;
      const arableHa = areaHa * (arablePct / 100);
      const effectiveHa = arableHa * (1 - fallowPct / 100);

      let maxPop = 0;
      if (strategy === 'hg') {
        maxPop = areaSqKm * 0.1;
      } else if (strategy === 'pastoral') {
        maxPop = areaSqKm * 2;
      } else {
        const totalProduction = effectiveHa * yieldKgHa;
        const totalCalories = totalProduction * calPerKg;
        const annualNeed = dailyCal * 365;
        maxPop = annualNeed > 0 ? totalCalories / annualNeed : 0;
      }

      const totalProduction = effectiveHa * yieldKgHa;
      const totalCalories = totalProduction * calPerKg;
      const density = areaSqKm > 0 ? maxPop / areaSqKm : 0;
      const haPerPerson = maxPop > 0 ? effectiveHa / maxPop : 0;
      const sustainPop = maxPop * 0.8;

      let prodStr = '';
      if (totalProduction >= 1e6) prodStr = (totalProduction / 1e6).toFixed(1) + 'M kg';
      else if (totalProduction >= 1000) prodStr = (totalProduction / 1000).toFixed(1) + 'k kg';
      else prodStr = totalProduction.toFixed(0) + ' kg';

      let calStr = '';
      if (totalCalories >= 1e9) calStr = (totalCalories / 1e9).toFixed(1) + 'B kcal';
      else if (totalCalories >= 1e6) calStr = (totalCalories / 1e6).toFixed(1) + 'M kcal';
      else calStr = Math.round(totalCalories).toLocaleString() + ' kcal';

      document.getElementById('cca-pop')!.textContent = Math.round(maxPop).toLocaleString();
      document.getElementById('cca-effland')!.textContent = effectiveHa.toFixed(0) + ' ha';
      document.getElementById('cca-density')!.textContent = density.toFixed(1) + ' /sq km';
      document.getElementById('cca-production')!.textContent = prodStr;
      document.getElementById('cca-totalcal')!.textContent = calStr;
      document.getElementById('cca-happ')!.textContent = haPerPerson.toFixed(2);
      document.getElementById('cca-sustain')!.textContent = Math.round(sustainPop).toLocaleString();

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.cca-in').forEach(el => { el.addEventListener('input', calcCCA); el.addEventListener('change', calcCCA); });
      calcCCA();
    }, 50);
  </script>
</CalculatorLayout>
