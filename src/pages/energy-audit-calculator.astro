---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Energy Audit Calculator - Home Energy Scoring & Savings Potential";
const description = "Score your home's energy efficiency and identify savings potential from insulation, HVAC, lighting, and appliance improvements.";
const relatedCalcs = [
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "Insulation ROI", url: "/insulation-roi-calculator", description: "Insulation savings." },
  { name: "Heat Pump", url: "/heat-pump-efficiency-calculator", description: "Heat pump COP." },
  { name: "LED Savings", url: "/led-savings-calculator", description: "Lighting savings." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Passive House", url: "/passive-house-calculator", description: "Passive design." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Energy Audit Calculator" keywords="home energy audit calculator, energy efficiency score, energy savings potential, home energy assessment, energy audit scoring" breadcrumbs={[{ name: "Energy Audit", url: "/energy-audit-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Energy Audit Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Score your home's energy performance and identify savings opportunities.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Current Energy Use</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Monthly Electric Bill ($)</label><input type="number" id="ea2-elec" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="150" min="0" step="10"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Monthly Gas Bill ($)</label><input type="number" id="ea2-gas" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="80" min="0" step="10"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Home Size (sq ft)</label><input type="number" id="ea2-sqft" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2000" min="500" max="10000" step="100"></div>
        <h3 class="font-semibold text-text">Building Envelope</h3>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Insulation Quality</label>
            <select id="ea2-insul" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">Excellent (well-sealed)</option>
              <option value="2" selected>Average</option>
              <option value="1">Poor / None</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Window Type</label>
            <select id="ea2-windows" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">Triple pane / Low-E</option>
              <option value="2" selected>Double pane</option>
              <option value="1">Single pane</option>
            </select>
          </div>
        </div>
        <h3 class="font-semibold text-text">Systems</h3>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">HVAC System</label>
            <select id="ea2-hvac" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">Heat pump (high-eff)</option>
              <option value="2" selected>Central A/C + Gas furnace</option>
              <option value="1">Window units / Old furnace</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Water Heater</label>
            <select id="ea2-wh" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">Heat pump water heater</option>
              <option value="2" selected>Standard tank (gas/electric)</option>
              <option value="1">Old / Inefficient</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Lighting</label>
            <select id="ea2-light" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">100% LED</option>
              <option value="2" selected>Mixed LED/CFL</option>
              <option value="1">Mostly incandescent</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Appliance Age</label>
            <select id="ea2-appl" class="ea2-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3">EnergyStar (under 5 yrs)</option>
              <option value="2" selected>Average (5-15 yrs)</option>
              <option value="1">Old (15+ yrs)</option>
            </select>
          </div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Energy Efficiency Score</div>
          <div class="text-4xl font-extrabold" id="ea2-score">0</div>
          <div class="text-sm text-blue-200 mt-1" id="ea2-grade">Calculating...</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Energy Cost</div><div class="text-xl font-bold" id="ea2-annual">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Cost per Sq Ft</div><div class="text-xl font-bold" id="ea2-persqft">$0</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Potential Savings</div><div class="text-xl font-bold" id="ea2-savings">$0/yr</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">CO₂ Reduction</div><div class="text-xl font-bold" id="ea2-co2">0 lbs/yr</div></div>
        </div>
      </div>
      <ShareButton calculatorId="energy-audit" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Home Energy Audits</h2>
      <p>A home energy audit evaluates how efficiently your home uses energy. Key areas include the building envelope (insulation, windows, air sealing), HVAC systems, water heating, lighting, and appliances. Professional audits use blower door tests and thermal imaging. The average U.S. home spends about $1.50 per square foot annually on energy. Upgrades can typically reduce energy costs by 20-40%.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcEA2() {
      const elec = parseFloat((document.getElementById('ea2-elec') as HTMLInputElement).value) || 0;
      const gas = parseFloat((document.getElementById('ea2-gas') as HTMLInputElement).value) || 0;
      const sqft = parseFloat((document.getElementById('ea2-sqft') as HTMLInputElement).value) || 2000;
      const insul = parseInt((document.getElementById('ea2-insul') as HTMLSelectElement).value) || 2;
      const windows = parseInt((document.getElementById('ea2-windows') as HTMLSelectElement).value) || 2;
      const hvac = parseInt((document.getElementById('ea2-hvac') as HTMLSelectElement).value) || 2;
      const wh = parseInt((document.getElementById('ea2-wh') as HTMLSelectElement).value) || 2;
      const light = parseInt((document.getElementById('ea2-light') as HTMLSelectElement).value) || 2;
      const appl = parseInt((document.getElementById('ea2-appl') as HTMLSelectElement).value) || 2;
      const annualCost = (elec + gas) * 12;
      const perSqft = sqft > 0 ? annualCost / sqft : 0;
      const rawScore = (insul + windows + hvac + wh + light + appl);
      const maxScore = 18;
      const score = Math.round((rawScore / maxScore) * 100);
      let grade = 'Poor';
      if (score >= 90) grade = 'Excellent';
      else if (score >= 75) grade = 'Good';
      else if (score >= 55) grade = 'Average';
      else if (score >= 40) grade = 'Below Average';
      const savingsPercent = Math.max(0, (maxScore - rawScore) / maxScore * 0.4);
      const potentialSavings = annualCost * savingsPercent;
      const co2Reduction = potentialSavings / annualCost * (annualCost * 4.5);
      document.getElementById('ea2-score')!.textContent = score + '/100';
      document.getElementById('ea2-grade')!.textContent = grade;
      document.getElementById('ea2-annual')!.textContent = '$' + Math.round(annualCost).toLocaleString();
      document.getElementById('ea2-persqft')!.textContent = '$' + perSqft.toFixed(2);
      document.getElementById('ea2-savings')!.textContent = '$' + Math.round(potentialSavings).toLocaleString() + '/yr';
      document.getElementById('ea2-co2')!.textContent = Math.round(co2Reduction).toLocaleString() + ' lbs/yr';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.ea2-in').forEach(el => { el.addEventListener('input', calcEA2); el.addEventListener('change', calcEA2); }); calcEA2(); }, 50);
  </script>
</CalculatorLayout>
