---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Sealer Calculator - Coverage Rate & Coats Needed";
const description = "Calculate concrete sealer coverage rate, number of coats, and total gallons needed. Supports penetrating, acrylic, epoxy, and polyurethane sealers.";

const relatedCalcs = [
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume." },
  { name: "Concrete Color Calculator", url: "/concrete-color-calculator", description: "Color pigment." },
  { name: "Concrete Curing Calculator", url: "/concrete-curing-calculator", description: "Curing time." },
  { name: "Stucco Calculator", url: "/stucco-calculator", description: "Stucco materials." },
  { name: "Concrete Form Calculator", url: "/concrete-form-calculator", description: "Formwork estimator." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Sealer Calculator"
  keywords="concrete sealer, sealer coverage, penetrating sealer, acrylic sealer, epoxy sealer, sealer calculator, concrete protection"
  breadcrumbs={[{ name: "Concrete Sealer Calculator", url: "/concrete-sealer-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Sealer Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate concrete sealer quantity based on surface area, sealer type, and concrete porosity.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Length (ft)</label>
            <input type="number" id="cse-length" class="cse-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Width (ft)</label>
            <input type="number" id="cse-width" class="cse-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="1" step="0.5">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Sealer Type</label>
          <select id="cse-type" class="cse-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="penetrating" selected>Penetrating Silane/Siloxane</option>
            <option value="acrylic">Acrylic (Film-Forming)</option>
            <option value="epoxy">Epoxy Coating</option>
            <option value="polyurethane">Polyurethane Coating</option>
            <option value="densifier">Lithium Silicate Densifier</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Concrete Porosity / Texture</label>
          <select id="cse-porosity" class="cse-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="smooth">Smooth / Troweled (Low Porosity)</option>
            <option value="medium" selected>Broom Finish (Medium Porosity)</option>
            <option value="rough">Exposed Aggregate / Rough (High Porosity)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Number of Coats</label>
          <select id="cse-coats" class="cse-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="1">1 Coat</option>
            <option value="2" selected>2 Coats (Recommended)</option>
            <option value="3">3 Coats</option>
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Sealer Needed</div>
          <div class="text-4xl font-extrabold" id="cse-gallons">0 gallons</div>
          <div class="text-sm text-blue-200 mt-1">for <span id="cse-coat-count">2</span> coats</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Surface Area</div>
            <div class="text-xl font-bold" id="cse-area">0 sq ft</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Coverage Rate</div>
            <div class="text-xl font-bold" id="cse-rate">0 sq ft/gal</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Per Coat</div>
            <div class="text-xl font-bold" id="cse-percoat">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">5-Gallon Pails</div>
            <div class="text-xl font-bold" id="cse-pails">0</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Re-coat Time</div>
          <div class="text-xl font-bold" id="cse-recoat">-</div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-sealer" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Concrete Sealer Types</h2>
      <ul>
        <li><strong>Penetrating:</strong> 150-300 sq ft/gal, invisible finish, best for driveways</li>
        <li><strong>Acrylic:</strong> 200-400 sq ft/gal, wet look or matte, decorative concrete</li>
        <li><strong>Epoxy:</strong> 200-350 sq ft/gal, high gloss, garage floors</li>
        <li><strong>Polyurethane:</strong> 200-350 sq ft/gal, high abrasion resistance</li>
        <li><strong>Densifier:</strong> 200-400 sq ft/gal, hardens and dust-proofs surface</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    interface SealerSpec {
      coverageSmooth: number; coverageMedium: number; coverageRough: number;
      recoatTime: string;
    }

    const cseSpecs: Record<string, SealerSpec> = {
      penetrating:  { coverageSmooth: 300, coverageMedium: 200, coverageRough: 150, recoatTime: '1-4 hours' },
      acrylic:      { coverageSmooth: 400, coverageMedium: 300, coverageRough: 200, recoatTime: '2-4 hours' },
      epoxy:        { coverageSmooth: 350, coverageMedium: 275, coverageRough: 200, recoatTime: '12-24 hours' },
      polyurethane: { coverageSmooth: 350, coverageMedium: 275, coverageRough: 200, recoatTime: '8-16 hours' },
      densifier:    { coverageSmooth: 400, coverageMedium: 300, coverageRough: 200, recoatTime: '4-8 hours' },
    };

    function calcCSE() {
      const length = parseFloat((document.getElementById('cse-length') as HTMLInputElement).value) || 0;
      const width = parseFloat((document.getElementById('cse-width') as HTMLInputElement).value) || 0;
      const type = (document.getElementById('cse-type') as HTMLSelectElement).value;
      const porosity = (document.getElementById('cse-porosity') as HTMLSelectElement).value;
      const coats = parseInt((document.getElementById('cse-coats') as HTMLSelectElement).value) || 2;

      const spec = cseSpecs[type] || cseSpecs.penetrating;
      const area = length * width;

      let coverageRate = spec.coverageMedium;
      if (porosity === 'smooth') coverageRate = spec.coverageSmooth;
      else if (porosity === 'rough') coverageRate = spec.coverageRough;

      const galPerCoat = area / coverageRate;
      const totalGal = galPerCoat * coats;
      const pails = Math.ceil(totalGal / 5);

      document.getElementById('cse-gallons')!.textContent = totalGal.toFixed(1) + ' gallons';
      document.getElementById('cse-coat-count')!.textContent = String(coats);
      document.getElementById('cse-area')!.textContent = Math.round(area).toLocaleString() + ' sq ft';
      document.getElementById('cse-rate')!.textContent = coverageRate + ' sq ft/gal';
      document.getElementById('cse-percoat')!.textContent = galPerCoat.toFixed(1) + ' gal';
      document.getElementById('cse-pails')!.textContent = String(pails);
      document.getElementById('cse-recoat')!.textContent = spec.recoatTime;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.cse-in').forEach(el => {
        el.addEventListener('input', calcCSE);
        el.addEventListener('change', calcCSE);
      });
      calcCSE();
    }, 50);
  </script>
</CalculatorLayout>
