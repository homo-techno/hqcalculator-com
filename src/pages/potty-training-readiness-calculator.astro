---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Potty Training Readiness Calculator - Is Your Child Ready?";
const description = "Assess your child's potty training readiness with this evidence-based checklist. Score physical, cognitive, and emotional signs to determine if your toddler is ready.";

const relatedCalcs = [
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper costs." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "Child BMI Calculator", url: "/child-bmi-calculator", description: "BMI percentiles." },
  { name: "Screen Time Calculator", url: "/screen-time-limit-calculator", description: "Screen limits." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare costs." },
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Height prediction." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Potty Training Readiness Calculator"
  keywords="potty training readiness, potty training checklist, when to start potty training, potty training signs, toddler potty training, toilet training readiness"
  breadcrumbs={[{ name: "Potty Training Readiness Calculator", url: "/potty-training-readiness-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Potty Training Readiness Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Check off the signs your child shows to determine their readiness for potty training.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age (months)</label>
          <input type="number" id="ptr-age" class="ptr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="24" min="12" max="48" step="1">
        </div>

        <div>
          <label class="block text-sm font-semibold text-text mb-3">Physical Signs</label>
          <div class="space-y-2">
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="physical" data-weight="3"> <span class="text-sm">Stays dry for 2+ hours during the day</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="physical" data-weight="3"> <span class="text-sm">Has regular, predictable bowel movements</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="physical" data-weight="2"> <span class="text-sm">Can walk to and sit on a toilet/potty</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="physical" data-weight="2"> <span class="text-sm">Can pull pants up and down</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-text mb-3">Cognitive Signs</label>
          <div class="space-y-2">
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="cognitive" data-weight="3"> <span class="text-sm">Understands and follows simple instructions</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="cognitive" data-weight="3"> <span class="text-sm">Tells you or shows signs when about to go</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="cognitive" data-weight="2"> <span class="text-sm">Uses words for pee and poop</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="cognitive" data-weight="2"> <span class="text-sm">Knows the difference between wet and dry</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-text mb-3">Emotional / Behavioral Signs</label>
          <div class="space-y-2">
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="emotional" data-weight="3"> <span class="text-sm">Shows interest in the toilet or others using it</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="emotional" data-weight="3"> <span class="text-sm">Wants to be independent ("I do it myself!")</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="emotional" data-weight="2"> <span class="text-sm">Uncomfortable in dirty/wet diapers</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="emotional" data-weight="2"> <span class="text-sm">Willing to sit on potty without fussing</span>
            </label>
            <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-surface-alt cursor-pointer">
              <input type="checkbox" class="ptr-check w-5 h-5 rounded" data-category="emotional" data-weight="1"> <span class="text-sm">No major life changes happening (new baby, moving, etc.)</span>
            </label>
          </div>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Readiness Score</div>
        <div class="text-5xl font-extrabold" id="ptr-score">--</div>
        <div class="text-sm text-blue-200 mt-1" id="ptr-verdict">check signs above</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Physical Score</div>
          <div class="text-lg font-bold" id="ptr-physical">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Cognitive Score</div>
          <div class="text-lg font-bold" id="ptr-cognitive">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Emotional Score</div>
          <div class="text-lg font-bold" id="ptr-emotional">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Signs Checked</div>
          <div class="text-lg font-bold" id="ptr-checked">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-2">Recommendation</h3>
        <p class="text-sm text-text-secondary" id="ptr-rec">Check the readiness signs above to get a personalized recommendation.</p>
      </div>

      <ShareButton calculatorId="potty-training-readiness" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">When to Start Potty Training</h2>
      <p>Most children show readiness signs between 18-36 months, with the average starting around 27 months. Starting before a child is ready often leads to longer training times and more frustration for both parent and child.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Potty Training Tips</h3>
      <ul>
        <li>Wait until your child shows most readiness signs</li>
        <li>Make it a positive experience with praise and encouragement</li>
        <li>Be patient -- accidents are normal and expected</li>
        <li>Avoid punishment for accidents</li>
        <li>Let your child pick out their own underwear or potty</li>
        <li>Establish a routine (after meals, before bed)</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Average Timeline</h3>
      <p>Once started, daytime training typically takes 3-6 months. Nighttime dryness often comes later, sometimes not until age 5-7. Boys tend to train slightly later than girls on average.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcPTR() {
      const age = parseFloat((document.getElementById('ptr-age') as HTMLInputElement).value) || 24;
      const checks = document.querySelectorAll('.ptr-check');

      let totalScore = 0;
      let maxScore = 0;
      let physicalScore = 0, physicalMax = 0;
      let cognitiveScore = 0, cognitiveMax = 0;
      let emotionalScore = 0, emotionalMax = 0;
      let checkedCount = 0;

      checks.forEach(chk => {
        const el = chk as HTMLInputElement;
        const weight = parseFloat(el.dataset.weight || '1');
        const category = el.dataset.category || '';
        maxScore += weight;

        if (category === 'physical') physicalMax += weight;
        else if (category === 'cognitive') cognitiveMax += weight;
        else emotionalMax += weight;

        if (el.checked) {
          totalScore += weight;
          checkedCount++;
          if (category === 'physical') physicalScore += weight;
          else if (category === 'cognitive') cognitiveScore += weight;
          else emotionalScore += weight;
        }
      });

      // Age bonus
      let ageBonus = 0;
      if (age >= 24) ageBonus += 5;
      if (age >= 30) ageBonus += 5;

      const pct = Math.round((totalScore / maxScore) * 100);
      const adjustedScore = Math.min(100, pct + ageBonus);

      let verdict = '';
      let rec = '';

      if (adjustedScore >= 80) {
        verdict = 'Ready to Start!';
        rec = 'Your child shows strong readiness signs. This is a great time to begin potty training. Start with a consistent routine and lots of positive reinforcement.';
      } else if (adjustedScore >= 60) {
        verdict = 'Almost Ready';
        rec = 'Your child is showing many readiness signs but may benefit from waiting a few more weeks. Focus on building the skills that are not yet checked off.';
      } else if (adjustedScore >= 35) {
        verdict = 'Getting There';
        rec = 'Your child is developing readiness but is not quite there yet. Introduce the concept casually -- read books about potty training, let them watch older siblings, and try sitting on the potty without pressure.';
      } else {
        verdict = 'Not Yet Ready';
        rec = 'Your child needs more time to develop readiness signs. This is completely normal, especially under 24 months. Continue with diapers and revisit in a month or two.';
      }

      document.getElementById('ptr-score')!.textContent = adjustedScore + '%';
      document.getElementById('ptr-verdict')!.textContent = verdict;
      document.getElementById('ptr-physical')!.textContent = Math.round((physicalScore / physicalMax) * 100) + '%';
      document.getElementById('ptr-cognitive')!.textContent = Math.round((cognitiveScore / cognitiveMax) * 100) + '%';
      document.getElementById('ptr-emotional')!.textContent = Math.round((emotionalScore / emotionalMax) * 100) + '%';
      document.getElementById('ptr-checked')!.textContent = checkedCount + ' of ' + checks.length;
      document.getElementById('ptr-rec')!.textContent = rec;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.ptr-check').forEach(el => {
        el.addEventListener('change', calcPTR);
      });
      document.querySelectorAll('.ptr-in').forEach(el => {
        el.addEventListener('input', calcPTR);
        el.addEventListener('change', calcPTR);
      });
      calcPTR();
    }, 50);
  </script>
</CalculatorLayout>
