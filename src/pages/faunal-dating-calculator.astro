---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Faunal Dating Calculator - Relative Dating from Animal Assemblages";
const description = "Analyze faunal assemblages for relative dating using species ratios, extinction markers, and biostratigraphic index fossils.";
const relatedCalcs = [
  { name: "Stratigraphy", url: "/stratigraphy-calculator", description: "Layer age estimation." },
  { name: "Bone Measurement", url: "/bone-measurement-calculator", description: "Skeletal measurements." },
  { name: "Pollen Analysis", url: "/pollen-analysis-calculator", description: "Palynology analysis." },
  { name: "Radiocarbon Dating", url: "/radiocarbon-dating-calculator", description: "C-14 age calculation." },
  { name: "Burial Analysis", url: "/burial-analysis-calculator", description: "Burial demographics." },
  { name: "Fossil Age", url: "/fossil-age-calculator", description: "Multi-method dating." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Faunal Dating Calculator" keywords="faunal dating, biostratigraphy, index fossil, faunal assemblage, relative dating, extinction marker, animal bone dating" breadcrumbs={[{ name: "Faunal Dating", url: "/faunal-dating-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Faunal Dating Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate relative dates from faunal assemblage composition using species proportions, diversity indices, and domestication ratios for biostratigraphic correlation.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total NISP (Number of Identified Specimens)</label>
          <input type="number" id="fad-nisp" class="fad-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="250" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Domesticated Animal Specimens</label>
          <input type="number" id="fad-dom" class="fad-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="180" min="0" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Wild Animal Specimens</label>
          <input type="number" id="fad-wild" class="fad-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="70" min="0" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Distinct Species</label>
          <input type="number" id="fad-species" class="fad-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Extinct Species Present</label>
          <input type="number" id="fad-extinct" class="fad-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Most Abundant Species Count</label>
          <input type="number" id="fad-abundant" class="fad-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="95" min="1" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Domestication Ratio</div>
          <div class="text-4xl font-extrabold" id="fad-domratio">0</div>
          <div class="text-sm text-blue-200 mt-1" id="fad-period">--</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Wild:Domestic Ratio</div>
            <div class="text-xl font-bold" id="fad-wdratio">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Simpson Diversity Index</div>
            <div class="text-xl font-bold" id="fad-simpson">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Species Richness</div>
            <div class="text-xl font-bold" id="fad-richness">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Dominance Index</div>
            <div class="text-xl font-bold" id="fad-dominance">0</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Subsistence Interpretation</div>
          <div class="text-sm font-bold" id="fad-interp">--</div>
        </div>
      </div>

      <ShareButton calculatorId="faunal-dating" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Faunal Analysis Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Domestication Ratio</strong> = Domestic NISP / Total NISP</p>
        <p><strong>Simpson Index</strong> = 1 - Sum(ni/N)^2 for each species</p>
        <p><strong>Dominance</strong> = Most Abundant Species / Total NISP</p>
      </div>
      <p>Faunal assemblage composition changes over time as domestication increases and wild species decline. High domestication ratios suggest later periods with established farming. The Simpson Diversity Index measures evenness of species representation. Extinct species serve as terminus ante quem markers.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcFAD() {
      const nisp = parseFloat((document.getElementById('fad-nisp') as HTMLInputElement).value) || 0;
      const dom = parseFloat((document.getElementById('fad-dom') as HTMLInputElement).value) || 0;
      const wild = parseFloat((document.getElementById('fad-wild') as HTMLInputElement).value) || 0;
      const species = parseFloat((document.getElementById('fad-species') as HTMLInputElement).value) || 1;
      const extinct = parseFloat((document.getElementById('fad-extinct') as HTMLInputElement).value) || 0;
      const abundant = parseFloat((document.getElementById('fad-abundant') as HTMLInputElement).value) || 0;

      const domRatio = nisp > 0 ? dom / nisp : 0;
      const wdRatio = dom > 0 ? wild / dom : (wild > 0 ? Infinity : 0);
      const dominance = nisp > 0 ? abundant / nisp : 0;

      const avgPerSpecies = species > 0 ? nisp / species : 0;
      let simpsonSum = 0;
      if (nisp > 0 && species > 0) {
        const p1 = abundant / nisp;
        simpsonSum += p1 * p1;
        const remaining = nisp - abundant;
        const otherSpecies = species - 1;
        if (otherSpecies > 0) {
          const avgOther = remaining / otherSpecies;
          for (let i = 0; i < otherSpecies; i++) {
            const pi = avgOther / nisp;
            simpsonSum += pi * pi;
          }
        }
      }
      const simpsonIndex = 1 - simpsonSum;

      let period = '';
      let interp = '';
      if (extinct > 0) {
        period = 'Pleistocene or earlier (extinct species present)';
        interp = 'Hunter-gatherer subsistence with Pleistocene megafauna';
      } else if (domRatio === 0) {
        period = 'Pre-Neolithic / Mesolithic';
        interp = 'Pure hunting-gathering-fishing economy, no domesticates';
      } else if (domRatio < 0.2) {
        period = 'Early Neolithic / Transitional';
        interp = 'Predominantly wild resources with incipient domestication';
      } else if (domRatio < 0.5) {
        period = 'Neolithic';
        interp = 'Mixed economy: significant hunting with growing pastoralism';
      } else if (domRatio < 0.8) {
        period = 'Late Neolithic / Bronze Age';
        interp = 'Pastoral economy dominant, supplemented by hunting';
      } else {
        period = 'Iron Age / Historic';
        interp = 'Fully agricultural/pastoral economy with minimal hunting';
      }

      document.getElementById('fad-domratio')!.textContent = (domRatio * 100).toFixed(1) + '%';
      document.getElementById('fad-period')!.textContent = period;
      document.getElementById('fad-wdratio')!.textContent = wdRatio === Infinity ? 'All wild' : wdRatio.toFixed(2) + ':1';
      document.getElementById('fad-simpson')!.textContent = simpsonIndex.toFixed(4);
      document.getElementById('fad-richness')!.textContent = species + ' species';
      document.getElementById('fad-dominance')!.textContent = (dominance * 100).toFixed(1) + '%';
      document.getElementById('fad-interp')!.textContent = interp;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.fad-in').forEach(el => { el.addEventListener('input', calcFAD); el.addEventListener('change', calcFAD); });
      calcFAD();
    }, 50);
  </script>
</CalculatorLayout>
