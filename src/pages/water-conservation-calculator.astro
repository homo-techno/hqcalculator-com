---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Water Conservation Calculator - Fixture Upgrade Savings";
const description = "Calculate water conservation potential from upgrading to low-flow fixtures including showerheads, faucets, and toilets.";
const relatedCalcs = [
  { name: "Rainwater Harvesting", url: "/rainwater-harvesting-calculator", description: "Rain collection." },
  { name: "Greywater Reuse", url: "/greywater-reuse-calculator", description: "Greywater systems." },
  { name: "Water Intake", url: "/water-intake-calculator", description: "Daily water needs." },
  { name: "Green Building", url: "/green-building-calculator", description: "Green certification." },
  { name: "Energy Audit", url: "/energy-audit-calculator", description: "Home audit." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Water Conservation Calculator" keywords="water conservation calculator, low flow fixtures, water saving calculator, fixture upgrade savings, WaterSense" breadcrumbs={[{ name: "Water Conservation", url: "/water-conservation-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Water Conservation Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate water and cost savings from upgrading to water-efficient fixtures.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Household</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">People in Household</label><input type="number" id="wcn-people" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" max="12" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Water Cost ($/1000 gal)</label><input type="number" id="wcn-cost" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" max="30" step="0.50"></div>
        </div>
        <h3 class="font-semibold text-text">Showerheads</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Current Flow (GPM)</label><input type="number" id="wcn-shold" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2.5" min="1" max="5" step="0.1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">New Flow (GPM)</label><input type="number" id="wcn-shnew" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.5" min="0.5" max="3" step="0.1"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Avg Shower Minutes/Person/Day</label><input type="number" id="wcn-shmin" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="3" max="30" step="1"></div>
        <h3 class="font-semibold text-text">Toilets</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Current GPF</label><input type="number" id="wcn-told" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3.5" min="1" max="7" step="0.1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">New GPF</label><input type="number" id="wcn-tnew" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.28" min="0.8" max="3" step="0.1"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Flushes/Person/Day</label><input type="number" id="wcn-flushes" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="2" max="15" step="1"></div>
        <h3 class="font-semibold text-text">Faucets</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Current GPM</label><input type="number" id="wcn-fold" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2.2" min="1" max="4" step="0.1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">New GPM</label><input type="number" id="wcn-fnew" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.0" min="0.5" max="2" step="0.1"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Faucet Minutes/Person/Day</label><input type="number" id="wcn-fmin" class="wcn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="30" step="1"></div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Annual Water Savings</div>
          <div class="text-4xl font-extrabold" id="wcn-total">0</div>
          <div class="text-sm text-blue-200 mt-1">gallons/year</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Cost Savings</div><div class="text-xl font-bold" id="wcn-savings">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Daily Savings</div><div class="text-xl font-bold" id="wcn-daily">0 gal/day</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Reduction</div><div class="text-xl font-bold" id="wcn-pct">0%</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Hot Water Energy Saved</div><div class="text-xl font-bold" id="wcn-energy">0 kWh</div></div>
        </div>
      </div>
      <ShareButton calculatorId="water-conservation" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Water Conservation Through Fixture Upgrades</h2>
      <p>WaterSense-labeled fixtures can reduce household water use by 20-30%. Low-flow showerheads (1.5 GPM vs 2.5 GPM) save 40% per shower. High-efficiency toilets (1.28 GPF vs 3.5 GPF) save 63% per flush. Low-flow faucet aerators (1.0 GPM vs 2.2 GPM) cut faucet water by 55%. Beyond water savings, reducing hot water use also saves energy for water heating.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcWCN() {
      const people = parseFloat((document.getElementById('wcn-people') as HTMLInputElement).value) || 4;
      const costPer1000 = parseFloat((document.getElementById('wcn-cost') as HTMLInputElement).value) || 8;
      const shOld = parseFloat((document.getElementById('wcn-shold') as HTMLInputElement).value) || 2.5;
      const shNew = parseFloat((document.getElementById('wcn-shnew') as HTMLInputElement).value) || 1.5;
      const shMin = parseFloat((document.getElementById('wcn-shmin') as HTMLInputElement).value) || 8;
      const tOld = parseFloat((document.getElementById('wcn-told') as HTMLInputElement).value) || 3.5;
      const tNew = parseFloat((document.getElementById('wcn-tnew') as HTMLInputElement).value) || 1.28;
      const flushes = parseFloat((document.getElementById('wcn-flushes') as HTMLInputElement).value) || 5;
      const fOld = parseFloat((document.getElementById('wcn-fold') as HTMLInputElement).value) || 2.2;
      const fNew = parseFloat((document.getElementById('wcn-fnew') as HTMLInputElement).value) || 1.0;
      const fMin = parseFloat((document.getElementById('wcn-fmin') as HTMLInputElement).value) || 5;
      const shSaveDay = people * shMin * (shOld - shNew);
      const tSaveDay = people * flushes * (tOld - tNew);
      const fSaveDay = people * fMin * (fOld - fNew);
      const dailySave = shSaveDay + tSaveDay + fSaveDay;
      const annualSave = dailySave * 365;
      const costSave = annualSave / 1000 * costPer1000;
      const oldDaily = people * (shMin * shOld + flushes * tOld + fMin * fOld);
      const pctSave = oldDaily > 0 ? (dailySave / oldDaily * 100) : 0;
      const hotWaterSaved = (shSaveDay + fSaveDay * 0.5) * 365;
      const energySaved = hotWaterSaved * 8.33 * 60 / 3412;
      document.getElementById('wcn-total')!.textContent = Math.round(annualSave).toLocaleString();
      document.getElementById('wcn-savings')!.textContent = '$' + Math.round(costSave).toLocaleString();
      document.getElementById('wcn-daily')!.textContent = Math.round(dailySave) + ' gal/day';
      document.getElementById('wcn-pct')!.textContent = pctSave.toFixed(0) + '%';
      document.getElementById('wcn-energy')!.textContent = Math.round(energySaved).toLocaleString() + ' kWh';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.wcn-in').forEach(el => { el.addEventListener('input', calcWCN); el.addEventListener('change', calcWCN); }); calcWCN(); }, 50);
  </script>
</CalculatorLayout>
