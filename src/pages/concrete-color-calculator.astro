---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Color Calculator - Integral Pigment Dosage Rate";
const description = "Calculate integral concrete color pigment dosage rate by weight of cement. Get total pigment needed for consistent color in stamped, exposed, or colored concrete.";

const relatedCalcs = [
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Mix design ratios." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume." },
  { name: "Concrete Sealer Calculator", url: "/concrete-sealer-calculator", description: "Sealer coverage." },
  { name: "Concrete Admixture Calculator", url: "/concrete-admixture-calculator", description: "Admixture dosage." },
  { name: "Stucco Calculator", url: "/stucco-calculator", description: "Stucco materials." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Color Calculator"
  keywords="concrete color, integral pigment, colored concrete, concrete dye, iron oxide pigment, concrete stain, pigment dosage"
  breadcrumbs={[{ name: "Concrete Color Calculator", url: "/concrete-color-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Color Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate integral concrete color pigment dosage for consistent coloring across your pour.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Concrete Volume (cubic yards)</label>
          <input type="number" id="ccl-volume" class="ccl-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0.5" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Cement Content (bags/yd3)</label>
          <input type="number" id="ccl-cement" class="ccl-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5.5" min="3" max="9" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Pigment Type</label>
          <select id="ccl-type" class="ccl-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="iron" selected>Iron Oxide (Standard Colors)</option>
            <option value="carbon">Carbon Black</option>
            <option value="chromium">Chromium Oxide (Green)</option>
            <option value="titanium">Titanium Dioxide (White)</option>
            <option value="liquid">Liquid Color Dispersion</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Color Intensity</label>
          <select id="ccl-intensity" class="ccl-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="light">Light / Pastel (1-3% loading)</option>
            <option value="medium" selected>Medium (3-5% loading)</option>
            <option value="deep">Deep / Bold (5-7% loading)</option>
            <option value="max">Maximum Saturation (7-10% loading)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Color Family</label>
          <select id="ccl-color" class="ccl-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="buff" selected>Buff / Tan</option>
            <option value="brown">Brown / Terra Cotta</option>
            <option value="red">Red / Brick Red</option>
            <option value="charcoal">Charcoal / Dark Gray</option>
            <option value="green">Green</option>
            <option value="white">White</option>
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Pigment Needed</div>
          <div class="text-4xl font-extrabold" id="ccl-total">0 lbs</div>
          <div class="text-sm text-blue-200 mt-1"><span id="ccl-loading">0</span>% of cement weight</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Per Cubic Yard</div>
            <div class="text-xl font-bold" id="ccl-peryd">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Per 94 lb Bag Cement</div>
            <div class="text-xl font-bold" id="ccl-perbag">0 lbs</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Cement Weight</div>
            <div class="text-xl font-bold" id="ccl-cement-wt">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Pigment Containers</div>
            <div class="text-xl font-bold" id="ccl-containers">0</div>
            <div class="text-xs text-text-muted" id="ccl-container-size">-</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Maximum Recommended Loading</div>
          <div class="text-xl font-bold" id="ccl-max">10% by weight of cement</div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-color" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Integral Concrete Color Guide</h2>
      <ul>
        <li><strong>Iron oxide:</strong> Most common; red, brown, buff, black. Max 10% loading.</li>
        <li><strong>Carbon black:</strong> Deep gray/black. Max 5% loading (affects strength at higher rates).</li>
        <li><strong>Chromium oxide:</strong> Green tones. Max 7% loading.</li>
        <li><strong>Titanium dioxide:</strong> White/brighten. Max 5% loading.</li>
        <li><strong>Consistency:</strong> Batch pigment by weight, not volume, for uniform color.</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCCL() {
      const volume = parseFloat((document.getElementById('ccl-volume') as HTMLInputElement).value) || 0;
      const cementBags = parseFloat((document.getElementById('ccl-cement') as HTMLInputElement).value) || 5.5;
      const pigType = (document.getElementById('ccl-type') as HTMLSelectElement).value;
      const intensity = (document.getElementById('ccl-intensity') as HTMLSelectElement).value;

      const cementLbsPerYd = cementBags * 94;
      const totalCement = cementLbsPerYd * volume;

      // Loading rates by intensity
      const loadingRates: Record<string, number> = {
        light: 2, medium: 4, deep: 6, max: 8,
      };
      let loading = loadingRates[intensity] || 4;

      // Carbon black max lower
      if (pigType === 'carbon' && loading > 5) loading = 5;
      if (pigType === 'titanium' && loading > 5) loading = 5;
      if (pigType === 'chromium' && loading > 7) loading = 7;

      const loadingFraction = loading / 100;
      const totalPigment = totalCement * loadingFraction;
      const perYd = totalPigment / (volume || 1);
      const perBag = 94 * loadingFraction;

      // Container sizes: iron oxide = 50lb bags, liquid = 5 gal (~55 lbs), others = 25lb bags
      let containerSize = 50;
      let containerLabel = '50 lb bags';
      if (pigType === 'liquid') { containerSize = 55; containerLabel = '5 gal jugs (~55 lb)'; }
      else if (pigType === 'carbon' || pigType === 'chromium' || pigType === 'titanium') { containerSize = 25; containerLabel = '25 lb bags'; }

      const containers = Math.ceil(totalPigment / containerSize);

      // Max loading
      const maxLoad: Record<string, number> = { iron: 10, carbon: 5, chromium: 7, titanium: 5, liquid: 10 };

      document.getElementById('ccl-total')!.textContent = Math.round(totalPigment).toLocaleString() + ' lbs';
      document.getElementById('ccl-loading')!.textContent = loading.toFixed(1);
      document.getElementById('ccl-peryd')!.textContent = perYd.toFixed(1) + ' lbs';
      document.getElementById('ccl-perbag')!.textContent = perBag.toFixed(1) + ' lbs';
      document.getElementById('ccl-cement-wt')!.textContent = Math.round(totalCement).toLocaleString() + ' lbs';
      document.getElementById('ccl-containers')!.textContent = String(containers);
      document.getElementById('ccl-container-size')!.textContent = containerLabel;
      document.getElementById('ccl-max')!.textContent = (maxLoad[pigType] || 10) + '% by weight of cement';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.ccl-in').forEach(el => {
        el.addEventListener('input', calcCCL);
        el.addEventListener('change', calcCCL);
      });
      calcCCL();
    }, 50);
  </script>
</CalculatorLayout>
