---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Breeding Tank Calculator - Setup for Fry & Spawning";
const description = "Calculate breeding tank setup requirements including fry space, divider placement, water parameters, and grow-out capacity.";
const relatedCalcs = [
  { name: "Fish Compatibility", url: "/fish-compatibility-calculator", description: "Fish species compatibility scores." },
  { name: "Fish Feeding", url: "/fish-feeding-calculator", description: "Feeding amount and frequency." },
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume." },
  { name: "Aquarium Heater", url: "/aquarium-heater-calculator", description: "Heater wattage calculator." },
  { name: "Aquarium Water Change", url: "/aquarium-water-change-calculator", description: "Water change schedule." },
  { name: "Fish Tank Stocking", url: "/fish-tank-stocking-calculator", description: "Fish stocking capacity." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Breeding Tank Calculator" keywords="breeding tank calculator, fish breeding setup, fry tank, spawning tank, fish breeding aquarium" breadcrumbs={[{ name: "Breeding Tank", url: "/breeding-tank-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Breeding Tank Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Plan your breeding tank setup including spawning space, fry capacity, divider placement, and water parameters.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tank Length (in)</label>
            <input type="number" id="btk-len" class="btk-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="24" min="6" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Width (in)</label>
            <input type="number" id="btk-wid" class="btk-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="6" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Height (in)</label>
            <input type="number" id="btk-hgt" class="btk-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="6" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Fish Type</label>
            <select id="btk-fish" class="btk-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="livebearer" selected>Livebearers (Guppy, Molly)</option>
              <option value="egglayer">Egg Layers (Tetras, Barbs)</option>
              <option value="cichlid">Cichlids (Mouth brooders)</option>
              <option value="betta">Betta / Bubble Nesters</option>
              <option value="catfish">Catfish / Corydoras</option>
              <option value="shrimp">Shrimp</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Number of Dividers</label>
            <input type="number" id="btk-div" class="btk-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="0" max="5" step="1">
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Adult Fish Size (inches)</label>
          <input type="number" id="btk-size" class="btk-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0.5" max="12" step="0.5">
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Max Fry Capacity (grow-out)</div>
          <div class="text-5xl font-extrabold font-mono" id="btk-result">0 fry</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Tank Volume</div>
            <div class="text-xl font-bold font-mono" id="btk-vol">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Section Size</div>
            <div class="text-xl font-bold font-mono" id="btk-section">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Ideal Temp (&deg;F)</div>
            <div class="text-xl font-bold font-mono" id="btk-temp">78&deg;F</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water Change</div>
            <div class="text-xl font-bold font-mono" id="btk-wc">--</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="breeding-tank" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcBTK() {
      const len = parseFloat((document.getElementById('btk-len') as HTMLInputElement).value) || 0;
      const wid = parseFloat((document.getElementById('btk-wid') as HTMLInputElement).value) || 0;
      const hgt = parseFloat((document.getElementById('btk-hgt') as HTMLInputElement).value) || 0;
      const fish = (document.getElementById('btk-fish') as HTMLSelectElement).value;
      const divs = parseFloat((document.getElementById('btk-div') as HTMLInputElement).value) || 0;
      const size = parseFloat((document.getElementById('btk-size') as HTMLInputElement).value) || 1;
      const gallons = (len * wid * hgt) / 231;
      const sections = divs + 1;
      const sectionGal = gallons / sections;
      // Fry capacity: small fry need ~0.5 gal each until 1", then 1" per gallon rule
      // For grow-out, use 0.25 gal per fry initially
      const fryPerGal: Record<string, number> = {
        livebearer: 4, egglayer: 5, cichlid: 2, betta: 3, catfish: 3, shrimp: 10
      };
      const maxFry = Math.floor(sectionGal * (fryPerGal[fish] || 3));
      // Temperature recommendations
      const temps: Record<string, string> = {
        livebearer: '78-80', egglayer: '76-80', cichlid: '78-82', betta: '80-82', catfish: '74-78', shrimp: '72-76'
      };
      // Water change frequency for fry
      const wcFreq: Record<string, string> = {
        livebearer: '25% 3x/week', egglayer: '20% 2x/week', cichlid: '30% 2x/week',
        betta: '25% 2x/week', catfish: '20% 2x/week', shrimp: '10% weekly'
      };
      document.getElementById('btk-result')!.textContent = maxFry + ' fry';
      document.getElementById('btk-vol')!.textContent = gallons.toFixed(1) + ' gal';
      document.getElementById('btk-section')!.textContent = sectionGal.toFixed(1) + ' gal';
      document.getElementById('btk-temp')!.textContent = (temps[fish] || '78') + '\u00B0F';
      document.getElementById('btk-wc')!.textContent = wcFreq[fish] || '25% 2x/week';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.btk-in').forEach(el => { el.addEventListener('input', calcBTK); el.addEventListener('change', calcBTK); });
      calcBTK();
    }, 50);
  </script>
</CalculatorLayout>
