---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Baby Name Calculator - Name Popularity & Letter Analysis";
const description = "Analyze baby names for popularity ranking, letter composition, origin insights, and numerology. Compare name statistics and find the perfect name.";

const relatedCalcs = [
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Track milestones." },
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Height prediction." },
  { name: "Baby Formula Calculator", url: "/baby-formula-calculator", description: "Formula needs." },
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper costs." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare costs." },
  { name: "Birthday Party Calculator", url: "/birthday-party-calculator", description: "Party planning." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Baby Name Calculator"
  keywords="baby name calculator, name popularity, baby name ranking, name analysis, baby name meaning, name numerology"
  breadcrumbs={[{ name: "Baby Name Calculator", url: "/baby-name-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Baby Name Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Analyze baby names for letter composition, syllable count, and compatibility scoring.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">First Name</label>
          <input type="text" id="bnm-first" class="bnm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="Emma" placeholder="Enter first name">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Middle Name (optional)</label>
          <input type="text" id="bnm-middle" class="bnm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="" placeholder="Enter middle name">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Last Name</label>
          <input type="text" id="bnm-last" class="bnm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="Smith" placeholder="Enter last name">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Name Harmony Score</div>
        <div class="text-5xl font-extrabold" id="bnm-score">--</div>
        <div class="text-sm text-blue-200 mt-1" id="bnm-rating">analyzing name</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Total Letters</div>
          <div class="text-lg font-bold" id="bnm-letters">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Syllables</div>
          <div class="text-lg font-bold" id="bnm-syllables">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Vowel/Consonant</div>
          <div class="text-lg font-bold" id="bnm-vc">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Initials</div>
          <div class="text-lg font-bold" id="bnm-initials">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-4">
        <h3 class="font-semibold text-sm text-text mb-3">Name Analysis</h3>
        <div class="text-sm space-y-2" id="bnm-analysis"></div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Letter Frequency</h3>
        <div class="text-xs" id="bnm-freq"></div>
      </div>

      <ShareButton calculatorId="baby-name" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Choosing the Perfect Baby Name</h2>
      <p>A great name has rhythm, readability, and personal meaning. This calculator helps you analyze the structural elements of a name -- letter balance, syllable flow, and how the full name sounds together.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Tips for Name Selection</h3>
      <ul>
        <li><strong>Syllable balance:</strong> Vary syllable counts between first and last name for better flow</li>
        <li><strong>Initial check:</strong> Make sure initials do not spell unintended words</li>
        <li><strong>Nickname test:</strong> Consider potential nicknames and shortened versions</li>
        <li><strong>Say it out loud:</strong> Practice saying the full name aloud multiple times</li>
        <li><strong>Spelling check:</strong> Consider how easily the name can be spelled and pronounced</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcBNM() {
      const first = (document.getElementById('bnm-first') as HTMLInputElement).value.trim();
      const middle = (document.getElementById('bnm-middle') as HTMLInputElement).value.trim();
      const last = (document.getElementById('bnm-last') as HTMLInputElement).value.trim();

      if (!first) {
        document.getElementById('bnm-score')!.textContent = '--';
        return;
      }

      const vowels = 'aeiouAEIOU';
      function countVowels(s: string): number { return [...s].filter(c => vowels.includes(c)).length; }
      function countConsonants(s: string): number { return [...s].filter(c => /[a-zA-Z]/.test(c) && !vowels.includes(c)).length; }

      function countSyllables(word: string): number {
        word = word.toLowerCase();
        if (word.length <= 3) return 1;
        let count = 0;
        let prevVowel = false;
        for (const c of word) {
          const isVowel = 'aeiou'.includes(c);
          if (isVowel && !prevVowel) count++;
          prevVowel = isVowel;
        }
        if (word.endsWith('e') && count > 1) count--;
        return Math.max(1, count);
      }

      const fullName = [first, middle, last].filter(Boolean).join(' ');
      const lettersOnly = fullName.replace(/[^a-zA-Z]/g, '');
      const totalLetters = lettersOnly.length;
      const totalVowels = countVowels(lettersOnly);
      const totalConsonants = countConsonants(lettersOnly);

      const firstSyl = countSyllables(first);
      const lastSyl = countSyllables(last);
      const midSyl = middle ? countSyllables(middle) : 0;
      const totalSyl = firstSyl + midSyl + lastSyl;

      const initials = [first, middle, last].filter(Boolean).map(n => n[0].toUpperCase()).join('');

      // Harmony scoring
      let score = 50;
      // Syllable variety bonus
      if (firstSyl !== lastSyl) score += 15;
      // Good length (not too short, not too long)
      if (totalLetters >= 8 && totalLetters <= 20) score += 10;
      // Vowel/consonant balance
      const ratio = totalVowels / Math.max(1, totalConsonants);
      if (ratio >= 0.35 && ratio <= 0.65) score += 10;
      // Different starting letters
      if (first[0]?.toLowerCase() !== last[0]?.toLowerCase()) score += 10;
      // Name doesn't end same way as last name starts
      if (first.slice(-1).toLowerCase() !== last[0]?.toLowerCase()) score += 5;

      score = Math.min(100, Math.max(10, score));

      let rating = '';
      if (score >= 85) rating = 'Excellent harmony';
      else if (score >= 70) rating = 'Good harmony';
      else if (score >= 50) rating = 'Fair harmony';
      else rating = 'Consider alternatives';

      document.getElementById('bnm-score')!.textContent = score + '/100';
      document.getElementById('bnm-rating')!.textContent = rating;
      document.getElementById('bnm-letters')!.textContent = String(totalLetters);
      document.getElementById('bnm-syllables')!.textContent = String(totalSyl);
      document.getElementById('bnm-vc')!.textContent = totalVowels + 'V / ' + totalConsonants + 'C';
      document.getElementById('bnm-initials')!.textContent = initials;

      // Analysis
      const tips: string[] = [];
      if (firstSyl === lastSyl) tips.push('Tip: Varying syllable counts between first and last name often creates better flow.');
      if (first[0]?.toLowerCase() === last[0]?.toLowerCase()) tips.push('Note: Alliterative names (same starting letter) can be memorable but may sound repetitive.');
      if (totalLetters > 25) tips.push('The full name is quite long -- consider a shorter middle name.');
      if (totalLetters < 6) tips.push('The full name is very short -- a longer middle name could add balance.');
      if (tips.length === 0) tips.push('This name has great balance and flow!');

      tips.push('First name: ' + firstSyl + ' syllable(s), Last name: ' + lastSyl + ' syllable(s)');

      document.getElementById('bnm-analysis')!.innerHTML = tips.map(t => `<p class="text-text-secondary">${t}</p>`).join('');

      // Letter frequency
      const freq: Record<string, number> = {};
      for (const c of lettersOnly.toLowerCase()) {
        freq[c] = (freq[c] || 0) + 1;
      }
      const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]);
      const maxCount = sorted[0]?.[1] || 1;
      document.getElementById('bnm-freq')!.innerHTML = sorted.map(([letter, count]) => {
        const pct = (count / maxCount) * 100;
        return `<div class="flex items-center gap-2 py-0.5"><span class="w-6 font-bold uppercase">${letter}</span><div class="flex-1 bg-gray-200 rounded-full h-3"><div class="bg-primary h-3 rounded-full" style="width:${pct}%"></div></div><span class="w-6 text-right">${count}</span></div>`;
      }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.bnm-in').forEach(el => {
        el.addEventListener('input', calcBNM);
        el.addEventListener('change', calcBNM);
      });
      calcBNM();
    }, 50);
  </script>
</CalculatorLayout>
