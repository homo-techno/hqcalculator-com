---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Net Metering Calculator - Solar Credits & Annual Utility Bill";
const description = "Calculate net metering credits and your annual utility bill with solar panels, including time-of-use rates and excess generation.";
const relatedCalcs = [
  { name: "Solar Panel", url: "/solar-panel-calculator", description: "Solar sizing." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Battery Storage", url: "/battery-storage-calculator", description: "Battery sizing." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "Solar Battery", url: "/solar-battery-calculator", description: "Solar battery." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Net Metering Calculator" keywords="net metering calculator, solar net metering credits, solar utility bill, solar excess generation, net metering savings" breadcrumbs={[{ name: "Net Metering", url: "/net-metering-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Net Metering Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate your net metering credits and annual utility bill with solar.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Solar Production</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">System Size (kW)</label><input type="number" id="nm2-kw" class="nm2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" max="50" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Sun Hours/Day</label><input type="number" id="nm2-sun" class="nm2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="10" step="0.5"></div>
        </div>
        <h3 class="font-semibold text-text">Energy Consumption</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Monthly Usage (kWh)</label><input type="number" id="nm2-usage" class="nm2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1000" min="100" max="5000" step="50"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Self-Consumption (%)</label><input type="number" id="nm2-self" class="nm2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="10" max="90" step="5"></div>
        </div>
        <h3 class="font-semibold text-text">Rates</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Retail Rate ($/kWh)</label><input type="number" id="nm2-retail" class="nm2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.15" min="0.01" max="0.60" step="0.01"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Export Rate ($/kWh)</label><input type="number" id="nm2-export" class="nm2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.10" min="0.01" max="0.60" step="0.01"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Monthly Fixed Charge ($)</label><input type="number" id="nm2-fixed" class="nm2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="0" max="50" step="1"></div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Annual Utility Bill with Solar</div>
          <div class="text-4xl font-extrabold" id="nm2-bill">$0</div>
          <div class="text-sm text-blue-200 mt-1">per year</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Bill Without Solar</div><div class="text-xl font-bold" id="nm2-nobill">$0/yr</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Savings</div><div class="text-xl font-bold" id="nm2-savings">$0/yr</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Exported to Grid</div><div class="text-xl font-bold" id="nm2-exported">0 kWh/yr</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Net Metering Credits</div><div class="text-xl font-bold" id="nm2-credits">$0/yr</div></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Solar Offset</div>
          <div class="text-2xl font-bold" id="nm2-offset">0%</div>
        </div>
      </div>
      <ShareButton calculatorId="net-metering" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Net Metering</h2>
      <p>Net metering allows solar owners to export excess electricity to the grid and receive credits on their utility bill. Full retail net metering credits exports at the same rate you buy; some utilities offer a lower export rate. Self-consumption (using solar directly) is most valuable since it offsets retail-rate purchases. The optimal system size matches annual production to annual consumption.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcNM2() {
      const kw = parseFloat((document.getElementById('nm2-kw') as HTMLInputElement).value) || 8;
      const sun = parseFloat((document.getElementById('nm2-sun') as HTMLInputElement).value) || 5;
      const usage = parseFloat((document.getElementById('nm2-usage') as HTMLInputElement).value) || 1000;
      const selfPct = parseFloat((document.getElementById('nm2-self') as HTMLInputElement).value) || 40;
      const retail = parseFloat((document.getElementById('nm2-retail') as HTMLInputElement).value) || 0.15;
      const exportRate = parseFloat((document.getElementById('nm2-export') as HTMLInputElement).value) || 0.10;
      const fixed = parseFloat((document.getElementById('nm2-fixed') as HTMLInputElement).value) || 12;
      const monthlyProd = kw * sun * 30 * 0.80;
      const annualProd = monthlyProd * 12;
      const annualUsage = usage * 12;
      const selfConsumed = annualProd * (selfPct / 100);
      const exported = annualProd - selfConsumed;
      const gridPurchased = Math.max(0, annualUsage - selfConsumed);
      const credits = exported * exportRate;
      const gridCost = gridPurchased * retail;
      const annualBill = Math.max(0, gridCost - credits) + fixed * 12;
      const noBill = annualUsage * retail + fixed * 12;
      const savings = noBill - annualBill;
      const offset = annualUsage > 0 ? Math.min(100, annualProd / annualUsage * 100) : 0;
      document.getElementById('nm2-bill')!.textContent = '$' + Math.round(annualBill).toLocaleString();
      document.getElementById('nm2-nobill')!.textContent = '$' + Math.round(noBill).toLocaleString() + '/yr';
      document.getElementById('nm2-savings')!.textContent = '$' + Math.round(savings).toLocaleString() + '/yr';
      document.getElementById('nm2-exported')!.textContent = Math.round(exported).toLocaleString() + ' kWh/yr';
      document.getElementById('nm2-credits')!.textContent = '$' + Math.round(credits).toLocaleString() + '/yr';
      document.getElementById('nm2-offset')!.textContent = offset.toFixed(0) + '%';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.nm2-in').forEach(el => { el.addEventListener('input', calcNM2); el.addEventListener('change', calcNM2); }); calcNM2(); }, 50);
  </script>
</CalculatorLayout>
