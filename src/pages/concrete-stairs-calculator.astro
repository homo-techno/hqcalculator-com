---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Stairs Calculator - Volume from Rise, Run & Width";
const description = "Calculate concrete volume for stairs from rise height, tread depth, width, and number of steps. Get total volume, weight, and rebar requirements.";

const relatedCalcs = [
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume." },
  { name: "Concrete Form Calculator", url: "/concrete-form-calculator", description: "Formwork estimator." },
  { name: "Rebar Calculator", url: "/rebar-calculator", description: "Rebar requirements." },
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Mix design." },
  { name: "Concrete Reinforcement Calculator", url: "/concrete-reinforcement-calculator", description: "Rebar sizing." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Stairs Calculator"
  keywords="concrete stairs, stair volume, stair riser, stair tread, concrete steps, stair calculator"
  breadcrumbs={[{ name: "Concrete Stairs Calculator", url: "/concrete-stairs-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Stairs Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate concrete volume for stairs from dimensions including rise, run, and width.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Number of Steps</label>
            <input type="number" id="css-steps" class="css-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="50" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Stair Width (ft)</label>
            <input type="number" id="css-width" class="css-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" step="0.25">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Rise Height (in per step)</label>
            <input type="number" id="css-rise" class="css-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="7.5" min="4" max="10" step="0.25">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Tread Depth (in per step)</label>
            <input type="number" id="css-tread" class="css-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="11" min="6" max="18" step="0.5">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Slab Thickness Under Stairs (in)</label>
          <input type="number" id="css-slab" class="css-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="4" max="12" step="1">
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-text mb-1">Waste Factor (%)</label>
              <input type="number" id="css-waste" class="css-in w-full px-3 py-2 border border-border rounded-lg" value="10" min="0" max="25" step="1">
            </div>
            <div>
              <label class="block text-xs font-medium text-text mb-1">Include Landing?</label>
              <select id="css-landing" class="css-in w-full px-3 py-2 border border-border rounded-lg">
                <option value="no" selected>No Landing</option>
                <option value="yes">Top Landing (4 ft deep)</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Concrete Volume</div>
          <div class="text-4xl font-extrabold" id="css-volume">0 yd3</div>
          <div class="text-sm text-blue-200 mt-1"><span id="css-cuft">0</span> cubic feet</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Rise</div>
            <div class="text-xl font-bold" id="css-total-rise">0 ft</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Run</div>
            <div class="text-xl font-bold" id="css-total-run">0 ft</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Stair Angle</div>
            <div class="text-xl font-bold" id="css-angle">0 deg</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Weight</div>
            <div class="text-xl font-bold" id="css-weight">0 lbs</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Code Check (IRC 2018)</div>
          <div class="text-xl font-bold" id="css-code">-</div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-stairs" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Concrete Stair Design Guide</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Step volume:</strong> Width x Tread x Rise (per step, cumulative from bottom)</p>
        <p><strong>Base slab:</strong> Width x Stair length x Slab thickness</p>
        <p><strong>Code rule:</strong> 2R + T should be 24-25 inches (comfort rule)</p>
      </div>
      <ul>
        <li><strong>Max riser height:</strong> 7.75 inches (IRC residential)</li>
        <li><strong>Min tread depth:</strong> 10 inches (IRC residential)</li>
        <li><strong>Min width:</strong> 36 inches (IRC residential)</li>
        <li><strong>Nosing:</strong> 0.75-1.25 inch overhang typical</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCSS() {
      const steps = parseInt((document.getElementById('css-steps') as HTMLInputElement).value) || 0;
      const width = parseFloat((document.getElementById('css-width') as HTMLInputElement).value) || 0;
      const rise = parseFloat((document.getElementById('css-rise') as HTMLInputElement).value) || 7.5;
      const tread = parseFloat((document.getElementById('css-tread') as HTMLInputElement).value) || 11;
      const slabThick = parseFloat((document.getElementById('css-slab') as HTMLInputElement).value) || 6;
      const waste = (parseFloat((document.getElementById('css-waste') as HTMLInputElement).value) || 0) / 100;
      const landing = (document.getElementById('css-landing') as HTMLSelectElement).value;

      const riseFt = rise / 12;
      const treadFt = tread / 12;
      const slabFt = slabThick / 12;

      const totalRiseFt = steps * riseFt;
      const totalRunFt = steps * treadFt;

      // Volume calculation: each step is a rectangular increment
      // Step i from bottom has height = i * riseFt
      // The stair volume = sum of (width * treadFt * riseFt) for each step
      // Plus the base slab running under the entire stair
      let stepVol = 0;
      for (let i = 1; i <= steps; i++) {
        stepVol += width * treadFt * riseFt;
      }

      // Base slab: triangular cross-section approximation + slab thickness
      const stairLength = Math.sqrt(totalRiseFt * totalRiseFt + totalRunFt * totalRunFt);
      const baseSlab = width * stairLength * slabFt;

      // Wedge volume under stairs (the solid fill)
      const wedgeVol = width * totalRunFt * totalRiseFt / 2;

      let totalCuFt = (stepVol + baseSlab + wedgeVol) * (1 + waste);

      // Landing
      if (landing === 'yes') {
        const landingVol = width * 4 * slabFt; // 4 ft deep landing
        totalCuFt += landingVol * (1 + waste);
      }

      const cuYd = totalCuFt / 27;
      const angle = Math.atan2(totalRiseFt, totalRunFt) * (180 / Math.PI);
      const weight = cuYd * 4050;

      // Code check: 2R + T
      const comfortCheck = 2 * rise + tread;
      let codeStatus = '';
      if (rise > 7.75) codeStatus = 'FAIL - Rise exceeds 7.75"';
      else if (tread < 10) codeStatus = 'FAIL - Tread less than 10"';
      else if (comfortCheck < 24 || comfortCheck > 25) codeStatus = 'OK (2R+T=' + comfortCheck.toFixed(1) + '", ideal 24-25")';
      else codeStatus = 'PASS (2R+T=' + comfortCheck.toFixed(1) + '")';

      document.getElementById('css-volume')!.textContent = cuYd.toFixed(2) + ' yd\u00B3';
      document.getElementById('css-cuft')!.textContent = totalCuFt.toFixed(1);
      document.getElementById('css-total-rise')!.textContent = totalRiseFt.toFixed(1) + ' ft';
      document.getElementById('css-total-run')!.textContent = totalRunFt.toFixed(1) + ' ft';
      document.getElementById('css-angle')!.textContent = angle.toFixed(1) + '\u00B0';
      document.getElementById('css-weight')!.textContent = Math.round(weight).toLocaleString() + ' lbs';
      document.getElementById('css-code')!.textContent = codeStatus;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.css-in').forEach(el => {
        el.addEventListener('input', calcCSS);
        el.addEventListener('change', calcCSS);
      });
      calcCSS();
    }, 50);
  </script>
</CalculatorLayout>
