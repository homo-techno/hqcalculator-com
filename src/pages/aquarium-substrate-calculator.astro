---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Substrate Calculator - Depth & Weight";
const description = "Calculate the amount of substrate (gravel, sand, soil) needed for your aquarium based on tank dimensions and desired depth.";
const relatedCalcs = [
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume and water weight." },
  { name: "Aquarium Lighting", url: "/aquarium-lighting-calculator", description: "Light intensity for planted tanks." },
  { name: "Aquarium CO2", url: "/aquarium-co2-calculator", description: "CO2 injection rate for planted tanks." },
  { name: "Aquarium Cost", url: "/aquarium-cost-calculator", description: "Total aquarium setup cost estimator." },
  { name: "Aquarium Background", url: "/aquarium-background-calculator", description: "Background dimensions calculator." },
  { name: "Live Rock", url: "/live-rock-calculator", description: "Live rock quantity for reef tanks." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Substrate Calculator" keywords="aquarium substrate calculator, aquarium gravel, fish tank sand, planted tank substrate, aquarium soil" breadcrumbs={[{ name: "Aquarium Substrate", url: "/aquarium-substrate-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Substrate Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Determine how much substrate you need to achieve the desired depth in your aquarium.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tank Length (inches)</label>
            <input type="number" id="asb-len" class="asb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="48" min="1" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tank Width (inches)</label>
            <input type="number" id="asb-wid" class="asb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="1" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Desired Depth (inches)</label>
            <input type="number" id="asb-dep" class="asb-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0.5" max="6" step="0.5">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Substrate Type</label>
            <select id="asb-type" class="asb-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="gravel">Gravel (96 lbs/cu ft)</option>
              <option value="sand">Sand (100 lbs/cu ft)</option>
              <option value="soil" selected>Aqua Soil (55 lbs/cu ft)</option>
              <option value="flourite">Flourite (85 lbs/cu ft)</option>
              <option value="crushed_coral">Crushed Coral (90 lbs/cu ft)</option>
              <option value="eco">Eco-Complete (70 lbs/cu ft)</option>
            </select>
          </div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Substrate Needed</div>
          <div class="text-5xl font-extrabold font-mono" id="asb-result">0 lbs</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Weight (kg)</div>
            <div class="text-xl font-bold font-mono" id="asb-kg">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Volume (cu in)</div>
            <div class="text-xl font-bold font-mono" id="asb-cuin">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Bags Needed (est.)</div>
            <div class="text-xl font-bold font-mono" id="asb-bags">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Coverage Area</div>
            <div class="text-xl font-bold font-mono" id="asb-area">0 sq in</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-substrate" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcASB() {
      const len = parseFloat((document.getElementById('asb-len') as HTMLInputElement).value) || 0;
      const wid = parseFloat((document.getElementById('asb-wid') as HTMLInputElement).value) || 0;
      const dep = parseFloat((document.getElementById('asb-dep') as HTMLInputElement).value) || 0;
      const type = (document.getElementById('asb-type') as HTMLSelectElement).value;
      // Density in lbs per cubic foot
      const densities: Record<string, number> = {
        gravel: 96, sand: 100, soil: 55, flourite: 85, crushed_coral: 90, eco: 70
      };
      const density = densities[type] || 96;
      const cuIn = len * wid * dep;
      const cuFt = cuIn / 1728;
      const lbs = cuFt * density;
      const kg = lbs * 0.4536;
      const area = len * wid;
      // Standard bag is about 10-20 lbs depending on type
      const bagSize = type === 'soil' ? 9 : type === 'eco' ? 20 : 20;
      const bags = Math.ceil(lbs / bagSize);
      document.getElementById('asb-result')!.textContent = lbs.toFixed(1) + ' lbs';
      document.getElementById('asb-kg')!.textContent = kg.toFixed(1);
      document.getElementById('asb-cuin')!.textContent = cuIn.toFixed(0);
      document.getElementById('asb-bags')!.textContent = bags.toString();
      document.getElementById('asb-area')!.textContent = area + ' sq in';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.asb-in').forEach(el => { el.addEventListener('input', calcASB); el.addEventListener('change', calcASB); });
      calcASB();
    }, 50);
  </script>
</CalculatorLayout>
