---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Bone Measurement Calculator - Skeletal Stature Estimation";
const description = "Estimate living stature from long bone measurements using regression formulas (Trotter & Gleser, Sjovold). Input femur, tibia, humerus, or radius length.";
const relatedCalcs = [
  { name: "Burial Analysis", url: "/burial-analysis-calculator", description: "Burial demographics." },
  { name: "Faunal Dating", url: "/faunal-dating-calculator", description: "Faunal assemblages." },
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
  { name: "Stable Isotope", url: "/stable-isotope-calculator", description: "Isotope analysis." },
  { name: "Radiocarbon Dating", url: "/radiocarbon-dating-calculator", description: "C-14 dating." },
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Bone Measurement Calculator" keywords="stature estimation, long bone measurement, femur length, osteology, skeletal analysis, Trotter Gleser, bioarchaeology" breadcrumbs={[{ name: "Bone Measurement", url: "/bone-measurement-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Bone Measurement Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate living stature from long bone maximum lengths using established regression formulas. Select the bone, population group, and enter measurements.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Bone Element</label>
          <select id="bom-bone" class="bom-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="femur">Femur (thigh bone)</option>
            <option value="tibia">Tibia (shin bone)</option>
            <option value="humerus">Humerus (upper arm)</option>
            <option value="radius">Radius (forearm)</option>
            <option value="ulna">Ulna (forearm)</option>
            <option value="fibula">Fibula (lower leg)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Maximum Length (cm)</label>
          <input type="number" id="bom-length" class="bom-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="45.5" min="1" max="100" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Sex Estimation</label>
          <select id="bom-sex" class="bom-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="male">Male</option>
            <option value="female">Female</option>
            <option value="unknown">Unknown / Indeterminate</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Population Reference</label>
          <select id="bom-pop" class="bom-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="white">European / White (Trotter & Gleser)</option>
            <option value="black">African / Black (Trotter & Gleser)</option>
            <option value="generic">Generic (Sjovold)</option>
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Living Stature</div>
          <div class="text-4xl font-extrabold" id="bom-stature">0</div>
          <div class="text-sm text-blue-200 mt-1" id="bom-range">+/- 0 cm</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Stature (ft/in)</div>
            <div class="text-xl font-bold" id="bom-imperial">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Stature Range</div>
            <div class="text-xl font-bold" id="bom-minmax">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Formula Used</div>
            <div class="text-sm font-bold" id="bom-formula">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Standard Error</div>
            <div class="text-xl font-bold" id="bom-se">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="bone-measurement" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Stature Estimation Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Trotter & Gleser (1952, 1958)</strong></p>
        <p>Stature = a * Bone Length (cm) + b</p>
        <p><strong>Sjovold (1990) - Generic</strong></p>
        <p>Uses weighted average across populations</p>
      </div>
      <p>Stature estimation from long bones is a core method in bioarchaeology and forensic anthropology. The Trotter and Gleser formulas remain the most widely used, though population-specific formulas provide more accurate results. Standard error ranges typically span 3-5 cm.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcBOM() {
      const bone = (document.getElementById('bom-bone') as HTMLSelectElement).value;
      const length = parseFloat((document.getElementById('bom-length') as HTMLInputElement).value) || 0;
      const sex = (document.getElementById('bom-sex') as HTMLSelectElement).value;
      const pop = (document.getElementById('bom-pop') as HTMLSelectElement).value;

      interface FormulaEntry { a: number; b: number; se: number; }
      interface SexFormulas { male: FormulaEntry; female: FormulaEntry; }
      interface PopFormulas { [key: string]: SexFormulas; }
      interface AllFormulas { [key: string]: PopFormulas; }

      const formulas: AllFormulas = {
        femur: {
          white: { male: { a: 2.38, b: 61.41, se: 3.27 }, female: { a: 2.47, b: 54.10, se: 3.72 } },
          black: { male: { a: 2.11, b: 70.35, se: 3.94 }, female: { a: 2.28, b: 59.76, se: 3.41 } },
          generic: { male: { a: 2.71, b: 45.00, se: 4.00 }, female: { a: 2.89, b: 36.00, se: 4.10 } }
        },
        tibia: {
          white: { male: { a: 2.52, b: 78.62, se: 3.37 }, female: { a: 2.90, b: 61.53, se: 3.66 } },
          black: { male: { a: 2.19, b: 86.02, se: 3.78 }, female: { a: 2.45, b: 72.65, se: 3.70 } },
          generic: { male: { a: 2.96, b: 63.00, se: 3.80 }, female: { a: 3.15, b: 53.00, se: 3.90 } }
        },
        humerus: {
          white: { male: { a: 3.08, b: 70.45, se: 4.05 }, female: { a: 3.36, b: 57.97, se: 4.45 } },
          black: { male: { a: 3.26, b: 62.10, se: 4.43 }, female: { a: 3.08, b: 64.67, se: 4.25 } },
          generic: { male: { a: 3.55, b: 54.00, se: 4.50 }, female: { a: 3.72, b: 44.00, se: 4.60 } }
        },
        radius: {
          white: { male: { a: 3.78, b: 79.01, se: 4.32 }, female: { a: 4.74, b: 54.93, se: 4.24 } },
          black: { male: { a: 3.32, b: 85.43, se: 4.57 }, female: { a: 3.67, b: 71.79, se: 4.59 } },
          generic: { male: { a: 3.93, b: 71.00, se: 4.50 }, female: { a: 4.50, b: 51.00, se: 4.60 } }
        },
        ulna: {
          white: { male: { a: 3.70, b: 74.05, se: 4.32 }, female: { a: 4.27, b: 57.76, se: 4.30 } },
          black: { male: { a: 3.20, b: 82.77, se: 4.74 }, female: { a: 3.31, b: 75.38, se: 4.83 } },
          generic: { male: { a: 3.65, b: 70.00, se: 4.50 }, female: { a: 4.10, b: 55.00, se: 4.60 } }
        },
        fibula: {
          white: { male: { a: 2.68, b: 71.78, se: 3.29 }, female: { a: 2.93, b: 59.61, se: 3.57 } },
          black: { male: { a: 2.19, b: 85.65, se: 4.08 }, female: { a: 2.49, b: 70.90, se: 3.80 } },
          generic: { male: { a: 2.85, b: 65.00, se: 3.80 }, female: { a: 3.10, b: 54.00, se: 3.90 } }
        }
      };

      const useSex = sex === 'unknown' ? 'male' : sex;
      const f = formulas[bone]?.[pop]?.[useSex as 'male' | 'female'] || { a: 2.38, b: 61.41, se: 3.27 };
      const stature = f.a * length + f.b;
      const se = f.se;
      const statureMin = stature - se;
      const statureMax = stature + se;

      const totalInches = stature / 2.54;
      const feet = Math.floor(totalInches / 12);
      const inches = (totalInches % 12).toFixed(1);

      const formulaName = pop === 'generic' ? 'Sjovold (1990)' : 'Trotter & Gleser';

      document.getElementById('bom-stature')!.textContent = stature.toFixed(1) + ' cm';
      document.getElementById('bom-range')!.textContent = '+/- ' + se.toFixed(1) + ' cm (1 SE)';
      document.getElementById('bom-imperial')!.textContent = feet + "'" + inches + '"';
      document.getElementById('bom-minmax')!.textContent = statureMin.toFixed(1) + ' - ' + statureMax.toFixed(1) + ' cm';
      document.getElementById('bom-formula')!.textContent = formulaName;
      document.getElementById('bom-se')!.textContent = se.toFixed(2) + ' cm';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.bom-in').forEach(el => { el.addEventListener('input', calcBOM); el.addEventListener('change', calcBOM); });
      calcBOM();
    }, 50);
  </script>
</CalculatorLayout>
