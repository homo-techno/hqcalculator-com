---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Greywater Reuse Calculator - System Sizing & Water Savings";
const description = "Calculate greywater system sizing and annual water savings from reusing shower, sink, and laundry water for irrigation and toilet flushing.";
const relatedCalcs = [
  { name: "Rainwater Harvesting", url: "/rainwater-harvesting-calculator", description: "Rain collection." },
  { name: "Water Conservation", url: "/water-conservation-calculator", description: "Water savings." },
  { name: "Water Intake", url: "/water-intake-calculator", description: "Daily water needs." },
  { name: "Green Building", url: "/green-building-calculator", description: "Green certifications." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Waste Diversion", url: "/waste-diversion-calculator", description: "Waste reduction." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Greywater Reuse Calculator" keywords="greywater reuse calculator, greywater system sizing, water recycling, greywater savings, laundry to landscape" breadcrumbs={[{ name: "Greywater Reuse", url: "/greywater-reuse-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Greywater Reuse Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Size a greywater system and estimate annual water and cost savings.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Household Water Sources</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">People in Household</label><input type="number" id="gwr-people" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" max="12" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Showers/Day (total)</label><input type="number" id="gwr-showers" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="0" max="20" step="1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Avg Shower (min)</label><input type="number" id="gwr-showmin" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="3" max="30" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Shower Flow (gpm)</label><input type="number" id="gwr-flow" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2.0" min="1" max="5" step="0.1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Laundry Loads/Week</label><input type="number" id="gwr-laundry" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0" max="20" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Gallons per Load</label><input type="number" id="gwr-loadgal" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="5" max="50" step="5"></div>
        </div>
        <h3 class="font-semibold text-text">Economics</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Water Cost ($/1000 gal)</label><input type="number" id="gwr-watercost" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" max="30" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Sewer Cost ($/1000 gal)</label><input type="number" id="gwr-sewercost" class="gwr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="0" max="30" step="0.5"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Daily Greywater Available</div>
          <div class="text-4xl font-extrabold" id="gwr-daily">0</div>
          <div class="text-sm text-blue-200 mt-1">gallons/day</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Volume</div><div class="text-xl font-bold" id="gwr-annual">0 gal</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Surge Tank Size</div><div class="text-xl font-bold" id="gwr-tank">0 gal</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Water Savings</div><div class="text-xl font-bold" id="gwr-savings">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Irrigation Coverage</div><div class="text-xl font-bold" id="gwr-irrig">0 sq ft</div></div>
        </div>
      </div>
      <ShareButton calculatorId="greywater-reuse" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Greywater Reuse</h2>
      <p>Greywater includes water from showers, bathroom sinks, and laundry (not kitchen or toilet water). It can be reused for subsurface irrigation and in some areas for toilet flushing. A typical household generates 30-50 gallons of greywater per person per day. Reuse can reduce household water consumption by 30-50% and lower sewer fees. Surge tanks should hold at least 1.5x the daily peak flow.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcGWR() {
      const people = parseFloat((document.getElementById('gwr-people') as HTMLInputElement).value) || 4;
      const showers = parseFloat((document.getElementById('gwr-showers') as HTMLInputElement).value) || 4;
      const showMin = parseFloat((document.getElementById('gwr-showmin') as HTMLInputElement).value) || 8;
      const flow = parseFloat((document.getElementById('gwr-flow') as HTMLInputElement).value) || 2.0;
      const laundry = parseFloat((document.getElementById('gwr-laundry') as HTMLInputElement).value) || 5;
      const loadGal = parseFloat((document.getElementById('gwr-loadgal') as HTMLInputElement).value) || 20;
      const waterCost = parseFloat((document.getElementById('gwr-watercost') as HTMLInputElement).value) || 8;
      const sewerCost = parseFloat((document.getElementById('gwr-sewercost') as HTMLInputElement).value) || 6;
      const showerGal = showers * showMin * flow;
      const sinkGal = people * 3;
      const laundryDaily = laundry * loadGal / 7;
      const dailyGW = showerGal + sinkGal + laundryDaily;
      const annualGal = dailyGW * 365;
      const tankSize = Math.ceil(dailyGW * 1.5 / 10) * 10;
      const totalSavedCost = annualGal / 1000 * (waterCost + sewerCost);
      const irrigArea = Math.round(dailyGW / 0.03);
      document.getElementById('gwr-daily')!.textContent = Math.round(dailyGW).toLocaleString();
      document.getElementById('gwr-annual')!.textContent = Math.round(annualGal).toLocaleString() + ' gal';
      document.getElementById('gwr-tank')!.textContent = tankSize + ' gal';
      document.getElementById('gwr-savings')!.textContent = '$' + Math.round(totalSavedCost).toLocaleString();
      document.getElementById('gwr-irrig')!.textContent = irrigArea.toLocaleString() + ' sq ft';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.gwr-in').forEach(el => { el.addEventListener('input', calcGWR); el.addEventListener('change', calcGWR); }); calcGWR(); }, 50);
  </script>
</CalculatorLayout>
