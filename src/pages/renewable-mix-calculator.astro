---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Renewable Mix Calculator - Energy Portfolio Optimizer";
const description = "Optimize your renewable energy portfolio mix across solar, wind, hydro, biomass, and geothermal to meet demand targets and minimize cost.";
const relatedCalcs = [
  { name: "Solar Panel", url: "/solar-panel-calculator", description: "Solar sizing." },
  { name: "Wind Turbine", url: "/wind-turbine-calculator", description: "Wind output." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Battery Storage", url: "/battery-storage-calculator", description: "Battery sizing." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Net Metering", url: "/net-metering-calculator", description: "Net metering." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Renewable Mix Calculator" keywords="renewable energy mix calculator, energy portfolio optimizer, solar wind mix, renewable energy planning, clean energy portfolio" breadcrumbs={[{ name: "Renewable Mix", url: "/renewable-mix-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Renewable Mix Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Design your renewable energy portfolio and estimate annual output by source.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Target Demand</h3>
        <div><label class="block text-xs font-medium text-text mb-1">Annual Energy Need (MWh)</label><input type="number" id="rmx-demand" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="100" min="1" max="100000" step="10"></div>
        <h3 class="font-semibold text-text">Solar PV</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Capacity (kW)</label><input type="number" id="rmx-solar" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="50" min="0" max="50000" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Capacity Factor (%)</label><input type="number" id="rmx-solcf" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18" min="10" max="30" step="1"></div>
        </div>
        <h3 class="font-semibold text-text">Wind</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Capacity (kW)</label><input type="number" id="rmx-wind" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" max="50000" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Capacity Factor (%)</label><input type="number" id="rmx-wndcf" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="28" min="15" max="50" step="1"></div>
        </div>
        <h3 class="font-semibold text-text">Other Sources</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Hydro (kW)</label><input type="number" id="rmx-hydro" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" max="50000" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Biomass (kW)</label><input type="number" id="rmx-bio" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0" max="50000" step="5"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Geothermal (kW)</label><input type="number" id="rmx-geo" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" max="50000" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">LCOE avg ($/MWh)</label><input type="number" id="rmx-lcoe" class="rmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="45" min="10" max="200" step="5"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Annual Generation</div>
          <div class="text-4xl font-extrabold" id="rmx-total">0</div>
          <div class="text-sm text-blue-200 mt-1">MWh/year</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Demand Coverage</div><div class="text-xl font-bold" id="rmx-cover">0%</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Cost</div><div class="text-xl font-bold" id="rmx-cost">$0</div></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl">
          <h3 class="font-semibold text-sm text-text mb-3">Portfolio Mix</h3>
          <div class="space-y-2" id="rmx-breakdown"></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">CO₂ Avoided</div>
          <div class="text-2xl font-bold" id="rmx-co2">0 tons/yr</div>
        </div>
      </div>
      <ShareButton calculatorId="renewable-mix" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Renewable Energy Portfolio Planning</h2>
      <p>A diversified renewable portfolio reduces intermittency risk. Solar and wind are complementary: solar peaks midday while wind often peaks at night. Capacity factor represents actual output versus nameplate capacity: solar averages 15-25%, onshore wind 25-45%, hydro 30-60%, biomass 70-90%, and geothermal 80-95%. Baseload renewables (biomass, geothermal) provide stability while variable renewables (solar, wind) offer lower costs.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcRMX() {
      const demand = parseFloat((document.getElementById('rmx-demand') as HTMLInputElement).value) || 100;
      const solarKW = parseFloat((document.getElementById('rmx-solar') as HTMLInputElement).value) || 0;
      const solCF = parseFloat((document.getElementById('rmx-solcf') as HTMLInputElement).value) || 18;
      const windKW = parseFloat((document.getElementById('rmx-wind') as HTMLInputElement).value) || 0;
      const wndCF = parseFloat((document.getElementById('rmx-wndcf') as HTMLInputElement).value) || 28;
      const hydroKW = parseFloat((document.getElementById('rmx-hydro') as HTMLInputElement).value) || 0;
      const bioKW = parseFloat((document.getElementById('rmx-bio') as HTMLInputElement).value) || 0;
      const geoKW = parseFloat((document.getElementById('rmx-geo') as HTMLInputElement).value) || 0;
      const lcoe = parseFloat((document.getElementById('rmx-lcoe') as HTMLInputElement).value) || 45;
      const solarMWh = solarKW * 8760 * (solCF / 100) / 1000;
      const windMWh = windKW * 8760 * (wndCF / 100) / 1000;
      const hydroMWh = hydroKW * 8760 * 0.40 / 1000;
      const bioMWh = bioKW * 8760 * 0.80 / 1000;
      const geoMWh = geoKW * 8760 * 0.90 / 1000;
      const totalMWh = solarMWh + windMWh + hydroMWh + bioMWh + geoMWh;
      const coverage = demand > 0 ? Math.min(totalMWh / demand * 100, 999) : 0;
      const annualCost = totalMWh * lcoe;
      const co2 = totalMWh * 0.417;
      const sources = [
        { name: 'Solar', val: solarMWh },
        { name: 'Wind', val: windMWh },
        { name: 'Hydro', val: hydroMWh },
        { name: 'Biomass', val: bioMWh },
        { name: 'Geothermal', val: geoMWh }
      ];
      document.getElementById('rmx-total')!.textContent = totalMWh.toFixed(1);
      document.getElementById('rmx-cover')!.textContent = coverage.toFixed(0) + '%';
      document.getElementById('rmx-cost')!.textContent = '$' + Math.round(annualCost).toLocaleString();
      document.getElementById('rmx-co2')!.textContent = Math.round(co2).toLocaleString() + ' tons/yr';
      const maxVal = Math.max(...sources.map(s => s.val), 0.1);
      document.getElementById('rmx-breakdown')!.innerHTML = sources
        .filter(s => s.val > 0)
        .map(s => {
          const pct = totalMWh > 0 ? (s.val / totalMWh * 100).toFixed(0) : '0';
          return `<div class="flex justify-between items-center"><span class="text-sm">${s.name}</span><div class="flex items-center gap-2"><div class="w-24 bg-gray-200 rounded-full h-2"><div class="bg-primary rounded-full h-2" style="width:${pct}%"></div></div><span class="text-sm font-bold">${s.val.toFixed(1)} MWh (${pct}%)</span></div></div>`;
        }).join('');
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.rmx-in').forEach(el => { el.addEventListener('input', calcRMX); el.addEventListener('change', calcRMX); }); calcRMX(); }, 50);
  </script>
</CalculatorLayout>
