---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Tuckpointing Calculator - Mortar Quantity & Labor Estimation";
const description = "Calculate tuckpointing mortar quantity and labor hours for repointing brick and block walls. Estimate material costs and project duration.";

const relatedCalcs = [
  { name: "Mortar Calculator", url: "/mortar-calculator", description: "Mortar estimator." },
  { name: "Brick Calculator", url: "/brick-calculator", description: "Brick quantity." },
  { name: "Masonry Mortar Calculator", url: "/masonry-mortar-calculator", description: "Mortar by type." },
  { name: "Block Wall Calculator", url: "/block-wall-calculator", description: "CMU block calculator." },
  { name: "Veneer Stone Calculator", url: "/veneer-stone-calculator", description: "Stone veneer." },
  { name: "Concrete Sealer Calculator", url: "/concrete-sealer-calculator", description: "Sealer coverage." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Tuckpointing Calculator"
  keywords="tuckpointing calculator, repointing, mortar joints, brick repointing, tuckpointing cost, tuckpointing mortar"
  breadcrumbs={[{ name: "Tuckpointing Calculator", url: "/tuckpointing-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Tuckpointing Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate mortar, labor, and time for repointing deteriorated brick and block joints.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Length (ft)</label>
            <input type="number" id="tkp-length" class="tkp-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Height (ft)</label>
            <input type="number" id="tkp-height" class="tkp-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="1" step="0.5">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Masonry Unit</label>
          <select id="tkp-unit" class="tkp-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="standard" selected>Standard Brick (8 x 2.25 in face)</option>
            <option value="modular">Modular Brick (7.625 x 2.25 in face)</option>
            <option value="king">King Size Brick (9.625 x 2.75 in face)</option>
            <option value="cmu">CMU Block (15.625 x 7.625 in face)</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Joint Width (in)</label>
            <select id="tkp-width" class="tkp-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="0.375" selected>3/8 inch</option>
              <option value="0.5">1/2 inch</option>
              <option value="0.625">5/8 inch</option>
              <option value="0.75">3/4 inch</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Grind Depth (in)</label>
            <select id="tkp-depth" class="tkp-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
              <option value="0.5">1/2 inch</option>
              <option value="0.75" selected>3/4 inch (standard)</option>
              <option value="1.0">1 inch (deep)</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Area Needing Repair (%)</label>
          <input type="number" id="tkp-pct" class="tkp-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="100" min="10" max="100" step="5">
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <label class="block text-xs font-medium text-text mb-1">Labor Rate ($/hr)</label>
          <input type="number" id="tkp-rate" class="tkp-in w-full px-3 py-2 border border-border rounded-lg" value="65" min="0" step="5">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Mortar Bags Needed (80 lb)</div>
          <div class="text-4xl font-extrabold" id="tkp-bags">0</div>
          <div class="text-sm text-blue-200 mt-1">Type N or S pre-mixed mortar</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Mortar Volume</div>
            <div class="text-xl font-bold" id="tkp-vol">0 cu ft</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Joint Linear Feet</div>
            <div class="text-xl font-bold" id="tkp-linft">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Estimated Labor Hours</div>
            <div class="text-xl font-bold" id="tkp-hours">0 hrs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Estimated Labor Cost</div>
            <div class="text-xl font-bold" id="tkp-labor-cost">$0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Repair Area</div>
            <div class="text-xl font-bold" id="tkp-area">0 sq ft</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Est. Project Days</div>
            <div class="text-xl font-bold" id="tkp-days">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="tuckpointing" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Tuckpointing Guide</h2>
      <ul>
        <li><strong>Grind depth:</strong> Minimum 3/4" for proper bond (2x joint width)</li>
        <li><strong>Production rate:</strong> ~20-30 sq ft/hr for experienced mason</li>
        <li><strong>Mortar match:</strong> Match type and color of original mortar</li>
        <li><strong>Curing:</strong> Mist with water for 3 days; avoid freezing temps</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    const tkpUnitSizes: Record<string, { w: number; h: number }> = {
      standard: { w: 8, h: 2.25 },
      modular:  { w: 7.625, h: 2.25 },
      king:     { w: 9.625, h: 2.75 },
      cmu:      { w: 15.625, h: 7.625 },
    };

    function calcTKP() {
      const wallL = parseFloat((document.getElementById('tkp-length') as HTMLInputElement).value) || 0;
      const wallH = parseFloat((document.getElementById('tkp-height') as HTMLInputElement).value) || 0;
      const unitType = (document.getElementById('tkp-unit') as HTMLSelectElement).value;
      const jointW = parseFloat((document.getElementById('tkp-width') as HTMLSelectElement).value) || 0.375;
      const grindDepth = parseFloat((document.getElementById('tkp-depth') as HTMLSelectElement).value) || 0.75;
      const repairPct = (parseFloat((document.getElementById('tkp-pct') as HTMLInputElement).value) || 100) / 100;
      const laborRate = parseFloat((document.getElementById('tkp-rate') as HTMLInputElement).value) || 65;

      const unit = tkpUnitSizes[unitType] || tkpUnitSizes.standard;
      const area = wallL * wallH;
      const repairArea = area * repairPct;

      // Units per sq ft
      const courseH = (unit.h + jointW) / 12;
      const unitL = (unit.w + jointW) / 12;
      const unitsPerSqFt = 1 / (courseH * unitL);
      const totalUnits = Math.ceil(unitsPerSqFt * repairArea);

      // Joint linear feet: bed joints + head joints per unit
      const bedLinFt = totalUnits * (unit.w / 12); // horizontal joints
      const headLinFt = totalUnits * (unit.h / 12); // vertical joints
      const totalLinFt = bedLinFt + headLinFt;

      // Mortar volume: cross section = jointWidth x grindDepth, along total linear feet
      const mortarCuFt = totalLinFt * (jointW / 12) * (grindDepth / 12);
      const mortarWithWaste = mortarCuFt * 1.15; // 15% waste
      const bags = Math.ceil(mortarWithWaste / 0.5);

      // Labor: ~25 sq ft/hr for brick tuckpointing
      const prodRate = unitType === 'cmu' ? 40 : 25;
      const laborHrs = repairArea / prodRate;
      const laborCost = laborHrs * laborRate;
      const projectDays = Math.ceil(laborHrs / 8);

      document.getElementById('tkp-bags')!.textContent = String(bags);
      document.getElementById('tkp-vol')!.textContent = mortarWithWaste.toFixed(1) + ' cu ft';
      document.getElementById('tkp-linft')!.textContent = Math.round(totalLinFt).toLocaleString();
      document.getElementById('tkp-hours')!.textContent = laborHrs.toFixed(1) + ' hrs';
      document.getElementById('tkp-labor-cost')!.textContent = '$' + Math.round(laborCost).toLocaleString();
      document.getElementById('tkp-area')!.textContent = Math.round(repairArea) + ' sq ft';
      document.getElementById('tkp-days')!.textContent = String(projectDays);

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.tkp-in').forEach(el => {
        el.addEventListener('input', calcTKP);
        el.addEventListener('change', calcTKP);
      });
      calcTKP();
    }, 50);
  </script>
</CalculatorLayout>
