---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Artifact Illustration Calculator - Scale Factor & Drawing Measurements";
const description = "Calculate scale factors, drawing dimensions, and reduction ratios for archaeological artifact illustrations. Convert between real and drawing measurements.";
const relatedCalcs = [
  { name: "Ceramic Analysis", url: "/ceramic-analysis-calculator", description: "Pottery analysis." },
  { name: "Lithic Analysis", url: "/lithic-analysis-calculator", description: "Stone tool analysis." },
  { name: "Bone Measurement", url: "/bone-measurement-calculator", description: "Skeletal measurements." },
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Aspect Ratio", url: "/aspect-ratio-calculator", description: "Ratio calculations." },
  { name: "Screen Size", url: "/screen-size-calculator", description: "Size calculations." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Artifact Illustration Calculator" keywords="artifact illustration, scale factor, drawing scale, archaeological illustration, reduction ratio, 1:1 scale, artifact drawing" breadcrumbs={[{ name: "Artifact Illustration", url: "/artifact-illustration-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Artifact Illustration Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate scale factors and drawing dimensions for archaeological artifact illustrations. Convert between actual and illustration measurements at various scales.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Actual Object Length (mm)</label>
          <input type="number" id="ail-actual" class="ail-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="85" min="0.1" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Actual Object Width (mm)</label>
          <input type="number" id="ail-width" class="ail-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="45" min="0.1" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Actual Object Thickness (mm)</label>
          <input type="number" id="ail-thick" class="ail-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="0.1" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Drawing Scale</label>
          <select id="ail-scale" class="ail-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="2">2:1 (double size)</option>
            <option value="1" selected>1:1 (full size)</option>
            <option value="0.75">3:4 (three-quarter)</option>
            <option value="0.5">1:2 (half size)</option>
            <option value="0.333">1:3 (one-third)</option>
            <option value="0.25">1:4 (one-quarter)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Publication Reduction (%)</label>
          <input type="number" id="ail-reduce" class="ail-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="50" min="10" max="100" step="5">
          <p class="text-xs text-text-muted mt-1">Typical: 50% for most publications, 33% for large objects</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Desired Line Weight at Publication (mm)</label>
          <input type="number" id="ail-publine" class="ail-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.3" min="0.1" max="2" step="0.05">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Drawing Length</div>
          <div class="text-4xl font-extrabold" id="ail-drawlen">0</div>
          <div class="text-sm text-blue-200 mt-1" id="ail-scalestr">at scale</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Drawing Width</div>
            <div class="text-xl font-bold" id="ail-drawwid">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Drawing Thickness</div>
            <div class="text-xl font-bold" id="ail-drawthk">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Published Length</div>
            <div class="text-xl font-bold" id="ail-publen">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Published Scale</div>
            <div class="text-xl font-bold" id="ail-pubscale">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Draw Line Weight</div>
            <div class="text-xl font-bold" id="ail-drawline">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Scale Bar (drawing)</div>
            <div class="text-xl font-bold" id="ail-scalebar">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="artifact-illustration" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Artifact Illustration Scale Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Drawing Size</strong> = Actual Size * Scale Factor</p>
        <p><strong>Published Size</strong> = Drawing Size * (Reduction % / 100)</p>
        <p><strong>Draw Line Weight</strong> = Pub Line Weight / (Reduction / 100)</p>
      </div>
      <p>Archaeological illustrations must include a scale bar and note the drawing scale. Standard practice is to draw at 1:1 for most artifacts, 2:1 for small finds, and 1:2 or smaller for large objects. Line weights must account for publication reduction to remain visible in print.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcAIL() {
      const actual = parseFloat((document.getElementById('ail-actual') as HTMLInputElement).value) || 0;
      const width = parseFloat((document.getElementById('ail-width') as HTMLInputElement).value) || 0;
      const thick = parseFloat((document.getElementById('ail-thick') as HTMLInputElement).value) || 0;
      const scale = parseFloat((document.getElementById('ail-scale') as HTMLSelectElement).value) || 1;
      const reducePct = parseFloat((document.getElementById('ail-reduce') as HTMLInputElement).value) || 100;
      const pubLine = parseFloat((document.getElementById('ail-publine') as HTMLInputElement).value) || 0.3;

      const drawLen = actual * scale;
      const drawWid = width * scale;
      const drawThk = thick * scale;
      const reduceFactor = reducePct / 100;
      const pubLen = drawLen * reduceFactor;
      const pubScale = scale * reduceFactor;
      const drawLine = pubLine / reduceFactor;
      const scaleBarReal = 50;
      const scaleBarDraw = scaleBarReal * scale;

      let scaleStr = '';
      if (scale >= 1) scaleStr = scale + ':1';
      else scaleStr = '1:' + (1 / scale).toFixed(0);

      let pubScaleStr = '';
      if (pubScale >= 1) pubScaleStr = pubScale.toFixed(2) + ':1';
      else pubScaleStr = '1:' + (1 / pubScale).toFixed(1);

      document.getElementById('ail-drawlen')!.textContent = drawLen.toFixed(1) + ' mm';
      document.getElementById('ail-scalestr')!.textContent = 'at ' + scaleStr + ' scale';
      document.getElementById('ail-drawwid')!.textContent = drawWid.toFixed(1) + ' mm';
      document.getElementById('ail-drawthk')!.textContent = drawThk.toFixed(1) + ' mm';
      document.getElementById('ail-publen')!.textContent = pubLen.toFixed(1) + ' mm';
      document.getElementById('ail-pubscale')!.textContent = pubScaleStr;
      document.getElementById('ail-drawline')!.textContent = drawLine.toFixed(2) + ' mm';
      document.getElementById('ail-scalebar')!.textContent = scaleBarDraw.toFixed(1) + ' mm = 5 cm';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.ail-in').forEach(el => { el.addEventListener('input', calcAIL); el.addEventListener('change', calcAIL); });
      calcAIL();
    }, 50);
  </script>
</CalculatorLayout>
