---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Tutoring Cost Calculator - Compare Tutoring Options & Prices";
const description = "Compare tutoring costs across in-person, online, group, and private options. Estimate monthly and annual tutoring expenses by subject and level.";

const relatedCalcs = [
  { name: "School Supply Calculator", url: "/school-supply-calculator", description: "School costs." },
  { name: "Homeschool Cost Calculator", url: "/homeschool-cost-calculator", description: "Homeschool budget." },
  { name: "College Fund Calculator", url: "/college-fund-calculator", description: "College savings." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare costs." },
  { name: "Allowance Calculator", url: "/allowance-calculator", description: "Kids allowance." },
  { name: "Budget Calculator", url: "/budget-calculator", description: "Family budget." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Tutoring Cost Calculator"
  keywords="tutoring cost calculator, private tutor cost, online tutoring prices, group tutoring cost, how much does tutoring cost, tutor rates"
  breadcrumbs={[{ name: "Tutoring Cost Calculator", url: "/tutoring-cost-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Tutoring Cost Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Compare tutoring costs by format, subject, and frequency to find the best option for your budget.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Tutoring Format</label>
          <select id="tuc-format" class="tuc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="private-person" selected>Private In-Person</option>
            <option value="private-online">Private Online</option>
            <option value="group-person">Group In-Person (3-6 students)</option>
            <option value="group-online">Group Online</option>
            <option value="learning-center">Learning Center (Kumon, Sylvan, etc.)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Subject</label>
          <select id="tuc-subject" class="tuc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="general" selected>General / Homework Help</option>
            <option value="math">Math</option>
            <option value="reading">Reading / Writing</option>
            <option value="science">Science</option>
            <option value="language">Foreign Language</option>
            <option value="test">Test Prep (SAT/ACT)</option>
            <option value="music">Music / Instrument</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Student Level</label>
          <select id="tuc-level" class="tuc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="elementary">Elementary School</option>
            <option value="middle" selected>Middle School</option>
            <option value="high">High School</option>
            <option value="ap">AP / Advanced</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Sessions Per Week</label>
          <input type="number" id="tuc-sessions" class="tuc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="1" max="7" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Session Duration (minutes)</label>
          <select id="tuc-duration" class="tuc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="30">30 minutes</option>
            <option value="45">45 minutes</option>
            <option value="60" selected>60 minutes (1 hour)</option>
            <option value="90">90 minutes</option>
            <option value="120">120 minutes (2 hours)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Students (your children)</label>
          <input type="number" id="tuc-students" class="tuc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="1" max="5" step="1">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Monthly Tutoring Cost</div>
        <div class="text-5xl font-extrabold" id="tuc-monthly">--</div>
        <div class="text-sm text-blue-200 mt-1" id="tuc-perhour">per hour rate</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Per Session</div>
          <div class="text-lg font-bold" id="tuc-persession">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Weekly Cost</div>
          <div class="text-lg font-bold" id="tuc-weekly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Annual Cost</div>
          <div class="text-lg font-bold" id="tuc-annual">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Sessions/Month</div>
          <div class="text-lg font-bold" id="tuc-sessmonth">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Format Comparison</h3>
        <div class="text-xs" id="tuc-comparison"></div>
      </div>

      <ShareButton calculatorId="tutoring-cost" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Tutoring Costs</h2>
      <p>Tutoring rates vary widely based on format, subject, tutor qualifications, and location. Private in-person tutoring is the most expensive, while group and online options offer more affordable alternatives.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Average Tutoring Rates</h3>
      <ul>
        <li><strong>Private In-Person:</strong> $40-$100/hour</li>
        <li><strong>Private Online:</strong> $25-$80/hour</li>
        <li><strong>Group (In-Person):</strong> $15-$40/hour</li>
        <li><strong>Group Online:</strong> $10-$30/hour</li>
        <li><strong>Learning Centers:</strong> $150-$400/month</li>
        <li><strong>Test Prep:</strong> $50-$200/hour</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">How to Choose a Tutor</h3>
      <ul>
        <li>Check qualifications and teaching experience</li>
        <li>Ask for references and reviews</li>
        <li>Start with a trial session before committing</li>
        <li>Discuss goals and progress tracking</li>
        <li>Consider whether your child learns better one-on-one or in groups</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcTUC() {
      const format = (document.getElementById('tuc-format') as HTMLSelectElement).value;
      const subject = (document.getElementById('tuc-subject') as HTMLSelectElement).value;
      const level = (document.getElementById('tuc-level') as HTMLSelectElement).value;
      const sessions = parseFloat((document.getElementById('tuc-sessions') as HTMLInputElement).value) || 2;
      const duration = parseFloat((document.getElementById('tuc-duration') as HTMLSelectElement).value) || 60;
      const students = parseFloat((document.getElementById('tuc-students') as HTMLInputElement).value) || 1;

      // Base hourly rates by format
      const baseRate: Record<string, number> = {
        'private-person': 60, 'private-online': 45, 'group-person': 25,
        'group-online': 18, 'learning-center': 35
      };

      // Subject multipliers
      const subjectMult: Record<string, number> = {
        general: 1.0, math: 1.1, reading: 1.0, science: 1.15,
        language: 1.2, test: 1.5, music: 1.3
      };

      // Level multipliers
      const levelMult: Record<string, number> = {
        elementary: 0.85, middle: 1.0, high: 1.15, ap: 1.35
      };

      const hourlyRate = Math.round(baseRate[format] * subjectMult[subject] * levelMult[level]);
      const sessionCost = Math.round(hourlyRate * (duration / 60));
      const weeklyTotal = sessionCost * sessions * students;
      const monthlyTotal = Math.round(weeklyTotal * 4.33);
      const annualTotal = weeklyTotal * 44; // ~10 month school year
      const sessionsPerMonth = Math.round(sessions * 4.33);

      document.getElementById('tuc-monthly')!.textContent = '$' + monthlyTotal.toLocaleString();
      document.getElementById('tuc-perhour')!.textContent = '$' + hourlyRate + '/hour';
      document.getElementById('tuc-persession')!.textContent = '$' + sessionCost;
      document.getElementById('tuc-weekly')!.textContent = '$' + weeklyTotal;
      document.getElementById('tuc-annual')!.textContent = '$' + annualTotal.toLocaleString();
      document.getElementById('tuc-sessmonth')!.textContent = String(sessionsPerMonth);

      // Comparison
      const formats = ['private-person', 'private-online', 'group-person', 'group-online', 'learning-center'];
      const formatNames: Record<string, string> = {
        'private-person': 'Private In-Person', 'private-online': 'Private Online',
        'group-person': 'Group In-Person', 'group-online': 'Group Online',
        'learning-center': 'Learning Center'
      };

      document.getElementById('tuc-comparison')!.innerHTML =
        '<div class="grid grid-cols-4 gap-2 font-semibold text-text-muted mb-1"><span>Format</span><span class="text-right">/Hour</span><span class="text-right">/Session</span><span class="text-right">/Month</span></div>' +
        formats.map(f => {
          const rate = Math.round(baseRate[f] * subjectMult[subject] * levelMult[level]);
          const sess = Math.round(rate * (duration / 60));
          const mo = Math.round(sess * sessions * students * 4.33);
          const isSelected = f === format;
          return `<div class="grid grid-cols-4 gap-2 py-1 ${isSelected ? 'bg-blue-50 rounded font-bold' : ''}"><span>${formatNames[f]}</span><span class="text-right">$${rate}</span><span class="text-right">$${sess}</span><span class="text-right">$${mo}</span></div>`;
        }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.tuc-in').forEach(el => {
        el.addEventListener('input', calcTUC);
        el.addEventListener('change', calcTUC);
      });
      calcTUC();
    }, 50);
  </script>
</CalculatorLayout>
