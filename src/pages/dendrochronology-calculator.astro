---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Dendrochronology Calculator - Tree Ring Dating & Growth Rate";
const description = "Calculate tree age from ring counts, analyze growth rates, estimate missing rings, and determine calendar dates from dendrochronological data.";
const relatedCalcs = [
  { name: "Radiocarbon Dating", url: "/radiocarbon-dating-calculator", description: "C-14 age calculation." },
  { name: "Stratigraphy", url: "/stratigraphy-calculator", description: "Layer age estimation." },
  { name: "Fossil Age", url: "/fossil-age-calculator", description: "Multi-method dating." },
  { name: "Luminescence Dating", url: "/luminescence-dating-calculator", description: "OSL/TL dating." },
  { name: "Obsidian Hydration", url: "/obsidian-hydration-calculator", description: "Obsidian rim dating." },
  { name: "Stable Isotope", url: "/stable-isotope-calculator", description: "Isotope analysis." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Dendrochronology Calculator" keywords="dendrochronology, tree ring dating, growth rate, ring width, tree age, cross dating, master chronology" breadcrumbs={[{ name: "Dendrochronology", url: "/dendrochronology-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Dendrochronology Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Analyze tree ring data to determine age, growth rates, and calendar dates. Useful for dating wooden structures, artifacts, and climate reconstruction.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Rings Counted</label>
          <input type="number" id="dnd-rings" class="dnd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="150" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Outermost Ring Year (AD/BC)</label>
          <input type="number" id="dnd-outyear" class="dnd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1850" step="1">
          <p class="text-xs text-text-muted mt-1">Use negative for BC (e.g., -500 for 500 BC)</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Trunk Radius at Breast Height (cm)</label>
          <input type="number" id="dnd-radius" class="dnd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="0.1" step="0.1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Estimated Missing Rings (pith/bark)</label>
          <input type="number" id="dnd-missing" class="dnd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Has Bark Edge?</label>
          <select id="dnd-bark" class="dnd-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="yes">Yes - cutting/felling date is exact</option>
            <option value="no">No - date is terminus post quem</option>
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Estimated Tree Age</div>
          <div class="text-4xl font-extrabold" id="dnd-age">0</div>
          <div class="text-sm text-blue-200 mt-1" id="dnd-dating">years</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Innermost Ring Year</div>
            <div class="text-xl font-bold" id="dnd-inyr">--</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Avg Ring Width</div>
            <div class="text-xl font-bold" id="dnd-avgwidth">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Growth Rate</div>
            <div class="text-xl font-bold" id="dnd-growth">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Diameter at BH</div>
            <div class="text-xl font-bold" id="dnd-diameter">0</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Date Interpretation</div>
          <div class="text-sm font-bold" id="dnd-interp">--</div>
        </div>
      </div>

      <ShareButton calculatorId="dendrochronology" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Dendrochronology Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Total Age</strong> = Ring Count + Missing Rings</p>
        <p><strong>Innermost Year</strong> = Outermost Year - Ring Count - Missing Rings + 1</p>
        <p><strong>Avg Ring Width</strong> = Radius / Ring Count</p>
      </div>
      <p>Dendrochronology provides one of the most precise dating methods available. Each ring represents one year of growth, and ring-width patterns can be matched to master chronologies extending thousands of years. The presence of bark edge confirms the exact felling date.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcDND() {
      const rings = parseFloat((document.getElementById('dnd-rings') as HTMLInputElement).value) || 0;
      const outYear = parseFloat((document.getElementById('dnd-outyear') as HTMLInputElement).value) || 0;
      const radius = parseFloat((document.getElementById('dnd-radius') as HTMLInputElement).value) || 0;
      const missing = parseFloat((document.getElementById('dnd-missing') as HTMLInputElement).value) || 0;
      const hasBark = (document.getElementById('dnd-bark') as HTMLSelectElement).value;

      const totalAge = rings + missing;
      const innerYear = outYear - rings - missing + 1;
      const avgWidth = rings > 0 ? radius / rings : 0;
      const growthRate = rings > 0 ? (radius * 2) / rings : 0;
      const diameter = radius * 2;

      const formatYear = (yr: number) => {
        if (yr <= 0) return Math.abs(yr - 1) + ' BC';
        return yr + ' AD';
      };

      let interp = '';
      if (hasBark === 'yes') {
        interp = 'Felling date: ' + formatYear(outYear) + ' (exact, bark edge present)';
      } else {
        interp = 'Terminus post quem: after ' + formatYear(outYear) + ' (no bark edge, outer rings may be missing)';
      }

      document.getElementById('dnd-age')!.textContent = totalAge.toString();
      document.getElementById('dnd-dating')!.textContent = 'years (' + formatYear(innerYear) + ' to ' + formatYear(outYear) + ')';
      document.getElementById('dnd-inyr')!.textContent = formatYear(innerYear);
      document.getElementById('dnd-avgwidth')!.textContent = avgWidth.toFixed(2) + ' mm';
      document.getElementById('dnd-growth')!.textContent = growthRate.toFixed(2) + ' mm/yr';
      document.getElementById('dnd-diameter')!.textContent = diameter.toFixed(1) + ' cm';
      document.getElementById('dnd-interp')!.textContent = interp;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.dnd-in').forEach(el => { el.addEventListener('input', calcDND); el.addEventListener('change', calcDND); });
      calcDND();
    }, 50);
  </script>
</CalculatorLayout>
