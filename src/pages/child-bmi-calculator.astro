---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Child BMI Calculator - BMI Percentile by Age & Gender (CDC)";
const description = "Calculate your child's BMI percentile using CDC growth charts. Determine healthy weight status for children ages 2-20 based on age and gender.";

const relatedCalcs = [
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Height prediction." },
  { name: "Child Nutrition Calculator", url: "/child-nutrition-calculator", description: "Nutrition needs." },
  { name: "BMI Calculator", url: "/bmi-calculator", description: "Adult BMI." },
  { name: "Child Dosage Calculator", url: "/child-dosage-calculator", description: "Medication dosing." },
  { name: "Calorie Calculator", url: "/calorie-calculator", description: "Daily calories." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Development." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Child BMI Calculator"
  keywords="child BMI calculator, pediatric BMI, BMI percentile, child weight status, CDC growth chart, kids BMI calculator"
  breadcrumbs={[{ name: "Child BMI Calculator", url: "/child-bmi-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Child BMI Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate your child's BMI and percentile ranking using CDC growth chart data for ages 2-20.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Gender</label>
          <select id="cbm-gender" class="cbm-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="boy">Boy</option>
            <option value="girl">Girl</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Age</label>
          <div class="flex gap-3">
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Years</label>
              <input type="number" id="cbm-years" class="cbm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="2" max="19" step="1">
            </div>
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Months</label>
              <input type="number" id="cbm-months" class="cbm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" max="11" step="1">
            </div>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Weight (lbs)</label>
          <input type="number" id="cbm-weight" class="cbm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="56" min="15" max="300" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Height</label>
          <div class="flex gap-2">
            <input type="number" id="cbm-feet" class="cbm-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="2" max="6" step="1" placeholder="ft">
            <input type="number" id="cbm-inches" class="cbm-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0" max="11" step="0.5" placeholder="in">
          </div>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">BMI Percentile</div>
        <div class="text-5xl font-extrabold" id="cbm-percentile">--</div>
        <div class="text-sm text-blue-200 mt-1" id="cbm-category">weight status</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">BMI Value</div>
          <div class="text-lg font-bold" id="cbm-bmi">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Weight Status</div>
          <div class="text-lg font-bold" id="cbm-status">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Healthy BMI Range</div>
          <div class="text-lg font-bold" id="cbm-healthy">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Healthy Weight Range</div>
          <div class="text-lg font-bold" id="cbm-weightrange">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">BMI Categories for Children</h3>
        <div class="text-xs" id="cbm-chart"></div>
      </div>

      <ShareButton calculatorId="child-bmi" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Child BMI</h2>
      <p>Unlike adult BMI, child BMI is interpreted using age and sex-specific percentiles because body composition changes as children grow. The CDC growth charts are used for children ages 2-20.</p>

      <h3 class="text-xl font-semibold text-text mt-8">BMI-for-Age Percentile Categories</h3>
      <ul>
        <li><strong>Underweight:</strong> Below 5th percentile</li>
        <li><strong>Healthy Weight:</strong> 5th to 84th percentile</li>
        <li><strong>Overweight:</strong> 85th to 94th percentile</li>
        <li><strong>Obese:</strong> 95th percentile or above</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Important Notes</h3>
      <p>BMI is a screening tool, not a diagnostic tool. A high or low BMI does not necessarily mean a health problem. Talk to your child's pediatrician for a complete assessment including diet, physical activity, and family history.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCBM() {
      const gender = (document.getElementById('cbm-gender') as HTMLSelectElement).value;
      const years = parseFloat((document.getElementById('cbm-years') as HTMLInputElement).value) || 8;
      const months = parseFloat((document.getElementById('cbm-months') as HTMLInputElement).value) || 0;
      const weight = parseFloat((document.getElementById('cbm-weight') as HTMLInputElement).value) || 56;
      const feet = parseFloat((document.getElementById('cbm-feet') as HTMLInputElement).value) || 4;
      const inches = parseFloat((document.getElementById('cbm-inches') as HTMLInputElement).value) || 0;

      const heightIn = feet * 12 + inches;
      const heightM = heightIn * 0.0254;
      const weightKg = weight * 0.453592;
      const bmi = weightKg / (heightM * heightM);
      const ageMonths = years * 12 + months;

      // Simplified CDC LMS approximation for percentile calculation
      // Median BMI by age (approximate CDC 50th percentile values)
      const medianBoy: Record<number, number> = {
        24: 16.5, 36: 16.0, 48: 15.7, 60: 15.5, 72: 15.5, 84: 15.7, 96: 16.0,
        108: 16.5, 120: 17.0, 132: 17.7, 144: 18.5, 156: 19.3, 168: 20.1, 180: 20.9,
        192: 21.6, 204: 22.2, 216: 22.7, 228: 23.1, 240: 23.5
      };
      const medianGirl: Record<number, number> = {
        24: 16.3, 36: 15.8, 48: 15.5, 60: 15.4, 72: 15.5, 84: 15.8, 96: 16.2,
        108: 16.8, 120: 17.5, 132: 18.3, 144: 19.1, 156: 19.9, 168: 20.6, 180: 21.2,
        192: 21.6, 204: 21.9, 216: 22.1, 228: 22.3, 240: 22.5
      };

      const medianData = gender === 'boy' ? medianBoy : medianGirl;
      const ages = Object.keys(medianData).map(Number).sort((a, b) => a - b);

      // Interpolate median
      let median = 16;
      for (let i = 0; i < ages.length - 1; i++) {
        if (ageMonths >= ages[i] && ageMonths <= ages[i + 1]) {
          const frac = (ageMonths - ages[i]) / (ages[i + 1] - ages[i]);
          median = medianData[ages[i]] + frac * (medianData[ages[i + 1]] - medianData[ages[i]]);
          break;
        }
      }
      if (ageMonths >= 240) median = medianData[240];
      if (ageMonths <= 24) median = medianData[24];

      // Approximate z-score using spread
      const spread = gender === 'boy' ? 3.0 : 2.8;
      const z = (bmi - median) / spread;

      // Convert z-score to percentile using approximation
      function zToPercentile(z: number): number {
        const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429;
        const p = 0.3275911;
        const sign = z < 0 ? -1 : 1;
        const x = Math.abs(z) / Math.sqrt(2);
        const t = 1.0 / (1.0 + p * x);
        const erf = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
        return Math.round(((1 + sign * erf) / 2) * 1000) / 10;
      }

      let percentile = zToPercentile(z);
      percentile = Math.max(0.1, Math.min(99.9, percentile));

      let status = '';
      let category = '';
      if (percentile < 5) { status = 'Underweight'; category = 'Below 5th percentile'; }
      else if (percentile < 85) { status = 'Healthy Weight'; category = '5th - 84th percentile'; }
      else if (percentile < 95) { status = 'Overweight'; category = '85th - 94th percentile'; }
      else { status = 'Obese'; category = '95th percentile or above'; }

      // Healthy weight range for this height
      const healthyBmiLow = median - 1.5;
      const healthyBmiHigh = median + 2.5;
      const healthyWeightLow = (healthyBmiLow * heightM * heightM) / 0.453592;
      const healthyWeightHigh = (healthyBmiHigh * heightM * heightM) / 0.453592;

      document.getElementById('cbm-percentile')!.textContent = percentile.toFixed(1) + '%';
      document.getElementById('cbm-category')!.textContent = category;
      document.getElementById('cbm-bmi')!.textContent = bmi.toFixed(1);
      document.getElementById('cbm-status')!.textContent = status;
      document.getElementById('cbm-healthy')!.textContent = healthyBmiLow.toFixed(1) + ' - ' + healthyBmiHigh.toFixed(1);
      document.getElementById('cbm-weightrange')!.textContent = Math.round(healthyWeightLow) + ' - ' + Math.round(healthyWeightHigh) + ' lbs';

      const categories = [
        { name: 'Underweight', range: 'Below 5th', color: percentile < 5 ? 'bg-blue-50 font-bold' : '' },
        { name: 'Healthy Weight', range: '5th - 84th', color: percentile >= 5 && percentile < 85 ? 'bg-blue-50 font-bold' : '' },
        { name: 'Overweight', range: '85th - 94th', color: percentile >= 85 && percentile < 95 ? 'bg-blue-50 font-bold' : '' },
        { name: 'Obese', range: '95th & above', color: percentile >= 95 ? 'bg-blue-50 font-bold' : '' },
      ];

      document.getElementById('cbm-chart')!.innerHTML =
        '<div class="grid grid-cols-2 gap-2 font-semibold text-text-muted mb-1"><span>Category</span><span>Percentile Range</span></div>' +
        categories.map(c => `<div class="grid grid-cols-2 gap-2 py-1 rounded ${c.color}"><span>${c.name}</span><span>${c.range}</span></div>`).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.cbm-in').forEach(el => {
        el.addEventListener('input', calcCBM);
        el.addEventListener('change', calcCBM);
      });
      calcCBM();
    }, 50);
  </script>
</CalculatorLayout>
