---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Concrete Mix Calculator - Design Ratios by Strength Grade";
const description = "Calculate concrete mix design ratios for cement, sand, gravel, and water by target strength. Get precise batch weights for any volume of concrete.";

const relatedCalcs = [
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Volume estimator." },
  { name: "Concrete Slab Calculator", url: "/concrete-slab-calculator", description: "Slab volume calculator." },
  { name: "Concrete Curing Calculator", url: "/concrete-curing-calculator", description: "Curing time estimator." },
  { name: "Rebar Calculator", url: "/rebar-calculator", description: "Rebar requirements." },
  { name: "Mortar Calculator", url: "/mortar-calculator", description: "Mortar estimator." },
  { name: "Concrete Admixture Calculator", url: "/concrete-admixture-calculator", description: "Admixture dosage." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Concrete Mix Calculator"
  keywords="concrete mix design, mix ratio, cement sand gravel ratio, concrete strength, water cement ratio, batch weight"
  breadcrumbs={[{ name: "Concrete Mix Calculator", url: "/concrete-mix-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Concrete Mix Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Design concrete mix ratios for cement, sand, gravel, and water by target strength grade.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Target Strength Grade</label>
          <select id="cmx-grade" class="cmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="2500">2,500 PSI (17 MPa) - Residential Footings</option>
            <option value="3000" selected>3,000 PSI (21 MPa) - Driveways, Sidewalks</option>
            <option value="3500">3,500 PSI (24 MPa) - Structural Slabs</option>
            <option value="4000">4,000 PSI (28 MPa) - Commercial Floors</option>
            <option value="4500">4,500 PSI (31 MPa) - Pre-stressed Members</option>
            <option value="5000">5,000 PSI (34 MPa) - High Strength</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Volume Needed (cubic yards)</label>
          <input type="number" id="cmx-volume" class="cmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="0.1" step="0.1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Aggregate Size</label>
          <select id="cmx-agg" class="cmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="0.375">3/8 inch (10 mm)</option>
            <option value="0.75" selected>3/4 inch (19 mm)</option>
            <option value="1.0">1 inch (25 mm)</option>
            <option value="1.5">1.5 inch (38 mm)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Cement Type</label>
          <select id="cmx-cement" class="cmx-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="I" selected>Type I - General Purpose</option>
            <option value="II">Type II - Moderate Sulfate Resistance</option>
            <option value="III">Type III - High Early Strength</option>
            <option value="V">Type V - High Sulfate Resistance</option>
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Mix Ratio (Cement : Sand : Gravel)</div>
          <div class="text-4xl font-extrabold" id="cmx-ratio">1 : 2 : 3</div>
          <div class="text-sm text-blue-200 mt-1">Water/Cement Ratio: <span id="cmx-wc">0.50</span></div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Cement (94 lb bags)</div>
            <div class="text-2xl font-bold" id="cmx-bags">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Cement Weight</div>
            <div class="text-2xl font-bold" id="cmx-cement-wt">0 lbs</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Sand</div>
            <div class="text-2xl font-bold" id="cmx-sand">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Gravel</div>
            <div class="text-2xl font-bold" id="cmx-gravel">0 lbs</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water</div>
            <div class="text-2xl font-bold" id="cmx-water">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Batch Weight</div>
            <div class="text-2xl font-bold" id="cmx-total">0 lbs</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="concrete-mix" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">How Concrete Mix Design Works</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Water/Cement Ratio:</strong> Lower ratio = higher strength but less workability</p>
        <p><strong>Cement content:</strong> Volume (yd3) x cement factor (bags/yd3)</p>
        <p><strong>Sand &amp; Gravel:</strong> Based on ratio parts relative to cement weight</p>
      </div>

      <h3 class="text-xl font-semibold text-text mt-8">Common Mix Ratios by Strength</h3>
      <ul>
        <li><strong>2,500 PSI:</strong> 1 : 2.5 : 3.5 with W/C 0.62</li>
        <li><strong>3,000 PSI:</strong> 1 : 2 : 3 with W/C 0.55</li>
        <li><strong>4,000 PSI:</strong> 1 : 1.5 : 2.5 with W/C 0.45</li>
        <li><strong>5,000 PSI:</strong> 1 : 1 : 2 with W/C 0.35</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    interface MixDesign {
      ratio: string;
      wc: number;
      cementFactor: number; // bags per cubic yard
      sandRatio: number;
      gravelRatio: number;
    }

    const cmxDesigns: Record<string, MixDesign> = {
      '2500': { ratio: '1 : 2.5 : 3.5', wc: 0.62, cementFactor: 4.5, sandRatio: 2.5, gravelRatio: 3.5 },
      '3000': { ratio: '1 : 2 : 3', wc: 0.55, cementFactor: 5.0, sandRatio: 2.0, gravelRatio: 3.0 },
      '3500': { ratio: '1 : 1.75 : 2.75', wc: 0.50, cementFactor: 5.5, sandRatio: 1.75, gravelRatio: 2.75 },
      '4000': { ratio: '1 : 1.5 : 2.5', wc: 0.45, cementFactor: 6.0, sandRatio: 1.5, gravelRatio: 2.5 },
      '4500': { ratio: '1 : 1.25 : 2.25', wc: 0.40, cementFactor: 6.5, sandRatio: 1.25, gravelRatio: 2.25 },
      '5000': { ratio: '1 : 1 : 2', wc: 0.35, cementFactor: 7.0, sandRatio: 1.0, gravelRatio: 2.0 },
    };

    function calcCMX() {
      const grade = (document.getElementById('cmx-grade') as HTMLSelectElement).value;
      const volume = parseFloat((document.getElementById('cmx-volume') as HTMLInputElement).value) || 0;

      const design = cmxDesigns[grade] || cmxDesigns['3000'];

      const cementBags = design.cementFactor * volume;
      const cementLbs = cementBags * 94;
      const sandLbs = cementLbs * design.sandRatio;
      const gravelLbs = cementLbs * design.gravelRatio;
      const waterLbs = cementLbs * design.wc;
      const waterGal = waterLbs / 8.34;
      const totalLbs = cementLbs + sandLbs + gravelLbs + waterLbs;

      document.getElementById('cmx-ratio')!.textContent = design.ratio;
      document.getElementById('cmx-wc')!.textContent = design.wc.toFixed(2);
      document.getElementById('cmx-bags')!.textContent = Math.ceil(cementBags).toLocaleString();
      document.getElementById('cmx-cement-wt')!.textContent = Math.round(cementLbs).toLocaleString() + ' lbs';
      document.getElementById('cmx-sand')!.textContent = Math.round(sandLbs).toLocaleString() + ' lbs';
      document.getElementById('cmx-gravel')!.textContent = Math.round(gravelLbs).toLocaleString() + ' lbs';
      document.getElementById('cmx-water')!.textContent = waterGal.toFixed(1) + ' gal';
      document.getElementById('cmx-total')!.textContent = Math.round(totalLbs).toLocaleString() + ' lbs';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.cmx-in').forEach(el => {
        el.addEventListener('input', calcCMX);
        el.addEventListener('change', calcCMX);
      });
      calcCMX();
    }, 50);
  </script>
</CalculatorLayout>
