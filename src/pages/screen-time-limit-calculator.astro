---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Screen Time Limit Calculator - AAP Guidelines by Age";
const description = "Calculate age-appropriate screen time limits based on AAP (American Academy of Pediatrics) guidelines. Track daily usage and get personalized recommendations.";

const relatedCalcs = [
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "Child Nutrition Calculator", url: "/child-nutrition-calculator", description: "Nutrition needs." },
  { name: "Potty Training Calculator", url: "/potty-training-readiness-calculator", description: "Potty readiness." },
  { name: "Sleep Calculator", url: "/sleep-calculator", description: "Sleep needs." },
  { name: "Child BMI Calculator", url: "/child-bmi-calculator", description: "BMI percentiles." },
  { name: "Allowance Calculator", url: "/allowance-calculator", description: "Kids allowance." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Screen Time Limit Calculator"
  keywords="screen time calculator, screen time limits by age, AAP screen time guidelines, kids screen time, how much screen time, children screen time"
  breadcrumbs={[{ name: "Screen Time Limit Calculator", url: "/screen-time-limit-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Screen Time Limit Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Find age-appropriate screen time limits based on AAP recommendations and track your child's daily usage.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age (years)</label>
          <input type="number" id="stl-age" class="stl-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="0" max="18" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Current Daily Screen Time (minutes)</label>
          <input type="number" id="stl-current" class="stl-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="90" min="0" max="720" step="5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Primary Screen Activity</label>
          <select id="stl-activity" class="stl-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="educational">Educational Content</option>
            <option value="entertainment" selected>Entertainment / Streaming</option>
            <option value="gaming">Video Games</option>
            <option value="social">Social Media</option>
            <option value="mixed">Mixed</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">School Day or Weekend?</label>
          <select id="stl-daytype" class="stl-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="school" selected>School Day</option>
            <option value="weekend">Weekend / Holiday</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Recommended Daily Limit</div>
        <div class="text-5xl font-extrabold" id="stl-limit">--</div>
        <div class="text-sm text-blue-200 mt-1" id="stl-guideline">AAP guideline</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Current Usage</div>
          <div class="text-lg font-bold" id="stl-usage">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Status</div>
          <div class="text-lg font-bold" id="stl-status">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Weekly Total</div>
          <div class="text-lg font-bold" id="stl-weekly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Suggested Reduction</div>
          <div class="text-lg font-bold" id="stl-reduce">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-4">
        <h3 class="font-semibold text-sm text-text mb-3">AAP Guidelines by Age</h3>
        <div class="text-xs" id="stl-chart"></div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-2">Suggested Daily Schedule</h3>
        <div class="text-sm" id="stl-schedule"></div>
      </div>

      <ShareButton calculatorId="screen-time-limit" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">AAP Screen Time Guidelines</h2>
      <p>The American Academy of Pediatrics provides evidence-based recommendations for children's media use. These guidelines consider developmental needs and the potential effects of screen time on health and learning.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Guidelines by Age</h3>
      <ul>
        <li><strong>Under 18 months:</strong> Avoid screen time except video chatting</li>
        <li><strong>18-24 months:</strong> Introduce high-quality content, watch together</li>
        <li><strong>2-5 years:</strong> Limit to 1 hour per day of high-quality programs</li>
        <li><strong>6+ years:</strong> Set consistent limits, ensure it does not replace sleep, exercise, or social interaction</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Healthy Screen Habits</h3>
      <ul>
        <li>No screens during meals or 1 hour before bedtime</li>
        <li>Keep bedrooms screen-free</li>
        <li>Co-view and discuss content with your child</li>
        <li>Prioritize educational and interactive content</li>
        <li>Model healthy screen habits yourself</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSTL() {
      const age = parseFloat((document.getElementById('stl-age') as HTMLInputElement).value) || 6;
      const current = parseFloat((document.getElementById('stl-current') as HTMLInputElement).value) || 0;
      const activity = (document.getElementById('stl-activity') as HTMLSelectElement).value;
      const daytype = (document.getElementById('stl-daytype') as HTMLSelectElement).value;

      // AAP recommended limits in minutes
      let limit: number;
      let guideline: string;

      if (age < 1.5) {
        limit = 0;
        guideline = 'No screen time except video calls (AAP)';
      } else if (age < 2) {
        limit = 15;
        guideline = 'Minimal, high-quality content with parent (AAP)';
      } else if (age < 6) {
        limit = 60;
        guideline = 'Max 1 hour/day of quality content (AAP)';
      } else if (age < 13) {
        limit = 120;
        guideline = 'Consistent limits, prioritize activity & sleep';
      } else {
        limit = 120;
        guideline = 'Balance with sleep, exercise, and homework';
      }

      // Educational bonus
      if (activity === 'educational' && age >= 2) {
        limit = Math.round(limit * 1.25);
      }

      // Weekend allowance
      if (daytype === 'weekend' && age >= 2) {
        limit = Math.round(limit * 1.25);
      }

      const over = current > limit;
      const diff = current - limit;
      const weeklyHours = (current * 7 / 60).toFixed(1);

      function formatMin(m: number): string {
        if (m < 60) return m + ' min';
        const h = Math.floor(m / 60);
        const r = m % 60;
        return r > 0 ? h + 'h ' + r + 'm' : h + ' hours';
      }

      document.getElementById('stl-limit')!.textContent = formatMin(limit);
      document.getElementById('stl-guideline')!.textContent = guideline;
      document.getElementById('stl-usage')!.textContent = formatMin(current);
      document.getElementById('stl-status')!.textContent = over ? 'Over Limit' : 'Within Limit';
      document.getElementById('stl-weekly')!.textContent = weeklyHours + ' hrs/wk';
      document.getElementById('stl-reduce')!.textContent = over ? formatMin(diff) : 'None needed';

      const guidelines = [
        { ageRange: '0-18 months', rec: 'None (video chat OK)', mins: 0 },
        { ageRange: '18-24 months', rec: '15 min with parent', mins: 15 },
        { ageRange: '2-5 years', rec: '1 hour max', mins: 60 },
        { ageRange: '6-12 years', rec: '1-2 hours', mins: 120 },
        { ageRange: '13-18 years', rec: '2 hours (non-homework)', mins: 120 },
      ];

      const currentRange = age < 1.5 ? 0 : age < 2 ? 1 : age < 6 ? 2 : age < 13 ? 3 : 4;

      document.getElementById('stl-chart')!.innerHTML =
        '<div class="grid grid-cols-3 gap-2 font-semibold text-text-muted mb-1"><span>Age Group</span><span>Recommendation</span><span>Daily Max</span></div>' +
        guidelines.map((g, i) => `<div class="grid grid-cols-3 gap-2 py-1 ${i === currentRange ? 'bg-blue-50 rounded font-bold' : ''}"><span>${g.ageRange}</span><span>${g.rec}</span><span>${formatMin(g.mins)}</span></div>`).join('');

      // Schedule suggestion
      let schedule = '';
      if (age < 1.5) {
        schedule = '<p class="text-text-secondary">Focus on interactive play, reading, and exploration. Video chatting with family is fine.</p>';
      } else if (age < 6) {
        schedule = '<p class="text-text-secondary"><strong>Morning:</strong> No screens -- active play and breakfast<br><strong>Midday:</strong> Up to 30 min educational content<br><strong>Afternoon:</strong> Up to 30 min before dinner<br><strong>Evening:</strong> No screens 1 hour before bed -- stories and calm play</p>';
      } else {
        schedule = '<p class="text-text-secondary"><strong>After school:</strong> Homework first, then up to 1 hour<br><strong>Weekend mornings:</strong> Up to 1 hour after chores/activities<br><strong>Evening:</strong> Up to 30 min, screens off 1 hour before bed<br><strong>Always:</strong> No screens during meals or family time</p>';
      }
      document.getElementById('stl-schedule')!.innerHTML = schedule;

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.stl-in').forEach(el => {
        el.addEventListener('input', calcSTL);
        el.addEventListener('change', calcSTL);
      });
      calcSTL();
    }, 50);
  </script>
</CalculatorLayout>
