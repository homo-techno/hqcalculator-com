---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Rainwater Harvesting Calculator - Collection Volume from Roof Area";
const description = "Calculate potential rainwater collection volume based on roof area, local rainfall, and collection efficiency for sustainable water supply.";
const relatedCalcs = [
  { name: "Water Conservation", url: "/water-conservation-calculator", description: "Water savings." },
  { name: "Greywater Reuse", url: "/greywater-reuse-calculator", description: "Greywater systems." },
  { name: "Water Intake", url: "/water-intake-calculator", description: "Daily water needs." },
  { name: "Square Footage", url: "/square-footage-calculator", description: "Area calculation." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Green Building", url: "/green-building-calculator", description: "Green certifications." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Rainwater Harvesting Calculator" keywords="rainwater harvesting calculator, rainwater collection, roof catchment area, rain barrel sizing, water conservation" breadcrumbs={[{ name: "Rainwater Harvesting", url: "/rainwater-harvesting-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Rainwater Harvesting Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate rainwater collection potential from your roof area and local rainfall.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Roof and Rainfall</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Roof Area (sq ft)</label><input type="number" id="rwh-area" class="rwh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1500" min="100" max="20000" step="100"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Annual Rainfall (inches)</label><input type="number" id="rwh-rain" class="rwh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="1" max="120" step="1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Collection Efficiency (%)</label><input type="number" id="rwh-eff" class="rwh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="80" min="50" max="95" step="5"></div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Roof Type</label>
            <select id="rwh-roof" class="rwh-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="0.95">Metal (95%)</option>
              <option value="0.90">Asphalt Shingle (90%)</option>
              <option value="0.85" selected>Concrete Tile (85%)</option>
              <option value="0.60">Flat/Gravel (60%)</option>
              <option value="0.50">Green Roof (50%)</option>
            </select>
          </div>
        </div>
        <h3 class="font-semibold text-text">Usage</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Daily Water Use (gal)</label><input type="number" id="rwh-daily" class="rwh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="80" min="10" max="500" step="10"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Water Cost ($/1000 gal)</label><input type="number" id="rwh-cost" class="rwh-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="6" min="1" max="30" step="0.5"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Annual Collection</div>
          <div class="text-4xl font-extrabold" id="rwh-total">0</div>
          <div class="text-sm text-blue-200 mt-1">gallons/year</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Monthly Average</div><div class="text-xl font-bold" id="rwh-monthly">0 gal</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Days Supply Covered</div><div class="text-xl font-bold" id="rwh-days">0 days</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Savings</div><div class="text-xl font-bold" id="rwh-savings">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Recommended Tank</div><div class="text-xl font-bold" id="rwh-tank">0 gal</div></div>
        </div>
      </div>
      <ShareButton calculatorId="rainwater-harvesting" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Rainwater Harvesting</h2>
      <p>The basic formula is: Gallons = Roof Area (sq ft) x Rainfall (inches) x 0.623 x Collection Efficiency. One inch of rain on one square foot yields 0.623 gallons. Efficiency depends on roof material, gutter losses, and first-flush diversion. Metal roofs provide the highest runoff coefficient (95%), while green roofs absorb more water (50%). Collected rainwater is ideal for irrigation, toilet flushing, and laundry.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcRWH() {
      const area = parseFloat((document.getElementById('rwh-area') as HTMLInputElement).value) || 1500;
      const rain = parseFloat((document.getElementById('rwh-rain') as HTMLInputElement).value) || 40;
      const eff = parseFloat((document.getElementById('rwh-eff') as HTMLInputElement).value) || 80;
      const roofCoeff = parseFloat((document.getElementById('rwh-roof') as HTMLSelectElement).value) || 0.85;
      const daily = parseFloat((document.getElementById('rwh-daily') as HTMLInputElement).value) || 80;
      const costPer1000 = parseFloat((document.getElementById('rwh-cost') as HTMLInputElement).value) || 6;
      const annualGal = area * rain * 0.623 * roofCoeff * (eff / 100);
      const monthlyGal = annualGal / 12;
      const daysCovered = daily > 0 ? annualGal / daily : 0;
      const savings = annualGal / 1000 * costPer1000;
      const tankSize = Math.ceil(monthlyGal / 50) * 50;
      document.getElementById('rwh-total')!.textContent = Math.round(annualGal).toLocaleString();
      document.getElementById('rwh-monthly')!.textContent = Math.round(monthlyGal).toLocaleString() + ' gal';
      document.getElementById('rwh-days')!.textContent = Math.round(daysCovered) + ' days';
      document.getElementById('rwh-savings')!.textContent = '$' + Math.round(savings).toLocaleString();
      document.getElementById('rwh-tank')!.textContent = tankSize.toLocaleString() + ' gal';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.rwh-in').forEach(el => { el.addEventListener('input', calcRWH); el.addEventListener('change', calcRWH); }); calcRWH(); }, 50);
  </script>
</CalculatorLayout>
