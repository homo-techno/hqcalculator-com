---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Playroom Size Calculator - Space Planning by Child Count & Age";
const description = "Calculate the ideal playroom size based on the number of children and their ages. Get activity zone recommendations and storage planning tips.";

const relatedCalcs = [
  { name: "Square Footage Calculator", url: "/square-footage-calculator", description: "Area calculation." },
  { name: "Birthday Party Calculator", url: "/birthday-party-calculator", description: "Party planning." },
  { name: "Screen Time Calculator", url: "/screen-time-limit-calculator", description: "Screen limits." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "Child Height Calculator", url: "/child-height-calculator", description: "Growth tracking." },
  { name: "Paint Calculator", url: "/paint-calculator", description: "Paint coverage." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Playroom Size Calculator"
  keywords="playroom size calculator, playroom dimensions, kids play area size, play space planning, playroom layout, play area square footage"
  breadcrumbs={[{ name: "Playroom Size Calculator", url: "/playroom-size-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Playroom Size Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Plan the ideal playroom space based on your children's ages and activities.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Children</label>
          <input type="number" id="prs-kids" class="prs-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="1" max="8" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Youngest Child's Age</label>
          <select id="prs-young" class="prs-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="baby">Baby (0-1 year)</option>
            <option value="toddler" selected>Toddler (1-3 years)</option>
            <option value="preschool">Preschooler (3-5 years)</option>
            <option value="school">School Age (6-10 years)</option>
            <option value="tween">Tween (10+ years)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Oldest Child's Age</label>
          <select id="prs-old" class="prs-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="toddler">Toddler (1-3 years)</option>
            <option value="preschool">Preschooler (3-5 years)</option>
            <option value="school" selected>School Age (6-10 years)</option>
            <option value="tween">Tween (10+ years)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Available Room Size (sq ft)</label>
          <input type="number" id="prs-room" class="prs-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="150" min="50" max="1000" step="10">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Include Play Equipment?</label>
          <select id="prs-equip" class="prs-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="minimal">Minimal (toys & books only)</option>
            <option value="moderate" selected>Moderate (small slide/climber)</option>
            <option value="full">Full (climbing wall, tent, etc.)</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Recommended Size</div>
        <div class="text-5xl font-extrabold" id="prs-recommended">--</div>
        <div class="text-sm text-blue-200 mt-1" id="prs-verdict">space assessment</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Sq Ft Per Child</div>
          <div class="text-lg font-bold" id="prs-perchild">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Your Room Rating</div>
          <div class="text-lg font-bold" id="prs-rating">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Storage Space Needed</div>
          <div class="text-lg font-bold" id="prs-storage">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Play Zones</div>
          <div class="text-lg font-bold" id="prs-zones">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Recommended Activity Zones</h3>
        <div class="text-sm" id="prs-zonelist"></div>
      </div>

      <ShareButton calculatorId="playroom-size" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Planning the Perfect Playroom</h2>
      <p>The ideal playroom provides enough space for active play, creative activities, and quiet time. Experts recommend 25-50 square feet per child as a general guideline, with more space needed for younger children who need room to move.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Key Design Principles</h3>
      <ul>
        <li><strong>Safety first:</strong> Soft flooring, corner guards, anchored furniture</li>
        <li><strong>Defined zones:</strong> Separate areas for different activities</li>
        <li><strong>Accessible storage:</strong> Low shelves and bins children can reach</li>
        <li><strong>Natural light:</strong> Position the playroom near windows when possible</li>
        <li><strong>Flexibility:</strong> Use modular furniture that can grow with your children</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Essential Playroom Zones</h3>
      <ul>
        <li>Active play / gross motor area</li>
        <li>Art and creativity station</li>
        <li>Reading nook</li>
        <li>Building and construction area</li>
        <li>Dramatic / pretend play space</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcPRS() {
      const kids = parseFloat((document.getElementById('prs-kids') as HTMLInputElement).value) || 2;
      const young = (document.getElementById('prs-young') as HTMLSelectElement).value;
      const old = (document.getElementById('prs-old') as HTMLSelectElement).value;
      const room = parseFloat((document.getElementById('prs-room') as HTMLInputElement).value) || 150;
      const equip = (document.getElementById('prs-equip') as HTMLSelectElement).value;

      // Base sq ft per child
      const basePerChild: Record<string, number> = {
        baby: 35, toddler: 40, preschool: 35, school: 30, tween: 25
      };

      const equipAdd: Record<string, number> = { minimal: 0, moderate: 25, full: 50 };

      const perChild = basePerChild[young];
      const recommended = perChild * kids + equipAdd[equip] + 15; // 15 for storage
      const sqftPerChild = Math.round(room / kids);

      let rating = '';
      const ratio = room / recommended;
      if (ratio >= 1.2) rating = 'Excellent';
      else if (ratio >= 1.0) rating = 'Good';
      else if (ratio >= 0.75) rating = 'Adequate';
      else if (ratio >= 0.5) rating = 'Tight';
      else rating = 'Too Small';

      let verdict = '';
      if (ratio >= 1.0) verdict = room + ' sq ft is sufficient for ' + kids + ' child' + (kids > 1 ? 'ren' : '');
      else verdict = 'Need ' + Math.round(recommended - room) + ' more sq ft ideally';

      const storageSqft = Math.round(room * 0.15);

      // Determine zones based on age and space
      interface Zone { name: string; sqft: number; desc: string; }
      const zones: Zone[] = [];

      if (young === 'baby' || young === 'toddler') {
        zones.push({ name: 'Soft Play Area', sqft: 30, desc: 'Padded floor mat for crawling and tumbling' });
      }
      zones.push({ name: 'Active Play', sqft: 35, desc: 'Open floor space for running, dancing, building' });
      zones.push({ name: 'Art Station', sqft: 20, desc: 'Table, chairs, art supplies, easel' });
      zones.push({ name: 'Reading Nook', sqft: 15, desc: 'Cozy corner with bookshelf and cushions' });

      if (old === 'school' || old === 'tween') {
        zones.push({ name: 'Building/STEM', sqft: 20, desc: 'LEGO, blocks, puzzles, science kits' });
      }
      if (young === 'toddler' || young === 'preschool') {
        zones.push({ name: 'Pretend Play', sqft: 20, desc: 'Play kitchen, dress-up, dollhouse' });
      }
      if (equip !== 'minimal') {
        zones.push({ name: 'Equipment Zone', sqft: equipAdd[equip], desc: 'Slide, climber, or tent' });
      }

      const totalZoneSqft = zones.reduce((s, z) => s + z.sqft, 0);
      const fittingZones = zones.filter(z => {
        const availableForZones = room - storageSqft;
        return true;
      });

      document.getElementById('prs-recommended')!.textContent = recommended + ' sq ft';
      document.getElementById('prs-verdict')!.textContent = verdict;
      document.getElementById('prs-perchild')!.textContent = sqftPerChild + ' sq ft';
      document.getElementById('prs-rating')!.textContent = rating;
      document.getElementById('prs-storage')!.textContent = storageSqft + ' sq ft';
      document.getElementById('prs-zones')!.textContent = zones.length + ' recommended';

      document.getElementById('prs-zonelist')!.innerHTML = zones.map(z => {
        const fits = z.sqft <= (room / zones.length);
        return `<div class="flex justify-between items-center py-2 border-b border-gray-100"><div><span class="font-semibold">${z.name}</span><br><span class="text-xs text-text-muted">${z.desc}</span></div><div class="text-right"><span class="font-bold">${z.sqft} sq ft</span></div></div>`;
      }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.prs-in').forEach(el => {
        el.addEventListener('input', calcPRS);
        el.addEventListener('change', calcPRS);
      });
      calcPRS();
    }, 50);
  </script>
</CalculatorLayout>
