---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "LED Savings Calculator - LED vs Incandescent/CFL Cost Comparison";
const description = "Calculate how much you can save by switching to LED bulbs from incandescent or CFL, including energy costs and bulb replacement over time.";
const relatedCalcs = [
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "Energy Audit", url: "/energy-audit-calculator", description: "Home audit." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Solar Payback", url: "/solar-payback-calculator", description: "Solar ROI." },
  { name: "Insulation ROI", url: "/insulation-roi-calculator", description: "Insulation savings." },
  { name: "Passive House", url: "/passive-house-calculator", description: "Passive design." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="LED Savings Calculator" keywords="LED savings calculator, LED vs incandescent, LED vs CFL, LED bulb cost savings, energy efficient lighting" breadcrumbs={[{ name: "LED Savings", url: "/led-savings-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">LED Savings Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">See how much switching to LED bulbs saves in energy and replacement costs.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Current Bulbs</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Number of Bulbs</label><input type="number" id="led-count" class="led-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="1" max="200" step="1"></div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Current Bulb Type</label>
            <select id="led-type" class="led-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="incandescent" selected>Incandescent (60W)</option>
              <option value="halogen">Halogen (43W)</option>
              <option value="cfl">CFL (13W)</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Hours On per Day</label><input type="number" id="led-hours" class="led-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="24" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Electricity Rate ($/kWh)</label><input type="number" id="led-rate" class="led-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.14" min="0.01" max="0.60" step="0.01"></div>
        </div>
        <h3 class="font-semibold text-text">LED Replacement</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">LED Wattage</label><input type="number" id="led-watts" class="led-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="9" min="3" max="25" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">LED Cost per Bulb ($)</label><input type="number" id="led-bulbcost" class="led-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0.50" max="25" step="0.50"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Comparison Period (years)</label><input type="number" id="led-years" class="led-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="1" max="25" step="1"></div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Savings Over Period</div>
          <div class="text-4xl font-extrabold" id="led-total">$0</div>
          <div class="text-sm text-blue-200 mt-1" id="led-period">over 10 years</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Energy Savings</div><div class="text-xl font-bold" id="led-annual">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">kWh Saved/Year</div><div class="text-xl font-bold" id="led-kwh">0</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">LED Upfront Cost</div><div class="text-xl font-bold" id="led-upfront">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">CO₂ Reduced/Year</div><div class="text-xl font-bold" id="led-co2">0 lbs</div></div>
        </div>
      </div>
      <ShareButton calculatorId="led-savings" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">LED vs Traditional Bulb Savings</h2>
      <p>LED bulbs use 75-85% less energy than incandescent bulbs and last 15-25 times longer (25,000+ hours vs 1,000 hours). A 9W LED produces the same light as a 60W incandescent. Over a 10-year period, switching 30 bulbs can save over $2,000 in energy costs alone, plus the cost of dozens of replacement incandescent bulbs. LEDs also produce less heat, reducing cooling costs in summer.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    const ledBulbData: Record<string, [number, number, number]> = {
      incandescent: [60, 1000, 1.00],
      halogen: [43, 2000, 2.00],
      cfl: [13, 8000, 3.00]
    };
    function calcLED() {
      const count = parseFloat((document.getElementById('led-count') as HTMLInputElement).value) || 30;
      const type = (document.getElementById('led-type') as HTMLSelectElement).value;
      const hours = parseFloat((document.getElementById('led-hours') as HTMLInputElement).value) || 5;
      const rate = parseFloat((document.getElementById('led-rate') as HTMLInputElement).value) || 0.14;
      const ledW = parseFloat((document.getElementById('led-watts') as HTMLInputElement).value) || 9;
      const ledCost = parseFloat((document.getElementById('led-bulbcost') as HTMLInputElement).value) || 3;
      const years = parseFloat((document.getElementById('led-years') as HTMLInputElement).value) || 10;
      const [oldW, oldLife, oldCost] = ledBulbData[type] || [60, 1000, 1.00];
      const annualHours = hours * 365;
      const oldKWhYr = count * oldW * annualHours / 1000;
      const ledKWhYr = count * ledW * annualHours / 1000;
      const kwhSaved = oldKWhYr - ledKWhYr;
      const annualEnergySaving = kwhSaved * rate;
      const oldReplacements = Math.ceil(annualHours * years / oldLife) - 1;
      const ledReplacements = Math.ceil(annualHours * years / 25000) - 1;
      const oldReplaceCost = count * Math.max(0, oldReplacements) * oldCost;
      const ledReplaceCost = count * Math.max(0, ledReplacements) * ledCost;
      const ledUpfront = count * ledCost;
      const totalSavings = annualEnergySaving * years + oldReplaceCost - ledReplaceCost - ledUpfront;
      const co2 = kwhSaved * 0.92;
      document.getElementById('led-total')!.textContent = '$' + Math.round(totalSavings).toLocaleString();
      document.getElementById('led-period')!.textContent = 'over ' + years + ' years';
      document.getElementById('led-annual')!.textContent = '$' + Math.round(annualEnergySaving).toLocaleString();
      document.getElementById('led-kwh')!.textContent = Math.round(kwhSaved).toLocaleString();
      document.getElementById('led-upfront')!.textContent = '$' + Math.round(ledUpfront).toLocaleString();
      document.getElementById('led-co2')!.textContent = Math.round(co2).toLocaleString() + ' lbs';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.led-in').forEach(el => { el.addEventListener('input', calcLED); el.addEventListener('change', calcLED); }); calcLED(); }, 50);
  </script>
</CalculatorLayout>
