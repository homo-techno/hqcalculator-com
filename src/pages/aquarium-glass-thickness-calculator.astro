---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Glass Thickness Calculator - Custom Tank Build";
const description = "Calculate the minimum glass or acrylic thickness for custom aquarium builds based on tank dimensions, water pressure, and safety factor.";
const relatedCalcs = [
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume and water weight." },
  { name: "Aquarium Stand", url: "/aquarium-stand-calculator", description: "Stand load capacity calculator." },
  { name: "Aquarium Cost", url: "/aquarium-cost-calculator", description: "Total aquarium setup cost estimator." },
  { name: "Aquarium Substrate", url: "/aquarium-substrate-calculator", description: "Substrate depth and weight." },
  { name: "Aquarium Sump", url: "/aquarium-sump-calculator", description: "Sump sizing and configuration." },
  { name: "Aquarium Background", url: "/aquarium-background-calculator", description: "Background material calculator." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Glass Thickness Calculator" keywords="aquarium glass thickness, custom aquarium build, fish tank glass calculator, acrylic tank thickness, aquarium safety factor" breadcrumbs={[{ name: "Aquarium Glass Thickness", url: "/aquarium-glass-thickness-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Glass Thickness Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Determine the minimum safe glass or acrylic thickness for a custom aquarium based on dimensions and material type.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Length (inches)</label>
            <input type="number" id="agt-len" class="agt-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="48" min="6" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Width (inches)</label>
            <input type="number" id="agt-wid" class="agt-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="6" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Height (inches)</label>
            <input type="number" id="agt-hgt" class="agt-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18" min="6" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Material</label>
            <select id="agt-mat" class="agt-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="glass" selected>Tempered Glass</option>
              <option value="float">Float Glass (standard)</option>
              <option value="acrylic">Acrylic (Plexiglas)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Safety Factor</label>
            <select id="agt-sf" class="agt-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="3.8" selected>Standard (3.8x)</option>
              <option value="5">Conservative (5x)</option>
              <option value="3">Minimum (3x)</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Bracing</label>
          <select id="agt-brace" class="agt-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="none" selected>No bracing (rimless)</option>
            <option value="top">Top brace / Euro brace</option>
            <option value="center">Center brace</option>
          </select>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Minimum Thickness</div>
          <div class="text-5xl font-extrabold font-mono" id="agt-result">0 mm</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Thickness (inches)</div>
            <div class="text-xl font-bold font-mono" id="agt-inches">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Tank Volume</div>
            <div class="text-xl font-bold font-mono" id="agt-vol">0 gal</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water Pressure (bottom)</div>
            <div class="text-xl font-bold font-mono" id="agt-psi">0 psi</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Water Weight</div>
            <div class="text-xl font-bold font-mono" id="agt-weight">0 lbs</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-glass-thickness" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcAGT() {
      const len = parseFloat((document.getElementById('agt-len') as HTMLInputElement).value) || 0;
      const wid = parseFloat((document.getElementById('agt-wid') as HTMLInputElement).value) || 0;
      const hgt = parseFloat((document.getElementById('agt-hgt') as HTMLInputElement).value) || 0;
      const mat = (document.getElementById('agt-mat') as HTMLSelectElement).value;
      const sf = parseFloat((document.getElementById('agt-sf') as HTMLSelectElement).value) || 3.8;
      const brace = (document.getElementById('agt-brace') as HTMLSelectElement).value;
      // Volume
      const gallons = (len * wid * hgt) / 231;
      const weight = gallons * 8.34;
      // Water pressure at bottom in psi: height(inches) * 0.0361 psi/inch
      const psi = hgt * 0.0361;
      // Allowable stress (psi) for materials
      const stressMap: Record<string, number> = { glass: 19300, float: 6000, acrylic: 10500 };
      const allowable = stressMap[mat] || 6000;
      // Longest unsupported span (the longer of length or width)
      let span = Math.max(len, wid);
      // Bracing reduces effective span
      if (brace === 'top') span *= 0.85;
      if (brace === 'center') span *= 0.65;
      // Glass thickness formula (simplified):
      // t = sqrt( (sf * pressure_at_bottom * span^2) / (allowable_stress) )
      // pressure at bottom in psi
      const pressure = psi;
      const thicknessInches = Math.sqrt((sf * pressure * span * span) / allowable);
      const thicknessMM = thicknessInches * 25.4;
      // Round up to standard sizes
      const stdMM = [3, 4, 5, 6, 8, 10, 12, 15, 19, 25];
      let recMM = stdMM[stdMM.length - 1];
      for (const s of stdMM) { if (s >= thicknessMM) { recMM = s; break; } }
      document.getElementById('agt-result')!.textContent = recMM + ' mm';
      document.getElementById('agt-inches')!.textContent = (recMM / 25.4).toFixed(2) + '"';
      document.getElementById('agt-vol')!.textContent = gallons.toFixed(1) + ' gal';
      document.getElementById('agt-psi')!.textContent = psi.toFixed(2) + ' psi';
      document.getElementById('agt-weight')!.textContent = weight.toFixed(0) + ' lbs';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.agt-in').forEach(el => { el.addEventListener('input', calcAGT); el.addEventListener('change', calcAGT); });
      calcAGT();
    }, 50);
  </script>
</CalculatorLayout>
