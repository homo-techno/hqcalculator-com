---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Diaper Cost Calculator - Estimate Diaper Expenses by Age & Brand";
const description = "Calculate how much you'll spend on diapers from birth to potty training. Compare costs by brand, diaper type, and usage rate to find the best value.";

const relatedCalcs = [
  { name: "Baby Formula Calculator", url: "/baby-formula-calculator", description: "Formula feeding costs." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare expenses." },
  { name: "Birthday Party Calculator", url: "/birthday-party-calculator", description: "Party budgeting." },
  { name: "Child Travel Calculator", url: "/child-travel-calculator", description: "Travel with kids costs." },
  { name: "Budget Calculator", url: "/budget-calculator", description: "Household budgeting." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Track milestones." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Diaper Cost Calculator"
  keywords="diaper cost calculator, diaper budget, diaper expenses, baby diaper cost, how much do diapers cost, diaper spending estimator"
  breadcrumbs={[{ name: "Diaper Cost Calculator", url: "/diaper-cost-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Diaper Cost Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate your total diaper costs from birth to potty training based on age, brand preference, and usage patterns.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Current Age (months)</label>
          <input type="number" id="dpc-age" class="dpc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" max="36" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Expected Potty Training Age (months)</label>
          <input type="number" id="dpc-potty" class="dpc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="18" max="48" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Diaper Brand / Tier</label>
          <select id="dpc-brand" class="dpc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="budget">Budget (Store Brand) ~ $0.15/diaper</option>
            <option value="mid" selected>Mid-Range (Huggies/Pampers) ~ $0.25/diaper</option>
            <option value="premium">Premium (Honest, Bambo) ~ $0.38/diaper</option>
            <option value="cloth">Cloth Diapers (upfront + wash)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Diaper Changes Per Day (override)</label>
          <input type="number" id="dpc-changes" class="dpc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" max="20" step="1" placeholder="0 = auto by age">
          <p class="text-xs text-text-muted mt-1">Leave at 0 to auto-calculate by age</p>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Remaining Diaper Cost</div>
        <div class="text-5xl font-extrabold" id="dpc-total">--</div>
        <div class="text-sm text-blue-200 mt-1" id="dpc-desc">from now until potty training</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Monthly Cost</div>
          <div class="text-lg font-bold" id="dpc-monthly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Diapers Per Day</div>
          <div class="text-lg font-bold" id="dpc-perday">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Total Diapers Remaining</div>
          <div class="text-lg font-bold" id="dpc-totalcount">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Cost Per Diaper</div>
          <div class="text-lg font-bold" id="dpc-cpd">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Monthly Breakdown</h3>
        <div class="text-xs overflow-x-auto" id="dpc-breakdown"></div>
      </div>

      <ShareButton calculatorId="diaper-cost" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">How Diaper Costs Add Up</h2>
      <p>The average baby uses approximately 6,000-8,000 diapers before potty training. Newborns use the most -- up to 12 per day -- while toddlers typically need only 5-6 per day.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Average Diaper Changes by Age</h3>
      <ul>
        <li><strong>0-3 months:</strong> 10-12 diapers per day</li>
        <li><strong>3-6 months:</strong> 8-10 diapers per day</li>
        <li><strong>6-12 months:</strong> 7-8 diapers per day</li>
        <li><strong>12-24 months:</strong> 6-7 diapers per day</li>
        <li><strong>24-36 months:</strong> 5-6 diapers per day</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Cloth vs Disposable</h3>
      <p>Cloth diapers cost more upfront ($300-$800 for a full set) but save money long-term. Factoring in water and detergent, cloth diapers typically cost $0.05-$0.10 per use.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Tips to Save on Diapers</h3>
      <ul>
        <li>Buy in bulk when on sale</li>
        <li>Use store brand diapers -- many perform comparably to name brands</li>
        <li>Sign up for diaper subscription services for discounts</li>
        <li>Use cashback apps and manufacturer coupons</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcDPC() {
      const age = parseFloat((document.getElementById('dpc-age') as HTMLInputElement).value) || 0;
      const potty = parseFloat((document.getElementById('dpc-potty') as HTMLInputElement).value) || 30;
      const brand = (document.getElementById('dpc-brand') as HTMLSelectElement).value;
      const manualChanges = parseFloat((document.getElementById('dpc-changes') as HTMLInputElement).value) || 0;

      const pricePerDiaper: Record<string, number> = { budget: 0.15, mid: 0.25, premium: 0.38, cloth: 0.07 };
      const clothUpfront = 500;

      function changesForAge(m: number): number {
        if (m < 3) return 11;
        if (m < 6) return 9;
        if (m < 12) return 8;
        if (m < 24) return 6.5;
        return 5.5;
      }

      let totalDiapers = 0;
      let totalCost = 0;
      const monthsRemaining = Math.max(0, potty - age);
      const breakdown: string[] = [];

      for (let m = Math.ceil(age); m < potty; m++) {
        const daily = manualChanges > 0 ? manualChanges : changesForAge(m);
        const monthlyDiapers = Math.round(daily * 30.44);
        const monthlyCost = monthlyDiapers * pricePerDiaper[brand];
        totalDiapers += monthlyDiapers;
        totalCost += monthlyCost;

        if (m % 3 === 0 || m === Math.ceil(age) || m === potty - 1) {
          breakdown.push(`<div class="grid grid-cols-3 gap-2 py-1 ${m === Math.ceil(age) ? 'bg-blue-50 rounded font-bold' : ''}"><span>Month ${m}</span><span>${daily.toFixed(0)}/day</span><span>$${monthlyCost.toFixed(2)}</span></div>`);
        }
      }

      if (brand === 'cloth') totalCost += clothUpfront;

      const avgMonthly = monthsRemaining > 0 ? totalCost / monthsRemaining : 0;
      const currentDaily = manualChanges > 0 ? manualChanges : changesForAge(age);

      document.getElementById('dpc-total')!.textContent = '$' + totalCost.toFixed(0);
      document.getElementById('dpc-monthly')!.textContent = '$' + avgMonthly.toFixed(0) + '/mo';
      document.getElementById('dpc-perday')!.textContent = currentDaily.toFixed(0);
      document.getElementById('dpc-totalcount')!.textContent = totalDiapers.toLocaleString();
      document.getElementById('dpc-cpd')!.textContent = '$' + pricePerDiaper[brand].toFixed(2);

      const clothNote = brand === 'cloth' ? ' (includes $500 startup)' : '';
      document.getElementById('dpc-desc')!.textContent = monthsRemaining + ' months remaining' + clothNote;

      document.getElementById('dpc-breakdown')!.innerHTML =
        '<div class="grid grid-cols-3 gap-2 font-semibold text-text-muted mb-1"><span>Age</span><span>Changes</span><span>Cost</span></div>' +
        breakdown.join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.dpc-in').forEach(el => {
        el.addEventListener('input', calcDPC);
        el.addEventListener('change', calcDPC);
      });
      calcDPC();
    }, 50);
  </script>
</CalculatorLayout>
