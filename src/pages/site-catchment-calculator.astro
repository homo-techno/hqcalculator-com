---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Site Catchment Calculator - Resource Territory Analysis";
const description = "Calculate the site catchment area and resource territory for an archaeological site based on walking time radii and terrain factors.";
const relatedCalcs = [
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
  { name: "Carrying Capacity", url: "/carrying-capacity-calculator", description: "Land capacity." },
  { name: "Survey Coverage", url: "/survey-coverage-calculator", description: "Survey sampling." },
  { name: "Site Grid", url: "/site-grid-calculator", description: "Grid layout." },
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Excavation Volume", url: "/excavation-volume-calculator", description: "Dig unit volume." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Site Catchment Calculator" keywords="site catchment analysis, resource territory, walking time, foraging radius, catchment area, Vita-Finzi, archaeological territory" breadcrumbs={[{ name: "Site Catchment", url: "/site-catchment-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Site Catchment Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate the catchment area and resource territory surrounding an archaeological site using walking-time radii and terrain correction factors.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Economy Type</label>
          <select id="sca-econ" class="sca-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="agriculture">Agricultural (1-hour / ~5 km radius)</option>
            <option value="pastoral">Pastoral (2-hour / ~10 km radius)</option>
            <option value="foraging">Foraging/Hunter-Gatherer (custom radius)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Walking Speed (km/h)</label>
          <input type="number" id="sca-speed" class="sca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="8" step="0.5">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Walking Time (hours, one-way)</label>
          <input type="number" id="sca-time" class="sca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="0.25" max="8" step="0.25">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Terrain Correction Factor</label>
          <select id="sca-terrain" class="sca-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="1.0">Flat terrain (1.0)</option>
            <option value="0.8">Rolling hills (0.8)</option>
            <option value="0.6">Hilly terrain (0.6)</option>
            <option value="0.4">Mountainous (0.4)</option>
            <option value="0.7">Dense forest (0.7)</option>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">% Arable Land</label>
            <input type="number" id="sca-arable" class="sca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="40" min="0" max="100" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">% Water/Wetland</label>
            <input type="number" id="sca-water" class="sca-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="0" max="100" step="1">
          </div>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Catchment Area</div>
          <div class="text-4xl font-extrabold" id="sca-area">0</div>
          <div class="text-sm text-blue-200 mt-1">sq km</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Effective Radius</div>
            <div class="text-xl font-bold" id="sca-radius">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Area (hectares)</div>
            <div class="text-xl font-bold" id="sca-hectares">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Arable Area</div>
            <div class="text-xl font-bold" id="sca-arablearea">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Water/Wetland Area</div>
            <div class="text-xl font-bold" id="sca-waterarea">0</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Supportable Population (est.)</div>
          <div class="text-xl font-bold" id="sca-pop">0</div>
        </div>
      </div>

      <ShareButton calculatorId="site-catchment" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Site Catchment Analysis</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Radius</strong> = Speed * Time * Terrain Factor</p>
        <p><strong>Area</strong> = pi * Radius^2</p>
        <p><strong>Standard</strong>: 1 hr (agriculture), 2 hr (pastoral)</p>
      </div>
      <p>Site Catchment Analysis (Vita-Finzi & Higgs, 1970) examines the territory around a site that would have been regularly exploited. Agricultural communities typically exploit resources within a 1-hour walk (5 km), while pastoral groups range further. Terrain significantly affects effective catchment size.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSCA() {
      const econ = (document.getElementById('sca-econ') as HTMLSelectElement).value;
      const speed = parseFloat((document.getElementById('sca-speed') as HTMLInputElement).value) || 5;
      let time = parseFloat((document.getElementById('sca-time') as HTMLInputElement).value) || 1;
      const terrain = parseFloat((document.getElementById('sca-terrain') as HTMLSelectElement).value) || 1;
      const arablePct = parseFloat((document.getElementById('sca-arable') as HTMLInputElement).value) || 0;
      const waterPct = parseFloat((document.getElementById('sca-water') as HTMLInputElement).value) || 0;

      if (econ === 'agriculture') time = 1;
      else if (econ === 'pastoral') time = 2;

      const radius = speed * time * terrain;
      const areaSqKm = Math.PI * radius * radius;
      const areaHa = areaSqKm * 100;
      const arableArea = areaHa * (arablePct / 100);
      const waterArea = areaHa * (waterPct / 100);

      let popEst = 0;
      if (econ === 'agriculture') {
        popEst = arableArea * 1.5;
      } else if (econ === 'pastoral') {
        popEst = areaHa * 0.3;
      } else {
        popEst = areaHa * 0.05;
      }

      document.getElementById('sca-area')!.textContent = areaSqKm.toFixed(1);
      document.getElementById('sca-radius')!.textContent = radius.toFixed(1) + ' km';
      document.getElementById('sca-hectares')!.textContent = Math.round(areaHa).toLocaleString() + ' ha';
      document.getElementById('sca-arablearea')!.textContent = Math.round(arableArea).toLocaleString() + ' ha';
      document.getElementById('sca-waterarea')!.textContent = Math.round(waterArea).toLocaleString() + ' ha';
      document.getElementById('sca-pop')!.textContent = Math.round(popEst).toLocaleString() + ' persons';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.sca-in').forEach(el => { el.addEventListener('input', calcSCA); el.addEventListener('change', calcSCA); });
      calcSCA();
    }, 50);
  </script>
</CalculatorLayout>
