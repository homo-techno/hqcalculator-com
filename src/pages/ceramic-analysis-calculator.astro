---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Ceramic Analysis Calculator - Pottery Sherd Type Frequency & MNV";
const description = "Analyze pottery sherd assemblages: calculate type frequencies, minimum number of vessels (MNV), sherd-to-vessel ratios, and assemblage diversity.";
const relatedCalcs = [
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Lithic Analysis", url: "/lithic-analysis-calculator", description: "Stone tool analysis." },
  { name: "Excavation Volume", url: "/excavation-volume-calculator", description: "Dig unit volume." },
  { name: "Artifact Illustration", url: "/artifact-illustration-calculator", description: "Drawing scale." },
  { name: "Stratigraphy", url: "/stratigraphy-calculator", description: "Layer age estimation." },
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Ceramic Analysis Calculator" keywords="ceramic analysis, pottery sherds, MNV, minimum number of vessels, type frequency, sherd analysis, pottery classification" breadcrumbs={[{ name: "Ceramic Analysis", url: "/ceramic-analysis-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Ceramic Analysis Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Analyze pottery assemblages by calculating type frequencies, minimum number of vessels (MNV), brokenness index, and assemblage diversity measures.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Sherd Count</label>
          <input type="number" id="ca2-total" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="350" min="1" step="1">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Rim Sherds</label>
            <input type="number" id="ca2-rims" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="45" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Body Sherds</label>
            <input type="number" id="ca2-body" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="270" min="0" step="1">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Base Sherds</label>
            <input type="number" id="ca2-base" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="25" min="0" step="1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Handle/Lug Sherds</label>
            <input type="number" id="ca2-handle" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="0" step="1">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Distinct Types/Wares</label>
          <input type="number" id="ca2-types" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Decorated Sherds</label>
          <input type="number" id="ca2-decorated" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="55" min="0" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Weight (g)</label>
          <input type="number" id="ca2-weight" class="ca2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4200" min="0" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Minimum Number of Vessels (MNV)</div>
          <div class="text-4xl font-extrabold" id="ca2-mnv">0</div>
          <div class="text-sm text-blue-200 mt-1">based on rim count method</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Sherd-to-Vessel Ratio</div>
            <div class="text-xl font-bold" id="ca2-svr">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Avg Sherd Weight</div>
            <div class="text-xl font-bold" id="ca2-avgwt">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Rim % of Total</div>
            <div class="text-xl font-bold" id="ca2-rimpct">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Decoration Rate</div>
            <div class="text-xl font-bold" id="ca2-decpct">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Brokenness Index</div>
            <div class="text-xl font-bold" id="ca2-broken">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Type Diversity</div>
            <div class="text-xl font-bold" id="ca2-diversity">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="ceramic-analysis" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Ceramic Analysis Methods</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>MNV (rim method)</strong> = Count of distinct rim profiles</p>
        <p><strong>Brokenness Index</strong> = Total Sherds / MNV</p>
        <p><strong>Type Diversity</strong> = Types / ln(Total Sherds)</p>
      </div>
      <p>The Minimum Number of Vessels (MNV) estimates how many complete pots are represented in a sherd assemblage. Rim sherds provide the most reliable MNV estimate. The brokenness index indicates post-depositional disturbance, and type diversity reflects the range of ceramic traditions present.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCA2() {
      const total = parseFloat((document.getElementById('ca2-total') as HTMLInputElement).value) || 0;
      const rims = parseFloat((document.getElementById('ca2-rims') as HTMLInputElement).value) || 0;
      const base = parseFloat((document.getElementById('ca2-base') as HTMLInputElement).value) || 0;
      const types = parseFloat((document.getElementById('ca2-types') as HTMLInputElement).value) || 1;
      const decorated = parseFloat((document.getElementById('ca2-decorated') as HTMLInputElement).value) || 0;
      const weight = parseFloat((document.getElementById('ca2-weight') as HTMLInputElement).value) || 0;

      const mnv = Math.max(rims, base);
      const svr = mnv > 0 ? total / mnv : 0;
      const avgWt = total > 0 ? weight / total : 0;
      const rimPct = total > 0 ? (rims / total) * 100 : 0;
      const decPct = total > 0 ? (decorated / total) * 100 : 0;
      const brokenness = mnv > 0 ? total / mnv : 0;
      const diversity = total > 1 ? types / Math.log(total) : 0;

      document.getElementById('ca2-mnv')!.textContent = mnv.toString();
      document.getElementById('ca2-svr')!.textContent = svr.toFixed(1) + ' sherds/vessel';
      document.getElementById('ca2-avgwt')!.textContent = avgWt.toFixed(1) + ' g';
      document.getElementById('ca2-rimpct')!.textContent = rimPct.toFixed(1) + '%';
      document.getElementById('ca2-decpct')!.textContent = decPct.toFixed(1) + '%';
      document.getElementById('ca2-broken')!.textContent = brokenness.toFixed(1);
      document.getElementById('ca2-diversity')!.textContent = diversity.toFixed(3);

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.ca2-in').forEach(el => { el.addEventListener('input', calcCA2); el.addEventListener('change', calcCA2); });
      calcCA2();
    }, 50);
  </script>
</CalculatorLayout>
