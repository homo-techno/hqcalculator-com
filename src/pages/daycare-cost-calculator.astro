---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Daycare Cost Calculator - Compare Childcare Options & Costs";
const description = "Compare daycare costs across center-based care, home daycare, nanny, and au pair options. Estimate annual childcare expenses by location and child age.";

const relatedCalcs = [
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper expenses." },
  { name: "Baby Formula Calculator", url: "/baby-formula-calculator", description: "Formula costs." },
  { name: "Homeschool Cost Calculator", url: "/homeschool-cost-calculator", description: "Homeschool budget." },
  { name: "Budget Calculator", url: "/budget-calculator", description: "Family budget." },
  { name: "Salary Calculator", url: "/salary-calculator", description: "Income analysis." },
  { name: "Tutoring Cost Calculator", url: "/tutoring-cost-calculator", description: "Tutoring costs." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Daycare Cost Calculator"
  keywords="daycare cost calculator, childcare cost comparison, nanny cost, daycare prices, au pair cost, childcare budget, preschool cost"
  breadcrumbs={[{ name: "Daycare Cost Calculator", url: "/daycare-cost-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Daycare Cost Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Compare childcare costs across different care types and find the best option for your family's budget.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Children</label>
          <input type="number" id="dyc-children" class="dyc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="1" max="6" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Age Group</label>
          <select id="dyc-agegroup" class="dyc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="infant">Infant (0-12 months)</option>
            <option value="toddler" selected>Toddler (1-3 years)</option>
            <option value="preschool">Preschool (3-5 years)</option>
            <option value="school">School Age (5+, before/after)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Care Type</label>
          <select id="dyc-type" class="dyc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="center" selected>Daycare Center</option>
            <option value="home">Home Daycare</option>
            <option value="nanny">Full-Time Nanny</option>
            <option value="aupair">Au Pair</option>
            <option value="share">Nanny Share</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Days Per Week</label>
          <input type="number" id="dyc-days" class="dyc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="7" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Cost of Living Area</label>
          <select id="dyc-area" class="dyc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="low">Low Cost (Rural / Small City)</option>
            <option value="medium" selected>Medium Cost (Average Metro)</option>
            <option value="high">High Cost (Major City)</option>
            <option value="vhigh">Very High Cost (NYC, SF, DC)</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Annual Childcare Cost</div>
        <div class="text-5xl font-extrabold" id="dyc-annual">--</div>
        <div class="text-sm text-blue-200 mt-1" id="dyc-type-label">estimated annual cost</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Monthly Cost</div>
          <div class="text-lg font-bold" id="dyc-monthly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Weekly Cost</div>
          <div class="text-lg font-bold" id="dyc-weekly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Daily Cost</div>
          <div class="text-lg font-bold" id="dyc-daily">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">% of Median Income</div>
          <div class="text-lg font-bold" id="dyc-pctincome">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Cost Comparison by Type</h3>
        <div class="text-xs" id="dyc-comparison"></div>
      </div>

      <ShareButton calculatorId="daycare-cost" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Childcare Costs</h2>
      <p>Childcare is one of the largest expenses for families with young children. In the U.S., families spend an average of $9,000-$25,000+ per year on childcare, depending on location, type, and age of the child.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Care Types Explained</h3>
      <ul>
        <li><strong>Daycare Center:</strong> Licensed facility with structured programs. Reliable hours but less flexibility.</li>
        <li><strong>Home Daycare:</strong> Care in a provider's home, typically smaller groups. Often 20-30% less than centers.</li>
        <li><strong>Nanny:</strong> In-home care with the most flexibility. Most expensive but offers personalized attention.</li>
        <li><strong>Au Pair:</strong> Live-in caregiver from another country. Fixed annual cost regardless of number of children.</li>
        <li><strong>Nanny Share:</strong> Sharing a nanny with another family. Splits the cost while keeping in-home care benefits.</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Tax Benefits</h3>
      <p>The Child and Dependent Care Credit allows you to claim up to $3,000 for one child or $6,000 for two or more children. Many employers also offer Dependent Care FSAs (up to $5,000 pre-tax).</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcDYC() {
      const children = parseFloat((document.getElementById('dyc-children') as HTMLInputElement).value) || 1;
      const agegroup = (document.getElementById('dyc-agegroup') as HTMLSelectElement).value;
      const type = (document.getElementById('dyc-type') as HTMLSelectElement).value;
      const days = parseFloat((document.getElementById('dyc-days') as HTMLInputElement).value) || 5;
      const area = (document.getElementById('dyc-area') as HTMLSelectElement).value;

      // Base weekly rates per child for 5-day care (medium cost area, toddler)
      const baseWeekly: Record<string, number> = {
        center: 300, home: 225, nanny: 800, aupair: 400, share: 450
      };

      // Age multiplier
      const ageMult: Record<string, number> = {
        infant: 1.25, toddler: 1.0, preschool: 0.9, school: 0.55
      };

      // Area multiplier
      const areaMult: Record<string, number> = {
        low: 0.65, medium: 1.0, high: 1.45, vhigh: 1.85
      };

      const dayFactor = days / 5;

      const types = ['center', 'home', 'nanny', 'aupair', 'share'];
      const typeNames: Record<string, string> = {
        center: 'Daycare Center', home: 'Home Daycare', nanny: 'Full-Time Nanny', aupair: 'Au Pair', share: 'Nanny Share'
      };

      function calcCost(t: string): number {
        let weekly = baseWeekly[t] * ageMult[agegroup] * areaMult[area] * dayFactor;
        if (t === 'aupair') {
          weekly = (19620 / 52) * areaMult[area]; // Au pair fixed ~$19,620/yr + stipend
        }
        if (t === 'nanny' || t === 'share') {
          return weekly * 52 * (children > 1 ? 1 + (children - 1) * 0.15 : 1);
        }
        return weekly * 52 * children;
      }

      const selectedCost = calcCost(type);
      const annual = Math.round(selectedCost);
      const monthly = Math.round(annual / 12);
      const weekly = Math.round(annual / 52);
      const daily = Math.round(annual / (52 * days));

      const medianIncome = 75000;
      const pctIncome = ((annual / medianIncome) * 100).toFixed(1);

      document.getElementById('dyc-annual')!.textContent = '$' + annual.toLocaleString();
      document.getElementById('dyc-monthly')!.textContent = '$' + monthly.toLocaleString();
      document.getElementById('dyc-weekly')!.textContent = '$' + weekly.toLocaleString();
      document.getElementById('dyc-daily')!.textContent = '$' + daily.toLocaleString();
      document.getElementById('dyc-pctincome')!.textContent = pctIncome + '%';
      document.getElementById('dyc-type-label')!.textContent = typeNames[type] + ' - ' + children + ' child' + (children > 1 ? 'ren' : '');

      document.getElementById('dyc-comparison')!.innerHTML =
        '<div class="grid grid-cols-3 gap-2 font-semibold text-text-muted mb-1"><span>Type</span><span>Monthly</span><span>Annual</span></div>' +
        types.map(t => {
          const cost = calcCost(t);
          const isSelected = t === type;
          return `<div class="grid grid-cols-3 gap-2 py-1 ${isSelected ? 'bg-blue-50 rounded font-bold' : ''}"><span>${typeNames[t]}</span><span>$${Math.round(cost / 12).toLocaleString()}</span><span>$${Math.round(cost).toLocaleString()}</span></div>`;
        }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.dyc-in').forEach(el => {
        el.addEventListener('input', calcDYC);
        el.addEventListener('change', calcDYC);
      });
      calcDYC();
    }, 50);
  </script>
</CalculatorLayout>
