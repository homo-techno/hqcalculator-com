---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Shotcrete Calculator - Volume & Rebound Waste Estimation";
const description = "Calculate shotcrete volume and rebound waste for pools, retaining walls, tunnels, and slope stabilization. Estimate total material including overspray.";

const relatedCalcs = [
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Concrete Pump Calculator", url: "/concrete-pump-calculator", description: "Pump sizing." },
  { name: "Concrete Mix Calculator", url: "/concrete-mix-calculator", description: "Mix design ratios." },
  { name: "Retaining Wall Calculator", url: "/retaining-wall-calculator", description: "Retaining wall design." },
  { name: "Concrete Reinforcement Calculator", url: "/concrete-reinforcement-calculator", description: "Rebar sizing." },
  { name: "Concrete Admixture Calculator", url: "/concrete-admixture-calculator", description: "Admixture dosage." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Shotcrete Calculator"
  keywords="shotcrete calculator, gunite, rebound waste, shotcrete volume, dry mix shotcrete, wet mix shotcrete, pool shotcrete"
  breadcrumbs={[{ name: "Shotcrete Calculator", url: "/shotcrete-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Shotcrete Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate shotcrete volume and rebound waste for spray-applied concrete applications.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Application Type</label>
          <select id="shc-app" class="shc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="wall" selected>Vertical Wall / Retaining Wall</option>
            <option value="overhead">Overhead / Ceiling</option>
            <option value="slope">Slope Stabilization</option>
            <option value="pool">Swimming Pool Shell</option>
            <option value="tunnel">Tunnel Lining</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Shotcrete Method</label>
          <select id="shc-method" class="shc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="wet" selected>Wet Mix Shotcrete</option>
            <option value="dry">Dry Mix (Gunite)</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Surface Area (sq ft)</label>
            <input type="number" id="shc-area" class="shc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="500" min="1" step="10">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Thickness (inches)</label>
            <input type="number" id="shc-thick" class="shc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" max="12" step="0.5">
          </div>
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <label class="block text-xs font-medium text-text mb-1">Custom Rebound Rate (%, or leave 0 for auto)</label>
          <input type="number" id="shc-rebound" class="shc-in w-full px-3 py-2 border border-border rounded-lg" value="0" min="0" max="50" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Shotcrete to Order</div>
          <div class="text-4xl font-extrabold" id="shc-total">0 yd3</div>
          <div class="text-sm text-blue-200 mt-1">including <span id="shc-rebound-pct">0</span>% rebound waste</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">In-Place Volume</div>
            <div class="text-xl font-bold" id="shc-inplace">0 yd3</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Rebound Waste</div>
            <div class="text-xl font-bold" id="shc-waste">0 yd3</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">In-Place Weight</div>
            <div class="text-xl font-bold" id="shc-weight">0 tons</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Truck Loads (10 yd3)</div>
            <div class="text-xl font-bold" id="shc-trucks">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="shotcrete" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Shotcrete Rebound Rates</h2>
      <ul>
        <li><strong>Wet mix, vertical:</strong> 5-15% rebound</li>
        <li><strong>Wet mix, overhead:</strong> 15-25% rebound</li>
        <li><strong>Dry mix, vertical:</strong> 15-30% rebound</li>
        <li><strong>Dry mix, overhead:</strong> 25-50% rebound</li>
        <li>Rebound material is not reusable and must be disposed of</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcSHC() {
      const app = (document.getElementById('shc-app') as HTMLSelectElement).value;
      const method = (document.getElementById('shc-method') as HTMLSelectElement).value;
      const area = parseFloat((document.getElementById('shc-area') as HTMLInputElement).value) || 0;
      const thick = parseFloat((document.getElementById('shc-thick') as HTMLInputElement).value) || 4;
      const customRebound = parseFloat((document.getElementById('shc-rebound') as HTMLInputElement).value) || 0;

      // Rebound rates by application and method
      let reboundRate = 0;
      if (customRebound > 0) {
        reboundRate = customRebound / 100;
      } else {
        const rates: Record<string, Record<string, number>> = {
          wall:     { wet: 0.10, dry: 0.20 },
          overhead: { wet: 0.20, dry: 0.35 },
          slope:    { wet: 0.08, dry: 0.15 },
          pool:     { wet: 0.12, dry: 0.18 },
          tunnel:   { wet: 0.15, dry: 0.30 },
        };
        reboundRate = (rates[app] && rates[app][method]) || 0.15;
      }

      const inPlaceCuFt = area * (thick / 12);
      const inPlaceYd3 = inPlaceCuFt / 27;
      const wasteYd3 = inPlaceYd3 * reboundRate;
      const totalYd3 = inPlaceYd3 + wasteYd3;
      const weightTons = inPlaceYd3 * 4050 / 2000;
      const trucks = Math.ceil(totalYd3 / 10);

      document.getElementById('shc-total')!.textContent = totalYd3.toFixed(1) + ' yd\u00B3';
      document.getElementById('shc-rebound-pct')!.textContent = (reboundRate * 100).toFixed(0);
      document.getElementById('shc-inplace')!.textContent = inPlaceYd3.toFixed(1) + ' yd\u00B3';
      document.getElementById('shc-waste')!.textContent = wasteYd3.toFixed(1) + ' yd\u00B3';
      document.getElementById('shc-weight')!.textContent = weightTons.toFixed(1) + ' tons';
      document.getElementById('shc-trucks')!.textContent = String(trucks);

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.shc-in').forEach(el => {
        el.addEventListener('input', calcSHC);
        el.addEventListener('change', calcSHC);
      });
      calcSHC();
    }, 50);
  </script>
</CalculatorLayout>
