---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Veneer Stone Calculator - Coverage, Corners & Adhesive Estimator";
const description = "Calculate veneer stone coverage area, corner pieces needed, and adhesive or mortar quantity. Supports natural and manufactured stone veneer.";

const relatedCalcs = [
  { name: "Brick Calculator", url: "/brick-calculator", description: "Brick quantity." },
  { name: "Stucco Calculator", url: "/stucco-calculator", description: "Stucco materials." },
  { name: "Mortar Calculator", url: "/mortar-calculator", description: "Mortar estimator." },
  { name: "Masonry Mortar Calculator", url: "/masonry-mortar-calculator", description: "Mortar by type." },
  { name: "Tuckpointing Calculator", url: "/tuckpointing-calculator", description: "Tuckpointing mortar." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Veneer Stone Calculator"
  keywords="veneer stone calculator, stone veneer, manufactured stone, corner pieces, stone adhesive, stone coverage"
  breadcrumbs={[{ name: "Veneer Stone Calculator", url: "/veneer-stone-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Veneer Stone Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Estimate veneer stone coverage, corner pieces, and adhesive or mortar for your project.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Length (ft)</label>
            <input type="number" id="vsn-length" class="vsn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="1" step="0.5">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-2">Wall Height (ft)</label>
            <input type="number" id="vsn-height" class="vsn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="1" step="0.5">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Openings to Deduct (sq ft)</label>
          <input type="number" id="vsn-openings" class="vsn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0" min="0" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Outside Corners (linear ft)</label>
          <input type="number" id="vsn-corners" class="vsn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="8" min="0" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Stone Type</label>
          <select id="vsn-type" class="vsn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="manufactured" selected>Manufactured Stone Veneer</option>
            <option value="natural">Natural Thin Stone Veneer</option>
            <option value="ledgestone">Ledgestone / Stacked</option>
            <option value="fieldstone">Fieldstone / Random</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Attachment Method</label>
          <select id="vsn-method" class="vsn-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="mortar" selected>Type S Mortar (Traditional)</option>
            <option value="adhesive">Polymer-Modified Thin-Set</option>
          </select>
        </div>

        <div class="p-4 bg-surface-alt rounded-xl">
          <label class="block text-xs font-medium text-text mb-1">Waste Factor (%)</label>
          <input type="number" id="vsn-waste" class="vsn-in w-full px-3 py-2 border border-border rounded-lg" value="10" min="0" max="25" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Flat Stone Needed</div>
          <div class="text-4xl font-extrabold" id="vsn-flats">0 sq ft</div>
          <div class="text-sm text-blue-200 mt-1">including waste</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Corner Pieces</div>
            <div class="text-xl font-bold" id="vsn-corner-qty">0 lin ft</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Coverage Area</div>
            <div class="text-xl font-bold" id="vsn-area">0 sq ft</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Mortar / Adhesive</div>
            <div class="text-xl font-bold" id="vsn-mortar">0 bags</div>
            <div class="text-xs text-text-muted" id="vsn-mortar-label">80 lb bags Type S</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Metal Lath</div>
            <div class="text-xl font-bold" id="vsn-lath">0 sheets</div>
            <div class="text-xs text-text-muted">2.5 lb/yd expanded</div>
          </div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Estimated Stone Weight</div>
          <div class="text-xl font-bold" id="vsn-weight">0 lbs</div>
        </div>
      </div>

      <ShareButton calculatorId="veneer-stone" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Veneer Stone Installation Guide</h2>
      <ul>
        <li><strong>Corner deduction:</strong> Each linear ft of corner covers ~0.75 sq ft of flat area</li>
        <li><strong>Manufactured stone:</strong> ~8-12 lbs/sq ft</li>
        <li><strong>Natural thin veneer:</strong> ~13-18 lbs/sq ft</li>
        <li><strong>Mortar bed:</strong> 1/2" thick scratch coat + 1/2" setting bed</li>
        <li><strong>Metal lath required:</strong> Over wood frame or any non-masonry substrate</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcVSN() {
      const length = parseFloat((document.getElementById('vsn-length') as HTMLInputElement).value) || 0;
      const height = parseFloat((document.getElementById('vsn-height') as HTMLInputElement).value) || 0;
      const openings = parseFloat((document.getElementById('vsn-openings') as HTMLInputElement).value) || 0;
      const corners = parseFloat((document.getElementById('vsn-corners') as HTMLInputElement).value) || 0;
      const stoneType = (document.getElementById('vsn-type') as HTMLSelectElement).value;
      const method = (document.getElementById('vsn-method') as HTMLSelectElement).value;
      const waste = (parseFloat((document.getElementById('vsn-waste') as HTMLInputElement).value) || 0) / 100;

      const grossArea = length * height - openings;
      // Corners cover ~0.75 sq ft of flat area per linear foot
      const cornerDeduction = corners * 0.75;
      const netFlatArea = Math.max(0, grossArea - cornerDeduction);
      const flatWithWaste = netFlatArea * (1 + waste);
      const cornerWithWaste = corners * (1 + waste);

      // Weight per sq ft by type
      const weightPerSqFt: Record<string, number> = {
        manufactured: 10, natural: 15, ledgestone: 12, fieldstone: 14,
      };
      const wt = weightPerSqFt[stoneType] || 10;
      const totalWeight = (flatWithWaste + cornerWithWaste * 0.75) * wt;

      // Mortar/adhesive: ~40 sq ft per 80lb bag mortar, ~60 sq ft per bag adhesive
      let mortarBags = 0;
      let mortarLabel = '';
      if (method === 'mortar') {
        mortarBags = Math.ceil((flatWithWaste + cornerWithWaste) / 40);
        mortarLabel = '80 lb bags Type S';
      } else {
        mortarBags = Math.ceil((flatWithWaste + cornerWithWaste) / 60);
        mortarLabel = '50 lb bags thin-set';
      }

      // Metal lath: 27x96in sheets = 18 sq ft
      const lathSheets = Math.ceil(grossArea / 18);

      document.getElementById('vsn-flats')!.textContent = Math.round(flatWithWaste) + ' sq ft';
      document.getElementById('vsn-corner-qty')!.textContent = Math.ceil(cornerWithWaste) + ' lin ft';
      document.getElementById('vsn-area')!.textContent = Math.round(grossArea) + ' sq ft';
      document.getElementById('vsn-mortar')!.textContent = mortarBags + ' bags';
      document.getElementById('vsn-mortar-label')!.textContent = mortarLabel;
      document.getElementById('vsn-lath')!.textContent = lathSheets + ' sheets';
      document.getElementById('vsn-weight')!.textContent = Math.round(totalWeight).toLocaleString() + ' lbs';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.vsn-in').forEach(el => {
        el.addEventListener('input', calcVSN);
        el.addEventListener('change', calcVSN);
      });
      calcVSN();
    }, 50);
  </script>
</CalculatorLayout>
