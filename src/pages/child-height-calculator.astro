---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Child Height Calculator - Predict Adult Height";
const description = "Predict your child's adult height using the mid-parental height method. Uses parents' heights and child's current measurements for accurate estimation.";

const relatedCalcs = [
  { name: "Child BMI Calculator", url: "/child-bmi-calculator", description: "BMI percentiles." },
  { name: "Child Nutrition Calculator", url: "/child-nutrition-calculator", description: "Daily nutrition." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Milestones." },
  { name: "BMI Calculator", url: "/bmi-calculator", description: "Adult BMI." },
  { name: "Ideal Weight Calculator", url: "/ideal-weight-calculator", description: "Healthy weight." },
  { name: "Calorie Calculator", url: "/calorie-calculator", description: "Calorie needs." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Child Height Calculator"
  keywords="child height calculator, predicted adult height, how tall will my child be, mid-parental height, growth prediction, height estimator"
  breadcrumbs={[{ name: "Child Height Calculator", url: "/child-height-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Child Height Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Predict your child's adult height using the mid-parental height formula and current growth data.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Gender</label>
          <select id="chc-gender" class="chc-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="boy">Boy</option>
            <option value="girl">Girl</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Current Age (years)</label>
          <input type="number" id="chc-age" class="chc-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="2" max="17" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Current Height</label>
          <div class="flex gap-2">
            <input type="number" id="chc-cfeet" class="chc-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="1" max="6" step="1" placeholder="ft">
            <input type="number" id="chc-cinches" class="chc-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="7" min="0" max="11" step="0.5" placeholder="in">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Father's Height</label>
          <div class="flex gap-2">
            <input type="number" id="chc-dfeet" class="chc-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="4" max="7" step="1" placeholder="ft">
            <input type="number" id="chc-dinches" class="chc-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="0" max="11" step="0.5" placeholder="in">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Mother's Height</label>
          <div class="flex gap-2">
            <input type="number" id="chc-mfeet" class="chc-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="4" max="7" step="1" placeholder="ft">
            <input type="number" id="chc-minches" class="chc-in w-1/2 px-4 py-3 border border-border rounded-xl text-lg font-bold" value="4" min="0" max="11" step="0.5" placeholder="in">
          </div>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Predicted Adult Height</div>
        <div class="text-5xl font-extrabold" id="chc-result">--</div>
        <div class="text-sm text-blue-200 mt-1" id="chc-range">predicted range</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Mid-Parental Height</div>
          <div class="text-lg font-bold" id="chc-midparent">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Growth Remaining</div>
          <div class="text-lg font-bold" id="chc-remaining">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Current Percentile</div>
          <div class="text-lg font-bold" id="chc-percentile">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Growth % Complete</div>
          <div class="text-lg font-bold" id="chc-complete">--</div>
        </div>
      </div>

      <ShareButton calculatorId="child-height" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">How to Predict a Child's Adult Height</h2>
      <p>The mid-parental height method is the most commonly used prediction tool. For boys, add 5 inches to the mother's height, average with the father's height. For girls, subtract 5 inches from the father's height, then average with the mother's height.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Factors That Affect Height</h3>
      <ul>
        <li><strong>Genetics:</strong> 60-80% of height is determined by genetics</li>
        <li><strong>Nutrition:</strong> Proper nutrition during growth years is essential</li>
        <li><strong>Sleep:</strong> Growth hormone is primarily released during deep sleep</li>
        <li><strong>Health:</strong> Chronic illness can affect growth</li>
        <li><strong>Exercise:</strong> Regular activity supports healthy growth</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Accuracy Note</h3>
      <p>The mid-parental height method has a margin of error of about +/- 2 inches. For more accurate predictions, a pediatrician can use bone age X-rays and growth charts.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCHC() {
      const gender = (document.getElementById('chc-gender') as HTMLSelectElement).value;
      const age = parseFloat((document.getElementById('chc-age') as HTMLInputElement).value) || 5;
      const cFeet = parseFloat((document.getElementById('chc-cfeet') as HTMLInputElement).value) || 3;
      const cInches = parseFloat((document.getElementById('chc-cinches') as HTMLInputElement).value) || 0;
      const dFeet = parseFloat((document.getElementById('chc-dfeet') as HTMLInputElement).value) || 5;
      const dInches = parseFloat((document.getElementById('chc-dinches') as HTMLInputElement).value) || 10;
      const mFeet = parseFloat((document.getElementById('chc-mfeet') as HTMLInputElement).value) || 5;
      const mInches = parseFloat((document.getElementById('chc-minches') as HTMLInputElement).value) || 4;

      const childIn = cFeet * 12 + cInches;
      const dadIn = dFeet * 12 + dInches;
      const momIn = mFeet * 12 + mInches;

      let midParent: number;
      if (gender === 'boy') {
        midParent = (dadIn + momIn + 5) / 2;
      } else {
        midParent = (dadIn - 5 + momIn) / 2;
      }

      // Percent of adult height by age (approximate CDC data)
      const pctByAge: Record<string, number[]> = {
        boy:  [0, 0, 0.49, 0.52, 0.55, 0.58, 0.61, 0.64, 0.67, 0.70, 0.73, 0.76, 0.80, 0.84, 0.88, 0.93, 0.97, 0.99],
        girl: [0, 0, 0.52, 0.55, 0.59, 0.62, 0.65, 0.68, 0.72, 0.76, 0.80, 0.84, 0.88, 0.93, 0.97, 0.99, 1.0, 1.0],
      };

      const ageIdx = Math.min(Math.max(Math.round(age), 2), 17);
      const pct = pctByAge[gender][ageIdx];
      const predictedFromCurrent = childIn / pct;
      const predicted = (midParent + predictedFromCurrent) / 2;

      const predFt = Math.floor(predicted / 12);
      const predIn = Math.round((predicted % 12) * 10) / 10;
      const midFt = Math.floor(midParent / 12);
      const midIn = Math.round((midParent % 12) * 10) / 10;

      const lowPred = predicted - 2;
      const highPred = predicted + 2;
      const lowFt = Math.floor(lowPred / 12);
      const lowIn = Math.round((lowPred % 12) * 10) / 10;
      const highFt = Math.floor(highPred / 12);
      const highIn = Math.round((highPred % 12) * 10) / 10;

      const remaining = Math.max(0, predicted - childIn);
      const remFt = Math.floor(remaining / 12);
      const remIn = Math.round((remaining % 12) * 10) / 10;

      const growthPct = Math.min(100, Math.round((childIn / predicted) * 100));

      // Rough percentile from average
      const avgBoy = 69.1, avgGirl = 63.7;
      const avg = gender === 'boy' ? avgBoy : avgGirl;
      const diff = predicted - avg;
      let percentile = 50 + diff * 8;
      percentile = Math.max(1, Math.min(99, Math.round(percentile)));

      document.getElementById('chc-result')!.textContent = predFt + "'" + predIn.toFixed(0) + '"';
      document.getElementById('chc-range')!.textContent = lowFt + "'" + lowIn.toFixed(0) + '" to ' + highFt + "'" + highIn.toFixed(0) + '" (+/- 2 in)';
      document.getElementById('chc-midparent')!.textContent = midFt + "'" + midIn.toFixed(0) + '"';
      document.getElementById('chc-remaining')!.textContent = remFt > 0 ? remFt + "'" + remIn.toFixed(0) + '"' : remIn.toFixed(1) + ' in';
      document.getElementById('chc-percentile')!.textContent = percentile + 'th';
      document.getElementById('chc-complete')!.textContent = growthPct + '%';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.chc-in').forEach(el => {
        el.addEventListener('input', calcCHC);
        el.addEventListener('change', calcCHC);
      });
      calcCHC();
    }, 50);
  </script>
</CalculatorLayout>
