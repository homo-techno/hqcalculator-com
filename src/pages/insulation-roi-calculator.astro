---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Insulation ROI Calculator - R-Value Upgrade Savings";
const description = "Calculate the return on investment from insulation upgrades based on R-value improvement, climate zone, and energy costs.";
const relatedCalcs = [
  { name: "Energy Audit", url: "/energy-audit-calculator", description: "Home audit." },
  { name: "Heat Pump", url: "/heat-pump-efficiency-calculator", description: "Heat pump COP." },
  { name: "Passive House", url: "/passive-house-calculator", description: "Passive design." },
  { name: "BTU Calculator", url: "/btu-calculator", description: "BTU sizing." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "ROI Calculator", url: "/roi-calculator", description: "Return on investment." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Insulation ROI Calculator" keywords="insulation ROI calculator, R-value upgrade savings, insulation payback period, attic insulation savings, wall insulation cost" breadcrumbs={[{ name: "Insulation ROI", url: "/insulation-roi-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Insulation ROI Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate how quickly an insulation upgrade pays for itself through energy savings.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Insulation Details</h3>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Location</label>
          <select id="iro-area" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="attic" selected>Attic / Ceiling</option>
            <option value="wall">Exterior Walls</option>
            <option value="floor">Floor / Crawlspace</option>
            <option value="basement">Basement Walls</option>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Area (sq ft)</label><input type="number" id="iro-sqft" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1200" min="50" max="10000" step="50"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Current R-Value</label><input type="number" id="iro-rold" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="11" min="0" max="60" step="1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">New R-Value</label><input type="number" id="iro-rnew" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="38" min="1" max="80" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Install Cost ($/sq ft)</label><input type="number" id="iro-costpsf" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.50" min="0.25" max="10" step="0.25"></div>
        </div>
        <h3 class="font-semibold text-text">Climate & Energy</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Heating Degree Days</label><input type="number" id="iro-hdd" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5000" min="500" max="10000" step="100"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Cooling Degree Days</label><input type="number" id="iro-cdd" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1500" min="0" max="5000" step="100"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Heating Fuel Cost ($/therm)</label><input type="number" id="iro-fuel" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.20" min="0.30" max="5" step="0.10"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Cooling Cost ($/kWh)</label><input type="number" id="iro-cool" class="iro-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.14" min="0.01" max="0.60" step="0.01"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Payback Period</div>
          <div class="text-4xl font-extrabold" id="iro-payback">0</div>
          <div class="text-sm text-blue-200 mt-1">years</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Total Cost</div><div class="text-xl font-bold" id="iro-total">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Annual Savings</div><div class="text-xl font-bold" id="iro-savings">$0/yr</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">10-Year ROI</div><div class="text-xl font-bold" id="iro-roi10">0%</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Heat Loss Reduction</div><div class="text-xl font-bold" id="iro-reduction">0%</div></div>
        </div>
      </div>
      <ShareButton calculatorId="insulation-roi" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Insulation ROI</h2>
      <p>Heat loss through a surface is inversely proportional to its R-value: Q = A * delta-T / R. Upgrading from R-11 to R-38 reduces heat flow by 71%. The savings depend on heating/cooling degree days (HDD/CDD) which measure climate severity. Attic insulation typically offers the best ROI, often paying back in 2-5 years. The DOE recommends R-38 to R-60 for attics in most U.S. climate zones.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcIRO() {
      const sqft = parseFloat((document.getElementById('iro-sqft') as HTMLInputElement).value) || 1200;
      const rOld = parseFloat((document.getElementById('iro-rold') as HTMLInputElement).value) || 11;
      const rNew = parseFloat((document.getElementById('iro-rnew') as HTMLInputElement).value) || 38;
      const costPSF = parseFloat((document.getElementById('iro-costpsf') as HTMLInputElement).value) || 1.50;
      const hdd = parseFloat((document.getElementById('iro-hdd') as HTMLInputElement).value) || 5000;
      const cdd = parseFloat((document.getElementById('iro-cdd') as HTMLInputElement).value) || 1500;
      const fuelCost = parseFloat((document.getElementById('iro-fuel') as HTMLInputElement).value) || 1.20;
      const coolCost = parseFloat((document.getElementById('iro-cool') as HTMLInputElement).value) || 0.14;
      const totalCost = sqft * costPSF;
      const uOld = rOld > 0 ? 1 / rOld : 1;
      const uNew = rNew > 0 ? 1 / rNew : 1;
      const heatSaveBTU = sqft * (uOld - uNew) * hdd * 24;
      const coolSaveBTU = sqft * (uOld - uNew) * cdd * 24;
      const heatSaveTherms = heatSaveBTU / 100000 / 0.85;
      const coolSaveKWh = coolSaveBTU / 3412 / 3;
      const heatSave$ = heatSaveTherms * fuelCost;
      const coolSave$ = coolSaveKWh * coolCost;
      const annualSavings = heatSave$ + coolSave$;
      const payback = annualSavings > 0 ? totalCost / annualSavings : 99;
      const roi10 = totalCost > 0 ? ((annualSavings * 10 - totalCost) / totalCost * 100) : 0;
      const reduction = rOld > 0 ? ((1 / rOld - 1 / rNew) / (1 / rOld) * 100) : 0;
      document.getElementById('iro-payback')!.textContent = payback < 50 ? payback.toFixed(1) : 'N/A';
      document.getElementById('iro-total')!.textContent = '$' + Math.round(totalCost).toLocaleString();
      document.getElementById('iro-savings')!.textContent = '$' + Math.round(annualSavings).toLocaleString() + '/yr';
      document.getElementById('iro-roi10')!.textContent = roi10.toFixed(0) + '%';
      document.getElementById('iro-reduction')!.textContent = reduction.toFixed(0) + '%';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.iro-in').forEach(el => { el.addEventListener('input', calcIRO); el.addEventListener('change', calcIRO); }); calcIRO(); }, 50);
  </script>
</CalculatorLayout>
