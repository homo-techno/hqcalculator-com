---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Excavation Volume Calculator - Unit Volume & Soil Weight";
const description = "Calculate excavation unit volume and estimate soil removal weight for archaeological digs. Plan backfill, screen time, and labor requirements.";
const relatedCalcs = [
  { name: "Artifact Density", url: "/artifact-density-calculator", description: "Finds per area." },
  { name: "Site Grid", url: "/site-grid-calculator", description: "Grid layout planning." },
  { name: "Stratigraphy", url: "/stratigraphy-calculator", description: "Layer age estimation." },
  { name: "Survey Coverage", url: "/survey-coverage-calculator", description: "Survey sampling." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Volume calculations." },
  { name: "Square Footage", url: "/square-footage-calculator", description: "Area calculations." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Excavation Volume Calculator" keywords="excavation volume, soil removal, archaeological excavation, unit volume, backfill, soil weight, dig planning" breadcrumbs={[{ name: "Excavation Volume", url: "/excavation-volume-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Excavation Volume Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate the volume of soil to be excavated, estimate soil weight, screening time, and labor needs for archaeological excavation units.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Unit Length (m)</label>
            <input type="number" id="ev2-len" class="ev2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0.1" step="0.1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Unit Width (m)</label>
            <input type="number" id="ev2-wid" class="ev2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="0.1" step="0.1">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Excavation Depth (cm)</label>
          <input type="number" id="ev2-depth" class="ev2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="100" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Soil Density (kg/cu m)</label>
          <input type="number" id="ev2-soildens" class="ev2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1500" min="100" step="50">
          <p class="text-xs text-text-muted mt-1">Typical: Dry sand 1600, Clay 1800, Loam 1400, Silt 1300</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Units</label>
          <input type="number" id="ev2-units" class="ev2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Level Thickness (cm)</label>
          <input type="number" id="ev2-level" class="ev2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="1" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Total Volume</div>
          <div class="text-4xl font-extrabold" id="ev2-vol">0</div>
          <div class="text-sm text-blue-200 mt-1">cubic meters</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Soil Weight</div>
            <div class="text-xl font-bold" id="ev2-weight">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Per-Unit Volume</div>
            <div class="text-xl font-bold" id="ev2-unitvol">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Number of Levels</div>
            <div class="text-xl font-bold" id="ev2-levels">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Volume per Level</div>
            <div class="text-xl font-bold" id="ev2-lvlvol">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Buckets (5 gal / 19L)</div>
            <div class="text-xl font-bold" id="ev2-buckets">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Wheelbarrow Loads</div>
            <div class="text-xl font-bold" id="ev2-wheel">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="excavation-volume" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Excavation Volume Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Volume</strong> = Length * Width * Depth * Number of Units</p>
        <p><strong>Weight</strong> = Volume * Soil Density</p>
        <p><strong>Levels</strong> = Total Depth / Level Thickness</p>
      </div>
      <p>Knowing the volume of soil to be excavated helps plan labor, equipment, and time requirements. A standard 5-gallon bucket holds approximately 0.019 cubic meters (19 liters). A typical wheelbarrow holds about 0.085 cubic meters (85 liters or 3 cubic feet).</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcEV2() {
      const len = parseFloat((document.getElementById('ev2-len') as HTMLInputElement).value) || 0;
      const wid = parseFloat((document.getElementById('ev2-wid') as HTMLInputElement).value) || 0;
      const depth = parseFloat((document.getElementById('ev2-depth') as HTMLInputElement).value) || 0;
      const soilDens = parseFloat((document.getElementById('ev2-soildens') as HTMLInputElement).value) || 0;
      const numUnits = parseFloat((document.getElementById('ev2-units') as HTMLInputElement).value) || 1;
      const levelThick = parseFloat((document.getElementById('ev2-level') as HTMLInputElement).value) || 10;

      const depthM = depth / 100;
      const unitVol = len * wid * depthM;
      const totalVol = unitVol * numUnits;
      const totalWeight = totalVol * soilDens;
      const numLevels = Math.ceil(depth / levelThick);
      const levelVol = len * wid * (levelThick / 100);
      const buckets = totalVol / 0.019;
      const wheelbarrows = totalVol / 0.085;

      let weightStr = '';
      if (totalWeight >= 1000) {
        weightStr = (totalWeight / 1000).toFixed(2) + ' tonnes';
      } else {
        weightStr = totalWeight.toFixed(0) + ' kg';
      }

      document.getElementById('ev2-vol')!.textContent = totalVol.toFixed(3);
      document.getElementById('ev2-weight')!.textContent = weightStr;
      document.getElementById('ev2-unitvol')!.textContent = unitVol.toFixed(3) + ' cu m';
      document.getElementById('ev2-levels')!.textContent = numLevels.toString();
      document.getElementById('ev2-lvlvol')!.textContent = levelVol.toFixed(4) + ' cu m';
      document.getElementById('ev2-buckets')!.textContent = Math.ceil(buckets).toLocaleString();
      document.getElementById('ev2-wheel')!.textContent = Math.ceil(wheelbarrows).toLocaleString();

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.ev2-in').forEach(el => { el.addEventListener('input', calcEV2); el.addEventListener('change', calcEV2); });
      calcEV2();
    }, 50);
  </script>
</CalculatorLayout>
