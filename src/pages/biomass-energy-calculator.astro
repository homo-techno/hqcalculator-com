---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Biomass Energy Calculator - Fuel Energy Content & Heating Value";
const description = "Calculate biomass fuel energy content, heating value, and output from various biomass feedstocks including wood, pellets, and agricultural waste.";
const relatedCalcs = [
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "BTU Calculator", url: "/btu-calculator", description: "Heating energy." },
  { name: "Heat Pump", url: "/heat-pump-efficiency-calculator", description: "Heat pump COP." },
  { name: "Composting Rate", url: "/composting-rate-calculator", description: "Compost calculations." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Energy costs." },
  { name: "Carbon Offset", url: "/carbon-offset-calculator", description: "Carbon offsets." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Biomass Energy Calculator" keywords="biomass energy calculator, biomass heating value, wood pellet BTU, biomass fuel content, renewable biomass energy" breadcrumbs={[{ name: "Biomass Energy", url: "/biomass-energy-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Biomass Energy Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate energy content and heating output from biomass fuels.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Biomass Fuel</h3>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Fuel Type</label>
          <select id="bme-type" class="bme-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="hardwood">Hardwood (cord) - 24 MMBTU</option>
            <option value="softwood">Softwood (cord) - 18 MMBTU</option>
            <option value="pellets" selected>Wood Pellets (ton) - 16.4 MMBTU</option>
            <option value="chips">Wood Chips (ton) - 10 MMBTU</option>
            <option value="corn">Corn (bushel) - 0.39 MMBTU</option>
            <option value="switchgrass">Switchgrass (ton) - 14 MMBTU</option>
            <option value="biogas">Biogas (1000 ft³) - 0.6 MMBTU</option>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Quantity</label><input type="number" id="bme-qty" class="bme-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0.1" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Moisture Content (%)</label><input type="number" id="bme-moist" class="bme-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" max="60" step="1"></div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Boiler/Stove Efficiency (%)</label><input type="number" id="bme-eff" class="bme-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="80" min="30" max="99" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Cost per Unit ($)</label><input type="number" id="bme-cost" class="bme-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="250" min="0" step="10"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Usable Heat Energy</div>
          <div class="text-4xl font-extrabold" id="bme-heat">0</div>
          <div class="text-sm text-blue-200 mt-1">MMBTU</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Gross Energy</div><div class="text-xl font-bold" id="bme-gross">0 MMBTU</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Equivalent kWh</div><div class="text-xl font-bold" id="bme-kwh">0 kWh</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Cost per MMBTU</div><div class="text-xl font-bold" id="bme-cperm">$0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Equivalent Gallons Propane</div><div class="text-xl font-bold" id="bme-propane">0 gal</div></div>
        </div>
      </div>
      <ShareButton calculatorId="biomass-energy" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Biomass Energy</h2>
      <p>Biomass energy comes from organic materials like wood, crops, and waste. The actual usable heat depends on moisture content (which reduces heating value) and combustion efficiency. Higher moisture reduces net energy because water must be evaporated. Wood pellets are popular due to low moisture (typically 5-10%) and consistent energy density of about 16.4 MMBTU per ton.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    const bmeData: Record<string, number> = { hardwood: 24, softwood: 18, pellets: 16.4, chips: 10, corn: 0.39, switchgrass: 14, biogas: 0.6 };
    function calcBME() {
      const type = (document.getElementById('bme-type') as HTMLSelectElement).value;
      const qty = parseFloat((document.getElementById('bme-qty') as HTMLInputElement).value) || 1;
      const moist = parseFloat((document.getElementById('bme-moist') as HTMLInputElement).value) || 20;
      const eff = parseFloat((document.getElementById('bme-eff') as HTMLInputElement).value) || 80;
      const cost = parseFloat((document.getElementById('bme-cost') as HTMLInputElement).value) || 0;
      const baseMMBTU = bmeData[type] || 16.4;
      const moistFactor = 1 - (moist / 100) * 1.1;
      const grossEnergy = baseMMBTU * qty * Math.max(moistFactor, 0.1);
      const usableHeat = grossEnergy * (eff / 100);
      const kwh = usableHeat * 293.07;
      const totalCost = cost * qty;
      const costPerMMBTU = usableHeat > 0 ? totalCost / usableHeat : 0;
      const propaneGal = usableHeat / 0.0916;
      document.getElementById('bme-heat')!.textContent = usableHeat.toFixed(1);
      document.getElementById('bme-gross')!.textContent = grossEnergy.toFixed(1) + ' MMBTU';
      document.getElementById('bme-kwh')!.textContent = Math.round(kwh).toLocaleString() + ' kWh';
      document.getElementById('bme-cperm')!.textContent = '$' + costPerMMBTU.toFixed(2);
      document.getElementById('bme-propane')!.textContent = Math.round(propaneGal).toLocaleString() + ' gal';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.bme-in').forEach(el => { el.addEventListener('input', calcBME); el.addEventListener('change', calcBME); }); calcBME(); }, 50);
  </script>
</CalculatorLayout>
