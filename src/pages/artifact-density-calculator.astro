---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Artifact Density Calculator - Finds Per Square Meter";
const description = "Calculate artifact density per square meter in excavation units. Analyze spatial distribution, compare units, and estimate total site artifact counts.";
const relatedCalcs = [
  { name: "Excavation Volume", url: "/excavation-volume-calculator", description: "Dig unit volume." },
  { name: "Site Grid", url: "/site-grid-calculator", description: "Grid layout planning." },
  { name: "Survey Coverage", url: "/survey-coverage-calculator", description: "Survey sampling." },
  { name: "Ceramic Analysis", url: "/ceramic-analysis-calculator", description: "Pottery sherd analysis." },
  { name: "Lithic Analysis", url: "/lithic-analysis-calculator", description: "Stone tool analysis." },
  { name: "Population Estimate", url: "/population-estimate-calculator", description: "Ancient population." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Artifact Density Calculator" keywords="artifact density, finds per square meter, excavation unit, spatial analysis, archaeological density, artifact distribution" breadcrumbs={[{ name: "Artifact Density", url: "/artifact-density-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Artifact Density Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate the density of artifacts recovered from excavation units. Compare densities across units and estimate total site assemblage size.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Artifacts Found</label>
          <input type="number" id="afd-count" class="afd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="47" min="0" step="1">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-text mb-1">Unit Length (m)</label>
            <input type="number" id="afd-len" class="afd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="0.1" step="0.1">
          </div>
          <div>
            <label class="block text-sm font-medium text-text mb-1">Unit Width (m)</label>
            <input type="number" id="afd-wid" class="afd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="0.1" step="0.1">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Level/Layer Depth (cm)</label>
          <input type="number" id="afd-depth" class="afd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Site Area (sq m)</label>
          <input type="number" id="afd-sitearea" class="afd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="500" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Artifact Total Weight (g)</label>
          <input type="number" id="afd-weight" class="afd-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="320" min="0" step="1">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Artifact Density</div>
          <div class="text-4xl font-extrabold" id="afd-density">0</div>
          <div class="text-sm text-blue-200 mt-1">artifacts per sq m</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Density per Cubic Meter</div>
            <div class="text-xl font-bold" id="afd-volcdens">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Unit Area (sq m)</div>
            <div class="text-xl font-bold" id="afd-area">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Est. Total Site Artifacts</div>
            <div class="text-xl font-bold" id="afd-total">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Avg Weight per Artifact</div>
            <div class="text-xl font-bold" id="afd-avgwt">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Weight Density (g/sq m)</div>
            <div class="text-xl font-bold" id="afd-wtdens">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Unit Volume (cu m)</div>
            <div class="text-xl font-bold" id="afd-vol">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="artifact-density" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Artifact Density Analysis</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Density (2D)</strong> = Artifact Count / Unit Area</p>
        <p><strong>Density (3D)</strong> = Artifact Count / Unit Volume</p>
        <p><strong>Site Estimate</strong> = Density * Total Site Area</p>
      </div>
      <p>Artifact density is a fundamental measure in archaeological analysis. High-density areas may indicate activity zones, middens, or occupation floors. Comparing densities across units helps archaeologists identify site structure and activity areas.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcAFD() {
      const count = parseFloat((document.getElementById('afd-count') as HTMLInputElement).value) || 0;
      const len = parseFloat((document.getElementById('afd-len') as HTMLInputElement).value) || 0;
      const wid = parseFloat((document.getElementById('afd-wid') as HTMLInputElement).value) || 0;
      const depth = parseFloat((document.getElementById('afd-depth') as HTMLInputElement).value) || 0;
      const siteArea = parseFloat((document.getElementById('afd-sitearea') as HTMLInputElement).value) || 0;
      const weight = parseFloat((document.getElementById('afd-weight') as HTMLInputElement).value) || 0;

      const area = len * wid;
      const volume = area * (depth / 100);
      const density2d = area > 0 ? count / area : 0;
      const density3d = volume > 0 ? count / volume : 0;
      const totalEst = density2d * siteArea;
      const avgWt = count > 0 ? weight / count : 0;
      const wtDensity = area > 0 ? weight / area : 0;

      document.getElementById('afd-density')!.textContent = density2d.toFixed(1);
      document.getElementById('afd-volcdens')!.textContent = density3d.toFixed(1) + ' /cu m';
      document.getElementById('afd-area')!.textContent = area.toFixed(2);
      document.getElementById('afd-total')!.textContent = Math.round(totalEst).toLocaleString();
      document.getElementById('afd-avgwt')!.textContent = avgWt.toFixed(1) + ' g';
      document.getElementById('afd-wtdens')!.textContent = wtDensity.toFixed(1) + ' g/sq m';
      document.getElementById('afd-vol')!.textContent = volume.toFixed(3);

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.afd-in').forEach(el => { el.addEventListener('input', calcAFD); el.addEventListener('change', calcAFD); });
      calcAFD();
    }, 50);
  </script>
</CalculatorLayout>
