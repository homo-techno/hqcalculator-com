---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "College Fund Calculator - 529 Savings Plan Projection";
const description = "Project your 529 college savings plan growth with regular contributions. See how much you need to save monthly to reach your college funding goal.";

const relatedCalcs = [
  { name: "College Cost Calculator", url: "/college-cost-calculator", description: "Tuition estimates." },
  { name: "Savings Calculator", url: "/savings-calculator", description: "Savings growth." },
  { name: "Compound Interest Calculator", url: "/compound-interest-calculator", description: "Interest growth." },
  { name: "Investment Calculator", url: "/investment-calculator", description: "Investment returns." },
  { name: "Allowance Calculator", url: "/allowance-calculator", description: "Kids allowance." },
  { name: "School Supply Calculator", url: "/school-supply-calculator", description: "School costs." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="College Fund Calculator"
  keywords="college fund calculator, 529 plan calculator, college savings calculator, save for college, 529 savings projection, education savings"
  breadcrumbs={[{ name: "College Fund Calculator", url: "/college-fund-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">College Fund Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Project your 529 college savings plan growth and determine how much to save monthly for your child's education.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Child's Current Age</label>
          <input type="number" id="clf-age" class="clf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0" max="17" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">College Start Age</label>
          <input type="number" id="clf-start" class="clf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18" min="16" max="22" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Current Savings ($)</label>
          <input type="number" id="clf-current" class="clf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5000" min="0" max="500000" step="100">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Monthly Contribution ($)</label>
          <input type="number" id="clf-monthly" class="clf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="250" min="0" max="5000" step="25">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Expected Annual Return (%)</label>
          <input type="number" id="clf-return" class="clf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="7" min="1" max="15" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">College Type</label>
          <select id="clf-type" class="clf-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="public-in">Public University (In-State)</option>
            <option value="public-out">Public University (Out-of-State)</option>
            <option value="private" selected>Private University</option>
            <option value="community">Community College (2 years)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">College Cost Inflation (%/year)</label>
          <input type="number" id="clf-inflation" class="clf-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="1" max="10" step="0.5">
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Projected Savings at College</div>
        <div class="text-5xl font-extrabold" id="clf-projected">--</div>
        <div class="text-sm text-blue-200 mt-1" id="clf-coverage">coverage of estimated cost</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Est. 4-Year Cost</div>
          <div class="text-lg font-bold" id="clf-cost">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Funding Gap</div>
          <div class="text-lg font-bold" id="clf-gap">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Total Contributions</div>
          <div class="text-lg font-bold" id="clf-totalcontrib">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Investment Earnings</div>
          <div class="text-lg font-bold" id="clf-earnings">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Growth Projection</h3>
        <div class="text-xs" id="clf-table"></div>
      </div>

      <ShareButton calculatorId="college-fund" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Saving for College with a 529 Plan</h2>
      <p>A 529 plan is a tax-advantaged savings plan designed for education expenses. Contributions grow tax-free, and withdrawals for qualified education expenses are also tax-free.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Current Average College Costs (per year)</h3>
      <ul>
        <li><strong>Public In-State:</strong> ~$22,000 (tuition, room & board)</li>
        <li><strong>Public Out-of-State:</strong> ~$39,000</li>
        <li><strong>Private University:</strong> ~$52,000</li>
        <li><strong>Community College:</strong> ~$12,000 (tuition & fees)</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Tips for College Savings</h3>
      <ul>
        <li>Start saving as early as possible to maximize compound growth</li>
        <li>Automate monthly contributions to stay consistent</li>
        <li>Consider age-based investment options that become more conservative over time</li>
        <li>Check your state's tax deduction or credit for 529 contributions</li>
        <li>Ask grandparents to contribute to the 529 instead of gifts</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcCLF() {
      const childAge = parseFloat((document.getElementById('clf-age') as HTMLInputElement).value) || 0;
      const startAge = parseFloat((document.getElementById('clf-start') as HTMLInputElement).value) || 18;
      const currentSavings = parseFloat((document.getElementById('clf-current') as HTMLInputElement).value) || 0;
      const monthlyContrib = parseFloat((document.getElementById('clf-monthly') as HTMLInputElement).value) || 0;
      const annualReturn = parseFloat((document.getElementById('clf-return') as HTMLInputElement).value) || 7;
      const collegeType = (document.getElementById('clf-type') as HTMLSelectElement).value;
      const inflation = parseFloat((document.getElementById('clf-inflation') as HTMLInputElement).value) || 5;

      const yearsToCollege = Math.max(0, startAge - childAge);
      const monthlyReturn = annualReturn / 100 / 12;

      // Current annual costs
      const annualCosts: Record<string, number> = {
        'public-in': 22000, 'public-out': 39000, 'private': 52000, 'community': 12000
      };
      const years = collegeType === 'community' ? 2 : 4;

      // Inflate cost to future value
      const futureAnnualCost = annualCosts[collegeType] * Math.pow(1 + inflation / 100, yearsToCollege);
      const totalCost = futureAnnualCost * years;

      // Project savings
      let balance = currentSavings;
      const rows: string[] = [];
      const totalMonths = yearsToCollege * 12;

      for (let y = 1; y <= yearsToCollege; y++) {
        for (let m = 0; m < 12; m++) {
          balance = balance * (1 + monthlyReturn) + monthlyContrib;
        }
        if (y <= 5 || y === yearsToCollege || y % 3 === 0) {
          rows.push(`<div class="grid grid-cols-4 gap-2 py-1 ${y === yearsToCollege ? 'bg-blue-50 rounded font-bold' : ''}"><span>Year ${y} (Age ${childAge + y})</span><span>$${Math.round(monthlyContrib * 12 * y + currentSavings).toLocaleString()}</span><span>$${Math.round(balance - (monthlyContrib * 12 * y + currentSavings)).toLocaleString()}</span><span>$${Math.round(balance).toLocaleString()}</span></div>`);
        }
      }

      const totalContributions = currentSavings + monthlyContrib * totalMonths;
      const earnings = balance - totalContributions;
      const gap = Math.max(0, totalCost - balance);
      const coverage = totalCost > 0 ? Math.min(100, (balance / totalCost) * 100) : 0;

      document.getElementById('clf-projected')!.textContent = '$' + Math.round(balance).toLocaleString();
      document.getElementById('clf-coverage')!.textContent = coverage.toFixed(0) + '% of estimated cost covered';
      document.getElementById('clf-cost')!.textContent = '$' + Math.round(totalCost).toLocaleString();
      document.getElementById('clf-gap')!.textContent = gap > 0 ? '$' + Math.round(gap).toLocaleString() : 'Fully Funded!';
      document.getElementById('clf-totalcontrib')!.textContent = '$' + Math.round(totalContributions).toLocaleString();
      document.getElementById('clf-earnings')!.textContent = '$' + Math.round(earnings).toLocaleString();

      document.getElementById('clf-table')!.innerHTML =
        '<div class="grid grid-cols-4 gap-2 font-semibold text-text-muted mb-1"><span>Year</span><span>Contributed</span><span>Earnings</span><span>Balance</span></div>' +
        rows.join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.clf-in').forEach(el => {
        el.addEventListener('input', calcCLF);
        el.addEventListener('change', calcCLF);
      });
      calcCLF();
    }, 50);
  </script>
</CalculatorLayout>
