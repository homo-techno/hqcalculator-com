---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Heat Pump Efficiency Calculator - COP/HSPF vs Furnace Comparison";
const description = "Compare heat pump efficiency (COP/HSPF/SEER) against furnace AFUE ratings to determine energy cost savings and environmental benefits.";
const relatedCalcs = [
  { name: "Energy Audit", url: "/energy-audit-calculator", description: "Home audit." },
  { name: "Insulation ROI", url: "/insulation-roi-calculator", description: "Insulation savings." },
  { name: "Electricity Cost", url: "/electricity-cost-calculator", description: "Electric bills." },
  { name: "BTU Calculator", url: "/btu-calculator", description: "BTU sizing." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Passive House", url: "/passive-house-calculator", description: "Passive design." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Heat Pump Efficiency Calculator" keywords="heat pump efficiency calculator, COP comparison, HSPF vs AFUE, heat pump vs furnace, heat pump cost savings" breadcrumbs={[{ name: "Heat Pump Efficiency", url: "/heat-pump-efficiency-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Heat Pump Efficiency Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Compare heat pump COP/HSPF performance against furnace efficiency for heating costs.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Heat Pump</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">HSPF2 Rating</label><input type="number" id="hpe-hspf" class="hpe-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="5" max="15" step="0.5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">SEER2 Rating</label><input type="number" id="hpe-seer" class="hpe-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18" min="10" max="30" step="0.5"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Electricity Rate ($/kWh)</label><input type="number" id="hpe-elec" class="hpe-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.14" min="0.01" max="0.60" step="0.01"></div>
        <h3 class="font-semibold text-text">Furnace Comparison</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Furnace AFUE (%)</label><input type="number" id="hpe-afue" class="hpe-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="92" min="60" max="99" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Gas Cost ($/therm)</label><input type="number" id="hpe-gas" class="hpe-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1.20" min="0.30" max="5" step="0.10"></div>
        </div>
        <h3 class="font-semibold text-text">Heating Load</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Annual Heating (MMBTU)</label><input type="number" id="hpe-load" class="hpe-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="60" min="10" max="200" step="5"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Annual Cooling (MMBTU)</label><input type="number" id="hpe-cool" class="hpe-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" max="100" step="5"></div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Annual Savings with Heat Pump</div>
          <div class="text-4xl font-extrabold" id="hpe-savings">$0</div>
          <div class="text-sm text-blue-200 mt-1">per year vs furnace + AC</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Heat Pump COP</div><div class="text-xl font-bold" id="hpe-cop">0</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Effective Furnace COP</div><div class="text-xl font-bold" id="hpe-fcop">0</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">HP Heating Cost</div><div class="text-xl font-bold" id="hpe-hpcost">$0/yr</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Furnace Heating Cost</div><div class="text-xl font-bold" id="hpe-fcost">$0/yr</div></div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">CO₂ Reduction</div>
          <div class="text-2xl font-bold" id="hpe-co2">0 lbs/yr</div>
        </div>
      </div>
      <ShareButton calculatorId="heat-pump-efficiency" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Heat Pump vs Furnace Efficiency</h2>
      <p>Heat pumps move heat rather than generating it, achieving COPs of 2-4 (200-400% efficient). The HSPF (Heating Seasonal Performance Factor) rates heating efficiency; divide by 3.412 to get average COP. A gas furnace with 96% AFUE has an effective COP of 0.96. Even at higher electricity rates, heat pumps often win when gas costs exceed $1/therm and electricity is under $0.15/kWh.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcHPE() {
      const hspf = parseFloat((document.getElementById('hpe-hspf') as HTMLInputElement).value) || 10;
      const seer = parseFloat((document.getElementById('hpe-seer') as HTMLInputElement).value) || 18;
      const elec = parseFloat((document.getElementById('hpe-elec') as HTMLInputElement).value) || 0.14;
      const afue = parseFloat((document.getElementById('hpe-afue') as HTMLInputElement).value) || 92;
      const gasPrice = parseFloat((document.getElementById('hpe-gas') as HTMLInputElement).value) || 1.20;
      const heatLoad = parseFloat((document.getElementById('hpe-load') as HTMLInputElement).value) || 60;
      const coolLoad = parseFloat((document.getElementById('hpe-cool') as HTMLInputElement).value) || 20;
      const cop = hspf / 3.412;
      const furnaceCOP = afue / 100;
      const heatBTU = heatLoad * 1000000;
      const coolBTU = coolLoad * 1000000;
      const hpHeatKWh = heatBTU / (cop * 3412);
      const hpCoolKWh = coolBTU / (seer / 3.412 * 3412);
      const hpTotalCost = (hpHeatKWh + hpCoolKWh) * elec;
      const furnaceHeatTherms = heatBTU / (furnaceCOP * 100000);
      const acCoolKWh = coolBTU / (13 / 3.412 * 3412);
      const furnaceTotalCost = furnaceHeatTherms * gasPrice + acCoolKWh * elec;
      const savings = furnaceTotalCost - hpTotalCost;
      const co2Furnace = furnaceHeatTherms * 11.7 + acCoolKWh * 0.92;
      const co2HP = (hpHeatKWh + hpCoolKWh) * 0.92;
      const co2Savings = co2Furnace - co2HP;
      document.getElementById('hpe-savings')!.textContent = '$' + Math.round(savings).toLocaleString();
      document.getElementById('hpe-cop')!.textContent = cop.toFixed(2);
      document.getElementById('hpe-fcop')!.textContent = furnaceCOP.toFixed(2);
      document.getElementById('hpe-hpcost')!.textContent = '$' + Math.round(hpTotalCost).toLocaleString() + '/yr';
      document.getElementById('hpe-fcost')!.textContent = '$' + Math.round(furnaceTotalCost).toLocaleString() + '/yr';
      document.getElementById('hpe-co2')!.textContent = Math.round(co2Savings).toLocaleString() + ' lbs/yr';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.hpe-in').forEach(el => { el.addEventListener('input', calcHPE); el.addEventListener('change', calcHPE); }); calcHPE(); }, 50);
  </script>
</CalculatorLayout>
