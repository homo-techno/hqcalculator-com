---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Masonry Anchor Calculator - Pullout Strength & Spacing";
const description = "Calculate masonry anchor pullout strength, required embedment depth, and spacing for concrete and CMU block. Select anchor type and load requirements.";

const relatedCalcs = [
  { name: "Concrete Reinforcement Calculator", url: "/concrete-reinforcement-calculator", description: "Rebar sizing." },
  { name: "Block Wall Calculator", url: "/block-wall-calculator", description: "CMU block calculator." },
  { name: "Concrete Calculator", url: "/concrete-calculator", description: "Concrete volume." },
  { name: "Rebar Calculator", url: "/rebar-calculator", description: "Rebar requirements." },
  { name: "Retaining Wall Calculator", url: "/retaining-wall-calculator", description: "Retaining wall." },
  { name: "Concrete Strength Calculator", url: "/concrete-strength-calculator", description: "Strength testing." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Masonry Anchor Calculator"
  keywords="masonry anchor, anchor bolt, pullout strength, wedge anchor, sleeve anchor, concrete anchor, anchor spacing"
  breadcrumbs={[{ name: "Masonry Anchor Calculator", url: "/masonry-anchor-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Masonry Anchor Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate anchor pullout strength, embedment depth, and spacing for concrete and masonry.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-text mb-2">Anchor Type</label>
          <select id="ma2-type" class="ma2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="wedge" selected>Wedge Anchor (Concrete)</option>
            <option value="sleeve">Sleeve Anchor (Concrete/Masonry)</option>
            <option value="drop">Drop-In Anchor (Concrete)</option>
            <option value="tapcon">Tapcon Screw (Concrete/Block)</option>
            <option value="toggle">Toggle Bolt (Hollow Block)</option>
            <option value="epoxy">Epoxy Anchor (All Substrates)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Anchor Diameter</label>
          <select id="ma2-diam" class="ma2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="0.25">1/4 inch</option>
            <option value="0.375" selected>3/8 inch</option>
            <option value="0.5">1/2 inch</option>
            <option value="0.625">5/8 inch</option>
            <option value="0.75">3/4 inch</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Base Material</label>
          <select id="ma2-base" class="ma2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="concrete" selected>Solid Concrete (3000+ PSI)</option>
            <option value="conc4000">Solid Concrete (4000+ PSI)</option>
            <option value="cmusolid">Solid CMU Block</option>
            <option value="cmuhollow">Hollow CMU Block</option>
            <option value="brick">Solid Brick</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Required Tension Load per Anchor (lbs)</label>
          <input type="number" id="ma2-load" class="ma2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="500" min="50" step="50">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Number of Anchors</label>
          <input type="number" id="ma2-qty" class="ma2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="1" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-2">Safety Factor</label>
          <select id="ma2-sf" class="ma2-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold">
            <option value="3">3:1 (Non-structural)</option>
            <option value="4" selected>4:1 (Standard)</option>
            <option value="5">5:1 (Overhead / Life Safety)</option>
          </select>
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Allowable Tension Load (per anchor)</div>
          <div class="text-4xl font-extrabold" id="ma2-allowable">0 lbs</div>
          <div class="text-sm text-blue-200 mt-1" id="ma2-status">-</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Ultimate Pullout</div>
            <div class="text-xl font-bold" id="ma2-ultimate">0 lbs</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Allowable Shear</div>
            <div class="text-xl font-bold" id="ma2-shear">0 lbs</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Min Embedment</div>
            <div class="text-xl font-bold" id="ma2-embed">0 in</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Min Edge Distance</div>
            <div class="text-xl font-bold" id="ma2-edge">0 in</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Min Spacing</div>
            <div class="text-xl font-bold" id="ma2-spacing">0 in</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Drill Bit Size</div>
            <div class="text-xl font-bold" id="ma2-drill">0 in</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="masonry-anchor" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Masonry Anchor Selection Guide</h2>
      <ul>
        <li><strong>Wedge anchors:</strong> Highest capacity in solid concrete; not for hollow block</li>
        <li><strong>Sleeve anchors:</strong> Versatile, works in concrete, brick, and block</li>
        <li><strong>Tapcon screws:</strong> Easy installation, removable, moderate loads</li>
        <li><strong>Toggle bolts:</strong> Best for hollow block and lightweight applications</li>
        <li><strong>Epoxy anchors:</strong> Highest capacity, vibration resistant, all substrates</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    interface AnchorSpec {
      ultimateBase: Record<string, number>; // ultimate pullout by diameter in lbs for concrete
      embedFactor: number; // embedment = diameter * factor
      edgeFactor: number; // edge distance = diameter * factor
      spacingFactor: number; // spacing = diameter * factor
      shearRatio: number; // shear as fraction of tension
      drillOversize: number; // drill bit oversize in inches
    }

    const ma2Specs: Record<string, AnchorSpec> = {
      wedge:   { ultimateBase: { '0.25': 2500, '0.375': 5000, '0.5': 8500, '0.625': 12000, '0.75': 17000 }, embedFactor: 8, edgeFactor: 10, spacingFactor: 10, shearRatio: 1.2, drillOversize: 0 },
      sleeve:  { ultimateBase: { '0.25': 1800, '0.375': 3500, '0.5': 6000, '0.625': 8500, '0.75': 12000 }, embedFactor: 6, edgeFactor: 8, spacingFactor: 8, shearRatio: 1.0, drillOversize: 0.125 },
      drop:    { ultimateBase: { '0.25': 2200, '0.375': 4500, '0.5': 7500, '0.625': 10500, '0.75': 15000 }, embedFactor: 4, edgeFactor: 8, spacingFactor: 8, shearRatio: 1.1, drillOversize: 0.0625 },
      tapcon:  { ultimateBase: { '0.25': 1500, '0.375': 2800, '0.5': 4200, '0.625': 5800, '0.75': 7500 }, embedFactor: 6, edgeFactor: 5, spacingFactor: 6, shearRatio: 0.8, drillOversize: -0.0625 },
      toggle:  { ultimateBase: { '0.25': 800, '0.375': 1200, '0.5': 1800, '0.625': 2500, '0.75': 3200 }, embedFactor: 3, edgeFactor: 4, spacingFactor: 6, shearRatio: 0.6, drillOversize: 0.25 },
      epoxy:   { ultimateBase: { '0.25': 3000, '0.375': 6500, '0.5': 11000, '0.625': 16000, '0.75': 22000 }, embedFactor: 10, edgeFactor: 12, spacingFactor: 12, shearRatio: 1.3, drillOversize: 0.0625 },
    };

    const ma2BaseFactor: Record<string, number> = {
      concrete: 1.0, conc4000: 1.15, cmusolid: 0.75, cmuhollow: 0.35, brick: 0.65,
    };

    function calcMA2() {
      const type = (document.getElementById('ma2-type') as HTMLSelectElement).value;
      const diam = parseFloat((document.getElementById('ma2-diam') as HTMLSelectElement).value) || 0.375;
      const base = (document.getElementById('ma2-base') as HTMLSelectElement).value;
      const reqLoad = parseFloat((document.getElementById('ma2-load') as HTMLInputElement).value) || 500;
      const sf = parseFloat((document.getElementById('ma2-sf') as HTMLSelectElement).value) || 4;

      const spec = ma2Specs[type] || ma2Specs.wedge;
      const baseFactor = ma2BaseFactor[base] || 1.0;
      const diamStr = String(diam);

      const ultimateRaw = spec.ultimateBase[diamStr] || 5000;
      const ultimate = ultimateRaw * baseFactor;
      const allowable = ultimate / sf;
      const shear = allowable * spec.shearRatio;

      const embedment = diam * spec.embedFactor;
      const edgeDist = diam * spec.edgeFactor;
      const spacing = diam * spec.spacingFactor;
      const drillBit = diam + spec.drillOversize;

      const sufficient = allowable >= reqLoad;

      document.getElementById('ma2-allowable')!.textContent = Math.round(allowable).toLocaleString() + ' lbs';
      document.getElementById('ma2-status')!.textContent = sufficient ? 'ADEQUATE for ' + reqLoad + ' lb load' : 'INSUFFICIENT - increase size or use epoxy';
      document.getElementById('ma2-ultimate')!.textContent = Math.round(ultimate).toLocaleString() + ' lbs';
      document.getElementById('ma2-shear')!.textContent = Math.round(shear).toLocaleString() + ' lbs';
      document.getElementById('ma2-embed')!.textContent = embedment.toFixed(1) + ' in';
      document.getElementById('ma2-edge')!.textContent = edgeDist.toFixed(1) + ' in';
      document.getElementById('ma2-spacing')!.textContent = spacing.toFixed(1) + ' in';
      document.getElementById('ma2-drill')!.textContent = drillBit.toFixed(3) + ' in';

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.ma2-in').forEach(el => {
        el.addEventListener('input', calcMA2);
        el.addEventListener('change', calcMA2);
      });
      calcMA2();
    }, 50);
  </script>
</CalculatorLayout>
