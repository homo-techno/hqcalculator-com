---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Aquarium Background Calculator - Material & Coverage";
const description = "Calculate the dimensions and material quantity needed for an aquarium background, including foam, vinyl, painted, or 3D backgrounds.";
const relatedCalcs = [
  { name: "Aquarium Volume", url: "/aquarium-calculator", description: "Calculate tank volume." },
  { name: "Aquarium Substrate", url: "/aquarium-substrate-calculator", description: "Substrate amount calculator." },
  { name: "Aquarium Cost", url: "/aquarium-cost-calculator", description: "Total aquarium setup cost." },
  { name: "Aquarium Glass Thickness", url: "/aquarium-glass-thickness-calculator", description: "Glass thickness for tanks." },
  { name: "Aquarium Stand", url: "/aquarium-stand-calculator", description: "Stand load capacity." },
  { name: "Aquarium Lighting", url: "/aquarium-lighting-calculator", description: "Lighting calculator." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Aquarium Background Calculator" keywords="aquarium background calculator, fish tank background, 3D background, aquarium backdrop, tank background size" breadcrumbs={[{ name: "Aquarium Background", url: "/aquarium-background-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Aquarium Background Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate background material dimensions and coverage for the back panel of your aquarium.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tank Length (inches)</label>
            <input type="number" id="abg-len" class="abg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="48" min="6" step="1">
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Tank Height (inches)</label>
            <input type="number" id="abg-hgt" class="abg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18" min="6" step="1">
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Background Type</label>
          <select id="abg-type" class="abg-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="vinyl" selected>Vinyl / Poster (thin film)</option>
            <option value="foam">Foam / 3D Sculpted</option>
            <option value="paint">Painted (spray paint)</option>
            <option value="cling">Static Cling Film</option>
            <option value="tile">Tile / Slate</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-text mb-1">Cover Sides Too?</label>
          <select id="abg-sides" class="abg-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="back" selected>Back panel only</option>
            <option value="both">Back + both sides</option>
            <option value="one">Back + one side</option>
          </select>
        </div>
        <div id="abg-sidewidth-wrap">
          <label class="block text-xs font-medium text-text mb-1">Side Panel Width (inches)</label>
          <input type="number" id="abg-sidew" class="abg-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="6" step="1">
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Material Needed</div>
          <div class="text-5xl font-extrabold font-mono" id="abg-result">0 sq in</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Square Feet</div>
            <div class="text-xl font-bold font-mono" id="abg-sqft">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Dimensions (cut size)</div>
            <div class="text-xl font-bold font-mono" id="abg-dims">0 x 0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Est. Material Cost</div>
            <div class="text-xl font-bold font-mono" id="abg-cost">$0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Weight Added</div>
            <div class="text-xl font-bold font-mono" id="abg-weight">0 lbs</div>
          </div>
        </div>
      </div>
      <ShareButton calculatorId="aquarium-background" />
      <FeedbackWidget />
    </div>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    function calcABG() {
      const len = parseFloat((document.getElementById('abg-len') as HTMLInputElement).value) || 0;
      const hgt = parseFloat((document.getElementById('abg-hgt') as HTMLInputElement).value) || 0;
      const type = (document.getElementById('abg-type') as HTMLSelectElement).value;
      const sides = (document.getElementById('abg-sides') as HTMLSelectElement).value;
      const sideW = parseFloat((document.getElementById('abg-sidew') as HTMLInputElement).value) || 0;
      // Back panel area
      let totalSqIn = len * hgt;
      let dims = len + ' x ' + hgt + ' in';
      if (sides === 'both') {
        totalSqIn += 2 * sideW * hgt;
        dims = len + '+2x' + sideW + ' x ' + hgt + ' in';
      } else if (sides === 'one') {
        totalSqIn += sideW * hgt;
        dims = len + '+' + sideW + ' x ' + hgt + ' in';
      }
      const sqFt = totalSqIn / 144;
      // Cost per sq ft by type
      const costPerSqFt: Record<string, number> = {
        vinyl: 2, foam: 8, paint: 0.5, cling: 3, tile: 12
      };
      const cost = sqFt * (costPerSqFt[type] || 2);
      // Weight: lbs per sq ft
      const weightPerSqFt: Record<string, number> = {
        vinyl: 0.1, foam: 2, paint: 0, cling: 0.05, tile: 8
      };
      const weight = sqFt * (weightPerSqFt[type] || 0.1);
      document.getElementById('abg-result')!.textContent = Math.round(totalSqIn) + ' sq in';
      document.getElementById('abg-sqft')!.textContent = sqFt.toFixed(2) + ' sq ft';
      document.getElementById('abg-dims')!.textContent = dims;
      document.getElementById('abg-cost')!.textContent = '$' + cost.toFixed(2);
      document.getElementById('abg-weight')!.textContent = weight.toFixed(1) + ' lbs';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.abg-in').forEach(el => { el.addEventListener('input', calcABG); el.addEventListener('change', calcABG); });
      calcABG();
    }, 50);
  </script>
</CalculatorLayout>
