---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Composting Rate Calculator - C:N Ratio & Decomposition Time";
const description = "Calculate your compost pile carbon-to-nitrogen ratio and estimate decomposition time based on materials, moisture, and aeration.";
const relatedCalcs = [
  { name: "Compost Calculator", url: "/compost-calculator", description: "Basic composting." },
  { name: "Waste Diversion", url: "/waste-diversion-calculator", description: "Waste reduction." },
  { name: "Biomass Energy", url: "/biomass-energy-calculator", description: "Biomass fuel." },
  { name: "Carbon Footprint", url: "/carbon-footprint-calculator", description: "CO2 emissions." },
  { name: "Recycling", url: "/recycling-calculator", description: "Recycling impact." },
  { name: "Green Building", url: "/green-building-calculator", description: "Green certification." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Composting Rate Calculator" keywords="composting rate calculator, carbon nitrogen ratio, C:N ratio, compost decomposition, composting speed" breadcrumbs={[{ name: "Composting Rate", url: "/composting-rate-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Composting Rate Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate your compost C:N ratio and estimated decomposition time.</p>
    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <h3 class="font-semibold text-text">Green Materials (Nitrogen-rich)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Food Scraps (lbs)</label><input type="number" id="cpr-food" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="10" min="0" max="200" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Grass Clippings (lbs)</label><input type="number" id="cpr-grass" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="20" min="0" max="200" step="1"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Coffee Grounds (lbs)</label><input type="number" id="cpr-coffee" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0" max="50" step="0.5"></div>
        <h3 class="font-semibold text-text">Brown Materials (Carbon-rich)</h3>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium text-text mb-1">Dry Leaves (lbs)</label><input type="number" id="cpr-leaves" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="30" min="0" max="200" step="1"></div>
          <div><label class="block text-xs font-medium text-text mb-1">Cardboard/Paper (lbs)</label><input type="number" id="cpr-card" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0" max="100" step="1"></div>
        </div>
        <div><label class="block text-xs font-medium text-text mb-1">Wood Chips/Sawdust (lbs)</label><input type="number" id="cpr-wood" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="5" min="0" max="100" step="1"></div>
        <h3 class="font-semibold text-text">Conditions</h3>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-text mb-1">Turning Frequency</label>
            <select id="cpr-turn" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="0.6">Every few days</option>
              <option value="0.8" selected>Weekly</option>
              <option value="1.0">Bi-weekly</option>
              <option value="1.5">Monthly</option>
              <option value="2.5">Never (static pile)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-text mb-1">Moisture Level</label>
            <select id="cpr-moisture" class="cpr-in w-full px-4 py-3 border border-border rounded-xl text-lg">
              <option value="1.3">Too dry</option>
              <option value="1.0" selected>Optimal (like wrung sponge)</option>
              <option value="1.2">Too wet</option>
            </select>
          </div>
        </div>
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">C:N Ratio</div>
          <div class="text-4xl font-extrabold" id="cpr-ratio">0:1</div>
          <div class="text-sm text-blue-200 mt-1" id="cpr-status">Calculating...</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Estimated Time</div><div class="text-xl font-bold" id="cpr-time">0 weeks</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Total Weight</div><div class="text-xl font-bold" id="cpr-weight">0 lbs</div></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Finished Compost</div><div class="text-xl font-bold" id="cpr-finished">0 lbs</div></div>
          <div class="p-4 bg-surface-alt rounded-xl text-center"><div class="text-xs text-text-muted uppercase">Ideal C:N Range</div><div class="text-xl font-bold">25-30:1</div></div>
        </div>
      </div>
      <ShareButton calculatorId="composting-rate" />
      <FeedbackWidget />
    </div>
    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">Understanding Compost C:N Ratio</h2>
      <p>The carbon-to-nitrogen ratio determines decomposition speed. The ideal range is 25-30:1. Too much carbon (over 40:1) slows decomposition; too much nitrogen (under 20:1) causes odor. Food scraps have a C:N of about 15:1, grass clippings 20:1, dry leaves 60:1, and wood chips 400:1. Regular turning accelerates the process by introducing oxygen for aerobic bacteria.</p>
    </article>
    <RelatedCalculators calculators={relatedCalcs} />
  </div>
  <script>
    const cprCN: Record<string, [number, number]> = {
      food: [15, 0.05], grass: [20, 0.04], coffee: [20, 0.04],
      leaves: [60, 0.01], card: [350, 0.002], wood: [400, 0.002]
    };
    function calcCPR() {
      const food = parseFloat((document.getElementById('cpr-food') as HTMLInputElement).value) || 0;
      const grass = parseFloat((document.getElementById('cpr-grass') as HTMLInputElement).value) || 0;
      const coffee = parseFloat((document.getElementById('cpr-coffee') as HTMLInputElement).value) || 0;
      const leaves = parseFloat((document.getElementById('cpr-leaves') as HTMLInputElement).value) || 0;
      const card = parseFloat((document.getElementById('cpr-card') as HTMLInputElement).value) || 0;
      const wood = parseFloat((document.getElementById('cpr-wood') as HTMLInputElement).value) || 0;
      const turnFactor = parseFloat((document.getElementById('cpr-turn') as HTMLSelectElement).value) || 1;
      const moistFactor = parseFloat((document.getElementById('cpr-moisture') as HTMLSelectElement).value) || 1;
      const mats = [
        { wt: food, cn: 15, n: 0.05 },
        { wt: grass, cn: 20, n: 0.04 },
        { wt: coffee, cn: 20, n: 0.04 },
        { wt: leaves, cn: 60, n: 0.01 },
        { wt: card, cn: 350, n: 0.002 },
        { wt: wood, cn: 400, n: 0.002 }
      ];
      let totalC = 0, totalN = 0, totalWt = 0;
      mats.forEach(m => {
        const n = m.wt * m.n;
        const c = n * m.cn;
        totalN += n;
        totalC += c;
        totalWt += m.wt;
      });
      const ratio = totalN > 0 ? totalC / totalN : 0;
      let status = 'Optimal range';
      if (ratio < 20) status = 'Too nitrogen-rich - add browns';
      else if (ratio > 40) status = 'Too carbon-rich - add greens';
      else if (ratio >= 25 && ratio <= 30) status = 'Ideal ratio!';
      else if (ratio < 25) status = 'Slightly nitrogen-heavy';
      else status = 'Slightly carbon-heavy';
      const baseWeeks = ratio >= 20 && ratio <= 40 ? 8 : ratio < 20 ? 12 : Math.min(ratio / 3, 30);
      const estWeeks = Math.round(baseWeeks * turnFactor * moistFactor);
      const finishedCompost = totalWt * 0.4;
      document.getElementById('cpr-ratio')!.textContent = ratio.toFixed(0) + ':1';
      document.getElementById('cpr-status')!.textContent = status;
      document.getElementById('cpr-time')!.textContent = estWeeks + ' weeks';
      document.getElementById('cpr-weight')!.textContent = Math.round(totalWt) + ' lbs';
      document.getElementById('cpr-finished')!.textContent = Math.round(finishedCompost) + ' lbs';
      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => { document.querySelectorAll('.cpr-in').forEach(el => { el.addEventListener('input', calcCPR); el.addEventListener('change', calcCPR); }); calcCPR(); }, 50);
  </script>
</CalculatorLayout>
