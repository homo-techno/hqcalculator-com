---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';

const title = "Baby Formula Calculator - How Much Formula Does Baby Need?";
const description = "Calculate the right amount of baby formula by age, weight, and feeding frequency. Get daily ounces, cost estimates, and feeding schedules.";

const relatedCalcs = [
  { name: "Diaper Cost Calculator", url: "/diaper-cost-calculator", description: "Diaper expenses." },
  { name: "Breastmilk Storage Calculator", url: "/breastmilk-storage-calculator", description: "Storage guidelines." },
  { name: "Child Nutrition Calculator", url: "/child-nutrition-calculator", description: "Daily nutrition needs." },
  { name: "Baby Milestone Calculator", url: "/baby-milestone-calculator", description: "Development tracking." },
  { name: "Child Dosage Calculator", url: "/child-dosage-calculator", description: "Medication dosing." },
  { name: "Daycare Cost Calculator", url: "/daycare-cost-calculator", description: "Childcare costs." },
];
---

<CalculatorLayout
  title={title}
  description={description}
  calculatorName="Baby Formula Calculator"
  keywords="baby formula calculator, formula amount by age, how much formula, formula feeding schedule, baby formula cost, infant formula calculator"
  breadcrumbs={[{ name: "Baby Formula Calculator", url: "/baby-formula-calculator" }]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Baby Formula Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate formula amounts, feeding frequency, and monthly costs based on your baby's age and weight.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Baby's Age (months)</label>
          <input type="number" id="bfm-age" class="bfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="3" min="0" max="12" step="1">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Baby's Weight (lbs)</label>
          <input type="number" id="bfm-weight" class="bfm-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="12" min="4" max="30" step="0.5">
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Formula Type</label>
          <select id="bfm-type" class="bfm-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="powder" selected>Powder Formula (~$0.10/oz prepared)</option>
            <option value="concentrate">Liquid Concentrate (~$0.15/oz)</option>
            <option value="ready">Ready-to-Feed (~$0.25/oz)</option>
            <option value="specialty">Specialty/Hypoallergenic (~$0.35/oz)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-text mb-1">Feeding Method</label>
          <select id="bfm-method" class="bfm-in w-full px-4 py-3 border border-border rounded-xl text-lg">
            <option value="exclusive" selected>Exclusively Formula Fed</option>
            <option value="combo">Combo (Breast + Formula)</option>
          </select>
        </div>
      </div>

      <div class="p-6 bg-primary rounded-2xl text-white text-center mb-4">
        <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Daily Formula Needed</div>
        <div class="text-5xl font-extrabold" id="bfm-daily">--</div>
        <div class="text-sm text-blue-200 mt-1">ounces per day</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Per Feeding</div>
          <div class="text-lg font-bold" id="bfm-perfeed">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Feedings/Day</div>
          <div class="text-lg font-bold" id="bfm-feeds">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Monthly Cost</div>
          <div class="text-lg font-bold" id="bfm-monthly">--</div>
        </div>
        <div class="p-4 bg-surface-alt rounded-xl text-center">
          <div class="text-xs text-text-muted uppercase">Yearly Cost</div>
          <div class="text-lg font-bold" id="bfm-yearly">--</div>
        </div>
      </div>

      <div class="p-4 bg-surface-alt rounded-xl mb-6">
        <h3 class="font-semibold text-sm text-text mb-3">Feeding Schedule Guide</h3>
        <div class="text-xs" id="bfm-schedule"></div>
      </div>

      <ShareButton calculatorId="baby-formula" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate mx-auto">
      <h2 class="text-2xl font-bold text-text">How Much Formula Does a Baby Need?</h2>
      <p>The general rule is 2.5 ounces of formula per pound of body weight per day, up to about 32 ounces maximum. However, every baby is different, so always consult your pediatrician.</p>

      <h3 class="text-xl font-semibold text-text mt-8">Formula by Age Guidelines</h3>
      <ul>
        <li><strong>Newborn (0-2 weeks):</strong> 1-2 oz per feeding, 8-12 times/day</li>
        <li><strong>1-2 months:</strong> 3-4 oz per feeding, 6-8 times/day</li>
        <li><strong>3-4 months:</strong> 4-6 oz per feeding, 5-6 times/day</li>
        <li><strong>5-6 months:</strong> 6-8 oz per feeding, 4-5 times/day</li>
        <li><strong>7-12 months:</strong> 6-8 oz per feeding, 3-4 times/day (with solids)</li>
      </ul>

      <h3 class="text-xl font-semibold text-text mt-8">Formula Safety Tips</h3>
      <ul>
        <li>Prepared formula is good for 1 hour at room temperature</li>
        <li>Refrigerated prepared formula lasts 24 hours</li>
        <li>Opened powder containers should be used within 30 days</li>
        <li>Never microwave formula -- use warm water bath instead</li>
      </ul>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcBFM() {
      const age = parseFloat((document.getElementById('bfm-age') as HTMLInputElement).value) || 0;
      const weight = parseFloat((document.getElementById('bfm-weight') as HTMLInputElement).value) || 12;
      const type = (document.getElementById('bfm-type') as HTMLSelectElement).value;
      const method = (document.getElementById('bfm-method') as HTMLSelectElement).value;

      const costPerOz: Record<string, number> = { powder: 0.10, concentrate: 0.15, ready: 0.25, specialty: 0.35 };

      function feedingsPerDay(m: number): number {
        if (m < 1) return 10;
        if (m < 3) return 7;
        if (m < 5) return 6;
        if (m < 7) return 5;
        return 4;
      }

      function ozPerFeeding(m: number): number {
        if (m < 0.5) return 1.5;
        if (m < 1) return 2.5;
        if (m < 3) return 4;
        if (m < 5) return 5;
        if (m < 7) return 7;
        return 7;
      }

      let dailyOz = Math.min(weight * 2.5, 32);
      const feeds = feedingsPerDay(age);
      let perFeed = ozPerFeeding(age);

      if (dailyOz < perFeed * feeds) {
        dailyOz = perFeed * feeds;
      }
      dailyOz = Math.min(dailyOz, 32);
      perFeed = Math.round((dailyOz / feeds) * 10) / 10;

      const comboFactor = method === 'combo' ? 0.5 : 1;
      dailyOz = Math.round(dailyOz * comboFactor * 10) / 10;

      const monthlyCost = dailyOz * 30.44 * costPerOz[type];
      const yearlyCost = monthlyCost * 12;

      document.getElementById('bfm-daily')!.textContent = dailyOz.toFixed(1);
      document.getElementById('bfm-perfeed')!.textContent = (perFeed * comboFactor).toFixed(1) + ' oz';
      document.getElementById('bfm-feeds')!.textContent = String(feeds);
      document.getElementById('bfm-monthly')!.textContent = '$' + monthlyCost.toFixed(0);
      document.getElementById('bfm-yearly')!.textContent = '$' + yearlyCost.toFixed(0);

      const scheduleData = [
        { ageRange: '0-1 mo', oz: '2-3 oz', times: '8-10x', daily: '20-24 oz' },
        { ageRange: '1-3 mo', oz: '3-4 oz', times: '6-8x', daily: '20-28 oz' },
        { ageRange: '3-5 mo', oz: '4-6 oz', times: '5-6x', daily: '24-32 oz' },
        { ageRange: '5-7 mo', oz: '6-8 oz', times: '4-5x', daily: '24-32 oz' },
        { ageRange: '7-12 mo', oz: '6-8 oz', times: '3-4x', daily: '24-32 oz' },
      ];

      document.getElementById('bfm-schedule')!.innerHTML =
        '<div class="grid grid-cols-4 gap-2 font-semibold text-text-muted mb-1"><span>Age</span><span>Per Feed</span><span>Frequency</span><span>Daily</span></div>' +
        scheduleData.map((r, i) => {
          const highlight = (age < 1 && i === 0) || (age >= 1 && age < 3 && i === 1) || (age >= 3 && age < 5 && i === 2) || (age >= 5 && age < 7 && i === 3) || (age >= 7 && i === 4);
          return `<div class="grid grid-cols-4 gap-2 py-1 ${highlight ? 'bg-blue-50 rounded font-bold' : ''}"><span>${r.ageRange}</span><span>${r.oz}</span><span>${r.times}</span><span>${r.daily}</span></div>`;
        }).join('');

      document.dispatchEvent(new CustomEvent('calc-update'));
    }

    setTimeout(() => {
      document.querySelectorAll('.bfm-in').forEach(el => {
        el.addEventListener('input', calcBFM);
        el.addEventListener('change', calcBFM);
      });
      calcBFM();
    }, 50);
  </script>
</CalculatorLayout>
