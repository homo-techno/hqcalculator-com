---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import ShareButton from '../components/ShareButton.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
const title = "Pollen Analysis Calculator - Grain Concentration & Percentage";
const description = "Calculate pollen grain concentrations, relative percentages, and influx rates for palynological analysis. Essential for paleoenvironmental reconstruction.";
const relatedCalcs = [
  { name: "Faunal Dating", url: "/faunal-dating-calculator", description: "Faunal assemblages." },
  { name: "Stratigraphy", url: "/stratigraphy-calculator", description: "Layer age estimation." },
  { name: "Radiocarbon Dating", url: "/radiocarbon-dating-calculator", description: "C-14 dating." },
  { name: "Stable Isotope", url: "/stable-isotope-calculator", description: "Isotope analysis." },
  { name: "Site Catchment", url: "/site-catchment-calculator", description: "Territory analysis." },
  { name: "Carrying Capacity", url: "/carrying-capacity-calculator", description: "Land capacity." },
];
---
<CalculatorLayout title={title} description={description} calculatorName="Pollen Analysis Calculator" keywords="pollen analysis, palynology, pollen concentration, pollen percentage, influx rate, Lycopodium, pollen grains, paleoenvironment" breadcrumbs={[{ name: "Pollen Analysis", url: "/pollen-analysis-calculator" }]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-2">Pollen Analysis Calculator</h1>
    <p class="text-text-secondary mb-8 max-w-2xl">Calculate pollen concentrations using the exotic marker (Lycopodium) method, relative pollen percentages, and pollen influx (accumulation) rates.</p>

    <div class="bg-white border border-border rounded-2xl shadow-sm p-6 sm:p-8 max-w-2xl mx-auto">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-text mb-1">Pollen Grains Counted (target taxon)</label>
          <input type="number" id="poa-pollen" class="poa-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="150" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Total Pollen Sum (all taxa)</label>
          <input type="number" id="poa-total" class="poa-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="500" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Lycopodium Spores Counted</label>
          <input type="number" id="poa-lyco" class="poa-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="200" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Lycopodium Spores Added (per tablet)</label>
          <input type="number" id="poa-lycoadd" class="poa-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="18583" min="1" step="1">
          <p class="text-xs text-text-muted mt-1">Standard tablet: Batch 3862 = 9,666; Batch 1031 = 18,583</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Number of Tablets Added</label>
          <input type="number" id="poa-tablets" class="poa-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="2" min="1" step="1">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Sample Volume/Weight (cm3 or g)</label>
          <input type="number" id="poa-vol" class="poa-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="1" min="0.01" step="0.01">
        </div>
        <div>
          <label class="block text-sm font-medium text-text mb-1">Sedimentation Rate (cm/yr) - for influx</label>
          <input type="number" id="poa-sedrate" class="poa-in w-full px-4 py-3 border border-border rounded-xl text-lg font-bold" value="0.05" min="0.001" step="0.001">
        </div>
      </div>

      <div class="mt-6 space-y-3">
        <div class="p-6 bg-primary rounded-2xl text-white text-center">
          <div class="text-sm text-blue-200 uppercase tracking-wide mb-1">Pollen Concentration</div>
          <div class="text-4xl font-extrabold" id="poa-conc">0</div>
          <div class="text-sm text-blue-200 mt-1">grains per cm3 (or g)</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Relative Percentage</div>
            <div class="text-xl font-bold" id="poa-pct">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Pollen Influx Rate</div>
            <div class="text-xl font-bold" id="poa-influx">0</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Total Concentration</div>
            <div class="text-xl font-bold" id="poa-totalconc">0</div>
          </div>
          <div class="p-4 bg-surface-alt rounded-xl text-center">
            <div class="text-xs text-text-muted uppercase">Pollen:Lycopodium Ratio</div>
            <div class="text-xl font-bold" id="poa-ratio">0</div>
          </div>
        </div>
      </div>

      <ShareButton calculatorId="pollen-analysis" />
      <FeedbackWidget />
    </div>

    <article class="mt-12 max-w-4xl prose prose-slate">
      <h2 class="text-2xl font-bold text-text">Pollen Analysis Formulas</h2>
      <div class="bg-surface-alt rounded-xl p-4 my-4 font-mono text-sm space-y-1">
        <p><strong>Concentration</strong> = (Pollen Counted / Lyco Counted) * (Lyco Added * Tablets) / Volume</p>
        <p><strong>Relative %</strong> = (Taxon Count / Total Pollen Sum) * 100</p>
        <p><strong>Influx</strong> = Concentration * Sedimentation Rate (grains/cm2/yr)</p>
      </div>
      <p>The exotic marker method (Stockmarr 1971) uses Lycopodium spore tablets of known count to calculate absolute pollen concentrations. Pollen percentages show relative abundance of taxa. Influx rates account for sedimentation speed, giving pollen accumulation per unit area per year.</p>
    </article>

    <RelatedCalculators calculators={relatedCalcs} />
  </div>

  <script>
    function calcPOA() {
      const pollen = parseFloat((document.getElementById('poa-pollen') as HTMLInputElement).value) || 0;
      const totalPollen = parseFloat((document.getElementById('poa-total') as HTMLInputElement).value) || 0;
      const lycoCounted = parseFloat((document.getElementById('poa-lyco') as HTMLInputElement).value) || 0;
      const lycoPerTablet = parseFloat((document.getElementById('poa-lycoadd') as HTMLInputElement).value) || 0;
      const tablets = parseFloat((document.getElementById('poa-tablets') as HTMLInputElement).value) || 1;
      const volume = parseFloat((document.getElementById('poa-vol') as HTMLInputElement).value) || 1;
      const sedRate = parseFloat((document.getElementById('poa-sedrate') as HTMLInputElement).value) || 0;

      const lycoAdded = lycoPerTablet * tablets;
      const concentration = lycoCounted > 0 && volume > 0 ? (pollen / lycoCounted) * (lycoAdded / volume) : 0;
      const totalConc = lycoCounted > 0 && volume > 0 ? (totalPollen / lycoCounted) * (lycoAdded / volume) : 0;
      const pct = totalPollen > 0 ? (pollen / totalPollen) * 100 : 0;
      const influx = concentration * sedRate;
      const plRatio = lycoCounted > 0 ? pollen / lycoCounted : 0;

      document.getElementById('poa-conc')!.textContent = Math.round(concentration).toLocaleString();
      document.getElementById('poa-pct')!.textContent = pct.toFixed(1) + '%';
      document.getElementById('poa-influx')!.textContent = Math.round(influx).toLocaleString() + ' /cm2/yr';
      document.getElementById('poa-totalconc')!.textContent = Math.round(totalConc).toLocaleString() + ' /cm3';
      document.getElementById('poa-ratio')!.textContent = plRatio.toFixed(3);

      document.dispatchEvent(new CustomEvent('calc-update'));
    }
    setTimeout(() => {
      document.querySelectorAll('.poa-in').forEach(el => { el.addEventListener('input', calcPOA); el.addEventListener('change', calcPOA); });
      calcPOA();
    }, 50);
  </script>
</CalculatorLayout>
